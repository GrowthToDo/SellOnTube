# Image API keys (used by scripts/new-post.mjs and scripts/get-feature-image.mjs)
PEXELS_API_KEY=your_pexels_api_key_here
UNSPLASH_ACCESS_KEY=your_unsplash_access_key_here

# Gemini AI API (used by Netlify functions for microtool AI features)
GEMINI_API_KEY=your_gemini_api_key_here
GOOGLE_API_KEY=your_google_api_key_here

# DataFetch API (used by youtube-transcript-generator AND youtube-seo-tool Netlify functions)
LF_YOUTUBE_KEY=your_datafetch_api_key_here

# YouTube Data API v3 (used by youtube-seo-tool for tags/metadata, future tools)
# Get from Google Cloud Console > APIs & Services > Credentials (enable YouTube Data API v3)
YOUTUBE_API_KEY=your_youtube_data_api_v3_key_here

# Loops.so email nurture (used by capture-email + cal-booking Netlify functions)
LOOPS_API_KEY=your_loops_api_key_here

# Cal.com webhook secret (used by cal-booking Netlify function to verify
# x-cal-signature-256; set the same value when creating the webhook in Cal.com)
CAL_WEBHOOK_SECRET=your_cal_webhook_secret_here

# Loops webhook signing secret (used by loops-webhook Netlify function; copy the
# whsec_... value shown when creating the webhook in Loops Settings > Webhooks)
LOOPS_WEBHOOK_SECRET=your_loops_webhook_secret_here

# Cloudflare API token for DNS management (Edit zone DNS permission, scoped to
# sellontube.com only; used for adding DNS records via API)
CLOUDFLARE_API_TOKEN=your_cloudflare_dns_token_here

# IndexNow (submit to Bing/search engines after deploy)
# Set these in Netlify dashboard > Site settings > Environment variables
# Key must match the filename in /public/{key}.txt
INDEXNOW_KEY=your_indexnow_key_here
SITE_URL=https://sellontube.com

# Reviews Scraper Tool — Resend email delivery
RESEND_API_KEY=your_resend_api_key_here
FROM_EMAIL=tools@sellontube.com

# Reviews Scraper Tool — Upstash Redis (serverless rate limiting + cache)
UPSTASH_REDIS_REST_URL=your_upstash_redis_rest_url_here
UPSTASH_REDIS_REST_TOKEN=your_upstash_redis_rest_token_here

# Reviews Scraper Tool — Google Sheets lead capture
GOOGLE_SHEETS_SA_JSON=base64_encoded_service_account_json_here
GOOGLE_SHEETS_LEADS_ID=your_google_sheets_spreadsheet_id_here

# Privacy policy URL (used in consent checkbox)
PRIVACY_POLICY_URL=https://sellontube.com/privacy-policy
