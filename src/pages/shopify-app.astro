---
import Layout from '~/layouts/PageLayout.astro';
import Header from '~/components/widgets/Header.astro';

const metadata = {
  title: 'Non-Technical Business Team for Shopify App Owners | SellOnTube',
  description: 'We handle everything a Shopify app owner needs except the engineering: ASO, user guides, product video, review management, SEO content, UX copy, pricing strategy, and more.',
};

const calLink = 'https://cal.com/gautham-8bdvdx/30min';
---

<Layout metadata={metadata}>

  <Fragment slot="header">
    <Header
      links={[
        { text: 'The Problem', href: '#problem' },
        { text: 'What We Do', href: '#work' },
        { text: 'Pricing', href: '#pricing' },
      ]}
      actions={[{ text: 'Book a discovery call', href: calLink, target: '_blank' }]}
      showToggleTheme
    />
  </Fragment>

  <!-- Hero -->
  <section class="relative bg-slate-900 text-white pt-20 sm:pt-28 pb-16 sm:pb-24 overflow-hidden">
    <div class="absolute inset-0 pointer-events-none">
      <div class="absolute top-0 right-0 w-[700px] h-[700px] bg-emerald-500/10 rounded-full blur-3xl"></div>
      <div class="absolute bottom-0 left-0 w-[500px] h-[500px] bg-blue-900/20 rounded-full blur-3xl"></div>
    </div>
    <div class="relative max-w-6xl mx-auto px-6">
      <div class="grid lg:grid-cols-2 gap-12 lg:gap-20 items-center">

        <div>
          <p class="text-emerald-400 text-xs font-bold uppercase tracking-[0.2em] mb-5">For Shopify app owners</p>
          <h1 class="text-3xl sm:text-5xl lg:text-5xl font-extrabold leading-[1.05] tracking-tight mb-6">
            You built the app.<br />
            <span class="text-emerald-400">We handle<br class="hidden sm:block" /> everything else.</span>
          </h1>
          <p class="text-slate-400 text-base leading-relaxed mb-10 max-w-lg">
            Technical founders build great products and run out of bandwidth before anyone hears about them. We are the non-engineering half of your company.
          </p>
          <div class="flex flex-col sm:flex-row gap-4">
            <a href={calLink} target="_blank" rel="noopener noreferrer"
              class="inline-block bg-emerald-500 hover:bg-emerald-400 text-white font-semibold px-8 py-4 rounded-full transition-colors text-base text-center">
              Book a discovery call
            </a>
            <a href="#proof" class="inline-block border border-slate-700 hover:border-slate-500 text-slate-300 font-semibold px-8 py-4 rounded-full transition-colors text-base text-center">
              See client results
            </a>
          </div>
        </div>

        <!-- Team manifest card -->
        <div class="hidden lg:block">
          <div class="bg-slate-800/80 backdrop-blur rounded-2xl border border-slate-700/80 overflow-hidden shadow-2xl">
            <div class="px-6 py-4 border-b border-slate-700/60 flex items-center justify-between">
              <p class="text-xs font-bold text-slate-400 uppercase tracking-widest">Your non-technical layer</p>
              <span class="text-xs bg-emerald-500/20 text-emerald-400 font-bold px-2 py-0.5 rounded-full">Active</span>
            </div>
            <div class="divide-y divide-slate-700/40">
              <div class="px-6 py-3.5 flex items-center justify-between">
                <div class="flex items-center gap-3">
                  <span class="w-1.5 h-1.5 rounded-full bg-emerald-400 flex-shrink-0"></span>
                  <span class="text-slate-200 text-sm">App Store optimisation</span>
                </div>
                <span class="text-xs text-emerald-400 font-semibold">Done</span>
              </div>
              <div class="px-6 py-3.5 flex items-center justify-between">
                <div class="flex items-center gap-3">
                  <span class="w-1.5 h-1.5 rounded-full bg-emerald-400 flex-shrink-0"></span>
                  <span class="text-slate-200 text-sm">User documentation</span>
                </div>
                <span class="text-xs text-emerald-400 font-semibold">Done</span>
              </div>
              <div class="px-6 py-3.5 flex items-center justify-between">
                <div class="flex items-center gap-3">
                  <span class="w-1.5 h-1.5 rounded-full bg-emerald-400 flex-shrink-0"></span>
                  <span class="text-slate-200 text-sm">Product demo video</span>
                </div>
                <span class="text-xs text-emerald-400 font-semibold">Done</span>
              </div>
              <div class="px-6 py-3.5 flex items-center justify-between">
                <div class="flex items-center gap-3">
                  <span class="w-1.5 h-1.5 rounded-full bg-blue-400 flex-shrink-0"></span>
                  <span class="text-slate-200 text-sm">SEO content</span>
                </div>
                <span class="text-xs text-blue-400 font-semibold">Running</span>
              </div>
              <div class="px-6 py-3.5 flex items-center justify-between">
                <div class="flex items-center gap-3">
                  <span class="w-1.5 h-1.5 rounded-full bg-blue-400 flex-shrink-0"></span>
                  <span class="text-slate-200 text-sm">Review management</span>
                </div>
                <span class="text-xs text-blue-400 font-semibold">Running</span>
              </div>
              <div class="px-6 py-3.5 flex items-center justify-between">
                <div class="flex items-center gap-3">
                  <span class="w-1.5 h-1.5 rounded-full bg-emerald-400 flex-shrink-0"></span>
                  <span class="text-slate-200 text-sm">Pricing strategy</span>
                </div>
                <span class="text-xs text-emerald-400 font-semibold">Done</span>
              </div>
              <div class="px-6 py-3.5 flex items-center justify-between">
                <div class="flex items-center gap-3">
                  <span class="w-1.5 h-1.5 rounded-full bg-emerald-400 flex-shrink-0"></span>
                  <span class="text-slate-200 text-sm">UX copy audit</span>
                </div>
                <span class="text-xs text-emerald-400 font-semibold">Done</span>
              </div>
            </div>
            <div class="px-6 py-4 bg-slate-900/60 border-t border-slate-700/60">
              <p class="text-slate-500 text-xs">All of this. So you don't have to.</p>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- Stat bar -->
  <section class="bg-slate-800 border-y border-slate-700/60 py-5">
    <div class="max-w-5xl mx-auto px-6">
      <div class="flex flex-col sm:flex-row items-center justify-center gap-6 sm:gap-16 text-center">
        <div>
          <p class="text-2xl font-black text-emerald-400">3.25x</p>
          <p class="text-xs text-slate-400 mt-0.5">more installs: positioning and content work</p>
        </div>
        <div class="hidden sm:block w-px h-10 bg-slate-700"></div>
        <div>
          <p class="text-2xl font-black text-white">120 days</p>
          <p class="text-xs text-slate-400 mt-0.5">to build a full non-technical layer from zero</p>
        </div>
        <div class="hidden sm:block w-px h-10 bg-slate-700"></div>
        <div>
          <p class="text-2xl font-black text-white">From $3,500/mo</p>
          <p class="text-xs text-slate-400 mt-0.5">retainer, ongoing</p>
        </div>
      </div>
    </div>
  </section>

  <!-- The Problem -->
  <section id="problem" class="relative py-24 bg-slate-950 overflow-hidden">
    <div class="absolute inset-0 pointer-events-none">
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[800px] bg-emerald-500/5 rounded-full blur-3xl"></div>
    </div>
    <div class="relative max-w-5xl mx-auto px-6">
      <div class="max-w-2xl mb-16">
        <p class="text-xs font-bold text-emerald-400 uppercase tracking-[0.2em] mb-4">The problem</p>
        <h2 class="text-4xl sm:text-5xl font-extrabold text-white leading-[1.08] tracking-tight">
          Good apps stay invisible.<br /><span class="text-slate-500">Not because they're bad.</span>
        </h2>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">

        <div class="relative rounded-2xl p-7 bg-slate-900 border border-slate-800 overflow-hidden group hover:border-emerald-500/40 transition-colors">
          <p class="absolute -bottom-3 -right-1 text-[7rem] font-black text-emerald-500/8 leading-none select-none z-[-1]">01</p>
          <div class="w-8 h-8 rounded-lg bg-emerald-500/10 border border-emerald-500/20 flex items-center justify-center mb-5">
            <div class="w-2 h-2 rounded-full bg-emerald-400"></div>
          </div>
          <h3 class="font-bold text-white mb-2 relative text-sm">Your listing loses merchants before they click</h3>
          <p class="text-sm text-slate-400 relative leading-relaxed">A weak title, vague description, and no reviews. Merchants scroll past in under three seconds. The listing is the first sale. Most apps never make it.</p>
        </div>

        <div class="relative rounded-2xl p-7 bg-slate-900 border border-slate-800 overflow-hidden group hover:border-emerald-500/40 transition-colors">
          <p class="absolute -bottom-3 -right-1 text-[7rem] font-black text-emerald-500/8 leading-none select-none z-[-1]">02</p>
          <div class="w-8 h-8 rounded-lg bg-emerald-500/10 border border-emerald-500/20 flex items-center justify-center mb-5">
            <div class="w-2 h-2 rounded-full bg-emerald-400"></div>
          </div>
          <h3 class="font-bold text-white mb-2 relative text-sm">Merchants uninstall in week one</h3>
          <p class="text-sm text-slate-400 relative leading-relaxed">High early churn is almost always an onboarding and documentation problem. They get confused, find no help, and leave. The product never had a chance.</p>
        </div>

        <div class="relative rounded-2xl p-7 bg-slate-900 border border-slate-800 overflow-hidden group hover:border-emerald-500/40 transition-colors">
          <p class="absolute -bottom-3 -right-1 text-[7rem] font-black text-emerald-500/8 leading-none select-none z-[-1]">03</p>
          <div class="w-8 h-8 rounded-lg bg-emerald-500/10 border border-emerald-500/20 flex items-center justify-center mb-5">
            <div class="w-2 h-2 rounded-full bg-emerald-400"></div>
          </div>
          <h3 class="font-bold text-white mb-2 relative text-sm">You answer the same support questions daily</h3>
          <p class="text-sm text-slate-400 relative leading-relaxed">Without a knowledge base, every merchant who gets stuck emails you. You become the documentation. That time cannot go toward shipping.</p>
        </div>

        <div class="relative rounded-2xl p-7 bg-slate-900 border border-slate-800 overflow-hidden group hover:border-emerald-500/40 transition-colors">
          <p class="absolute -bottom-3 -right-1 text-[7rem] font-black text-emerald-500/8 leading-none select-none z-[-1]">04</p>
          <div class="w-8 h-8 rounded-lg bg-emerald-500/10 border border-emerald-500/20 flex items-center justify-center mb-5">
            <div class="w-2 h-2 rounded-full bg-emerald-400"></div>
          </div>
          <h3 class="font-bold text-white mb-2 relative text-sm">Reviews pile up with no response</h3>
          <p class="text-sm text-slate-400 relative leading-relaxed">Unanswered reviews, good and bad, signal to new merchants that nobody is minding the store. Review velocity also directly affects your App Store ranking.</p>
        </div>

        <div class="relative rounded-2xl p-7 bg-slate-900 border border-slate-800 overflow-hidden group hover:border-emerald-500/40 transition-colors">
          <p class="absolute -bottom-3 -right-1 text-[7rem] font-black text-emerald-500/8 leading-none select-none z-[-1]">05</p>
          <div class="w-8 h-8 rounded-lg bg-emerald-500/10 border border-emerald-500/20 flex items-center justify-center mb-5">
            <div class="w-2 h-2 rounded-full bg-emerald-400"></div>
          </div>
          <h3 class="font-bold text-white mb-2 relative text-sm">No content working while you ship</h3>
          <p class="text-sm text-slate-400 relative leading-relaxed">User guides, SEO content, and product videos compound over time. Most apps skip them entirely. The installs that should be finding you, find a competitor instead.</p>
        </div>

        <div class="relative rounded-2xl p-7 bg-slate-900 border border-slate-800 overflow-hidden group hover:border-emerald-500/40 transition-colors">
          <p class="absolute -bottom-3 -right-1 text-[7rem] font-black text-emerald-500/8 leading-none select-none z-[-1]">06</p>
          <div class="w-8 h-8 rounded-lg bg-emerald-500/10 border border-emerald-500/20 flex items-center justify-center mb-5">
            <div class="w-2 h-2 rounded-full bg-emerald-400"></div>
          </div>
          <h3 class="font-bold text-white mb-2 relative text-sm">You are the engineer and the entire company</h3>
          <p class="text-sm text-slate-400 relative leading-relaxed">Founder, engineer, support team, marketer. Something always gets dropped. It is always the non-technical work, because the next bug is more urgent.</p>
        </div>

      </div>
    </div>
  </section>

  <!-- Proof: Left Foot Software -->
  <section id="proof" class="relative py-24 bg-slate-900 overflow-hidden">
    <div class="absolute inset-0 pointer-events-none">
      <div class="absolute top-0 left-0 w-[600px] h-[600px] bg-emerald-500/5 rounded-full blur-3xl"></div>
      <div class="absolute bottom-0 right-0 w-[400px] h-[400px] bg-blue-900/15 rounded-full blur-3xl"></div>
    </div>
    <div class="relative max-w-5xl mx-auto px-6">

      <div class="flex items-center gap-4 mb-14">
        <div class="flex-shrink-0 w-px h-12 bg-emerald-500"></div>
        <div>
          <p class="text-xs font-bold text-emerald-400 uppercase tracking-[0.2em] mb-1">Client story</p>
          <h2 class="text-xl font-bold text-white">Left Foot Software <span class="text-sm font-normal text-slate-500 ml-2">Multi-app Shopify suite: barcode, label, and scanner apps</span></h2>
        </div>
      </div>

      <div class="grid lg:grid-cols-2 gap-12 items-start mb-8">
        <div>
          <p class="text-[7rem] sm:text-[10rem] lg:text-[12rem] font-black text-slate-800 leading-none select-none -mb-4 sm:-mb-6">0</p>
          <p class="text-3xl sm:text-5xl font-extrabold text-white mb-8 leading-tight">to everything.</p>
          <p class="text-slate-400 leading-relaxed mb-4">
            A solo technical founder running a multi-app suite. Great product, zero non-technical capacity. No positioning, no documentation, no support ops, no marketing. We built all of it.
          </p>
          <p class="text-slate-400 leading-relaxed">
            ASO rewrite. Product video. Knowledge base. Pricing strategy. Review management. Product strategy input. In 120 days.
          </p>
        </div>
        <div class="space-y-4">
          <div class="rounded-2xl bg-slate-800/60 border border-slate-700/60 overflow-hidden">
            <div class="px-7 py-5 border-b border-slate-700/60">
              <p class="text-xl font-black text-emerald-400">App Store listing rewritten</p>
            </div>
            <div class="px-7 py-5">
              <p class="text-sm text-slate-400 leading-relaxed">Title, subtitle, description, and search terms rebuilt around merchant intent. The listing now explains the product before a merchant reads past the first line. Founder recorded nothing for the product video. We scripted, recorded, and edited it.</p>
            </div>
          </div>
          <div class="rounded-2xl bg-slate-800/60 border border-slate-700/60 overflow-hidden">
            <div class="px-7 py-5 border-b border-slate-700/60">
              <p class="text-xl font-black text-white">Pricing strategy delivered</p>
            </div>
            <div class="px-7 py-5">
              <p class="text-sm text-slate-400 leading-relaxed">Free plan removed. Migration to a credit-based model built around actual merchant usage patterns. Full knowledge base published to help centre and embedded in-app. Uninstall rate improving.</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Second client callout -->
      <div class="relative rounded-2xl overflow-hidden">
        <div class="absolute inset-0 bg-emerald-500/10 rounded-2xl"></div>
        <div class="relative border border-emerald-500/30 rounded-2xl p-8 flex flex-col sm:flex-row sm:items-center gap-8">
          <div class="flex-1">
            <p class="text-xs font-bold text-emerald-400 uppercase tracking-[0.2em] mb-3">Separate engagement</p>
            <p class="text-slate-300 leading-relaxed text-base">Content and positioning work for a Shopify app portfolio. Results tracked via Google Analytics on install button clicks.</p>
          </div>
          <div class="flex-shrink-0 text-center sm:text-right">
            <p class="text-6xl font-black text-emerald-400">3.25x</p>
            <p class="text-sm text-slate-400 mt-2">more conversions</p>
          </div>
        </div>
      </div>

    </div>
  </section>

  <!-- What We Do -->
  <section id="work" class="py-24 bg-white dark:bg-slate-950">
    <div class="max-w-5xl mx-auto px-6">

      <div class="max-w-2xl mb-14">
        <p class="text-xs font-bold text-emerald-600 dark:text-emerald-400 uppercase tracking-[0.2em] mb-4">What we handle</p>
        <h2 class="text-4xl sm:text-5xl font-extrabold text-gray-900 dark:text-white leading-[1.08] tracking-tight mb-4">The complete non-technical side of your app.</h2>
        <p class="text-gray-500 dark:text-slate-400 text-lg">You stay in the code. Everything else is ours.</p>
      </div>

      <!-- Featured service card -->
      <div class="relative rounded-3xl overflow-hidden mb-5 border border-emerald-200 dark:border-emerald-500/30 bg-gradient-to-br from-emerald-50 to-white dark:from-emerald-500/10 dark:to-slate-900">
        <div class="p-8 sm:p-10 flex flex-col sm:flex-row gap-10 items-center">
          <div class="flex-1">
            <div class="inline-block bg-emerald-500 text-white text-xs font-bold uppercase tracking-wider px-3 py-1 rounded-full mb-5">Biggest impact on churn</div>
            <h3 class="text-2xl font-extrabold text-gray-900 dark:text-white mb-3">User guides and knowledge base</h3>
            <p class="text-gray-600 dark:text-slate-400 mb-5 leading-relaxed">Merchants uninstall in week one because they get stuck and find no help. A full knowledge base (30 to 50 articles covering every feature, edge case, and support question) fixes this. Published to your help centre, embedded in-app.</p>
            <p class="font-semibold text-emerald-700 dark:text-emerald-400 text-sm">Uninstall rate improving after knowledge base went live. <span class="font-normal text-gray-400 dark:text-slate-500">Left Foot Software</span></p>
          </div>
          <div class="flex-shrink-0 text-center bg-white dark:bg-slate-800/80 rounded-2xl px-10 py-8 border border-emerald-100 dark:border-emerald-700/40 shadow-sm">
            <p class="text-4xl font-black text-emerald-600 dark:text-emerald-400">Churn</p>
            <p class="text-xs text-gray-400 dark:text-slate-500 mt-2 font-medium uppercase tracking-wider">improving post-launch</p>
          </div>
        </div>
      </div>

      <!-- Service grid -->
      <div class="grid sm:grid-cols-2 gap-4 mb-14">

        <div class="rounded-2xl p-6 bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 flex flex-col hover:border-emerald-200 dark:hover:border-emerald-500/30 transition-colors">
          <p class="text-2xl font-black text-gray-900 dark:text-white mb-1">Listing rewrite</p>
          <p class="text-xs text-gray-400 dark:text-slate-500 mb-5">title, subtitle, description, search terms</p>
          <h3 class="font-bold text-gray-900 dark:text-white text-sm mb-2">App Store optimisation</h3>
          <p class="text-sm text-gray-500 dark:text-slate-400 flex-1 leading-relaxed">Rewritten around what merchants actually search for. Your listing converts before they click through to the full description.</p>
          <p class="text-xs text-emerald-600 dark:text-emerald-500 mt-5 pt-4 border-t border-slate-100 dark:border-slate-800 font-semibold uppercase tracking-wider">Foundation</p>
        </div>

        <div class="rounded-2xl p-6 bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 flex flex-col hover:border-emerald-200 dark:hover:border-emerald-500/30 transition-colors">
          <p class="text-2xl font-black text-emerald-600 dark:text-emerald-400 mb-1">No recording needed</p>
          <p class="text-xs text-gray-400 dark:text-slate-500 mb-5">voiceover and screen capture, fully produced</p>
          <h3 class="font-bold text-gray-900 dark:text-white text-sm mb-2">Product demo video</h3>
          <p class="text-sm text-gray-500 dark:text-slate-400 flex-1 leading-relaxed">We script, record, and edit. A professional video for your App Store listing, YouTube channel, and landing page. Founder does not need to appear on camera.</p>
          <p class="text-xs text-emerald-600 dark:text-emerald-500 mt-5 pt-4 border-t border-slate-100 dark:border-slate-800 font-semibold uppercase tracking-wider">Foundation</p>
        </div>

        <div class="rounded-2xl p-6 bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 flex flex-col hover:border-emerald-200 dark:hover:border-emerald-500/30 transition-colors">
          <p class="text-2xl font-black text-gray-900 dark:text-white mb-1">Compounding installs</p>
          <p class="text-xs text-gray-400 dark:text-slate-500 mb-5">2 to 4 posts/month, permanently indexed</p>
          <h3 class="font-bold text-gray-900 dark:text-white text-sm mb-2">SEO content</h3>
          <p class="text-sm text-gray-500 dark:text-slate-400 flex-1 leading-relaxed">Educational content targeting merchants before they search for your app. Keeps generating installs after it publishes. We research, write, and publish.</p>
          <p class="text-xs text-blue-600 dark:text-blue-400 mt-5 pt-4 border-t border-slate-100 dark:border-slate-800 font-semibold uppercase tracking-wider">Ongoing</p>
        </div>

        <div class="rounded-2xl p-6 bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 flex flex-col hover:border-emerald-200 dark:hover:border-emerald-500/30 transition-colors">
          <p class="text-2xl font-black text-gray-900 dark:text-white mb-1">Every review answered</p>
          <p class="text-xs text-gray-400 dark:text-slate-500 mb-5">under your brand voice, plus new review outreach</p>
          <h3 class="font-bold text-gray-900 dark:text-white text-sm mb-2">Review management</h3>
          <p class="text-sm text-gray-500 dark:text-slate-400 flex-1 leading-relaxed">Shopify reviews replied to. G2, Capterra, Product Hunt submitted. Outreach sequences to surface new reviews from active merchants.</p>
          <p class="text-xs text-blue-600 dark:text-blue-400 mt-5 pt-4 border-t border-slate-100 dark:border-slate-800 font-semibold uppercase tracking-wider">Ongoing</p>
        </div>

        <div class="rounded-2xl p-6 bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 flex flex-col sm:col-span-2 hover:border-emerald-200 dark:hover:border-emerald-500/30 transition-colors">
          <p class="text-2xl font-black text-gray-900 dark:text-white mb-1">UX copy and pricing strategy</p>
          <p class="text-xs text-gray-400 dark:text-slate-500 mb-5">onboarding, button labels, error messages, empty states, pricing model</p>
          <p class="text-sm text-gray-500 dark:text-slate-400 flex-1 leading-relaxed">Audit of every word a merchant sees that isn't a feature. Pricing model recommendations grounded in merchant behaviour, not what competitors charge.</p>
          <p class="text-xs text-slate-400 dark:text-slate-500 mt-5 pt-4 border-t border-slate-100 dark:border-slate-800 font-semibold uppercase tracking-wider">Project-based</p>
        </div>

      </div>

      <!-- Is this a fit -->
      <div class="relative bg-slate-950 rounded-3xl overflow-hidden border border-slate-800">
        <div class="absolute top-0 right-0 w-64 h-64 bg-emerald-500/8 rounded-full blur-3xl pointer-events-none"></div>
        <div class="relative px-8 sm:px-12 pt-12 pb-8">
          <p class="text-xs font-bold text-emerald-400 uppercase tracking-[0.2em] mb-4">Is this a fit?</p>
          <h2 class="text-3xl sm:text-4xl font-extrabold text-white leading-tight mb-10">You are a fit if your app<br class="hidden sm:block" /> looks like this.</h2>
          <div class="divide-y divide-slate-800">
            <div class="py-4 flex items-center gap-5">
