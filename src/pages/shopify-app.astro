---
import Layout from '~/layouts/PageLayout.astro';
import Header from '~/components/widgets/Header.astro';
import ShopifyAppTheme from '~/components/widgets/ShopifyAppTheme.astro';

const metadata = {
  title: 'Shopify App Marketing: ASO, SEO Content, Product Video',
  description: 'Shopify app growth, end to end: ASO, SEO content, product video, user guides, review management. One client saw 3.25x more conversions.',
};

const calLink = 'https://cal.com/gautham-8bdvdx/30min';

const problems = [
  { n: '01', tag: 'Discovery', t: 'Your listing is not converting like it should', d: 'Generic title, vague value prop, screenshots that do not sell. Merchants scroll past in under three seconds. The listing is the first sale and most apps lose it.' },
  { n: '02', tag: 'Discovery', t: 'Reviews are not working for you', d: 'Replies are late or generic. No outreach to happy merchants. No presence on G2 or Capterra. Review velocity affects your App Store ranking and you are leaving it to chance.' },
  { n: '03', tag: 'Evaluation', t: 'Content is not generating installs', d: 'Blog that stalled after two posts. Product video that was never made or never updated. The apps that grow past 500 installs all have content compounding for them.' },
  { n: '04', tag: 'Retention', t: 'Merchants churn in the first week', d: 'Early churn is almost always an onboarding and documentation gap. The product works. Merchants just never figure that out before they leave.' },
  { n: '05', tag: 'Retention', t: 'Support is reactive, not scalable', d: 'Same questions, answered one at a time. No knowledge base deflecting the repeats. No onboarding docs preventing the confusion in the first place. Support costs time that should go to building.' },
];

const services = [
  {
    word: 'Discovery',
    label: 'App Store optimization',
    items: [
      { t: 'Listing rewrite', s: 'title, subtitle, description, search terms', d: 'Rewritten for what merchants actually type into the search bar. Your listing converts before they even click through.' },
      { t: 'Product demo video', s: 'voiceover + screen capture, fully produced', d: 'We script, record, and edit. A professional video for your App Store listing, YouTube, and landing page. You never touch a camera.' },
      { t: 'Review management', s: 'every review answered, new ones surfaced', d: 'Shopify reviews replied to under your brand voice. G2, Capterra, Product Hunt submitted. Outreach sequences to surface new reviews.' },
    ],
  },
  {
    word: 'Evaluation',
    label: 'Website & SEO content',
    items: [
      { t: 'SEO content', s: '2 to 4 posts/month, permanently indexed', d: 'Content that reaches merchants before they search for your app. Landing pages, use-case pages, comparison guides. Publishes once, keeps generating installs.' },
    ],
  },
  {
    word: 'Understanding',
    label: 'YouTube & video',
    items: [
      { t: 'Video marketing for Shopify apps', s: 'demo, tutorial, onboarding, feature explainers', d: 'Demo videos, feature walkthroughs, onboarding tutorials. Goes on your listing, landing page, and YouTube. We scripted, recorded, and edited Left Foot’s product demo. The founder never touched a camera.' },
    ],
  },
  {
    word: 'Retention',
    label: 'User guides & documentation',
    proof: 'Uninstall rate improving after the knowledge base went live. Left Foot Software.',
    items: [
      { t: 'Knowledge base and user guides', s: '30 to 50 articles, help center + embedded in-app', d: 'Merchants uninstall in week one because they get stuck and find no help. A 30-to-50-article knowledge base turns that around. This is the single biggest lever on churn.' },
    ],
  },
];

const faqs = [
  { q: 'How is this different from a marketing agency?', a: 'A marketing agency runs campaigns across industries. We run a dedicated Shopify app growth practice: ASO, content, video, documentation, reviews, pricing. We know what moves installs and retention in the Shopify ecosystem because we work in it every day.' },
  { q: 'How much of my time does this require?', a: 'Heavy input at the start: we need to understand your app, your customers, and what you already know about why merchants install and uninstall. After the first few weeks, involvement stays light.' },
  { q: 'How long does the foundation phase take?', a: 'Six to eight weeks per app for ASO, user guides, product video, and landing page copy. Timeline depends mostly on how quickly you can give us product access and turn around content reviews.' },
  { q: 'Can you work across multiple apps?', a: 'Yes. The positioning and customer research for your first app largely carries over to the rest of your portfolio. Expanding is faster and cheaper than starting fresh each time.' },
  { q: 'What results can I expect?', a: 'Left Foot Software: uninstall rate improving, support load cut, app ranking #1 on Google for its category. All in 120 days. A separate client saw 3.25x more conversions from YouTube content vs blog over 12 months. Results depend on your starting point. The discovery call tells us what is realistic for your app.' },
  { q: 'How do we get started?', a: 'Book a 30-minute discovery call. We look at your app, your listing, and your install curve. If we can help, we tell you exactly what we would propose and what it would cost. If we cannot, we say so on the call.' },
];

const tiers = [
  {
    name: 'Foundation',
    price: '$2,500',
    unit: '+ one-time, per app',
    note: '',
    items: ['App Store optimization rewrite', 'Product demo video', 'User guide library (30-50 articles)', 'Landing page copy'],
  },
  {
    name: 'Retainer',
    price: '$3,500',
    unit: '/month, per app',
    note: 'Most clients start here',
    items: ['SEO content (2-4 posts/mo)', 'Review management and outreach', 'Directory submissions', 'Support inbox drafts from knowledge base', 'In-app UX copy updates'],
  },
  {
    name: 'Embedded partner',
    price: '$6,000',
    unit: '+ /month, portfolio-wide',
    note: '',
    items: ['All retainer deliverables across apps', 'Website redesign', 'Pricing strategy consulting', 'Product strategy input', 'Enterprise support expansion'],
  },
];
---

<Layout metadata={metadata}>

  <Fragment slot="announcement"></Fragment>

  <Fragment slot="header">
    <Header
      isDark
      links={[
        { text: 'Case Studies', href: '#proof', links: [
          { text: 'Left Foot Software', href: '/shopify-app/case-studies/left-foot-software' },
          { text: 'YouTube Video Marketing: Inventory App Case Study', href: '/shopify-app/case-studies/shopify-app-growth-youtube-marketing' },
        ]},
        { text: 'Services', href: '#work' },
        { text: 'Tools', href: '/shopify-app/tools' },
        { text: 'Pricing', href: '#pricing' },
        { text: 'FAQ', href: '#faq' },
      ]}
      actions={[{ text: 'Book a discovery call', href: calLink, target: '_blank', variant: 'primary' }]}
      isSticky
    />
  </Fragment>

  <Fragment slot="footer"></Fragment>

  <script is:inline>
    document.addEventListener('DOMContentLoaded', () => {
      const logoLink = document.querySelector('#header a[href="/"]');
      if (logoLink) logoLink.setAttribute('href', '/shopify-app');
    });
  </script>

  <ShopifyAppTheme />

  <style is:global>
    /* Marker annotations: hand-drawn red marks, drawn on like a reviewer's pen. */
    .sfy .sfy-circ { position: relative; display: inline-block; }
    .sfy .sfy-circ > svg {
      position: absolute;
      inset: -0.1em -0.22em -0.16em -0.24em;
      width: calc(100% + 0.46em);
      height: calc(100% + 0.26em);
      overflow: visible;
      pointer-events: none;
    }
    .sfy .sfy-anno path {
      stroke: var(--accent);
      fill: none;
      stroke-linecap: round;
      stroke-linejoin: round;
      vector-effect: non-scaling-stroke;
    }
    .sfy .sfy-anno-load path {
      stroke-dasharray: 1;
      stroke-dashoffset: 1;
      animation: sfy-draw 1.1s ease-out 0.6s forwards;
    }
    .sfy .sfy-anno-reveal path {
      stroke-dasharray: 1;
      stroke-dashoffset: 1;
      transition: stroke-dashoffset 0.9s ease-out 0.35s;
    }
    .sfy .sfy-in .sfy-anno-reveal path,
    .sfy .sfy-in.sfy-anno-host .sfy-anno-reveal path {
      stroke-dashoffset: 0;
    }
    .sfy .sfy-plate {
      position: relative;
      background: var(--bg2);
      border: 1px solid var(--border);
      box-shadow: 0 24px 48px -24px rgba(0, 0, 0, 0.55);
    }
    .sfy .sfy-plate::before,
    .sfy .sfy-plate::after {
      content: '';
      position: absolute;
      width: 13px;
      height: 13px;
      pointer-events: none;
    }
    .sfy .sfy-plate::before {
      top: -7px;
      left: -7px;
      border-top: 2px solid var(--accent);
      border-left: 2px solid var(--accent);
    }
    .sfy .sfy-plate::after {
      bottom: -7px;
      right: -7px;
      border-bottom: 2px solid var(--accent);
      border-right: 2px solid var(--accent);
    }
    .sfy .sfy-framed .sfy-frame {
      position: absolute;
      inset: -10px;
      width: calc(100% + 20px);
      height: calc(100% + 20px);
      overflow: visible;
      pointer-events: none;
    }
    @keyframes sfy-draw {
      to { stroke-dashoffset: 0; }
    }
    @media (prefers-reduced-motion: reduce) {
      .sfy .sfy-anno-load path,
      .sfy .sfy-anno-reveal path {
        animation: none;
        transition: none;
        stroke-dashoffset: 0;
      }
    }
  </style>

  <div class="sfy">

    <!-- ===== HERO ===== -->
    <section id="hero" class="relative overflow-hidden">
      <div class="sfy-grain"></div>
      <div class="sfy-container relative pt-20 sm:pt-24 pb-16 sm:pb-20">
        <p class="sfy-label mb-10 flex items-center gap-2.5">
          <span class="inline-block w-1.5 h-1.5 rounded-full" style="background: var(--accent);"></span>
          For Shopify app owners
        </p>
        <h1 class="sfy-display text-[2.9rem] sm:text-7xl lg:text-[6.5rem] mb-10 max-w-5xl">
          You build the app.<br />We help you <span class="sfy-circ">grow it.<svg class="sfy-anno sfy-anno-load" viewBox="0 0 320 110" preserveAspectRatio="none" aria-hidden="true"><path pathLength="1" style="stroke-width: 3.5;" d="M24,60 C16,30 92,10 168,9 C256,8 307,27 305,55 C303,86 234,102 148,100 C68,98 17,83 16,58 C15,37 54,21 110,15" /></svg></span>
        </h1>
        <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-10">
          <p class="text-lg leading-relaxed max-w-md" style="color: var(--muted);">
            More installs, less churn, merchants who actually stick around. We run growth for Shopify apps end to end.
          </p>
          <div class="flex items-center gap-7 flex-shrink-0">
            <a href={calLink} target="_blank" rel="noopener noreferrer" class="sfy-btn">Book a discovery call</a>
            <a href="#proof" class="sfy-link text-sm">See client results</a>
          </div>
        </div>
      </div>

      <!-- Work strip: actual client artifacts, not decoration -->
      <div class="sfy-container relative pb-20 pt-4">
        <div class="sfy-strip">
          <figure class="sfy-shot" style="--rot: -1deg;">
            <img src="/images/shopify-app/gs1-listing.jpg" alt="GS1 Assistant listing on the Shopify App Store: Built for Shopify badge, 4.9 star rating, produced demo video" width="1600" height="539" loading="eager" />
            <figcaption>The listing we rewrote: Built for Shopify, 4.9&#9733; rating</figcaption>
          </figure>
          <figure class="sfy-shot sfy-framed mt-0 md:mt-10" style="--rot: 1deg;">
            <img src="/images/shopify-app/gs1-serp.jpg" alt="Google search results for gs1 assistant showing the client app ranking first with sitelinks and an AI Overview citation" width="790" height="550" loading="lazy" />
            <figcaption>Google, &ldquo;gs1 assistant&rdquo;: ranked #1, cited in the AI Overview</figcaption>
            <svg class="sfy-anno sfy-anno-load sfy-frame" viewBox="0 0 100 100" preserveAspectRatio="none" aria-hidden="true"><path pathLength="1" style="stroke-width: 2.6; animation-delay: 1.3s;" d="M3.5,4.5 C30,2.5 70,2 96.5,3.5 C98.5,30 98,68 97,96 C65,98 30,97.5 4,96.5 C2,66 2.5,32 3.5,4.5 Z" /></svg>
          </figure>
          <figure class="sfy-shot mt-0 md:mt-4" style="--rot: -0.5deg;">
            <img src="/images/shopify-app/gs1-slide.jpg" alt="App Store listing creative produced for GS1 Assistant showing the barcode status dashboard" width="1600" height="900" loading="lazy" />
            <figcaption>Listing creative we produced for the same client</figcaption>
          </figure>
        </div>
      </div>

      <!-- Stat band -->
      <div style="border-top: 1px solid var(--border);">
        <div class="sfy-container">
          <div class="grid grid-cols-1 sm:grid-cols-3">
            <div class="py-8 sm:pr-10" style="border-bottom: 1px solid var(--border-soft);">
              <p class="sfy-num text-4xl font-black inline-flex items-end gap-3" style="color: var(--accent);">3.25&times;<svg class="sfy-anno mb-1" width="40" height="34" viewBox="0 0 40 34" aria-hidden="true"><path pathLength="1" style="stroke-width: 2.4;" d="M4,30 C12,27.5 23,19 31,6.5 M31,6.5 l-9.5,2 M31,6.5 l-0.5,10" /></svg></p>
              <p class="text-sm mt-2" style="color: var(--muted);">more conversions from YouTube vs blog, same topics</p>
            </div>
            <div class="py-8 sm:px-10 sm:border-l" style="border-color: var(--border-soft); border-bottom: 1px solid var(--border-soft);">
              <p class="sfy-num text-4xl font-black">120 days</p>
              <p class="text-sm mt-2" style="color: var(--muted);">from listing rewrite to live knowledge base</p>
            </div>
            <div class="py-8 sm:pl-10 sm:border-l" style="border-color: var(--border-soft); border-bottom: 1px solid var(--border-soft);">
              <p class="sfy-num text-4xl font-black">$3,500<span class="text-xl font-bold" style="color: var(--dim);">/mo</span></p>
              <p class="text-sm mt-2" style="color: var(--muted);">flat retainer, month to month, cancel anytime</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ===== PROBLEM ===== -->
    <section id="problem" class="py-24 sm:py-32">
      <div class="sfy-container">
        <div class="grid lg:grid-cols-12 gap-12 lg:gap-16">
          <div class="lg:col-span-5">
            <div class="lg:sticky lg:top-28 sfy-reveal">
              <h2 class="sfy-display text-4xl sm:text-5xl lg:text-6xl mb-8">Good apps stay <span class="sfy-circ">invisible.<svg class="sfy-anno sfy-anno-reveal" viewBox="0 0 200 24" preserveAspectRatio="none" aria-hidden="true" style="top: auto; height: 0.15em; bottom: -0.13em;"><path pathLength="1" style="stroke-width: 3;" d="M5,10 C60,4 135,4 195,8 M18,17 C75,11.5 145,12 188,15" /></svg></span></h2>
              <p class="text-base leading-relaxed max-w-sm" style="color: var(--muted);">
                Your listing underperforms. Support tickets pile up that docs should handle. Content that should drive installs does not exist or does not rank. Every month it stays that way: merchants who need your app install a competitor instead.
              </p>
            </div>
          </div>
          <div class="lg:col-span-7">
            {problems.map((p) => (
              <div class="sfy-reveal py-8 grid grid-cols-[3rem_1fr] gap-5" style="border-top: 1px solid var(--border);">
                <p class="sfy-num text-sm font-bold pt-1" style="color: var(--dim);">{p.n}</p>
                <div>
                  <div class="flex items-baseline justify-between gap-4 mb-2.5">
                    <h3 class="text-xl font-bold">{p.t}</h3>
                    <p class="sfy-label hidden sm:block flex-shrink-0">{p.tag}</p>
                  </div>
                  <p class="text-[0.95rem] leading-relaxed max-w-xl" style="color: var(--muted);">{p.d}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- ===== PROOF / CASE STUDIES ===== -->
    <section id="proof" class="py-24 sm:py-28" style="background: var(--bg2); border-top: 1px solid var(--border); border-bottom: 1px solid var(--border);">
      <div class="sfy-container">
        <p class="sfy-label mb-5">Case studies</p>
        <h2 class="sfy-display text-4xl sm:text-5xl lg:text-6xl mb-16 sm:mb-20">Two clients. Two types of proof.</h2>

        <!-- CS1 -->
        <div class="sfy-reveal grid lg:grid-cols-12 gap-8 lg:gap-12 pb-16 mb-16 items-start" style="border-bottom: 1px solid var(--border);">
          <div class="lg:col-span-5">
            <p class="sfy-num sfy-display text-7xl sm:text-8xl mb-4" style="color: var(--accent);">120<span class="text-4xl sm:text-5xl"> days</span></p>
            <p class="text-lg font-bold">Zero growth infrastructure to full growth layer</p>
          </div>
          <div class="lg:col-span-7">
            <div class="flex items-baseline gap-4 mb-6">
              <h3 class="text-xl font-bold">Left Foot Software</h3>
              <p class="text-sm" style="color: var(--dim);">Multi-app Shopify suite</p>
            </div>
            <ul class="space-y-3 text-[0.95rem] leading-relaxed mb-8 max-w-xl" style="color: var(--muted);">
              <li>ASO rewrite. Now ranking #1 on Google for &ldquo;gs1 assistant.&rdquo;</li>
              <li>Product video scripted, recorded, and edited. Founder never on camera.</li>
              <li>30-50 article knowledge base. Uninstall rate improving.</li>
              <li>Pricing strategy rebuilt around real merchant usage.</li>
            </ul>
            <a href="/shopify-app/case-studies/left-foot-software" class="sfy-link text-sm">Read the full case study &rarr;</a>
            <figure class="sfy-shot max-w-md mt-10">
              <img src="/images/shopify-app/gs1-serp.jpg" alt="Google search results for gs1 assistant: the client app ranks first with sitelinks and an AI Overview citation" width="790" height="550" loading="lazy" />
              <figcaption>The actual result: #1 on Google for &ldquo;gs1 assistant,&rdquo; cited in the AI Overview</figcaption>
            </figure>
          </div>
        </div>

        <!-- CS2 (mirrored) -->
        <div class="sfy-reveal grid lg:grid-cols-12 gap-8 lg:gap-12 items-start">
          <div class="lg:col-span-7 order-2 lg:order-1">
            <div class="flex items-baseline gap-4 mb-6">
              <h3 class="text-xl font-bold">Shopify App Company</h3>
              <p class="text-sm" style="color: var(--dim);">Inventory &amp; operations category, 12-month data</p>
            </div>
            <ul class="space-y-3 text-[0.95rem] leading-relaxed mb-8 max-w-xl" style="color: var(--muted);">
              <li>YouTube: 1,257 conversions. Blog: 411. Same topics, same offers.</li>
              <li>48 videos over 12 months. Bottom-of-funnel keywords only.</li>
              <li>Gap widened every month. Started at 2.5x, ended at 4.9x.</li>
              <li>Tracked via Google Analytics on install-button clicks.</li>
            </ul>
            <a href="/shopify-app/case-studies/shopify-app-growth-youtube-marketing" class="sfy-link text-sm">Read the full case study &rarr;</a>
          </div>
          <div class="lg:col-span-5 order-1 lg:order-2">
            <p class="sfy-num sfy-display text-7xl sm:text-8xl mb-4 lg:text-right" style="color: var(--accent);">3.25&times;</p>
            <p class="text-lg font-bold mb-8 lg:text-right">More conversions from YouTube vs blog</p>
            <div class="max-w-md lg:ml-auto">
              <div class="mb-4">
                <div class="flex items-baseline justify-between mb-1.5">
                  <p class="text-sm font-bold">YouTube</p>
                  <p class="sfy-num text-sm font-bold">1,257</p>
                </div>
                <div class="sfy-bar-track h-2 w-full"><div class="sfy-bar-fill" style="width: 100%; background: var(--accent);"></div></div>
              </div>
              <div class="mb-3">
                <div class="flex items-baseline justify-between mb-1.5">
                  <p class="text-sm font-bold" style="color: var(--muted);">Blog</p>
                  <p class="sfy-num text-sm font-bold" style="color: var(--muted);">411</p>
                </div>
                <div class="sfy-bar-track h-2 w-full"><div class="sfy-bar-fill" style="width: 32.7%; background: var(--dim);"></div></div>
              </div>
              <p class="text-xs" style="color: var(--dim);">Install-button clicks over 12 months, Google Analytics</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ===== COMPARISON ===== -->
    <section class="py-24 sm:py-28">
      <div class="sfy-container">
        <h2 class="sfy-display text-4xl sm:text-5xl mb-16 max-w-3xl">Two ways to run a Shopify app company.</h2>
        <div class="grid md:grid-cols-2 gap-2">
          <div class="sfy-reveal md:pr-14 pb-12 md:pb-0 md:pt-6">
            <p class="sfy-label mb-8 flex items-center gap-4">
              Without app growth expertise
              <svg class="sfy-anno sfy-anno-reveal flex-shrink-0" width="54" height="24" viewBox="0 0 56 24" aria-hidden="true"><path pathLength="1" style="stroke: var(--dim); stroke-width: 1.8;" d="M3,6 C10,10 16,8 24,13 C32,18 42,16 50,20 M50,20 l-7,-0.5 M50,20 l-1.5,-6.5" /></svg>
            </p>
            <ul class="space-y-0">
              {[
                'Listing copy written by whoever had 20 minutes between sprints',
                'Same five support questions, answered from scratch, every single day',
                'No product video. Merchants install blind and churn.',
                'Reviews answered late, if at all. No outreach to happy merchants.',
                'Blog or content plan that stalled after the first two posts',
                'Pricing set at launch and never stress-tested against real usage',
              ].map((text) => (
                <li class="py-4 flex items-start gap-3.5 text-[0.95rem] leading-relaxed" style="color: var(--muted); border-top: 1px solid var(--border-soft);"><svg class="flex-shrink-0 mt-1" width="13" height="13" viewBox="0 0 14 14" aria-hidden="true"><path d="M2.5,2.5 C5.5,5.5 9,9.5 11.8,12 M11.5,2 C8.5,5.5 5,9 2,11.8" fill="none" stroke="var(--dim)" stroke-width="1.7" stroke-linecap="round" /></svg><span>{text}</span></li>
              ))}
            </ul>
          </div>
          <div class="sfy-reveal sfy-plate p-8 sm:p-10" style="transform: rotate(-0.4deg);">
            <p class="sfy-label mb-8 flex items-center gap-4" style="color: var(--text);">
              With SellOnTube
              <svg class="sfy-anno sfy-anno-reveal flex-shrink-0" width="54" height="24" viewBox="0 0 56 24" aria-hidden="true"><path pathLength="1" style="stroke-width: 2;" d="M3,20 C11,16 17,18 26,12 C34,6.5 42,8 50,4 M50,4 l-7,0.5 M50,4 l-1.5,6.5" /></svg>
            </p>
            <ul class="space-y-0">
              {[
                'Listing rewritten by ASO specialists. Converts before the click.',
                'Knowledge base deflects the repeat questions. Support scales.',
                'Product video scripted, recorded, and edited by our team. Reusable everywhere.',
                'Every review answered on-brand. G2, Capterra, Product Hunt covered.',
                'SEO content publishes monthly. Installs come in from search.',
                'Pricing model built on actual merchant usage patterns. Not guesswork.',
              ].map((text) => (
                <li class="py-4 flex items-start gap-3.5 text-[0.95rem] leading-relaxed" style="color: var(--text); border-top: 1px solid var(--border);"><svg class="flex-shrink-0 mt-1" width="15" height="13" viewBox="0 0 16 14" aria-hidden="true"><path d="M2,7.5 C3.5,9 5,11.3 6,13 C8.5,8 11.5,4 14.5,1.5" fill="none" stroke="var(--accent)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" /></svg><span>{text}</span></li>
              ))}
            </ul>
          </div>
        </div>
      </div>
    </section>

    <!-- ===== SERVICES ===== -->
    <section id="work" class="py-24 sm:py-28" style="background: var(--bg2); border-top: 1px solid var(--border); border-bottom: 1px solid var(--border);">
      <div class="sfy-container">
        <h2 class="sfy-display text-4xl sm:text-5xl lg:text-6xl mb-6">Everything a Shopify app<br />needs to grow.</h2>
        <p class="text-base leading-relaxed mb-16 max-w-xl" style="color: var(--muted);">
          We build the content layer around your product. From the App Store listing to the help center article a merchant reads at 11 PM. Four stages of the merchant journey, one team covering all of them.
        </p>

        {services.map((s, i) => (
          <details class="sfy-row sfy-reveal" open={i === 0}>
            <summary>
              <span class="flex items-baseline gap-5 min-w-0">
                <span class="sfy-num text-sm font-bold" style="color: var(--dim);">{String(i + 1).padStart(2, '0')}</span>
                <span class="sfy-display text-3xl sm:text-5xl">{s.word}</span>
              </span>
              <span class="hidden md:block text-sm flex-1 text-right mr-6" style="color: var(--dim);">{s.label}</span>
              <span class="sfy-plus">+</span>
            </summary>
            <div class:list={['pb-10 md:pl-[4.3rem]', s.word === 'Discovery' ? 'grid md:grid-cols-[1fr_20rem] gap-10 max-w-5xl' : 'max-w-3xl']}>
              <div>
              {s.items.map((item) => (
                <div class="pt-6">
                  <div class="flex items-baseline gap-4 mb-1.5">
                    <h3 class="text-lg font-bold">{item.t}</h3>
                    <p class="text-xs hidden sm:block" style="color: var(--dim);">{item.s}</p>
                  </div>
                  <p class="text-[0.95rem] leading-relaxed" style="color: var(--muted);">{item.d}</p>
                </div>
              ))}
              {s.proof && (
                <p class="mt-6 text-sm font-bold" style="color: var(--accent);">{s.proof}</p>
              )}
              </div>
              {s.word === 'Discovery' && (
                <figure class="sfy-shot self-start mt-6 hidden md:block">
                  <img src="/images/shopify-app/gs1-slide.jpg" alt="App Store listing creative produced for GS1 Assistant" width="1600" height="900" loading="lazy" />
                  <figcaption>Listing creative from the GS1 Assistant rewrite</figcaption>
                </figure>
              )}
            </div>
          </details>
        ))}

        <div class="pt-10 max-w-3xl">
          <p class="text-sm font-bold mb-1.5">Project-based add-on: UX copy and pricing strategy</p>
          <p class="text-[0.95rem] leading-relaxed" style="color: var(--muted);">
            We audit the words merchants see that are not features: onboarding, empty states, error messages. Pricing model based on merchant behavior, not what competitors charge.
          </p>
        </div>
      </div>
    </section>

    <!-- ===== HOW IT WORKS ===== -->
    <section id="how" class="py-24 sm:py-28">
      <div class="sfy-container">
        <h2 class="sfy-display text-4xl sm:text-5xl mb-16">From first call to shipped work.</h2>
        <div class="grid md:grid-cols-3 gap-10 md:gap-8">
          {[
            { n: '01', t: 'Book a discovery call', d: '30 minutes. We review your app, listing, install curve, and top support tickets. If we can help, we tell you exactly what we would propose and what it costs.' },
            { n: '02', t: 'We audit and propose', d: 'Specific deliverables scoped to your app. Listing rewrite, knowledge base plan, video brief, content calendar. No surprises once we start.' },
            { n: '03', t: 'We build, you ship', d: 'Foundation phase: 6 to 8 weeks. We handle listing, docs, video, and content while your team ships features. Retainer kicks in for ongoing content, reviews, and support infrastructure.' },
          ].map((step) => (
            <div class="sfy-reveal pt-6" style="border-top: 1px solid var(--border);">
              <p class="sfy-num sfy-display text-6xl mb-6" style="color: var(--border);">{step.n}</p>
              <h3 class="text-lg font-bold mb-3">{step.t}</h3>
              <p class="text-[0.95rem] leading-relaxed" style="color: var(--muted);">{step.d}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ===== FIT CHECK ===== -->
    <section class="py-4 pb-24">
      <div class="sfy-container">
        <div class="sfy-reveal px-8 sm:px-14 py-12 sm:py-14" style="background: var(--bg2); border: 1px solid var(--border);">
          <h2 class="sfy-display text-3xl sm:text-4xl mb-10 max-w-2xl">You are a fit if your app looks like this.</h2>
          <ul>
            {[
              'Shopify app company that wants more installs, better activation, or lower churn',
              'Active installs and some revenue, past the early experimental stage',
              'High early churn you cannot fully explain',
              'Support inbox stealing time from building',
              'Multiple apps in portfolio, or plans to build more',
            ].map((text) => (
              <li class="py-4 flex items-baseline gap-5" style="border-top: 1px solid var(--border);">
                <svg class="flex-shrink-0 translate-y-[2px]" width="15" height="13" viewBox="0 0 16 14" aria-hidden="true"><path d="M2,7.5 C3.5,9 5,11.3 6,13 C8.5,8 11.5,4 14.5,1.5" fill="none" stroke="var(--accent)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" /></svg>
                <p class="font-medium">{text}</p>
              </li>
            ))}
          </ul>
          <p class="text-sm leading-relaxed mt-8" style="color: var(--dim);">
            Not the right fit: apps in the very early experimental stage, teams that already have Shopify-app-specific growth expertise in-house, or teams looking purely for paid ads management.
          </p>
        </div>
      </div>
    </section>

    <!-- ===== PRICING ===== -->
    <section id="pricing" class="py-24 sm:py-28" style="border-top: 1px solid var(--border);">
      <div class="sfy-container">
        <p class="sfy-label mb-5">Pricing</p>
        <h2 class="sfy-display text-4xl sm:text-5xl lg:text-6xl mb-6">Start where you need to.<br />Expand as you grow.</h2>
        <p class="text-base mb-16 max-w-lg" style="color: var(--muted);">
          Foundation work is one-time. Ongoing is monthly. Most clients start both at once. Month-to-month, no lock-in contract, cancel anytime.
        </p>

        {tiers.map((tier) => (
          <div class="sfy-reveal grid lg:grid-cols-12 gap-6 lg:gap-12 py-10" style="border-top: 1px solid var(--border);">
            <div class="lg:col-span-5">
              <div class="flex items-baseline gap-4 mb-3">
                <h3 class="text-xl font-bold">{tier.name}</h3>
                {tier.note && <p class="text-xs font-bold" style="color: var(--accent);">{tier.note}</p>}
              </div>
              <p class="sfy-num sfy-display text-5xl sm:text-6xl">{tier.note ? <span class="sfy-circ">{tier.price}<svg class="sfy-anno sfy-anno-reveal" viewBox="0 0 320 110" preserveAspectRatio="none" aria-hidden="true"><path pathLength="1" style="stroke-width: 2.8;" d="M24,60 C16,30 92,10 168,9 C256,8 307,27 305,55 C303,86 234,102 148,100 C68,98 17,83 16,58 C15,37 54,21 110,15" /></svg></span> : tier.price}<span class="text-lg font-bold tracking-normal" style="color: var(--dim);"> {tier.unit}</span></p>
            </div>
            <div class="lg:col-span-7">
              <ul class="grid sm:grid-cols-2 gap-x-10">
                {tier.items.map((item) => (
                  <li class="py-2.5 text-[0.95rem]" style="color: var(--muted); border-bottom: 1px solid var(--border-soft);">{item}</li>
                ))}
              </ul>
            </div>
          </div>
        ))}

        <div class="pt-12">
          <a href={calLink} target="_blank" rel="noopener noreferrer" class="sfy-btn">Book a discovery call</a>
        </div>
      </div>
    </section>

    <!-- ===== FAQ ===== -->
    <section id="faq" class="py-24 sm:py-28" style="background: var(--bg2); border-top: 1px solid var(--border);">
      <div class="sfy-container">
        <h2 class="sfy-display text-4xl sm:text-5xl mb-16">Common questions</h2>
        <div>
          {faqs.map((faq) => (
            <div class="sfy-reveal grid lg:grid-cols-12 gap-3 lg:gap-12 py-9" style="border-top: 1px solid var(--border);">
              <h3 class="lg:col-span-5 text-lg font-bold">{faq.q}</h3>
              <p class="lg:col-span-7 text-[0.95rem] leading-relaxed max-w-2xl" style="color: var(--muted);">{faq.a}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ===== CLOSER ===== -->
    <section class="relative overflow-hidden py-28 sm:py-36" style="border-top: 1px solid var(--border);">
      <div class="sfy-grain"></div>
      <div class="sfy-container relative">
        <h2 class="sfy-display sfy-reveal sfy-anno-host text-[2.75rem] sm:text-7xl lg:text-[6rem] mb-12 max-w-5xl">Let&rsquo;s <span class="sfy-circ">grow<svg class="sfy-anno sfy-anno-reveal" viewBox="0 0 200 24" preserveAspectRatio="none" aria-hidden="true" style="top: auto; height: 0.16em; bottom: -0.14em;"><path pathLength="1" style="stroke-width: 3.5;" d="M5,10 C60,4 135,4 195,8 M18,17 C75,11.5 145,12 188,15" /></svg></span> your Shopify app.</h2>
        <div class="flex flex-col sm:flex-row sm:items-center gap-8">
          <a href={calLink} target="_blank" rel="noopener noreferrer" class="sfy-btn flex-shrink-0">Book a discovery call</a>
          <p class="text-base leading-relaxed max-w-sm" style="color: var(--muted);">
            30 minutes. We look at your app, find the biggest gaps, and tell you exactly where we would start. There is no pitch deck and no follow-up sequence.
          </p>
        </div>
      </div>
    </section>

    <!-- ===== FOOTER ===== -->
    <footer class="py-16" style="border-top: 1px solid var(--border);">
      <div class="sfy-container">
        <div class="grid sm:grid-cols-3 gap-10 mb-12">
          <div>
            <p class="font-bold text-sm mb-4">SellOnTube for Shopify Apps</p>
            <p class="text-sm leading-relaxed max-w-xs" style="color: var(--muted);">Shopify app growth specialists. ASO, content, video, documentation, reviews, pricing strategy.</p>
          </div>
          <div>
            <p class="sfy-label mb-5">Services</p>
            <div class="space-y-2.5 text-sm" style="color: var(--muted);">
              <p>App Store Optimization</p>
              <p>User Guides &amp; Knowledge Base</p>
              <p>Product Demo Video</p>
              <p>SEO Content</p>
              <p>Video Marketing</p>
              <p>Review Management</p>
            </div>
          </div>
          <div>
            <p class="sfy-label mb-5">Explore</p>
            <div class="space-y-2.5 text-sm">
              <a href="/shopify-app/case-studies/left-foot-software" class="block sfy-link" style="color: var(--muted);">Left Foot Software case study</a>
              <a href="/shopify-app/case-studies/shopify-app-growth-youtube-marketing" class="block sfy-link" style="color: var(--muted);">YouTube video marketing case study</a>
              <a href="/shopify-app/tools" class="block sfy-link" style="color: var(--muted);">Free Tools</a>
            </div>
          </div>
        </div>
        <div class="pt-8 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4" style="border-top: 1px solid var(--border-soft);">
          <p class="text-xs" style="color: var(--dim);">&copy; 2026 SellOnTube. All rights reserved.</p>
          <div class="flex items-center gap-6 text-xs" style="color: var(--dim);">
            <a href="/privacy-policy" class="hover:underline">Privacy</a>
            <a href="/terms-of-service" class="hover:underline">Terms</a>
