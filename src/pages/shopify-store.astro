---
import Layout from '~/layouts/PageLayout.astro';
import Header from '~/components/widgets/Header.astro';
import '~/assets/styles/sfo.css';

const metadata = {
  title: 'Shopify Operations for Scaled Merchants | SellOnTube',
  description: 'We run the operational layer of scaled Shopify Plus stores. Custom apps, cross-border infrastructure, Klaviyo email, compliance systems. One client went from $1.5M to $10M in 18 months.',
  openGraph: {
    images: [{ url: '~/assets/images/og/shopify-store.jpg', width: 1200, height: 630 }],
  },
};

const calLink = 'https://cal.com/gautham-8bdvdx/30min';

const problems = [
  { n: '01', t: 'Your team spends half the day on work that doesn’t grow the business.', d: 'Orders, tagging, refunds, fraud checks, catalog updates. You keep hiring and the new people end up doing the same grunt work.' },
  { n: '02', t: 'Someone changed a price and nobody knows who.', d: 'A brand calls about MAP pricing. You dig through Shopify logs. They don’t tell you enough. This happens every week.' },
  { n: '03', t: 'Merchant Center keeps disapproving products.', d: 'Missing GTINs. Duplicate barcodes. An ingredient flagged in Germany. You fix 10, and 15 more pop up.' },
  { n: '04', t: 'Selling in multiple countries but guessing which ones work.', d: 'Shopify analytics don’t slice it the way you need. Which countries are growing? Where are ads returning? You go with your gut.' },
  { n: '05', t: 'Paying $500+/month for apps that do 70% of what you need.', d: 'The other 30% is workarounds, manual steps, or yet another app. Nobody has built something for your exact workflow.' },
  { n: '06', t: 'There’s data in your store that nobody acts on.', d: 'Surfacing insights means spreadsheets and hoping someone reads them. Trends show up three weeks after they started.' },
];

const outcomes = [
  { stat: '100+', t: 'localized country subdomains', d: 'From one English site. Owner still only manages the US version.' },
  { stat: '30', t: 'Merchant Centers and ad accounts', d: 'Built from one master product feed. Each localized to currency and language.' },
  { stat: '$1M+/yr', t: 'email revenue', d: 'Klaviyo was sitting dormant. We warmed it over 6 weeks and built every flow from scratch.' },
  { stat: '400,000', t: 'compliance touchpoints', d: '100+ brands with MAP pricing rules, managed manually. Now automated from one screen.' },
  { stat: '$100K+', t: 'saved in one weekend', d: 'A vendor uploaded rupee pricing across the entire catalog. Daily backups meant full rollback in minutes.' },
  { stat: 'Oracle ERP', t: 'fraud integration', d: 'High-risk orders automatically flagged and blocked before fulfillment. No manual review queue.' },
];

// The actual expansion story: 2 launch markets to 50+ active countries.
const countries = [
  { c: 'US', on: true }, { c: 'CA', on: true }, { c: 'GB', on: false }, { c: 'DE', on: false }, { c: 'FR', on: false }, { c: 'AU', on: false },
  { c: 'NL', on: false }, { c: 'ES', on: false }, { c: 'IT', on: false }, { c: 'CH', on: false }, { c: 'SE', on: false }, { c: 'NO', on: false },
  { c: 'DK', on: false }, { c: 'FI', on: false }, { c: 'IE', on: false }, { c: 'BE', on: false }, { c: 'AT', on: false }, { c: 'PT', on: false },
  { c: 'PL', on: false }, { c: 'CZ', on: false }, { c: 'GR', on: false }, { c: 'RO', on: false }, { c: 'HU', on: false }, { c: 'NZ', on: false },
  { c: 'JP', on: false }, { c: 'KR', on: false }, { c: 'SG', on: false }, { c: 'HK', on: false }, { c: 'AE', on: false }, { c: 'SA', on: false },
  { c: 'IL', on: false }, { c: 'ZA', on: false }, { c: 'MX', on: false }, { c: 'BR', on: false }, { c: 'CL', on: false }, { c: 'CO', on: false },
  { c: 'AR', on: false }, { c: 'IN', on: false }, { c: 'MY', on: false }, { c: 'TH', on: false }, { c: 'PH', on: false }, { c: 'ID', on: false },
  { c: 'TW', on: false }, { c: 'TR', on: false }, { c: 'HR', on: false }, { c: 'SK', on: false }, { c: 'SI', on: false }, { c: 'EE', on: false },
  { c: 'LV', on: false }, { c: 'LT', on: false }, { c: 'LU', on: false }, { c: 'IS', on: false },
];

const apps = [
  { stat: '400,000', sub: 'compliance touchpoints, one screen', t: 'Market Exclusion Manager', d: '8,000 SKUs across 50 markets. Some products can’t legally ship everywhere. Toggling them one by one is not a system.', client: 'US Supplements Brand' },
  { stat: 'Under 1%', sub: 'compliance error rate, disapprovals nearly gone', t: 'GTIN / Barcode Scanner', d: 'Missing or duplicate barcodes getting products pulled from Merchant Center. With 1,000+ SKUs you can’t catch them by hand.', client: 'UK Jewellery Brand' },
  { stat: 'Full audit trail', sub: 'who changed what, when: searchable', t: 'Staff Activity Monitor', d: 'Teams grow, people change things, nobody tracks who did what. A brand calls about a MAP violation and you have nowhere to look.', client: 'Both clients' },
  { stat: '30 seconds', sub: 'revenue, top products, countries: one screen', t: 'Executive Dashboard', d: 'Clicking through six Shopify screens every morning to get a picture of the business.', client: 'Both clients' },
  { stat: 'Zero manual steps', sub: 'new products auto-tagged into Klaviyo flows', t: 'New Arrivals Auto-Tagger', d: 'New products added but the email team is always a week behind on tagging them for campaigns.', client: 'US Supplements Brand' },
  { stat: 'Any country, instantly', sub: 'revenue by country, source, and time range', t: 'Country Sales Dashboard', d: 'Selling in 50+ countries with no quick way to see which are growing and which are stalling.', client: 'US Supplements Brand' },
];

const shots = [
  { src: '/images/shopify-portfolio/llm-traffic-dashboard.png', alt: 'LLM Traffic Dashboard inside Shopify admin', t: 'LLM Traffic Dashboard', d: 'Tracks which AI shopping surfaces (ChatGPT, Perplexity, Google AI) are sending traffic and converting. Built for US Supplements Brand.', tint: '#e8ede7' },
  { src: '/images/shopify-portfolio/executive-dashboard.png', alt: 'Executive Dashboard inside Shopify admin', t: 'Executive Dashboard', d: 'Revenue, top products, out-of-stock movers, and country breakdown in one screen. Replaces clicking through six Shopify reports every morning. Built for both clients.', tint: '#ece7df' },
  { src: '/images/shopify-portfolio/staff-activity-logs.png', alt: 'Staff Activity Logs inside Shopify admin', t: 'Staff Activity Monitor', d: 'Full audit trail of every product, price, and order change, searchable by staff member, date, and action. Built for both clients.', tint: '#e9e4ea' },
  { src: '/images/shopify-portfolio/llm-readiness-scorecard.png', alt: 'LLM Readiness Scorecard inside Shopify admin', t: 'LLM Readiness Scorecard', d: 'Scores every product in the catalog for AI shopping surface eligibility. Products with data gaps get skipped by ChatGPT and Perplexity. Built for US Supplements Brand.', tint: '#e5e9ec' },
];

const whyUs = [
  { t: 'Operators, not consultants.', d: '10+ years inside real stores. Managing orders, fixing catalog data, scaling channels, handling peak-season chaos. We know what breaks when a store grows because we have been the ones fixing it.' },
  { t: 'Ops and growth, together.', d: 'Most agencies pick one lane. We combine both. Automate the grunt work, reinvest that time into growth. One client added $1M/year from email while cutting ops workload in half.' },
  { t: 'Infrastructure, not a vendor.', d: 'Once we’re managing compliance, fraud workflows, and catalog health inside your store, we’re not a line item. We’re the plumbing. The switching cost is high because the value is high. Our longest client has been with us for nine years.' },
  { t: 'AI-native from day one.', d: 'Shopify now integrates natively with ChatGPT and Claude. We’ve been building with Sidekick and Flow since they launched. While other agencies figure out what AI means for commerce, we’re already deploying it inside stores.' },
];

const guarantees = [
  { t: 'Everything stays in your store.', d: 'Every app, workflow, and dashboard lives in your admin. Stop working with us and it all stays.' },
  { t: 'No long-term contracts.', d: 'Monthly retainer, cancel anytime. We earn it every month.' },
  { t: 'You own the code.', d: 'Sidekick apps are built in your admin using your account. They’re yours, not ours.' },
  { t: 'Start with one project, not a long commitment.', d: 'Pick one Quick Win. See how we work. Then decide if you want more.' },
  { t: 'Transparent access.', d: 'Staff or super admin. Every change logged. You can see exactly what was done and when.' },
];

const fit = [
  'Shopify Plus with $5M+ revenue and 5,000+ SKUs',
  'Selling internationally, or planning to expand into new markets',
  'Compliance requirements: MAP pricing, brand restrictions, or regulated products',
  'Selling across 2 or more channels (Shopify, Amazon, eBay)',
  'Team of 10 or more and your processes are starting to crack',
  'You’re spending more time on operations than on growth',
];

const steps = [
  { n: '01', t: 'Discovery call (30 min)', d: 'We look at your store, your current operational setup, and where the biggest bottlenecks are. We tell you upfront whether and how we can help.' },
  { n: '02', t: 'Store and operations audit', d: 'We review your tech stack, feed infrastructure, integrations, and workflows. You get a prioritised list of what to fix, ranked by operational impact.' },
  { n: '03', t: 'Scoped proposal', d: 'Clear scope, deliverables, and timeline. Quick Win projects start from $2,000. Retainers start at $3,500/mo. No vague commitments.' },
  { n: '04', t: 'Build and hand over', d: 'We build, test, and document. Every app and workflow is handed over with documentation so your team can own it.' },
];

const tiers = [
  { name: 'Quick Win', price: '$2,000–$4,000', unit: 'one-time', note: '', d: 'One-time project. One Sidekick app, one Flow automation, one feed repair. Delivered in 1 to 2 weeks. No commitment beyond that.' },
  { name: 'Discovery and Build', price: '$3,500–$6,000', unit: 'one-time', note: 'Best entry point', d: 'Full workflow audit plus a scoped build. Best entry point for stores that don’t know exactly what they need yet.' },
  { name: 'Monthly retainer', price: '$3,500–$6,000', unit: '/month', note: '', d: 'Ongoing ops, feed management, Klaviyo, new automations. Cancel anytime. Everything we build stays in your store.' },
];

const faqs = [
  { q: 'What size of Shopify store do you work with?', a: 'Best fit is Shopify Plus merchants doing $5M+ in annual revenue, 5,000+ SKUs, team of 10 or more. Below that, the investment in custom operational infrastructure typically does not pencil out. We’ll tell you honestly on the discovery call.' },
  { q: 'How is this different from a Shopify agency?', a: 'Agencies build and maintain stores. We handle the operational infrastructure underneath: feed management, ERP connectors, compliance automation, international expansion, custom Sidekick apps, and analytics. The work that does not fit neatly into a theme or a Shopify app.' },
  { q: 'What does Sidekick app development actually mean?', a: 'Shopify Sidekick lets us build custom apps that live directly inside your merchant admin. No App Store fees. No approval process. We build internal tools specific to your store: dashboards, exclusion managers, compliance monitors, staff logs. Each app goes through 4 to 15 rounds of refinement to reach production quality.' },
  { q: 'Can you work alongside our existing development team or agency?', a: 'Yes. Most agencies handle design, dev, or paid marketing. We do operational automation and internal tooling. No overlap. We have worked alongside in-house teams and existing agencies for multiple clients without friction.' },
  { q: 'What if something goes wrong during the engagement?', a: 'We run daily catalog backups with rollback capability. When a vendor uploads wrong pricing or a third-party app corrupts data, you recover in minutes. Our flagship client avoided an estimated $100K+ loss when a vendor uploaded rupee pricing across an entire catalog over a weekend.' },
  { q: 'How do we get started?', a: 'Book a 30-minute discovery call. We’ll look at your store, your current setup, and where operations are costing you time or revenue. If we can help, we’ll tell you exactly what we’d propose and what it would cost.' },
];
---

<Layout metadata={metadata}>

  <Fragment slot="footer"></Fragment>

  <Fragment slot="header">
    <Header
      links={[
        { text: 'Results', href: '#proof' },
        { text: 'What We Build', href: '#work' },
        { text: 'Case Studies', links: [
          { text: 'US Supplements Brand', href: '/case-studies/us-supplements-brand' },
          { text: 'UK Jewellery Brand', href: '/case-studies/luxury-jewellery-client' },
        ]},
        { text: 'Pricing', href: '#pricing' },
      ]}
      actions={[{ text: 'Book a discovery call', href: calLink, target: '_blank', variant: 'primary' }]}
      isSticky
    />
  </Fragment>

  <script is:inline>
    // This page is light-only. The site theme script can re-apply .dark (stored
    // preference or OS setting), so keep stripping it for as long as we're here.
    (() => {
      const strip = () => {
        if (document.documentElement.classList.contains('dark')) {
          document.documentElement.classList.remove('dark');
        }
      };
      strip();
      new MutationObserver(strip).observe(document.documentElement, { attributes: true, attributeFilter: ['class'] });
    })();
  </script>


  <div class="sfo">

    <!-- ===== HERO ===== -->
    <section id="hero" class="relative overflow-hidden">
      <div class="sfo-grid-light"></div>
      <div class="sfo-container relative pt-20 sm:pt-28 pb-16 sm:pb-24">
        <div class="grid lg:grid-cols-12 gap-14 lg:gap-10 items-center">
          <div class="lg:col-span-6">
            <p class="sfo-label mb-9 flex items-center gap-2.5">
              <span class="inline-block w-1.5 h-1.5 rounded-full" style="background: var(--accent);"></span>
              AI-native Shopify operations partner
            </p>
            <h1 class="sfo-display text-[2.7rem] sm:text-6xl lg:text-[4.6rem] mb-8">
              We run the <span class="sfo-circ">operational<svg class="sfo-anno sfo-anno-load" viewBox="0 0 320 110" preserveAspectRatio="none" aria-hidden="true"><path pathLength="1" style="stroke-width: 3.2;" d="M24,60 C16,30 92,10 168,9 C256,8 307,27 305,55 C303,86 234,102 148,100 C68,98 17,83 16,58 C15,37 54,21 110,15" /></svg></span> layer of scaled Shopify stores.
            </h1>
            <p class="text-lg leading-relaxed max-w-md mb-10" style="color: var(--muted);">
              At $5M+ revenue you need more than a developer and a theme. You need someone who knows what breaks at scale and builds the systems before it does.
            </p>
            <div class="flex items-center gap-7">
              <a href={calLink} target="_blank" rel="noopener noreferrer" class="sfo-btn">Book a discovery call</a>
              <a href="#proof" class="sfo-link text-sm">See the results</a>
            </div>
          </div>
          <div class="lg:col-span-6 hidden lg:block">
            <div class="sfo-collage h-[560px]">
              <figure class="sfo-shot c1" style="--rot: -1.5deg;">
                <img src="/images/shopify-portfolio/llm-traffic-dashboard.png" alt="LLM Traffic Dashboard inside Shopify admin" width="1600" height="1000" loading="eager" />
              </figure>
              <figure class="sfo-shot c2" style="--rot: 1deg;">
                <img src="/images/shopify-portfolio/executive-dashboard.png" alt="Executive Dashboard inside Shopify admin" width="1600" height="1000" loading="eager" />
              </figure>
              <figure class="sfo-shot c3" style="--rot: -0.5deg;">
                <img src="/images/shopify-portfolio/staff-activity-logs.png" alt="Staff Activity Logs inside Shopify admin" width="1600" height="1000" loading="eager" />
                <figcaption>Three of the 14+ apps we run inside client admins</figcaption>
              </figure>
            </div>
          </div>
        </div>

        <!-- Mobile: single screenshot -->
        <figure class="sfo-shot mt-14 lg:hidden">
          <img src="/images/shopify-portfolio/executive-dashboard.png" alt="Executive Dashboard inside Shopify admin" width="1600" height="1000" loading="eager" />
          <figcaption>Executive Dashboard, running inside a client&rsquo;s Shopify admin</figcaption>
        </figure>
      </div>

      <!-- Stat band -->
      <div style="border-top: 1px solid var(--border);">
        <div class="sfo-container">
          <div class="grid grid-cols-1 sm:grid-cols-3">
            <div class="py-8 sm:pr-10" style="border-bottom: 1px solid var(--border-soft);">
              <p class="sfo-num text-4xl font-black inline-flex items-end gap-3" style="color: var(--accent-deep);">$1.5M &rarr; $10M<svg class="sfo-anno mb-1 flex-shrink-0" width="40" height="34" viewBox="0 0 40 34" aria-hidden="true"><path pathLength="1" style="stroke-width: 2.4;" d="M4,30 C12,27.5 23,19 31,6.5 M31,6.5 l-9.5,2 M31,6.5 l-0.5,10" /></svg></p>
              <p class="text-sm mt-2" style="color: var(--muted);">one client&rsquo;s revenue over 18 months</p>
            </div>
            <div class="py-8 sm:px-10 sm:border-l" style="border-color: var(--border-soft); border-bottom: 1px solid var(--border-soft);">
              <p class="sfo-num text-4xl font-black">9 years</p>
              <p class="text-sm mt-2" style="color: var(--muted);">our longest client relationship, still running</p>
            </div>
            <div class="py-8 sm:pl-10 sm:border-l" style="border-color: var(--border-soft); border-bottom: 1px solid var(--border-soft);">
              <p class="sfo-num text-4xl font-black">14+</p>
              <p class="text-sm mt-2" style="color: var(--muted);">custom apps built inside client admins</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ===== PROBLEMS ===== -->
    <section id="pain" class="py-24 sm:py-32">
      <div class="sfo-container">
        <div class="grid lg:grid-cols-12 gap-12 lg:gap-16">
          <div class="lg:col-span-5">
            <div class="lg:sticky lg:top-28 sfo-reveal">
              <h2 class="sfo-display text-4xl sm:text-5xl mb-8">These are the problems <span class="sfo-circ">nobody talks about.<svg class="sfo-anno sfo-anno-reveal" viewBox="0 0 200 24" preserveAspectRatio="none" aria-hidden="true" style="top: auto; height: 0.15em; bottom: -0.13em;"><path pathLength="1" style="stroke-width: 3;" d="M5,10 C60,4 135,4 195,8 M18,17 C75,11.5 145,12 188,15" /></svg></span></h2>
              <p class="text-base leading-relaxed max-w-sm" style="color: var(--muted);">
                Everyone assumes it&rsquo;s just how it is. None of this is &ldquo;how it is.&rdquo; You just haven&rsquo;t had someone build the fix inside Shopify.
              </p>
              <a href="#proof" class="sfo-link text-sm inline-block mt-8">See what we&rsquo;ve built &rarr;</a>
            </div>
          </div>
          <div class="lg:col-span-7">
            {problems.map((p) => (
              <div class="sfo-reveal py-8 grid grid-cols-[3rem_1fr] gap-5" style="border-top: 1px solid var(--border);">
                <p class="sfo-num text-sm font-bold pt-1" style="color: var(--dim);">{p.n}</p>
                <div>
                  <h3 class="text-xl font-bold mb-2.5">{p.t}</h3>
                  <p class="text-[0.95rem] leading-relaxed max-w-xl" style="color: var(--muted);">{p.d}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- ===== CASE STUDY 1: US SUPPLEMENTS (deep green panel) ===== -->
    <section id="proof" class="sfo-panel sfo-panel-green relative overflow-hidden py-24 sm:py-32">
      <div class="sfo-grain"></div>
      <div class="sfo-container relative">
        <div class="flex flex-wrap items-baseline justify-between gap-4 mb-14 sm:mb-20 pb-8" style="border-bottom: 1px solid var(--border);">
          <h2 class="text-2xl sm:text-3xl font-bold">US Supplements Brand</h2>
          <p class="text-sm" style="color: var(--dim);">US nutraceuticals &middot; 18-month engagement</p>
        </div>

        <div class="sfo-reveal grid lg:grid-cols-12 gap-10 lg:gap-14 items-start mb-20">
          <div class="lg:col-span-6">
            <p class="sfo-num sfo-display text-[6.5rem] sm:text-[9rem] lg:text-[11rem] mb-6" style="color: #f3f0ea;"><span class="sfo-circ">$10M<svg class="sfo-anno sfo-anno-reveal" viewBox="0 0 320 110" preserveAspectRatio="none" aria-hidden="true"><path pathLength="1" style="stroke-width: 2.6;" d="M24,60 C16,30 92,10 168,9 C256,8 307,27 305,55 C303,86 234,102 148,100 C68,98 17,83 16,58 C15,37 54,21 110,15" /></svg></span></p>
            <p class="text-xl font-bold mb-4">Total revenue over 18 months.</p>
            <p class="text-base leading-relaxed max-w-md" style="color: var(--muted);">
              Started at $1.5M. US and Canada only. Zero email revenue. Now selling in 50+ countries with email as a seven-figure channel.
            </p>
          </div>
          <div class="lg:col-span-6">
            <div class="grid grid-cols-3 mb-10">
              <div class="pr-6">
                <p class="sfo-num text-3xl sm:text-4xl font-black" style="color: #ff9d8a;">51%</p>
                <p class="text-xs mt-2 leading-snug" style="color: var(--muted);">YoY Shopify growth</p>
              </div>
              <div class="px-6 border-l" style="border-color: var(--border);">
                <p class="sfo-num text-3xl sm:text-4xl font-black">50+</p>
                <p class="text-xs mt-2 leading-snug" style="color: var(--muted);">countries, from 2</p>
              </div>
              <div class="pl-6 border-l" style="border-color: var(--border);">
                <p class="sfo-num text-3xl sm:text-4xl font-black" style="color: #ff9d8a;">$1M+/yr</p>
                <p class="text-xs mt-2 leading-snug" style="color: var(--muted);">email revenue, from zero</p>
              </div>
            </div>
            <ul>
              {outcomes.map((o) => (
                <li class="py-4 grid grid-cols-[7.5rem_1fr] sm:grid-cols-[9rem_1fr] gap-4 items-baseline" style="border-top: 1px solid var(--border);">
                  <p class="sfo-num font-black text-base sm:text-lg leading-tight">{o.stat}</p>
                  <p class="text-[0.95rem] leading-relaxed" style="color: var(--muted);"><strong class="font-bold" style="color: var(--text);">{o.t}.</strong> {o.d}</p>
                </li>
              ))}
            </ul>
          </div>
        </div>

        <!-- Expansion grid: 2 launch markets to 50+ -->
        <div class="sfo-reveal grid lg:grid-cols-12 gap-10 lg:gap-14 items-center mb-20">
          <div class="lg:col-span-4">
            <p class="sfo-label mb-5" style="color: var(--dim);">Market expansion</p>
            <p class="sfo-num sfo-display text-6xl sm:text-7xl mb-5">2 &rarr; 52</p>
            <p class="text-base leading-relaxed max-w-sm" style="color: var(--muted);">
              Every market gets a localized subdomain, currency, language, and its own Merchant Center feed. All built from one master catalog the owner never has to think about.
            </p>
          </div>
          <div class="lg:col-span-8">
            <div class="sfo-cgrid" role="img" aria-label="Grid of country codes showing expansion from 2 launch markets, US and Canada, to 52 active countries">
              {countries.map((k) => (
                <span class={k.on ? 'on' : ''}>{k.c}</span>
              ))}
            </div>
            <p class="text-xs mt-3" style="color: var(--dim);"><span style="color: #ff9d8a;">US, CA</span> launch markets &middot; every other tile is a market we opened</p>
          </div>
        </div>

        <!-- Email proof -->
        <div class="sfo-reveal grid lg:grid-cols-12 gap-10 lg:gap-14 items-start pt-16" style="border-top: 1px solid var(--border);">
          <div class="lg:col-span-5">
            <p class="sfo-num sfo-display text-7xl sm:text-8xl mb-5">$34K</p>
            <p class="text-xl font-bold mb-4">From one Easter campaign email. Single send.</p>
            <p class="text-base leading-relaxed max-w-sm" style="color: var(--muted);">
              Klaviyo was dormant when we arrived. We warmed the list over six weeks and built every flow from scratch. Email revenue is growing 25% year over year, and every email is double-digit sales.
            </p>
          </div>
          <div class="lg:col-span-7 lg:pt-3">
            <p class="sfo-label mb-7" style="color: var(--dim);">Revenue per email send</p>
            <div class="mb-5">
              <div class="flex items-baseline justify-between mb-2">
                <p class="text-sm font-bold">Easter campaign</p>
                <p class="sfo-num text-sm font-bold">$34,000</p>
              </div>
              <div class="h-3 w-full" style="background: var(--border-soft);"><div class="h-full" style="width: 100%; background: var(--accent);"></div></div>
            </div>
            <div class="mb-5">
              <div class="flex items-baseline justify-between mb-2">
                <p class="text-sm font-bold" style="color: var(--muted);">Clearance email</p>
                <p class="sfo-num text-sm font-bold" style="color: var(--muted);">$12,000+</p>
              </div>
