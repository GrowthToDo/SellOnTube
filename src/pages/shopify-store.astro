  function initCharts() {
    const dark = document.documentElement.classList.contains('dark');
    const textColor   = dark ? '#94a3b8' : '#6b7280';
    const gridColor   = dark ? 'rgba(255,255,255,0.06)' : 'rgba(0,0,0,0.05)';
    const emerald     = '#10b981';
    const mutedBar    = dark ? 'rgba(148,163,184,0.25)' : 'rgba(148,163,184,0.35)';

    Chart.defaults.font.family = 'inherit';
    Chart.defaults.color = textColor;

    // Revenue before/after bar chart
    const revCtx = document.getElementById('revenueChart');
    if (revCtx) {
      new Chart(revCtx, {
        type: 'bar',
        data: {
          labels: ['Starting revenue', '18 months later'],
          datasets: [{
            data: [1.5, 10],
            backgroundColor: [mutedBar, emerald],
            borderRadius: 8,
            borderSkipped: false,
          }]
        },
        options: {
          responsive: true,
          plugins: {
            legend: { display: false },
            tooltip: {
              callbacks: { label: (c) => ' $' + c.parsed.y + 'M' }
            }
          },
          scales: {
            x: { grid: { display: false }, border: { display: false } },
            y: {
              grid: { color: gridColor },
              border: { display: false },
              ticks: { callback: (v) => '$' + v + 'M' }
            }
          }
        }
      });
    }

    // Email campaign horizontal bar chart
    const emailCtx = document.getElementById('emailChart');
    if (emailCtx) {
      new Chart(emailCtx, {
        type: 'bar',
        data: {
          labels: ['Easter campaign', 'Clearance email', 'Regular send'],
          datasets: [{
            data: [34000, 12000, 10000],
            backgroundColor: [emerald, '#34d399', '#6ee7b7'],
            borderRadius: 6,
            borderSkipped: false,
          }]
        },
        options: {
          indexAxis: 'y',
          responsive: true,
          plugins: {
            legend: { display: false },
            tooltip: {
              callbacks: { label: (c) => ' $' + c.parsed.x.toLocaleString() }
            }
          },
          scales: {
            x: {
              grid: { color: gridColor },
              border: { display: false },
              ticks: { callback: (v) => '$' + (v / 1000) + 'K' }
            },
            y: { grid: { display: false }, border: { display: false } }
          }
        }
      });
    }
  }
})();
</script>

</Layout>

