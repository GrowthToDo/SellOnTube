  <script is:inline>
    (() => {
      if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
        document.querySelectorAll('.sfo-reveal').forEach((el) => el.classList.add('sfo-in'));
        return;
      }
      const io = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('sfo-in');
              io.unobserve(entry.target);
            }
          });
        },
        { rootMargin: '0px 0px -8% 0px' }
      );
      document.querySelectorAll('.sfo-reveal').forEach((el) => io.observe(el));
    })();
  </script>

