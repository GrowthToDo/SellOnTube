---
import Layout from '~/layouts/PageLayout.astro';
import Header from '~/components/widgets/Header.astro';
import Steps from '~/components/widgets/Steps.astro';
import FAQs from '~/components/widgets/FAQs.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

const metadata = {
  title: 'Shopify Operations for Scaled Merchants | SellOnTube',
  description: 'We run the operational layer of scaled Shopify Plus stores. Custom apps, cross-border infrastructure, Klaviyo email, compliance systems. One client went from $1.5M to $10M in 18 months.',
};

const calLink = 'https://cal.com/gautham-8bdvdx/30min';
---

<Layout metadata={metadata}>

  <Fragment slot="header">
    <Header
      links={[
        { text: 'Results', href: '#proof' },
        { text: 'What We Build', href: '#work' },
        { text: 'Case Studies', links: [
          { text: 'Hebron Nutrition', href: '/case-studies/hebron-nutrition' },
          { text: 'H.S. Johnson', href: '/case-studies/hs-johnson' },
        ]},
        { text: 'Pricing', href: '#pricing' },
      ]}
      actions={[{ text: 'Book a discovery call', href: calLink, target: '_blank' }]}
      showToggleTheme
    />
  </Fragment>

  <!-- Hero *************************** -->

  <section class="relative overflow-hidden bg-slate-900 text-white pt-20 sm:pt-28 pb-16 sm:pb-24">
    <div class="absolute inset-0 pointer-events-none">
      <div class="absolute top-0 right-0 w-[700px] h-[700px] bg-emerald-500/10 rounded-full blur-3xl"></div>
      <div class="absolute bottom-0 left-0 w-[400px] h-[400px] bg-slate-700/40 rounded-full blur-3xl"></div>
    </div>
    <div class="relative max-w-6xl mx-auto px-6">
      <div class="grid lg:grid-cols-2 gap-8 lg:gap-16 items-center">

        <div>
          <p class="text-emerald-400 text-xs font-bold uppercase tracking-[0.2em] mb-5">AI-native Shopify operations partner</p>
          <h1 class="text-3xl sm:text-4xl lg:text-5xl font-extrabold leading-[1.1] tracking-tight mb-6">
            We run the operational layer<br />
            <span class="text-emerald-400">of scaled Shopify stores.</span>
          </h1>
          <p class="text-slate-300 text-lg leading-relaxed mb-8 max-w-lg">
            At $5M+ revenue you need more than a developer and a theme. You need someone who knows what breaks at scale and builds the systems before it does.
          </p>
          <div class="flex flex-wrap gap-3 mb-10">
            <span class="bg-slate-800/80 border border-slate-700 text-slate-300 rounded-full px-4 py-1.5 text-sm font-medium">$1.5M to $10M in 18 months</span>
            <span class="bg-slate-800/80 border border-slate-700 text-slate-300 rounded-full px-4 py-1.5 text-sm font-medium">9-year client relationship</span>
            <span class="bg-slate-800/80 border border-slate-700 text-slate-300 rounded-full px-4 py-1.5 text-sm font-medium">14+ custom apps built</span>
          </div>
          <a href={calLink} target="_blank" rel="noopener noreferrer"
            class="inline-block bg-emerald-500 hover:bg-emerald-400 text-white font-semibold px-8 py-4 rounded-full transition-colors text-base">
            Book a discovery call
          </a>
        </div>

        <div class="hidden lg:block relative h-[400px]">
          <div class="browser-frame absolute top-0 left-0 right-12 shadow-2xl rotate-1">
            <div class="browser-bar-strip">
              <span class="bdot bdot-r"></span><span class="bdot bdot-y"></span><span class="bdot bdot-g"></span>
              <span class="browser-url-bar">store-admin.myshopify.com/apps/executive-dashboard</span>
            </div>
            <div style="aspect-ratio:16/10;overflow:hidden;">
              <img src="/images/shopify-portfolio/executive-dashboard.png" alt="Executive Dashboard inside Shopify admin" class="w-full h-full object-cover object-top" />
            </div>
          </div>
          <div class="browser-frame absolute bottom-0 right-0 left-12 shadow-2xl -rotate-1">
            <div class="browser-bar-strip">
              <span class="bdot bdot-r"></span><span class="bdot bdot-y"></span><span class="bdot bdot-g"></span>
              <span class="browser-url-bar">store-admin.myshopify.com/apps/activity-logs</span>
            </div>
            <div style="aspect-ratio:16/10;overflow:hidden;">
              <img src="/images/shopify-portfolio/staff-activity-logs.png" alt="Staff Activity Logs inside Shopify admin" class="w-full h-full object-cover object-top" />
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- Pain Points ******************** -->

  <section id="pain" class="py-20 bg-white dark:bg-slate-900">
    <div class="max-w-5xl mx-auto px-6">
      <div class="max-w-xl mb-14">
        <p class="text-xs font-bold text-emerald-600 dark:text-emerald-400 uppercase tracking-[0.2em] mb-3">Sound familiar?</p>
        <h2 class="text-3xl font-bold text-gray-900 dark:text-white leading-snug">These are the problems nobody talks about. Everyone assumes it's just how it is.</h2>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5 mb-12">

        <div class="bg-slate-50 dark:bg-slate-800/50 rounded-2xl p-6 border border-slate-100 dark:border-slate-700/50">
          <p class="text-7xl font-black text-slate-200 dark:text-slate-700 leading-none mb-4 select-none">01</p>
          <h3 class="font-bold text-gray-900 dark:text-white mb-2">Your team spends half the day on work that doesn't grow the business.</h3>
          <p class="text-sm text-gray-500 dark:text-slate-400 leading-relaxed">Orders, tagging, refunds, fraud checks, catalog updates. You keep hiring and the new people end up doing the same grunt work.</p>
        </div>

        <div class="bg-slate-50 dark:bg-slate-800/50 rounded-2xl p-6 border border-slate-100 dark:border-slate-700/50">
          <p class="text-7xl font-black text-slate-200 dark:text-slate-700 leading-none mb-4 select-none">02</p>
          <h3 class="font-bold text-gray-900 dark:text-white mb-2">Someone changed a price and nobody knows who.</h3>
          <p class="text-sm text-gray-500 dark:text-slate-400 leading-relaxed">A brand calls about MAP pricing. You dig through Shopify logs. They don't tell you enough. This happens every week.</p>
        </div>

        <div class="bg-slate-50 dark:bg-slate-800/50 rounded-2xl p-6 border border-slate-100 dark:border-slate-700/50">
          <p class="text-7xl font-black text-slate-200 dark:text-slate-700 leading-none mb-4 select-none">03</p>
          <h3 class="font-bold text-gray-900 dark:text-white mb-2">Merchant Center keeps disapproving products.</h3>
          <p class="text-sm text-gray-500 dark:text-slate-400 leading-relaxed">Missing GTINs. Duplicate barcodes. An ingredient flagged in Germany. You fix 10, and 15 more pop up.</p>
        </div>

        <div class="bg-slate-50 dark:bg-slate-800/50 rounded-2xl p-6 border border-slate-100 dark:border-slate-700/50">
          <p class="text-7xl font-black text-slate-200 dark:text-slate-700 leading-none mb-4 select-none">04</p>
          <h3 class="font-bold text-gray-900 dark:text-white mb-2">Selling in multiple countries but guessing which ones work.</h3>
          <p class="text-sm text-gray-500 dark:text-slate-400 leading-relaxed">Shopify analytics don't slice it the way you need. Which countries are growing? Where are ads returning? You go with your gut.</p>
        </div>

        <div class="bg-slate-50 dark:bg-slate-800/50 rounded-2xl p-6 border border-slate-100 dark:border-slate-700/50">
          <p class="text-7xl font-black text-slate-200 dark:text-slate-700 leading-none mb-4 select-none">05</p>
          <h3 class="font-bold text-gray-900 dark:text-white mb-2">Paying $500+/month for apps that do 70% of what you need.</h3>
          <p class="text-sm text-gray-500 dark:text-slate-400 leading-relaxed">The other 30% is workarounds, manual steps, or yet another app. Nobody has built something for your exact workflow.</p>
        </div>

        <div class="bg-slate-50 dark:bg-slate-800/50 rounded-2xl p-6 border border-slate-100 dark:border-slate-700/50">
          <p class="text-7xl font-black text-slate-200 dark:text-slate-700 leading-none mb-4 select-none">06</p>
          <h3 class="font-bold text-gray-900 dark:text-white mb-2">There's data in your store that nobody acts on.</h3>
          <p class="text-sm text-gray-500 dark:text-slate-400 leading-relaxed">Surfacing insights means spreadsheets and hoping someone reads them. Trends show up three weeks after they started.</p>
        </div>

      </div>

      <div class="border-t border-slate-200 dark:border-slate-700 pt-8 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-6">
        <p class="text-xl font-bold text-gray-900 dark:text-white max-w-xl">None of this is "how it is." You just haven't had someone build the fix inside Shopify.</p>
        <a href="#proof" class="flex-shrink-0 inline-block bg-black dark:bg-white text-white dark:text-black font-semibold text-sm px-6 py-3 rounded-full hover:opacity-80 transition-opacity">See what we've built</a>
      </div>
    </div>
  </section>

  <!-- Case Study 1: Hebron ************ -->

  <section id="proof" class="py-20 bg-slate-50 dark:bg-slate-800/40">
    <div class="max-w-5xl mx-auto px-6">

      <div class="flex items-center gap-4 mb-10">
        <span class="w-9 h-9 rounded-full bg-emerald-100 dark:bg-emerald-900/40 text-emerald-600 dark:text-emerald-400 text-xs font-bold flex items-center justify-center flex-shrink-0">01</span>
        <div>
          <p class="text-xs font-bold text-emerald-600 dark:text-emerald-400 uppercase tracking-[0.2em]">Client story</p>
          <h2 class="text-2xl font-bold text-gray-900 dark:text-white">Hebron Nutrition <span class="text-base font-normal text-gray-400 dark:text-slate-500 ml-2">US nutraceuticals · 18-month engagement</span></h2>
        </div>
      </div>

      <!-- Big anchor stat -->
      <div class="bg-white dark:bg-slate-900 rounded-3xl border border-slate-200 dark:border-slate-700 overflow-hidden mb-6">
        <div class="px-10 py-12 text-center border-b border-slate-100 dark:border-slate-700/50">
          <p class="text-slate-400 text-xs uppercase tracking-[0.2em] mb-3">Total revenue · 18 months</p>
          <p class="text-5xl sm:text-7xl lg:text-[7rem] font-black text-gray-900 dark:text-white leading-none tracking-tighter">$10M</p>
          <p class="text-slate-400 mt-3 text-sm">Started at $1.5M. US and Canada only. Zero email revenue.</p>
        </div>
        <div class="grid grid-cols-3 divide-x divide-slate-100 dark:divide-slate-700/50">
          <div class="px-3 sm:px-8 py-5 sm:py-6 text-center">
            <p class="text-xl sm:text-3xl font-bold text-emerald-600 dark:text-emerald-400">51%</p>
            <p class="text-xs text-gray-500 dark:text-slate-400 mt-1 leading-tight">YoY Shopify growth</p>
          </div>
          <div class="px-3 sm:px-8 py-5 sm:py-6 text-center">
            <p class="text-xl sm:text-3xl font-bold text-gray-900 dark:text-white">50+</p>
            <p class="text-xs text-gray-500 dark:text-slate-400 mt-1 leading-tight">countries, from 2</p>
          </div>
          <div class="px-3 sm:px-8 py-5 sm:py-6 text-center">
            <p class="text-xl sm:text-3xl font-bold text-emerald-600 dark:text-emerald-400">$1M+/yr</p>
            <p class="text-xs text-gray-500 dark:text-slate-400 mt-1 leading-tight">email, from zero</p>
          </div>
        </div>
      </div>

      <!-- Revenue chart -->
      <div class="bg-white dark:bg-slate-900 rounded-2xl p-6 border border-slate-200 dark:border-slate-700 mb-6">
        <p class="text-xs font-bold text-slate-400 uppercase tracking-widest mb-1">Revenue growth</p>
        <p class="text-sm text-gray-600 dark:text-slate-400 mb-5">$1.5M to $10M in 18 months</p>
        <canvas id="revenueChart" height="140"></canvas>
      </div>

      <!-- Outcome cards -->
      <div class="grid grid-cols-2 sm:grid-cols-3 gap-4 mb-6">

        <div class="bg-white dark:bg-slate-900 rounded-2xl p-5 border border-slate-200 dark:border-slate-700">
          <p class="text-2xl font-black text-emerald-600 dark:text-emerald-400 mb-1">100+</p>
          <p class="text-sm font-semibold text-gray-900 dark:text-white mb-2">localized country subdomains</p>
          <p class="text-xs text-gray-400 dark:text-slate-500">From one English site. Owner still only manages the US version.</p>
        </div>

        <div class="bg-white dark:bg-slate-900 rounded-2xl p-5 border border-slate-200 dark:border-slate-700">
          <p class="text-2xl font-black text-emerald-600 dark:text-emerald-400 mb-1">30</p>
          <p class="text-sm font-semibold text-gray-900 dark:text-white mb-2">Merchant Centers and ad accounts</p>
          <p class="text-xs text-gray-400 dark:text-slate-500">Built from one master product feed. Each localized to currency and language.</p>
        </div>

        <div class="bg-white dark:bg-slate-900 rounded-2xl p-5 border border-slate-200 dark:border-slate-700">
          <p class="text-2xl font-black text-emerald-600 dark:text-emerald-400 mb-1">$1M+/yr</p>
          <p class="text-sm font-semibold text-gray-900 dark:text-white mb-2">email revenue</p>
          <p class="text-xs text-gray-400 dark:text-slate-500">Klaviyo was sitting dormant. We warmed it over 6 weeks and built every flow from scratch.</p>
        </div>

        <div class="bg-white dark:bg-slate-900 rounded-2xl p-5 border border-slate-200 dark:border-slate-700">
          <p class="text-2xl font-black text-gray-900 dark:text-white mb-1">400,000</p>
          <p class="text-sm font-semibold text-gray-900 dark:text-white mb-2">compliance touchpoints</p>
          <p class="text-xs text-gray-400 dark:text-slate-500">100+ brands with MAP pricing rules, managed manually. Now automated from one screen.</p>
        </div>

        <div class="bg-white dark:bg-slate-900 rounded-2xl p-5 border border-slate-200 dark:border-slate-700">
          <p class="text-2xl font-black text-gray-900 dark:text-white mb-1">$100K+</p>
          <p class="text-sm font-semibold text-gray-900 dark:text-white mb-2">saved in one weekend</p>
          <p class="text-xs text-gray-400 dark:text-slate-500">A vendor uploaded rupee pricing across the entire catalog. Daily backups meant full rollback in minutes.</p>
        </div>

        <div class="bg-white dark:bg-slate-900 rounded-2xl p-5 border border-slate-200 dark:border-slate-700">
          <p class="text-2xl font-black text-gray-900 dark:text-white mb-1">Oracle ERP</p>
          <p class="text-sm font-semibold text-gray-900 dark:text-white mb-2">fraud integration</p>
          <p class="text-xs text-gray-400 dark:text-slate-500">High-risk orders automatically flagged and blocked before fulfillment. No manual review queue.</p>
        </div>

      </div>

      <!-- Email callout -->
      <div class="bg-emerald-50 dark:bg-emerald-900/20 rounded-2xl p-8 border border-emerald-100 dark:border-emerald-800">
        <p class="text-xs font-bold text-emerald-600 dark:text-emerald-400 uppercase tracking-[0.2em] mb-8">What email looks like now</p>
        <div class="grid sm:grid-cols-3 gap-6 text-center mb-8">
          <div>
            <p class="text-4xl sm:text-5xl font-black text-gray-900 dark:text-white mb-2">$34K</p>
            <p class="text-sm text-gray-600 dark:text-slate-400">from one Easter campaign email. Single send.</p>
          </div>
          <div>
            <p class="text-4xl sm:text-5xl font-black text-gray-900 dark:text-white mb-2">$12K+</p>
            <p class="text-sm text-gray-600 dark:text-slate-400">from one clearance email. Products expiring, 10% off. Single send.</p>
          </div>
          <div>
            <p class="text-4xl sm:text-5xl font-black text-emerald-600 dark:text-emerald-400 mb-2">25%</p>
            <p class="text-sm text-gray-600 dark:text-slate-400">YoY email revenue growth. Every email is double-digit sales.</p>
          </div>
        </div>
        <div>
          <p class="text-xs font-bold text-slate-400 uppercase tracking-widest mb-4">Revenue per email send</p>
          <canvas id="emailChart" height="110"></canvas>
        </div>
      </div>

      <div class="mt-8 text-center">
        <a href="/case-studies/hebron-nutrition" class="inline-flex items-center gap-2 text-emerald-600 dark:text-emerald-400 font-semibold text-sm hover:underline">
          Read the full Hebron Nutrition case study
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- Case Study 2: H.S. Johnson ****** -->

  <section class="py-20 bg-white dark:bg-slate-900">
    <div class="max-w-5xl mx-auto px-6">

      <div class="flex items-center gap-4 mb-10">
        <span class="w-9 h-9 rounded-full bg-slate-100 dark:bg-slate-800 text-slate-500 text-xs font-bold flex items-center justify-center flex-shrink-0">02</span>
        <div>
          <p class="text-xs font-bold text-emerald-600 dark:text-emerald-400 uppercase tracking-[0.2em]">Client story</p>
          <h2 class="text-2xl font-bold text-gray-900 dark:text-white">H.S. Johnson <span class="text-base font-normal text-gray-400 dark:text-slate-500 ml-2">UK watches and jewelry · 50+ countries</span></h2>
        </div>
      </div>

      <div class="grid lg:grid-cols-2 gap-10 items-start">
        <div>
          <p class="text-[5rem] sm:text-[7rem] lg:text-[9rem] font-black text-slate-300 dark:text-slate-700 leading-none select-none -mb-2 sm:-mb-4">9</p>
          <p class="text-3xl sm:text-4xl font-extrabold text-gray-900 dark:text-white mb-6">years.</p>
          <p class="text-gray-600 dark:text-slate-400 leading-relaxed mb-4 text-base">
            Not a project. Not a retainer that got renewed once. Nine years of knowing exactly what the business needs, where it gets stuck, and what to build next.
          </p>
          <p class="text-gray-600 dark:text-slate-400 leading-relaxed text-base">
            We scaled them from £1M to £5M+. 50+ countries. Compliance error rate under 1%.
          </p>
        </div>
        <div class="space-y-4">
          <div class="rounded-2xl border border-slate-200 dark:border-slate-700 overflow-hidden">
            <div class="bg-slate-50 dark:bg-slate-800/50 px-7 py-5 border-b border-slate-200 dark:border-slate-700">
              <p class="text-2xl font-black text-emerald-600 dark:text-emerald-400">8 hours to 15 minutes</p>
            </div>
            <div class="px-7 py-6">
              <p class="text-xs font-bold text-slate-400 uppercase tracking-widest mb-5">Daily image processing time</p>
              <div class="space-y-3 mb-4">
                <div>
                  <div class="flex justify-between text-xs mb-1.5">
                    <span class="text-gray-500 dark:text-slate-400">Before</span>
                    <span class="font-bold text-gray-600 dark:text-slate-300">8 hours / day</span>
                  </div>
                  <div class="w-full bg-slate-100 dark:bg-slate-700 rounded-full h-6 overflow-hidden">
                    <div class="h-full bg-red-400/70 dark:bg-red-500/50 rounded-full flex items-center justify-end pr-3" style="width:100%">
                      <span class="text-xs font-bold text-white">480 min</span>
                    </div>
                  </div>
                </div>
                <div>
                  <div class="flex justify-between text-xs mb-1.5">
                    <span class="text-gray-500 dark:text-slate-400">After our app</span>
                    <span class="font-bold text-emerald-600 dark:text-emerald-400">15 minutes / day</span>
                  </div>
                  <div class="w-full bg-slate-100 dark:bg-slate-700 rounded-full h-6 overflow-hidden">
                    <div class="h-full bg-emerald-500 rounded-full" style="width:3.125%"></div>
                  </div>
                </div>
              </div>
              <p class="text-xs text-slate-400">97% time reduction. That team member now does work that actually matters.</p>
            </div>
          </div>
          <div class="rounded-2xl border border-slate-200 dark:border-slate-700 overflow-hidden">
            <div class="bg-slate-50 dark:bg-slate-800/50 px-7 py-5 border-b border-slate-200 dark:border-slate-700">
              <p class="text-2xl font-black text-gray-900 dark:text-white">Under 1% error rate</p>
            </div>
            <div class="px-7 py-5">
              <p class="text-sm text-gray-600 dark:text-slate-400 leading-relaxed">Weekly GTIN and barcode health audits run automatically. Missing GTINs and duplicate barcodes get caught before Google flags them. Merchant Center disapprovals are nearly gone.</p>
            </div>
          </div>
        </div>
      </div>

      <div class="mt-10 text-center">
        <a href="/case-studies/hs-johnson" class="inline-flex items-center gap-2 text-emerald-600 dark:text-emerald-400 font-semibold text-sm hover:underline">
          Read the full H.S. Johnson case study
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- What We Build ****************** -->

  <section id="work" class="py-20 bg-slate-50 dark:bg-slate-800/40">
    <div class="max-w-5xl mx-auto px-6">

      <div class="max-w-2xl mb-12">
        <p class="text-xs font-bold text-emerald-600 dark:text-emerald-400 uppercase tracking-[0.2em] mb-3">What we build</p>
        <h2 class="text-3xl font-bold text-gray-900 dark:text-white mb-3">Custom tools inside your Shopify admin.</h2>
        <p class="text-gray-600 dark:text-slate-400">No app store installs. No monthly fees. Built for your exact workflow using Shopify Sidekick. 14+ apps across two stores.</p>
      </div>

      <!-- Featured card -->
      <div class="bg-white dark:bg-slate-900 rounded-2xl p-8 border border-slate-200 dark:border-slate-700 mb-5 flex flex-col sm:flex-row gap-8 items-center">
        <div class="flex-1">
          <div class="inline-block bg-emerald-100 dark:bg-emerald-900/40 text-emerald-700 dark:text-emerald-400 text-xs font-bold uppercase tracking-wider px-3 py-1 rounded-full mb-4">Save Time</div>
          <h3 class="text-xl font-bold text-gray-900 dark:text-white mb-3">Product Image Processor</h3>
          <p class="text-sm text-gray-500 dark:text-slate-400 mb-4">One team member, 8 hours every day. Resizing vendor images, removing backgrounds, formatting everything for Google Ads. All done by hand.</p>
          <p class="font-bold text-emerald-600 dark:text-emerald-400">8 hours to 15 minutes, fully automated. <span class="text-sm font-normal text-gray-400">H.S. Johnson</span></p>
        </div>
        <div class="flex-shrink-0 bg-emerald-50 dark:bg-emerald-900/20 rounded-2xl px-10 py-8 text-center border border-emerald-100 dark:border-emerald-800">
          <p class="text-5xl font-black text-emerald-600 dark:text-emerald-400">97%</p>
          <p class="text-xs text-gray-500 dark:text-slate-400 mt-2">time saved per day</p>
        </div>
      </div>

      <!-- Grid -->
      <div class="grid sm:grid-cols-2 gap-5 mb-12">

        <div class="bg-white dark:bg-slate-900 rounded-2xl p-6 border border-slate-200 dark:border-slate-700">
