---
import Layout from '~/layouts/PageLayout.astro';
import Header from '~/components/widgets/Header.astro';

const metadata = {
  title: 'Free Shopify App Store Listing Grader - Grade Your Listing | SellOnTube',
  description: 'Find out what\'s costing you installs. Grade your Shopify app listing against 30+ official rules and best practices. Free, instant, actionable.',
  openGraph: {
    type: 'website',
    title: 'Shopify App Store Listing Grader - Free Audit Tool',
    description: 'Grade your Shopify app listing against 30+ official rules. Get a score, see what\'s hurting your installs, and a prioritized fix plan.',
  },
};

const calLink = 'https://cal.com/gautham-8bdvdx/30min';
const siteUrl = 'https://sellontube.com';
const pageUrl = `${siteUrl}/shopify-app/tools/shopify-app-store-listing-grader`;

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": siteUrl },
    { "@type": "ListItem", "position": 2, "name": "Shopify App Services", "item": `${siteUrl}/shopify-app` },
    { "@type": "ListItem", "position": 3, "name": "Tools", "item": `${siteUrl}/shopify-app/tools` },
    { "@type": "ListItem", "position": 4, "name": "Listing Grader", "item": pageUrl },
  ]
};

const webAppSchema = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "Shopify App Store Listing Grader",
  "url": pageUrl,
  "description": "Grade your Shopify app listing against 30+ official rules and best practices that drive installs.",
  "applicationCategory": "BusinessApplication",
  "operatingSystem": "Any",
  "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
  "provider": { "@type": "Organization", "name": "SellOnTube", "url": siteUrl },
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    { "@type": "Question", "name": "What does this tool check?", "acceptedAnswer": { "@type": "Answer", "text": "The grader checks 30+ rules across 6 categories: Search Visibility, Screenshots & Video, Listing Copy, Shopify Rules, Install Triggers, and Standout Score. Each check maps to Shopify's official listing requirements and evidence-based ASO best practices." } },
    { "@type": "Question", "name": "How is the score calculated?", "acceptedAnswer": { "@type": "Answer", "text": "The score is a transparent 0-100 rubric. Each check earns points based on whether your listing passes. The six sections are weighted by their impact on installs: Search Visibility (25%), Screenshots & Video (25%), Listing Copy (20%), Shopify Rules (10%), Install Triggers (10%), and Standout Score (10%). No black box — every point is explainable." } },
    { "@type": "Question", "name": "Is my listing data stored?", "acceptedAnswer": { "@type": "Answer", "text": "We cache results for up to 6 hours to speed up re-grades. Anonymized score data may be used to improve the tool. We never share your listing URL or email with third parties." } },
    { "@type": "Question", "name": "Can I re-grade after making changes?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. If you update your listing, come back and grade it again. The tool detects content changes and runs a fresh analysis automatically — even within the cache window." } },
    { "@type": "Question", "name": "What's in the full fix plan?", "acceptedAnswer": { "@type": "Answer", "text": "The fix plan is a prioritized list of up to 7 fixes, ordered by impact on installs. Each fix includes the specific issue, a concrete action to take, and a structural pattern to follow. Risk issues (compliance) come first, then growth issues (install impact)." } },
  ]
};

const PERSONAL_DOMAINS = ['gmail.com','yahoo.com','hotmail.com','outlook.com','aol.com','icloud.com','mail.com','protonmail.com','zoho.com','ymail.com','live.com'];
---

<Layout metadata={metadata}>
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(webAppSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

  <Fragment slot="header">
    <Header
      links={[
        { text: 'Case Studies', href: '/shopify-app#proof', links: [
          { text: 'Left Foot Software', href: '/shopify-app/case-studies/left-foot-software' },
          { text: 'YouTube Video Marketing: Inventory App Case Study', href: '/shopify-app/case-studies/shopify-app-growth-youtube-marketing' },
        ]},
        { text: 'Services', href: '/shopify-app#work' },
        { text: 'Tools', href: '/shopify-app/tools' },
        { text: 'Pricing', href: '/shopify-app#pricing' },
      ]}
      actions={[{ text: 'Book a discovery call', href: calLink, target: '_blank', variant: 'primary' }]}
      isSticky
      showToggleTheme
    />
  </Fragment>

  <Fragment slot="footer"></Fragment>

  <script is:inline>
    document.addEventListener('DOMContentLoaded', () => {
      const logoLink = document.querySelector('#header a[href="/"]');
      if (logoLink) logoLink.setAttribute('href', '/shopify-app');
    });
  </script>

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=Inter:wght@400;500;600&family=Space+Grotesk:wght@500;600;700&display=swap" rel="stylesheet" />

  <style>
    .sfy h1, .sfy h2, .sfy h3, .sfy .sfy-h { font-family: 'Plus Jakarta Sans', system-ui, sans-serif; }
    .sfy .sfy-m { font-family: 'Space Grotesk', monospace; }
    .sfy { font-family: 'Inter', system-ui, sans-serif; }
    .sfy-grad { background: linear-gradient(135deg, #818CF8 0%, #A5B4FC 50%, #C7D2FE 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }

    .sfy-dark { --bg: #08080A; --bg2: #0E0E11; --card: #131316; --border: #1C1C21; --text: #F5F5F2; --muted: #8E8E93; --dim: #55555A; --accent: #818CF8; --accent-l: #A5B4FC; }
    .sfy-light { --bg: #FAFAF8; --bg2: #F2F2EE; --card: #FFFFFF; --border: #E2E2DD; --text: #111113; --muted: #6B6B73; --dim: #9CA3AF; --accent: #6366F1; --accent-l: #818CF8; }

    .sfy-btn-primary { background: linear-gradient(135deg, #6366F1 0%, #818CF8 100%); color: white; transition: all 0.2s ease; }
    .sfy-btn-primary:hover { background: linear-gradient(135deg, #818CF8 0%, #A5B4FC 100%); box-shadow: 0 0 30px -5px rgba(129,140,248,0.5); transform: translateY(-1px); }

    .score-ring { transition: stroke-dashoffset 1.5s ease-out; }
    @media (prefers-reduced-motion: reduce) { .score-ring { transition: none; } }

    .section-bar-fill { transition: width 0.8s ease-out; }
    @media (prefers-reduced-motion: reduce) { .section-bar-fill { transition: none; } }

    .finding-card { background: var(--card); border: 1px solid var(--border); border-radius: 12px; padding: 1rem 1.25rem; transition: border-color 0.2s ease; }
    .finding-card:hover { border-color: rgba(99,102,241,0.3); }

    .char-bar { height: 6px; border-radius: 3px; }
    .char-bar-fill { height: 100%; border-radius: 3px; transition: width 0.6s ease; }

    .modal-backdrop { position: fixed; inset: 0; background: rgba(0,0,0,0.6); backdrop-filter: blur(4px); z-index: 100; display: none; align-items: center; justify-content: center; }
    .modal-backdrop.active { display: flex; }

    .copy-toast { position: fixed; bottom: 2rem; left: 50%; transform: translateX(-50%); background: #111; color: #fff; padding: 0.5rem 1.5rem; border-radius: 8px; font-size: 0.85rem; z-index: 200; opacity: 0; transition: opacity 0.3s; pointer-events: none; }
    .copy-toast.show { opacity: 1; }

    @keyframes spin { to { transform: rotate(360deg); } }
    .spinner { width: 40px; height: 40px; border: 3px solid var(--border); border-top-color: var(--accent); border-radius: 50%; animation: spin 0.8s linear infinite; }

    @keyframes countUp { from { opacity: 0; transform: translateY(8px); } to { opacity: 1; transform: translateY(0); } }
    .animate-in { animation: countUp 0.4s ease-out forwards; }

    .search-card-mock { background: var(--card); border: 1px solid var(--border); border-radius: 12px; padding: 1rem; max-width: 360px; }
    .truncation-line { border-top: 2px dashed #EF4444; position: relative; margin: 0.5rem 0; }
    .truncation-line::after { content: 'Truncated in search results ↓'; position: absolute; top: -10px; right: 0; font-size: 0.65rem; color: #EF4444; background: var(--bg); padding: 0 4px; }
  </style>

  <div class="sfy">

    <!-- ===== HERO + INPUT (dark) ===== -->
    <section class="sfy-dark relative pt-28 pb-12 overflow-hidden" style="background: var(--bg);">
      <div class="absolute inset-0 pointer-events-none" style="background: radial-gradient(ellipse 50% 40% at 50% 30%, rgba(129,140,248,0.06) 0%, transparent 60%);"></div>
      <div class="relative max-w-3xl mx-auto px-6 text-center">
        <p class="text-xs font-semibold uppercase tracking-[0.2em] mb-4 sfy-h" style="color: var(--accent);">Free Tool · For Shopify App Developers</p>
        <h1 class="text-3xl sm:text-4xl lg:text-5xl font-extrabold mb-5 leading-[1.08] tracking-[-0.02em] sfy-h" style="color: var(--text);">
          Shopify App Store Listing Grader
        </h1>
        <p class="text-base sm:text-lg leading-relaxed max-w-xl mx-auto mb-2" style="color: var(--muted);">
          Find out what's costing you installs. 30+ checks against Shopify's listing rules and the patterns top-rated apps use.
        </p>
      </div>
    </section>

    <!-- ===== INPUT (dark) ===== -->
    <section class="sfy-dark py-6 pb-10" style="background: var(--bg);">
      <div class="max-w-2xl mx-auto px-6">
        <div id="step-input" class="rounded-2xl p-6 sm:p-8" style="background: var(--card); border: 1px solid var(--border);">
          <label for="app-url" class="block text-xs font-semibold uppercase tracking-wider mb-2" style="color: var(--muted);">Shopify App Store URL</label>
          <input type="url" id="app-url" placeholder="https://apps.shopify.com/your-app"
            class="w-full text-base font-medium px-4 py-3 rounded-xl outline-none transition-colors"
            style="background: var(--bg); border: 1px solid var(--border); color: var(--text);" />
          <p id="url-error" class="hidden mt-2 text-sm" style="color: #EF4444;"></p>
          <button id="grade-btn"
            class="sfy-btn-primary mt-5 w-full font-bold px-6 py-3.5 rounded-xl text-base sfy-h"
            style="box-shadow: 0 0 30px -8px rgba(129,140,248,0.3);">
            Grade my listing
          </button>
          <p class="text-center text-xs mt-3" style="color: var(--dim);">Free · No account needed · Takes ~15 seconds</p>
        </div>

        <!-- What we check (preview cards) -->
        <div id="check-preview" class="grid grid-cols-2 sm:grid-cols-3 gap-3 mt-6">
          <div class="rounded-xl p-3 text-center" style="background: var(--card); border: 1px solid var(--border);">
            <div class="text-lg mb-1">🔍</div>
            <p class="text-xs font-medium" style="color: var(--muted);">Search Visibility</p>
          </div>
          <div class="rounded-xl p-3 text-center" style="background: var(--card); border: 1px solid var(--border);">
            <div class="text-lg mb-1">📸</div>
            <p class="text-xs font-medium" style="color: var(--muted);">Screenshots & Video</p>
          </div>
          <div class="rounded-xl p-3 text-center" style="background: var(--card); border: 1px solid var(--border);">
            <div class="text-lg mb-1">✍️</div>
            <p class="text-xs font-medium" style="color: var(--muted);">Listing Copy</p>
          </div>
          <div class="rounded-xl p-3 text-center" style="background: var(--card); border: 1px solid var(--border);">
            <div class="text-lg mb-1">📋</div>
            <p class="text-xs font-medium" style="color: var(--muted);">Shopify Rules</p>
          </div>
          <div class="rounded-xl p-3 text-center" style="background: var(--card); border: 1px solid var(--border);">
            <div class="text-lg mb-1">⚡</div>
            <p class="text-xs font-medium" style="color: var(--muted);">Install Triggers</p>
          </div>
          <div class="rounded-xl p-3 text-center" style="background: var(--card); border: 1px solid var(--border);">
            <div class="text-lg mb-1">✨</div>
            <p class="text-xs font-medium" style="color: var(--muted);">Standout Score</p>
          </div>
        </div>

        <!-- Loading -->
        <div id="step-loading" class="hidden rounded-2xl p-8 text-center mt-4" style="background: var(--card); border: 1px solid var(--border);">
          <div class="flex flex-col items-center gap-4 py-8">
            <div class="spinner"></div>
            <p id="loading-msg" class="text-sm font-medium" style="color: var(--muted);">Fetching your listing...</p>
            <p class="text-xs" style="color: var(--dim);">This takes about 15 seconds</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ===== RESULTS (light) ===== -->
    <section id="step-results" class="hidden sfy-light py-10" style="background: var(--bg);">
      <div class="max-w-3xl mx-auto px-6 space-y-8">

        <!-- Listing mirror -->
        <div id="listing-mirror" class="rounded-2xl p-6" style="background: var(--card); border: 1px solid var(--border);"></div>

        <!-- Score hero -->
        <div id="score-hero" class="rounded-2xl p-8 text-center" style="background: var(--card); border: 1px solid var(--border);"></div>

        <!-- Search card preview -->
        <div id="search-card-section" class="rounded-2xl p-6" style="background: var(--card); border: 1px solid var(--border);"></div>

        <!-- Section scorecard -->
        <div id="section-scores" class="grid grid-cols-1 sm:grid-cols-2 gap-4"></div>

        <!-- Issues list (Risk + Growth) -->
        <div id="issues-section" class="space-y-6"></div>

        <!-- Your Growth Roadmap -->
        <div id="roadmap-section" class="rounded-2xl p-6" style="background: var(--card); border: 1px solid var(--border);"></div>

        <!-- Email gate for fix plan -->
        <div id="email-gate" class="hidden text-center rounded-2xl p-8" style="background: var(--card); border: 1px solid var(--border);"></div>

        <!-- Pre-submission checklist -->
        <div id="checklist-section" class="rounded-2xl p-6" style="background: var(--card); border: 1px solid var(--border);">
          <h3 class="text-base font-bold mb-4 sfy-h" style="color: var(--text);">Your Pre-Submission Checklist</h3>
          <p class="text-xs mb-4" style="color: var(--muted);">These rules require a human eye. Check them before updating your listing.</p>
          <div class="space-y-3" id="manual-checks">
            <label class="flex items-start gap-3 cursor-pointer"><input type="checkbox" class="mt-0.5 accent-indigo-500" /><span class="text-sm" style="color: var(--text);">First screenshot shows the primary use case clearly</span></label>
            <label class="flex items-start gap-3 cursor-pointer"><input type="checkbox" class="mt-0.5 accent-indigo-500" /><span class="text-sm" style="color: var(--text);">Screenshots show real app UI, not mockups or generic graphics</span></label>
            <label class="flex items-start gap-3 cursor-pointer"><input type="checkbox" class="mt-0.5 accent-indigo-500" /><span class="text-sm" style="color: var(--text);">Screenshots have annotation text explaining what they show</span></label>
            <label class="flex items-start gap-3 cursor-pointer"><input type="checkbox" class="mt-0.5 accent-indigo-500" /><span class="text-sm" style="color: var(--text);">No pricing or promotional text baked into screenshot images</span></label>
            <label class="flex items-start gap-3 cursor-pointer"><input type="checkbox" class="mt-0.5 accent-indigo-500" /><span class="text-sm" style="color: var(--text);">Demo store link works and loads quickly</span></label>
            <label class="flex items-start gap-3 cursor-pointer"><input type="checkbox" class="mt-0.5 accent-indigo-500" /><span class="text-sm" style="color: var(--text);">App icon is legible at 48x48px</span></label>
          </div>
        </div>

        <!-- Context panel -->
        <div id="context-panel" class="rounded-2xl p-6" style="background: var(--card); border: 1px solid var(--border);"></div>

        <!-- Grade another -->
        <div class="text-center">
          <button id="reset-btn" class="text-sm font-medium px-6 py-2 rounded-lg transition-colors" style="color: var(--accent);">
            Grade another listing
          </button>
        </div>
      </div>
    </section>

    <!-- ===== CTA (dark, shown after grading) ===== -->
    <section id="cta-section" class="hidden sfy-dark py-14" style="background: var(--bg);">
      <div class="max-w-2xl mx-auto px-6 text-center">
        <h2 class="text-xl sm:text-2xl font-bold mb-3 sfy-h" style="color: var(--text);">Want us to rewrite your listing?</h2>
        <p class="text-sm mb-6 max-w-lg mx-auto" style="color: var(--muted);">
          We rebuilt the GS1 Assistant listing from scratch. It's now #1 on Google and 4.9 stars on the App Store.
        </p>
        <div class="flex flex-col sm:flex-row items-center justify-center gap-3">
          <a href="/shopify-app" class="sfy-btn-primary font-semibold px-6 py-2.5 rounded-lg text-sm sfy-h">See how we help apps grow</a>
          <a href="https://cal.com/gautham-8bdvdx/30min" target="_blank" rel="noopener noreferrer"
            class="font-semibold px-6 py-2.5 rounded-lg text-sm sfy-h" style="border: 1px solid var(--border); color: var(--muted);">
            Book a discovery call
          </a>
        </div>
      </div>
    </section>

    <!-- ===== HOW IT WORKS (dark) ===== -->
    <section class="sfy-dark py-14" style="background: var(--bg);">
      <div class="max-w-3xl mx-auto px-6">
        <h2 class="text-2xl font-bold mb-10 text-center sfy-h" style="color: var(--text);">How It Works</h2>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-8">
          <div class="text-center">
            <div class="w-12 h-12 rounded-full flex items-center justify-center mx-auto mb-4 sfy-m" style="background: rgba(99,102,241,0.15); color: var(--accent); font-size: 1.25rem; font-weight: 700;">1</div>
            <h3 class="text-sm font-bold mb-2 sfy-h" style="color: var(--text);">Paste your URL</h3>
            <p class="text-xs leading-relaxed" style="color: var(--muted);">Enter your Shopify App Store listing URL. We fetch your listing data directly from the public page.</p>
          </div>
          <div class="text-center">
            <div class="w-12 h-12 rounded-full flex items-center justify-center mx-auto mb-4 sfy-m" style="background: rgba(99,102,241,0.15); color: var(--accent); font-size: 1.25rem; font-weight: 700;">2</div>
            <h3 class="text-sm font-bold mb-2 sfy-h" style="color: var(--text);">We check 30+ rules</h3>
            <p class="text-xs leading-relaxed" style="color: var(--muted);">Your listing is graded against Shopify's official requirements and the patterns that top-rated apps use. Structure and copy quality are scored separately.</p>
          </div>
          <div class="text-center">
            <div class="w-12 h-12 rounded-full flex items-center justify-center mx-auto mb-4 sfy-m" style="background: rgba(99,102,241,0.15); color: var(--accent); font-size: 1.25rem; font-weight: 700;">3</div>
            <h3 class="text-sm font-bold mb-2 sfy-h" style="color: var(--text);">Get your fix plan</h3>
            <p class="text-xs leading-relaxed" style="color: var(--muted);">See your score, every issue ranked by impact, and a prioritized fix plan. Make changes, come back, and re-grade to track improvement.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ===== WHAT WE CHECK (light) ===== -->
    <section class="sfy-light py-14" style="background: var(--bg);">
      <div class="max-w-3xl mx-auto px-6">
        <h2 class="text-2xl font-bold mb-3 sfy-h" style="color: var(--text);">What We Check</h2>
        <p class="text-sm mb-8" style="color: var(--muted);">Every listing is graded across two tiers. Structure (30% of your score) checks whether the basics are in place. Quality (70%) checks whether your copy actually converts.</p>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
          <div class="rounded-xl p-5" style="background: var(--card); border: 1px solid var(--border);">
            <p class="text-xs font-semibold uppercase tracking-wider mb-2" style="color: var(--accent);">Search Visibility</p>
            <p class="text-sm leading-relaxed" style="color: var(--muted);">Keywords in your app name, intro, and SEO fields. Category assignment. Consistency across listing sections. This is how merchants find you in the App Store.</p>
          </div>
          <div class="rounded-xl p-5" style="background: var(--card); border: 1px solid var(--border);">
            <p class="text-xs font-semibold uppercase tracking-wider mb-2" style="color: var(--accent);">Screenshots & Video</p>
            <p class="text-sm leading-relaxed" style="color: var(--muted);">Screenshot count, alt text quality, demo video presence, and demo store link. Shopify requires a demo screencast. Screenshots are the primary visual conversion driver.</p>
          </div>
          <div class="rounded-xl p-5" style="background: var(--card); border: 1px solid var(--border);">
            <p class="text-xs font-semibold uppercase tracking-wider mb-2" style="color: var(--accent);">Listing Copy</p>
            <p class="text-sm leading-relaxed" style="color: var(--muted);">Character limits, description depth, benefit-led intro, feature count. Whether your description explains outcomes or just lists features. This is the most important section for conversion.</p>
          </div>
          <div class="rounded-xl p-5" style="background: var(--card); border: 1px solid var(--border);">
            <p class="text-xs font-semibold uppercase tracking-wider mb-2" style="color: var(--accent);">Shopify Rules</p>
            <p class="text-sm leading-relaxed" style="color: var(--muted);">Compliance checks from Shopify's official listing requirements. Superlative claims ("best", "#1"), promotional stats in your intro, and description structure rules that could get your listing flagged.</p>
          </div>
          <div class="rounded-xl p-5" style="background: var(--card); border: 1px solid var(--border);">
            <p class="text-xs font-semibold uppercase tracking-wider mb-2" style="color: var(--accent);">Install Triggers</p>
            <p class="text-sm leading-relaxed" style="color: var(--muted);">Free plan or trial availability, pricing transparency, and Built for Shopify badge status. Free plans earn better search impressions. Transparent pricing builds merchant trust.</p>
          </div>
          <div class="rounded-xl p-5" style="background: var(--card); border: 1px solid var(--border);">
            <p class="text-xs font-semibold uppercase tracking-wider mb-2" style="color: var(--accent);">Standout Score</p>
            <p class="text-sm leading-relaxed" style="color: var(--muted);">Buzzword density, generic language detection, readability, and copy distinctiveness. Flags filler words and cookie-cutter descriptions that make your listing blend in with every other app.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ===== WHY IT MATTERS + WHO IS THIS FOR (dark) ===== -->
    <section class="sfy-dark py-14" style="background: var(--bg);">
      <div class="max-w-3xl mx-auto px-6">
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-10">
          <div>
            <h2 class="text-xl font-bold mb-4 sfy-h" style="color: var(--text);">Why Listing Quality Matters</h2>
            <p class="text-sm leading-relaxed mb-3" style="color: var(--muted);">Your App Store listing is the first thing merchants evaluate. A weak listing loses installs to competitors with better copy, even if your app is better.</p>
            <p class="text-sm leading-relaxed mb-3" style="color: var(--muted);">Most developers build a great product and write their listing in 20 minutes. The listing becomes the bottleneck. Merchants scan 5-10 apps and click 1-2. If your intro, screenshots, or description don't convert that scan into a click, nothing else matters.</p>
            <p class="text-sm leading-relaxed" style="color: var(--muted);">This tool shows you exactly what to fix, in order of impact on installs.</p>
