  <script is:inline define:vars={{ PERSONAL_DOMAINS }}>
    (function () {
      var gradeData = null;

      var $ = function(id) { return document.getElementById(id); };
      var show = function(el) { el.classList.remove('hidden'); };
      var hide = function(el) { el.classList.add('hidden'); };
      var esc = function(s) { var d = document.createElement('div'); d.textContent = s; return d.innerHTML; };
      var impactColor = function(label) {
        if (label === 'Highest impact') return '#EF4444';
        if (label === 'High impact') return '#F97316';
        if (label === 'Medium impact') return '#F59E0B';
        return '#6B7280';
      };

      var $input = $('step-input');
      var $loading = $('step-loading');
      var $results = $('step-results');
      var $cta = $('cta-section');
      var $checkPreview = $('check-preview');
      var $urlInput = $('app-url');
      var $urlError = $('url-error');
      var $gradeBtn = $('grade-btn');
      var $loadingMsg = $('loading-msg');
      var $resetBtn = $('reset-btn');

      var $modal = $('email-modal');
      var $modalEmail = $('modal-email');
      var $modalEmailError = $('modal-email-error');
      var $modalConsent = $('modal-consent');
      var $modalSubmitBtn = $('modal-submit-btn');
      var $modalCloseBtn = $('modal-close-btn');

      var loadingMessages = [
        'Fetching your listing...',
        'Checking character limits and copy structure...',
        'Analyzing search visibility...',
        'Evaluating screenshots and video...',
        'Scoring against 30+ rules...',
        'Preparing your results...'
      ];

      function showError(msg) {
        $urlError.textContent = msg;
        show($urlError);
      }

      function isValidUrl(url) {
        return /^https?:\/\/(apps\.shopify\.com)\/[a-z0-9-]+\/?$/i.test(url.trim());
      }

      function isBusinessEmail(email) {
        var domain = email.split('@')[1];
        if (!domain) return false;
        return !PERSONAL_DOMAINS.includes(domain.toLowerCase());
      }

      function scoreColor(pct) {
        if (pct >= 80) return '#10B981';
        if (pct >= 60) return '#F59E0B';
        if (pct >= 40) return '#F97316';
        return '#EF4444';
      }

      function severityIcon(sev) {
        if (sev === 'pass') return '<span style="color: #10B981;">✓</span>';
        if (sev === 'warning') return '<span style="color: #F59E0B;">⚠</span>';
        if (sev === 'fail') return '<span style="color: #EF4444;">✗</span>';
        return '<span style="color: var(--dim);">ℹ</span>';
      }

      function severityBg(sev) {
        if (sev === 'pass') return 'rgba(16,185,129,0.08)';
        if (sev === 'warning') return 'rgba(245,158,11,0.08)';
        if (sev === 'fail') return 'rgba(239,68,68,0.08)';
        return 'rgba(99,102,241,0.08)';
      }

      // Progressive loading messages
      function animateLoading() {
        var i = 0;
        var iv = setInterval(function() {
          i++;
          if (i < loadingMessages.length) {
            $loadingMsg.textContent = loadingMessages[i];
          } else {
            clearInterval(iv);
          }
        }, 2500);
        return iv;
      }

      // Score hero with two-tier breakdown
      function renderScoreHero(data) {
        var score = data.health_score;
        var grade = data.grade;
        var color = scoreColor(score);
        var circumference = 2 * Math.PI * 54;
        var offset = circumference - (score / 100) * circumference;
        var st = data.structural_score;
        var qt = data.quality_score;
        var stPct = Math.round(st / 30 * 100);
        var qtPct = Math.round(qt / 70 * 100);

        var html = '<div style="display: flex; flex-direction: column; align-items: center; gap: 1.25rem;">' +
          '<div style="position: relative; width: 160px; height: 160px;">' +
            '<svg viewBox="0 0 120 120" style="width: 160px; height: 160px; transform: rotate(-90deg);">' +
              '<circle cx="60" cy="60" r="54" fill="none" stroke="var(--border)" stroke-width="8"/>' +
              '<circle class="score-ring" cx="60" cy="60" r="54" fill="none" stroke="' + color + '" stroke-width="8" stroke-linecap="round" stroke-dasharray="' + circumference + '" stroke-dashoffset="' + circumference + '" data-target="' + offset + '"/>' +
            '</svg>' +
            '<div style="position: absolute; inset: 0; display: flex; flex-direction: column; align-items: center; justify-content: center;">' +
              '<span class="sfy-m" style="font-size: 2.5rem; font-weight: 700; color: ' + color + ';">' + score + '</span>' +
              '<span style="font-size: 0.75rem; color: var(--muted);">out of 100</span>' +
            '</div>' +
          '</div>' +
          '<div class="sfy-h" style="font-size: 1.25rem; font-weight: 700; color: var(--text);">Grade: ' + grade + '</div>';

        // Two-tier breakdown bars
        html += '<div style="width: 100%; max-width: 340px; display: flex; flex-direction: column; gap: 0.75rem;">' +
          '<div>' +
            '<div style="display: flex; justify-content: space-between; margin-bottom: 0.35rem;">' +
              '<span style="font-size: 0.75rem; font-weight: 600; color: var(--text);">Structure</span>' +
              '<span class="sfy-m" style="font-size: 0.75rem; color: ' + scoreColor(stPct) + ';">' + st + '/30</span>' +
            '</div>' +
            '<div class="char-bar" style="background: var(--border);">' +
              '<div class="section-bar-fill" style="width: 0%; background: ' + scoreColor(stPct) + ';" data-target="' + stPct + '%"></div>' +
            '</div>' +
          '</div>' +
          '<div>' +
            '<div style="display: flex; justify-content: space-between; margin-bottom: 0.35rem;">' +
              '<span style="font-size: 0.75rem; font-weight: 600; color: var(--text);">Quality</span>' +
              '<span class="sfy-m" style="font-size: 0.75rem; color: ' + scoreColor(qtPct) + ';">' + qt + '/70</span>' +
            '</div>' +
            '<div class="char-bar" style="background: var(--border);">' +
              '<div class="section-bar-fill" style="width: 0%; background: ' + scoreColor(qtPct) + ';" data-target="' + qtPct + '%"></div>' +
            '</div>' +
          '</div>' +
        '</div>';

        // Overrides + coherence
        if (data.overrides_applied && data.overrides_applied.length > 0) {
          html += '<div style="width: 100%; max-width: 340px; margin-top: 0.25rem;">';
          for (var i = 0; i < data.overrides_applied.length; i++) {
            html += '<p style="font-size: 0.7rem; color: #EF4444; margin-top: 0.25rem;">⛔ ' + esc(data.overrides_applied[i]) + '</p>';
          }
          html += '</div>';
        }

        html += '<p style="font-size: 0.8rem; color: var(--muted); max-width: 400px; text-align: center;">Structure = did you fill out the listing correctly. Quality = is your copy effective. Quality drives 70% of your score.</p>';
        html += '</div>';
        return html;
      }

      // Section bars
      function renderSectionScores(sections) {
        var html = '';
        for (var i = 0; i < sections.length; i++) {
          var s = sections[i];
          var color = scoreColor(s.percentage);
          html += '<div class="rounded-xl p-4" style="background: var(--card); border: 1px solid var(--border);">' +
            '<div style="display: flex; justify-content: space-between; align-items: baseline; margin-bottom: 0.5rem;">' +
              '<span class="sfy-h" style="font-size: 0.8rem; font-weight: 600; color: var(--text);">' + esc(s.label) + '</span>' +
              '<span class="sfy-m" style="font-size: 0.8rem; font-weight: 600; color: ' + color + ';">' + s.grade + ' · ' + s.percentage + '%</span>' +
            '</div>' +
            '<div class="char-bar" style="background: var(--border);">' +
              '<div class="section-bar-fill" style="width: 0%; background: ' + color + ';" data-target="' + s.percentage + '%"></div>' +
            '</div>' +
          '</div>';
        }
        return html;
      }

      // Listing mirror (shows their listing data back)
      function renderListingMirror(meta, ctx) {
        var iconHtml = meta.icon_url
          ? '<img src="' + esc(meta.icon_url) + '" alt="" style="width: 48px; height: 48px; border-radius: 10px; border: 1px solid var(--border);" />'
          : '<div style="width: 48px; height: 48px; border-radius: 10px; background: var(--bg2); display: flex; align-items: center; justify-content: center; font-size: 1.5rem;">📦</div>';

        return '<div style="display: flex; align-items: center; gap: 1rem; margin-bottom: 1rem;">' +
          iconHtml +
          '<div>' +
            '<h2 class="sfy-h" style="font-size: 1.125rem; font-weight: 700; color: var(--text);">' + esc(meta.app_name) + '</h2>' +
            '<p style="font-size: 0.8rem; color: var(--muted);">' + esc(ctx.developer_name) + ' · ' + esc(ctx.category) + '</p>' +
          '</div>' +
        '</div>' +
        '<p style="font-size: 0.875rem; color: var(--muted); line-height: 1.5;">' + esc(meta.introduction) + '</p>';
      }

      // Search card mock
      function renderSearchCard(meta, ctx) {
        var introTrunc = meta.introduction.length > 60 ? meta.introduction.substring(0, 57) + '...' : meta.introduction;
        var nameTrunc = meta.app_name.length > 30 ? meta.app_name.substring(0, 27) + '...' : meta.app_name;
        var isTruncated = meta.introduction.length > 60;

        var iconHtml = meta.icon_url
          ? '<img src="' + esc(meta.icon_url) + '" alt="" style="width: 40px; height: 40px; border-radius: 8px;" />'
          : '<div style="width: 40px; height: 40px; border-radius: 8px; background: var(--bg2);"></div>';

        var issues = [];
        if (meta.introduction.length > 60) issues.push('⚠ Your intro gets cut at ~60 chars in search results');
        if (meta.app_name.length > 25) issues.push('⚠ App name may be truncated in some views');
        if (ctx.rating >= 4.5) issues.push('✓ Rating above 4.5 stands out in search');
        if (ctx.review_count < 20) issues.push('⚠ Low review count (' + ctx.review_count + ') may reduce click-through');

        return '<h3 class="sfy-h" style="font-size: 0.9rem; font-weight: 700; color: var(--text); margin-bottom: 1rem;">What Merchants See in Search Results</h3>' +
          '<div class="search-card-mock" style="margin: 0 auto;">' +
            '<div style="display: flex; gap: 0.75rem; align-items: start;">' +
              iconHtml +
              '<div style="flex: 1; min-width: 0;">' +
                '<div style="font-weight: 600; font-size: 0.875rem; color: var(--text); white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">' + esc(nameTrunc) + '</div>' +
                '<div style="font-size: 0.75rem; color: var(--muted); margin-top: 2px;">' + esc(introTrunc) + '</div>' +
                (isTruncated ? '<div class="truncation-line"></div>' : '') +
                '<div style="display: flex; align-items: center; gap: 0.5rem; margin-top: 0.5rem;">' +
                  '<span style="font-size: 0.75rem; font-weight: 600; color: var(--text);">' + ctx.rating + ' ★</span>' +
                  '<span style="font-size: 0.7rem; color: var(--dim);">(' + ctx.review_count + ')</span>' +
                '</div>' +
              '</div>' +
            '</div>' +
          '</div>' +
          (issues.length > 0 ? '<div style="margin-top: 1rem; display: flex; flex-direction: column; gap: 0.35rem;">' +
            issues.map(function(i) { return '<p style="font-size: 0.75rem; color: var(--muted);">' + i + '</p>'; }).join('') +
          '</div>' : '');
      }

      // Prioritized fixes (numbered with impact labels)
      function renderPrioritizedFixes(fixes) {
        if (!fixes || fixes.length === 0) return '<p style="font-size: 0.875rem; color: #10B981;">All checks passed. Your listing is well-optimized.</p>';
        var html = '<div style="display: flex; flex-direction: column; gap: 0.75rem;">';
        for (var i = 0; i < fixes.length; i++) {
          var f = fixes[i];
          var ic = impactColor(f.impact_label);
          var isOverride = f.detail.startsWith('[Override]');
          var cleanDetail = f.detail.replace('[Override] ', '');
          html += '<div class="finding-card">' +
            '<div style="display: flex; align-items: start; gap: 0.75rem;">' +
              '<div style="flex-shrink: 0; width: 28px; height: 28px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 0.75rem; font-weight: 700; color: white; background: ' + ic + ';">' + f.rank + '</div>' +
              '<div style="flex: 1; min-width: 0;">' +
                '<div style="display: flex; align-items: baseline; gap: 0.5rem; flex-wrap: wrap;">' +
                  '<span style="font-size: 0.8rem; font-weight: 600; color: var(--text);">' + esc(f.check) + '</span>' +
                  '<span style="font-size: 0.65rem; padding: 1px 6px; border-radius: 4px; background: ' + ic + '20; color: ' + ic + ';">' + esc(f.impact_label) + '</span>' +
                  (isOverride ? '<span style="font-size: 0.65rem; padding: 1px 6px; border-radius: 4px; background: rgba(239,68,68,0.1); color: #EF4444;">Override</span>' : '') +
                '</div>' +
                '<p style="font-size: 0.8rem; color: var(--muted); margin-top: 0.25rem; line-height: 1.4;">' + esc(cleanDetail) + '</p>' +
                (f.score_range_estimate ? '<p style="font-size: 0.75rem; color: var(--accent); margin-top: 0.35rem; font-weight: 500;">' + esc(f.score_range_estimate) + '</p>' : '') +
              '</div>' +
            '</div>' +
          '</div>';
        }
        html += '</div>';
        return html;
      }

      // Passing checks (collapsed)
      function renderPassingChecks(findings) {
        var passed = findings.filter(function(f) { return f.passed; });
        if (passed.length === 0) return '';
        return '<details style="margin-top: 0.5rem;">' +
          '<summary style="font-size: 0.8rem; font-weight: 600; color: var(--muted); cursor: pointer; padding: 0.5rem 0;">Passing checks (' + passed.length + ')</summary>' +
          '<div style="display: flex; flex-direction: column; gap: 0.35rem; margin-top: 0.5rem;">' +
          passed.map(function(f) {
            return '<div style="display: flex; align-items: center; gap: 0.5rem; padding: 0.25rem 0;">' +
              '<span style="color: #10B981; font-size: 0.8rem;">✓</span>' +
              '<span style="font-size: 0.75rem; color: var(--muted);">' + esc(f.check) + '</span>' +
            '</div>';
          }).join('') +
          '</div></details>';
      }

      // Context panel with benchmark insights
      function renderContext(ctx) {
        var items = [];

        // Rating — directional insights based on Shopify's documented practices
        var ri = ctx.rating >= 4.5 ? 'Strong. Higher-rated apps rank better in Shopify search.'
          : ctx.rating >= 4.0 ? 'Good. Aim for 4.5+ to stand out in search results.'
          : ctx.rating >= 3.0 ? 'Below average. Low ratings reduce search visibility and merchant trust.'
          : 'Needs attention. Ratings under 3.0 significantly hurt discoverability.';
        items.push({ label: 'Rating', value: ctx.rating + ' ★', insight: ri });

        // Reviews
        var rvi = ctx.review_count >= 100 ? 'Strong social proof. Review count is a Shopify search ranking signal.'
          : ctx.review_count >= 20 ? 'Decent. More reviews strengthen search ranking and merchant confidence.'
          : ctx.review_count >= 5 ? 'Low. Shopify search weights review count. Active review outreach helps.'
          : 'Very few reviews. New merchants hesitate to install apps without social proof.';
        items.push({ label: 'Reviews', value: String(ctx.review_count), insight: rvi });

        if (ctx.latest_review_date && ctx.latest_review_date !== 'N/A') {
          items.push({ label: 'Latest review', value: ctx.latest_review_date, insight: '' });
        }
        if (ctx.developer_name && ctx.developer_name !== 'N/A') {
          items.push({ label: 'Developer', value: ctx.developer_name, insight: '' });
        }
        if (ctx.built_for_shopify) {
          items.push({ label: 'Built for Shopify', value: '✓ Earned', insight: 'Improves search placement and merchant trust.' });
        }
        if (ctx.category && ctx.category !== 'N/A') {
          items.push({ label: 'Category', value: ctx.category, insight: '' });
        }
        if (ctx.launched_date && ctx.launched_date !== 'N/A') {
          items.push({ label: 'Launched', value: ctx.launched_date, insight: '' });
        }

        var html = '<h3 class="sfy-h" style="font-size: 0.9rem; font-weight: 700; color: var(--text); margin-bottom: 0.25rem;">Context</h3>' +
          '<p style="font-size: 0.7rem; color: var(--dim); margin-bottom: 1rem;">Not scored. You can\'t change these by editing copy.</p>' +
          '<div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 0.75rem;">';

        for (var i = 0; i < items.length; i++) {
          var it = items[i];
          html += '<div style="padding: 0.5rem 0;">' +
            '<div style="font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.05em; color: var(--dim); margin-bottom: 0.25rem;">' + esc(it.label) + '</div>' +
            '<div style="font-size: 0.9rem; font-weight: 600; color: var(--text);">' + esc(it.value) + '</div>' +
            (it.insight ? '<div style="font-size: 0.7rem; color: var(--muted); margin-top: 0.15rem;">' + esc(it.insight) + '</div>' : '') +
          '</div>';
        }
        html += '</div>';
        return html;
      }

      // Growth roadmap
      function renderRoadmap(fixes, issueCount) {
        if (issueCount === 0) {
          return '<h3 class="sfy-h" style="font-size: 1rem; font-weight: 700; color: var(--text); margin-bottom: 0.5rem;">Your listing is well-optimized.</h3>' +
            '<p style="font-size: 0.8rem; color: var(--muted);">Focus on getting more reviews and maintaining quality.</p>';
        }
        return '<h3 class="sfy-h" style="font-size: 1rem; font-weight: 700; color: var(--text); margin-bottom: 1rem;">Your Next 48 Hours</h3>' +
          '<div style="display: flex; flex-direction: column; gap: 1rem;">' +
            '<div style="display: flex; gap: 0.75rem; align-items: start;">' +
              '<span class="sfy-m" style="font-size: 0.875rem; font-weight: 700; color: var(--accent);">1</span>' +
              '<div><span style="font-size: 0.875rem; font-weight: 600; color: var(--text);">Work through your ' + issueCount + ' fixes above</span> <span style="font-size: 0.8rem; color: var(--muted);">starting with #1 (highest impact)</span></div>' +
            '</div>' +
            '<div style="display: flex; gap: 0.75rem; align-items: start;">' +
              '<span class="sfy-m" style="font-size: 0.875rem; font-weight: 700; color: var(--accent);">2</span>' +
              '<div><span style="font-size: 0.875rem; font-weight: 600; color: var(--text);">Get your detailed fix plan</span> <span style="font-size: 0.8rem; color: var(--muted);">with step-by-step instructions and patterns</span></div>' +
            '</div>' +
            '<div style="display: flex; gap: 0.75rem; align-items: start;">' +
              '<span class="sfy-m" style="font-size: 0.875rem; font-weight: 700; color: var(--accent);">3</span>' +
              '<div><span style="font-size: 0.875rem; font-weight: 600; color: var(--text);">Re-grade your listing</span> <span style="font-size: 0.8rem; color: var(--muted);">after changes to track improvement</span></div>' +
            '</div>' +
          '</div>';
      }

      // Email gate
      function renderEmailGate(issueCount) {
        return '<p class="sfy-h" style="font-size: 1.125rem; font-weight: 700; color: var(--text); margin-bottom: 0.5rem;">We found ' + issueCount + ' issues affecting your installs</p>' +
          '<p style="font-size: 0.875rem; color: var(--muted); margin-bottom: 1.5rem; max-width: 420px; margin-left: auto; margin-right: auto;">Get a detailed fix plan with step-by-step instructions, structural patterns, and example formats for each issue.</p>' +
          '<button id="get-fixplan-btn" class="sfy-btn-primary font-semibold px-8 py-3 rounded-xl text-sm sfy-h">Get Fix Plan</button>';
      }

      // Render all results
      function renderResults(data) {
        // Listing mirror
        $('listing-mirror').innerHTML = renderListingMirror(data.listing_meta, data.context);

        // Score hero (two-tier)
        $('score-hero').innerHTML = renderScoreHero(data);

        // Animate score ring + bars
        requestAnimationFrame(function() {
          var ring = document.querySelector('.score-ring');
          if (ring) {
            requestAnimationFrame(function() {
              ring.style.strokeDashoffset = ring.getAttribute('data-target');
            });
          }
          var bars = document.querySelectorAll('.section-bar-fill');
          bars.forEach(function(bar) {
            requestAnimationFrame(function() {
              bar.style.width = bar.getAttribute('data-target');
            });
          });
        });

        // Search card
        $('search-card-section').innerHTML = renderSearchCard(data.listing_meta, data.context);

        // Section scores
        $('section-scores').innerHTML = renderSectionScores(data.section_scores);

        // Prioritized fixes (replaces old risk/growth split)
        var fixes = data.prioritized_fixes || [];
        var issuesHtml = '<h3 class="sfy-h" style="font-size: 1rem; font-weight: 700; color: var(--text); margin-bottom: 0.25rem;">Your Fixes, In Order of Impact</h3>' +
          '<p style="font-size: 0.75rem; color: var(--muted); margin-bottom: 1rem;">' + fixes.length + ' issue' + (fixes.length !== 1 ? 's' : '') + ' found. Fix #1 first for the biggest improvement.</p>';
        issuesHtml += renderPrioritizedFixes(fixes);
        issuesHtml += renderPassingChecks(data.findings);
        $('issues-section').innerHTML = issuesHtml;

        // Roadmap
        $('roadmap-section').innerHTML = renderRoadmap(fixes, fixes.length);

        // Email gate
        if (fixes.length > 0) {
          $('email-gate').innerHTML = renderEmailGate(fixes.length);
          show($('email-gate'));
          var fpBtn = $('get-fixplan-btn');
          if (fpBtn) {
            fpBtn.addEventListener('click', function() {
              $modal.classList.add('active');
            });
          }
        }

        // Context panel
        $('context-panel').innerHTML = renderContext(data.context);

        // Disclaimer
        var disclaimerHtml = '<p style="font-size: 0.7rem; color: var(--dim); text-align: center; margin-top: 1rem;">This tool grades your listing\'s quality, not your app\'s success. Apps with strong brand recognition may convert well despite listing gaps.</p>';
        $('context-panel').innerHTML += disclaimerHtml;
      }

      // Main grade flow
      async function doGrade() {
        var url = $urlInput.value.trim();
        hide($urlError);

        if (!url) { showError('Please enter a URL.'); return; }
        if (!isValidUrl(url)) { showError('Please enter a valid Shopify app URL (e.g. https://apps.shopify.com/loox)'); return; }

        // Show loading
        hide($input);
        hide($checkPreview);
        show($loading);
        $loadingMsg.textContent = loadingMessages[0];
        var loadingInterval = animateLoading();

        try {
          var res = await fetch('/.netlify/functions/grade-listing', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ url: url }),
          });

          clearInterval(loadingInterval);

          if (res.status === 429) {
            hide($loading);
            show($input);
            show($checkPreview);
            showError('Daily limit reached. You can grade up to 5 listings per day.');
            return;
          }

          var data = await res.json();

          if (!res.ok || data.error) {
            hide($loading);
            show($input);
            show($checkPreview);
            showError(data.error || 'Something went wrong. Please try again.');
            return;
          }

          gradeData = data;
          hide($loading);
          show($results);
          show($cta);
          renderResults(data);

        } catch (err) {
          clearInterval(loadingInterval);
          hide($loading);
          show($input);
          show($checkPreview);
          showError('Network error. Please check your connection and try again.');
        }
      }

      // Fix plan submission
      async function submitFixPlan() {
        var email = $modalEmail.value.trim();
        hide($modalEmailError);

        if (!email || !email.includes('@')) {
          $modalEmailError.textContent = 'Please enter a valid email address.';
          show($modalEmailError);
          return;
        }

        if (!isBusinessEmail(email)) {
          $modalEmailError.textContent = 'Please enter a business email (not Gmail, Yahoo, etc.)';
          show($modalEmailError);
          return;
        }

        $modalSubmitBtn.textContent = 'Generating...';
        $modalSubmitBtn.disabled = true;

        try {
          var res = await fetch('/.netlify/functions/send-grader-report', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              email: email,
              findings: gradeData.findings,
              appName: gradeData.listing_meta.app_name,
            }),
          });

          var data = await res.json();

          if (!res.ok || data.error) {
            $modalEmailError.textContent = data.error || 'Something went wrong.';
            show($modalEmailError);
            $modalSubmitBtn.textContent = 'Get Fix Plan';
            $modalSubmitBtn.disabled = false;
            return;
          }

          // Close modal and show fix plan
          $modal.classList.remove('active');
          hide($('email-gate'));

          if (data.fixPlan) {
            var fpSection = $('fix-plan-section');
            var fpContent = $('fix-plan-content');
            // Simple markdown-to-html (headers, bold, lists)
            var md = data.fixPlan
              .replace(/### (.*)/g, '<h4 class="sfy-h" style="font-size: 0.9rem; font-weight: 700; color: var(--text); margin-top: 1.5rem; margin-bottom: 0.5rem;">$1</h4>')
              .replace(/\*\*(.*?)\*\*/g, '<strong style="color: var(--text);">$1</strong>')
              .replace(/^- (.*)/gm, '<li style="font-size: 0.8rem; color: var(--muted); margin-left: 1rem;">$1</li>')
              .replace(/\n\n/g, '<br/><br/>')
              .replace(/\n/g, '<br/>');
            fpContent.innerHTML = md;
            show(fpSection);
            fpSection.scrollIntoView({ behavior: 'smooth', block: 'start' });
          }

        } catch (err) {
          $modalEmailError.textContent = 'Network error. Please try again.';
          show($modalEmailError);
          $modalSubmitBtn.textContent = 'Get Fix Plan';
          $modalSubmitBtn.disabled = false;
        }
      }

      // Event listeners
      $gradeBtn.addEventListener('click', doGrade);
      $urlInput.addEventListener('keydown', function(e) { if (e.key === 'Enter') doGrade(); });

      $resetBtn.addEventListener('click', function() {
        hide($results);
        hide($cta);
        hide($('fix-plan-section'));
        show($input);
        show($checkPreview);
        $urlInput.value = '';
        gradeData = null;
      });

      // Modal controls
      $modalConsent.addEventListener('change', function() {
        var enabled = $modalConsent.checked && $modalEmail.value.trim().length > 3;
        $modalSubmitBtn.disabled = !enabled;
        $modalSubmitBtn.classList.toggle('opacity-50', !enabled);
        $modalSubmitBtn.classList.toggle('cursor-not-allowed', !enabled);
      });
      $modalEmail.addEventListener('input', function() {
        $modalConsent.dispatchEvent(new Event('change'));
      });
      $modalSubmitBtn.addEventListener('click', submitFixPlan);
      $modalCloseBtn.addEventListener('click', function() { $modal.classList.remove('active'); });
      $modal.addEventListener('click', function(e) { if (e.target === $modal) $modal.classList.remove('active'); });

      // Copy fix plan
      var $copyFP = $('copy-fixplan-btn');
      if ($copyFP) {
        $copyFP.addEventListener('click', function() {
          var text = $('fix-plan-content').innerText;
          navigator.clipboard.writeText(text).then(function() {
            var toast = $('copy-toast');
            toast.classList.add('show');
            setTimeout(function() { toast.classList.remove('show'); }, 2000);
          });
        });
      }
    })();
  </script>
</Layout>
