---
import Layout from '~/layouts/PageLayout.astro';
import Header from '~/components/widgets/Header.astro';
import ShopifyAppTheme from '~/components/widgets/ShopifyAppTheme.astro';

const metadata = {
  title: 'Free Tools for Shopify App Growth | SellOnTube',
  description: 'Free tools to help Shopify app companies grow installs, reduce churn, and improve activation. Coming soon.',
  robots: { index: false, follow: true },
};

const calLink = 'https://cal.com/gautham-8bdvdx/30min';

const tools = [
  {
    n: '01',
    href: '/shopify-app/tools/shopify-app-store-listing-grader',
    t: 'Shopify App Store Listing Grader',
    d: 'Grade your listing against 30+ official rules. Get a score, section breakdown, and prioritized fix plan.',
  },
  {
    n: '02',
    href: '/shopify-app/tools/shopify-app-review-scraper-analyzer',
    t: 'Shopify App Reviews Scraper',
    d: 'Extract reviews from any app listing. View ratings, AI sentiment, download CSV.',
  },
];
---

<Layout metadata={metadata}>

  <Fragment slot="announcement"></Fragment>

  <Fragment slot="header">
    <Header
      isDark
      links={[
        { text: 'Case Studies', href: '/shopify-app#proof', links: [
          { text: 'Left Foot Software', href: '/shopify-app/case-studies/left-foot-software' },
          { text: 'YouTube Video Marketing: Inventory App Case Study', href: '/shopify-app/case-studies/shopify-app-growth-youtube-marketing' },
        ]},
        { text: 'Services', href: '/shopify-app#work' },
        { text: 'Tools', href: '/shopify-app/tools' },
        { text: 'Pricing', href: '/shopify-app#pricing' },
      ]}
      actions={[{ text: 'Book a discovery call', href: calLink, target: '_blank', variant: 'primary' }]}
      isSticky
    />
  </Fragment>

  <Fragment slot="footer"></Fragment>

  <script is:inline>
    document.addEventListener('DOMContentLoaded', () => {
      const logoLink = document.querySelector('#header a[href="/"]');
      if (logoLink) logoLink.setAttribute('href', '/shopify-app');
    });
  </script>

  <ShopifyAppTheme />

  <div class="sfy">

    <section class="relative overflow-hidden min-h-[70vh]">
      <div class="sfy-grain"></div>
      <div class="sfy-container relative pt-20 sm:pt-28 pb-24">
        <p class="sfy-label mb-10 flex items-center gap-2.5">
          <span class="inline-block w-1.5 h-1.5 rounded-full" style="background: var(--accent);"></span>
          Free tools
        </p>
        <h1 class="sfy-display text-[2.75rem] sm:text-6xl lg:text-7xl mb-10 max-w-4xl">
          Free tools for Shopify app growth.
        </h1>
        <p class="text-lg leading-relaxed mb-20 max-w-md" style="color: var(--muted);">
          Diagnose and fix your app's growth. No signup, no email gate.
        </p>

        <div class="max-w-3xl">
          {tools.map((tool) => (
            <a href={tool.href} class="sfy-tool-row group grid grid-cols-[3rem_1fr_auto] items-baseline gap-5 py-8" style="border-top: 1px solid var(--border);">
              <p class="sfy-num text-sm font-bold pt-1" style="color: var(--dim);">{tool.n}</p>
              <div>
                <h2 class="text-xl sm:text-2xl font-bold mb-2">{tool.t}</h2>
                <p class="text-[0.95rem] leading-relaxed max-w-xl" style="color: var(--muted);">{tool.d}</p>
              </div>
              <span class="sfy-tool-arrow text-2xl self-center" style="color: var(--dim);">&rarr;</span>
            </a>
          ))}
          <div style="border-top: 1px solid var(--border);"></div>
        </div>
      </div>
    </section>

    <style>
      .sfy-tool-row {
        transition: background 0.2s ease;
      }
      .sfy-tool-row:hover {
        background: var(--bg2);
      }
      .sfy-tool-arrow {
        transition: transform 0.2s ease, color 0.2s ease;
      }
      .sfy-tool-row:hover .sfy-tool-arrow {
        transform: translateX(4px);
        color: var(--accent);
      }
    </style>

    <footer class="py-10" style="border-top: 1px solid var(--border);">
      <div class="sfy-container">
        <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">
          <p class="text-xs" style="color: var(--dim);">&copy; 2026 SellOnTube. All rights reserved.</p>
          <div class="flex items-center gap-6 text-xs" style="color: var(--dim);">
            <a href="/shopify-app" class="hover:underline">Back to Services</a>
            <a href="/privacy-policy" class="hover:underline">Privacy</a>
            <a href="/terms-of-service" class="hover:underline">Terms</a>
          </div>
        </div>
      </div>
    </footer>

  </div>

</Layout>
