---
import { Image } from 'astro:assets';
import Layout from '~/layouts/PageLayout.astro';
import Header from '~/components/widgets/Header.astro';
import ShopifyAppTheme from '~/components/widgets/ShopifyAppTheme.astro';

import gs1Logo from '~/assets/images/case-studies/gs1-assistant-logo.png';
import builtForShopify from '~/assets/images/case-studies/gs1-built-for-shopify.png';
import serpGs1App from '~/assets/images/case-studies/gs1-serp-gs1-app.jpg';
import serpGs1Assistant from '~/assets/images/case-studies/gs1-serp-gs1-assistant.jpg';
import gs1GtinFlow from '~/assets/images/case-studies/gs1-gtin-flow.png';
import gs1Dashboard from '~/assets/images/case-studies/gs1-dashboard.png';
import gs1Verified from '~/assets/images/case-studies/gs1-verified.png';

const metadata = {
  title: 'Left Foot Software Case Study | Shopify App Growth | SellOnTube',
  description: 'No listing, no docs, no growth plan. 120 days later: ASO rewrite, knowledge base, product video, pricing strategy, review management. Left Foot Software case study.',
  openGraph: {
    images: [{ url: '~/assets/images/og/shopify-app.jpg', width: 1200, height: 630 }],
  },
};

const calLink = 'https://cal.com/gautham-8bdvdx/30min';

const challenges = [
  { n: '01', t: 'Solo technical founder', d: 'Building and maintaining a multi-app Shopify suite. Every hour spent on non-engineering work was an hour not spent shipping features.' },
  { n: '02', t: 'No positioning or marketing', d: 'App Store listings did the minimum. Functional titles, generic descriptions. Merchants who would have benefited from the apps scrolled right past them.' },
  { n: '03', t: 'No documentation', d: 'No knowledge base, no help center, no onboarding guides. Merchants who installed got stuck and left. The founder became the documentation.' },
  { n: '04', t: 'No support infrastructure', d: 'Reviews sat unanswered. Support was email, one question at a time, with the founder typing every reply from scratch.' },
  { n: '05', t: 'Unexplained early churn', d: 'Install numbers looked fine. Retention did not. Something was going wrong in the first week but the founder had no visibility into what.' },
  { n: '06', t: 'No pricing strategy', d: 'Free plan with no conversion path. Pricing set at launch and never revisited. No data on what merchants would pay based on actual usage.' },
];

const results = [
  { big: 'Churn cut by 15 points', accent: true, d: '69.6% churn ratio down to 54.7% after the listing and screenshot rewrite. Effect was immediate: installs/day up 41% and churn down 18 points in the same month the new copy went live.' },
  { big: 'Rating went from 1.0 to 4.9', accent: false, d: 'Up from 1.0 stars in early 2025 to 4.9 across 11 reviews. "Hard to set up" mentions in reviews fell 71% once the new screenshots showed the setup clearly.' },
  { big: 'Revenue up 66%, entirely organic', accent: false, d: '$1,491/mo to $2,474/mo over 12 months. Every install organic, zero paid acquisition spend. $27,123 in total revenue over the year.' },
  { big: 'A loyal core, not just installs', accent: false, d: '230 active subscribers, ~9 months average tenure, 69% still paying after 6+ months. Foundation phase done; monthly retainer now covers SEO content, review management, and strategy calls.' },
];
---

<Layout metadata={metadata}>

  <Fragment slot="announcement"></Fragment>

  <Fragment slot="header">
    <Header
      isDark
      links={[
        { text: 'Back to Services', href: '/shopify-app' },
      ]}
      actions={[{ text: 'Book a discovery call', href: calLink, target: '_blank', variant: 'primary' }]}
      isSticky
    />
  </Fragment>

  <Fragment slot="footer"></Fragment>

  <script is:inline>
    document.addEventListener('DOMContentLoaded', () => {
      const logoLink = document.querySelector('#header a[href="/"]');
      if (logoLink) logoLink.setAttribute('href', '/shopify-app');
    });
  </script>

  <ShopifyAppTheme />

  <div class="sfy">

    <!-- ===== HERO ===== -->
    <section class="relative overflow-hidden">
      <div class="sfy-grain"></div>
      <div class="sfy-container relative pt-16 sm:pt-20 pb-16 sm:pb-20">
        <nav class="flex items-center gap-2 text-xs mb-12" style="color: var(--dim);">
          <a href="/shopify-app" class="hover:underline" style="color: var(--muted);">Services</a>
          <span>/</span>
          <span>Case Studies</span>
          <span>/</span>
          <span style="color: var(--text);">Left Foot Software</span>
        </nav>

        <p class="sfy-label mb-8 flex items-center gap-2.5">
          <span class="inline-block w-1.5 h-1.5 rounded-full" style="background: var(--accent);"></span>
          Case study
        </p>

        <h1 class="sfy-display text-[2.6rem] sm:text-6xl lg:text-7xl mb-10 max-w-4xl">
          Great apps. No one knew they existed.
        </h1>

        <p class="text-lg leading-relaxed mb-12 max-w-2xl" style="color: var(--muted);">
          Left Foot Software had a multi-app Shopify suite and their flagship, <a href="https://apps.shopify.com/gs1-assistant" target="_blank" rel="noopener noreferrer" class="sfy-link">GS1 Assistant</a>, had 4.9-star ratings waiting to happen. No ASO, no docs, no content, no video. This is what 120 days changed.
        </p>

        <!-- App identity strip -->
        <div class="flex flex-wrap items-center gap-10 pt-8" style="border-top: 1px solid var(--border);">
          <div class="flex items-center gap-4">
            <Image src={gs1Logo} alt="GS1 Assistant app logo" width={44} height={44} />
            <div>
              <p class="text-sm font-bold">GS1 Assistant</p>
              <p class="text-xs mt-0.5" style="color: var(--dim);">4.9 &#9733; on Shopify App Store</p>
            </div>
          </div>
          <div class="max-w-[180px]">
            <Image src={builtForShopify} alt="Built for Shopify badge" width={180} height={101} class="object-contain" />
          </div>
        </div>
      </div>

      <!-- Stat band -->
      <div style="border-top: 1px solid var(--border);">
        <div class="sfy-container">
          <div class="grid grid-cols-1 sm:grid-cols-3">
            <div class="py-8 sm:pr-10" style="border-bottom: 1px solid var(--border-soft);">
              <p class="sfy-num text-4xl font-black" style="color: var(--accent);">1.0 &rarr; 4.9</p>
              <p class="text-sm mt-2" style="color: var(--muted);">App Store rating, 12 months</p>
            </div>
            <div class="py-8 sm:px-10 sm:border-l" style="border-color: var(--border-soft); border-bottom: 1px solid var(--border-soft);">
              <p class="sfy-num text-4xl font-black">-71%</p>
              <p class="text-sm mt-2" style="color: var(--muted);">&ldquo;hard to set up&rdquo; complaints in reviews</p>
            </div>
            <div class="py-8 sm:pl-10 sm:border-l" style="border-color: var(--border-soft); border-bottom: 1px solid var(--border-soft);">
              <p class="sfy-num text-4xl font-black">+66%</p>
              <p class="text-sm mt-2" style="color: var(--muted);">revenue growth, 100% organic</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ===== THE CHALLENGE ===== -->
    <section id="challenge" class="py-24 sm:py-28">
      <div class="sfy-container">
        <div class="grid lg:grid-cols-12 gap-12 lg:gap-16">
          <div class="lg:col-span-5">
            <div class="lg:sticky lg:top-28 sfy-reveal">
              <h2 class="sfy-display text-4xl sm:text-5xl mb-8">A great product with no one handling anything outside the code.</h2>
            </div>
          </div>
          <div class="lg:col-span-7">
            {challenges.map((c) => (
              <div class="sfy-reveal py-7 grid grid-cols-[3rem_1fr] gap-5" style="border-top: 1px solid var(--border);">
                <p class="sfy-num text-sm font-bold pt-1" style="color: var(--dim);">{c.n}</p>
                <div>
                  <h3 class="text-lg font-bold mb-2">{c.t}</h3>
                  <p class="text-[0.95rem] leading-relaxed max-w-xl" style="color: var(--muted);">{c.d}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- ===== WHAT WE DID ===== -->
    <section id="work" class="py-24 sm:py-28" style="background: var(--bg2); border-top: 1px solid var(--border); border-bottom: 1px solid var(--border);">
      <div class="sfy-container">
        <p class="sfy-label mb-5">What we did</p>
        <h2 class="sfy-display text-4xl sm:text-5xl mb-16 max-w-3xl">Six workstreams. 120 days. Everything in parallel.</h2>

        <!-- 1. ASO -->
        <div class="sfy-reveal grid lg:grid-cols-12 gap-8 lg:gap-12 py-12" style="border-top: 1px solid var(--border);">
          <div class="lg:col-span-5">
            <p class="sfy-num text-sm font-bold mb-4" style="color: var(--dim);">01 &middot; Discovery</p>
            <h3 class="text-2xl font-bold mb-4">App Store optimization rewrite</h3>
            <p class="text-[0.95rem] leading-relaxed" style="color: var(--muted);">Title, subtitle, description, and search terms rebuilt around what merchants actually type into the Shopify App Store. The listing went from functional to persuasive. Now ranking #1 for &ldquo;gs1 assistant&rdquo; on Google with an AI Overview citation.</p>
          </div>
          <div class="lg:col-span-7">
            <figure class="sfy-shot">
              <Image src={gs1GtinFlow} alt="GS1 Assistant listing - GTINs accepted on Amazon, Google and Walmart" width={800} height={450} class="w-full" loading="lazy" />
              <figcaption>Listing creative from the rewrite: GTINs accepted on Amazon, Google and Walmart</figcaption>
            </figure>
          </div>
        </div>

        <!-- 2. Video (mirrored) -->
        <div class="sfy-reveal grid lg:grid-cols-12 gap-8 lg:gap-12 py-12" style="border-top: 1px solid var(--border);">
          <div class="lg:col-span-7 order-2 lg:order-1">
            <figure class="sfy-shot">
              <Image src={gs1Verified} alt="GS1 Assistant demo slide: every barcode checked against GS1's official database" width={800} height={450} class="w-full" loading="lazy" />
              <figcaption>A slide from the demo assets we produced</figcaption>
            </figure>
          </div>
          <div class="lg:col-span-5 order-1 lg:order-2">
            <p class="sfy-num text-sm font-bold mb-4" style="color: var(--dim);">02 &middot; Discovery</p>
            <h3 class="text-2xl font-bold mb-4">Product demo video</h3>
            <p class="text-[0.95rem] leading-relaxed" style="color: var(--muted);">We scripted, recorded, and edited a professional product demo. The founder never touched a camera. The video now lives on the App Store listing, YouTube channel, and landing page. It shows merchants exactly how the app works before they commit to installing.</p>
          </div>
        </div>

        <!-- 3. Knowledge base (featured) -->
        <div class="sfy-reveal grid lg:grid-cols-12 gap-8 lg:gap-12 py-12" style="border-top: 1px solid var(--border);">
          <div class="lg:col-span-5">
            <p class="sfy-num text-sm font-bold mb-4" style="color: var(--dim);">03 &middot; Retention</p>
            <h3 class="text-2xl font-bold mb-4">Full knowledge base</h3>
            <p class="text-sm font-bold mb-4" style="color: var(--accent);">The single biggest lever against week-one churn.</p>
            <p class="text-[0.95rem] leading-relaxed" style="color: var(--muted);">30 to 50 articles covering every feature, edge case, and common support question. Published to the help center and embedded directly in-app. Merchants who get stuck now find answers without emailing support.</p>
          </div>
          <div class="lg:col-span-7">
            <figure class="sfy-shot">
              <Image src={gs1Dashboard} alt="GS1 Assistant dashboard - barcode status view" width={800} height={450} class="w-full" loading="lazy" />
              <figcaption>The barcode status dashboard the guides walk merchants through</figcaption>
            </figure>
          </div>
        </div>

        <!-- 4-6: text workstreams -->
        <div class="grid md:grid-cols-3 gap-10 md:gap-8 py-12" style="border-top: 1px solid var(--border);">
          <div class="sfy-reveal">
            <p class="sfy-num text-sm font-bold mb-4" style="color: var(--dim);">04 &middot; Conversion</p>
            <h3 class="text-lg font-bold mb-3">Pricing strategy</h3>
            <p class="text-[0.95rem] leading-relaxed" style="color: var(--muted);">Free plan removed entirely. Migrated to a credit-based model built around actual merchant usage patterns. Pricing matches what merchants actually get, not a number picked on launch day. The model gives merchants a clear reason to upgrade.</p>
          </div>
          <div class="sfy-reveal">
            <p class="sfy-num text-sm font-bold mb-4" style="color: var(--dim);">05 &middot; Discovery + Retention</p>
            <h3 class="text-lg font-bold mb-3">Review management</h3>
            <p class="text-[0.95rem] leading-relaxed" style="color: var(--muted);">Every Shopify review answered under the brand voice. Profiles submitted on G2, Capterra, and Product Hunt. Outreach sequences launched to surface new reviews from active merchants. Review velocity directly affects App Store ranking.</p>
          </div>
          <div class="sfy-reveal">
            <p class="sfy-num text-sm font-bold mb-4" style="color: var(--dim);">06 &middot; Ongoing</p>
            <h3 class="text-lg font-bold mb-3">Product strategy input</h3>
            <p class="text-[0.95rem] leading-relaxed" style="color: var(--muted);">We stay involved after the foundation phase: feature prioritization based on merchant feedback, positioning calls based on what competitors miss.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ===== RESULTS ===== -->
    <section id="results" class="py-24 sm:py-28">
      <div class="sfy-container">
        <p class="sfy-label mb-5">Results</p>
        <h2 class="sfy-display text-4xl sm:text-5xl lg:text-6xl mb-16">What 120 days produced.</h2>

        <div class="grid md:grid-cols-2 gap-x-14">
          {results.map((r) => (
            <div class="sfy-reveal py-9" style="border-top: 1px solid var(--border);">
              <p class="text-2xl font-black mb-3" style={r.accent ? 'color: var(--accent);' : ''}>{r.big}</p>
              <p class="text-[0.95rem] leading-relaxed max-w-lg" style="color: var(--muted);">{r.d}</p>
            </div>
          ))}
        </div>

        <!-- ASO proof: SERP rankings -->
        <div class="mt-16">
          <p class="sfy-label mb-8">ASO in action: Google search results after our rewrite</p>
          <div class="grid md:grid-cols-2 gap-8">
            <figure class="sfy-shot sfy-reveal" style="--rot: -0.5deg;">
              <Image src={serpGs1Assistant} alt="GS1 Assistant ranking #1 on Google for gs1 assistant with AI Overview" width={700} height={500} class="w-full" loading="lazy" />
              <figcaption>Search: &ldquo;gs1 assistant&rdquo;. #1 result, plus an AI Overview citation</figcaption>
            </figure>
            <figure class="sfy-shot sfy-reveal" style="--rot: 0.5deg;">
              <Image src={serpGs1App} alt="GS1 Assistant appearing in top Google results for gs1 app with 4.9 star rating" width={700} height={500} class="w-full" loading="lazy" />
              <figcaption>Search: &ldquo;gs1 app&rdquo;. Top results, 4.9 &#9733; visible in the SERP</figcaption>
            </figure>
          </div>
        </div>

        <p class="text-sm mt-14 pt-8 max-w-xl" style="color: var(--dim); border-top: 1px solid var(--border);">
          Measurement: all results tracked via Google Analytics on install-button clicks. No vanity metrics.
        </p>
      </div>
    </section>

    <!-- ===== CTA ===== -->
    <section class="relative overflow-hidden py-28 sm:py-32" style="border-top: 1px solid var(--border);">
      <div class="sfy-grain"></div>
      <div class="sfy-container relative">
        <h2 class="sfy-display text-[2.6rem] sm:text-6xl lg:text-7xl mb-12 max-w-4xl">Run the same playbook on your app.</h2>
        <div class="flex flex-col sm:flex-row sm:items-center gap-8">
          <a href={calLink} target="_blank" rel="noopener noreferrer" class="sfy-btn flex-shrink-0">Book a discovery call</a>
          <p class="text-base leading-relaxed max-w-md" style="color: var(--muted);">
            30 minutes. We look at your app, find the biggest gaps, and tell you exactly where we would start. If your app has installs but nobody owns the non-technical side, this call is for you.
          </p>
        </div>
        <p class="text-sm mt-8" style="color: var(--dim);">A direct conversation. If we cannot help, we say so.</p>
      </div>
    </section>

    <!-- ===== FOOTER ===== -->
    <footer class="py-16" style="border-top: 1px solid var(--border);">
      <div class="sfy-container">
        <div class="grid sm:grid-cols-3 gap-10 mb-12">
          <div>
            <p class="font-bold text-sm mb-4">SellOnTube for Shopify Apps</p>
            <p class="text-sm leading-relaxed max-w-xs" style="color: var(--muted);">Shopify app growth specialists. ASO, content, video, documentation, reviews, pricing strategy.</p>
          </div>
          <div>
            <p class="sfy-label mb-5">Services</p>
            <div class="space-y-2.5 text-sm" style="color: var(--muted);">
              <p>App Store Optimization</p>
              <p>User Guides &amp; Knowledge Base</p>
              <p>Product Demo Video</p>
              <p>SEO Content</p>
              <p>Video Marketing</p>
              <p>Review Management</p>
            </div>
          </div>
          <div>
            <p class="sfy-label mb-5">Explore</p>
            <div class="space-y-2.5 text-sm">
              <a href="/shopify-app/case-studies/shopify-app-growth-youtube-marketing" class="block sfy-link" style="color: var(--muted);">YouTube video marketing case study</a>
              <a href="/shopify-app" class="block sfy-link" style="color: var(--muted);">Back to Services</a>
              <a href="/shopify-app/tools" class="block sfy-link" style="color: var(--muted);">Free Tools</a>
            </div>
          </div>
        </div>
        <div class="pt-8 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4" style="border-top: 1px solid var(--border-soft);">
          <p class="text-xs" style="color: var(--dim);">&copy; 2026 SellOnTube. All rights reserved.</p>
          <div class="flex items-center gap-6 text-xs" style="color: var(--dim);">
            <a href="/privacy-policy" class="hover:underline">Privacy</a>
            <a href="/terms-of-service" class="hover:underline">Terms</a>
          </div>
        </div>
      </div>
    </footer>

  </div>

</Layout>
