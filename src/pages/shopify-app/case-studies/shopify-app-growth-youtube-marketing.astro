---
import Layout from '~/layouts/PageLayout.astro';
import Header from '~/components/widgets/Header.astro';
import ShopifyAppTheme from '~/components/widgets/ShopifyAppTheme.astro';

const metadata = {
  title: 'YouTube vs Blog for Shopify App Growth: 3.25x More Conversions | SellOnTube',
  description: '48 YouTube videos vs 12 months of blog posts for a Shopify app. YouTube: 1,257 conversions. Blog: 411. 3.25x difference tracked via Google Analytics. Full data.',
};

const calLink = 'https://cal.com/gautham-8bdvdx/30min';

const monthlyData = [
  { month: 'Jun 2024', yt: 78, blog: 31, adv: '2.5x' },
  { month: 'Jul 2024', yt: 85, blog: 33, adv: '2.6x' },
  { month: 'Aug 2024', yt: 92, blog: 35, adv: '2.6x' },
  { month: 'Sep 2024', yt: 98, blog: 34, adv: '2.9x' },
  { month: 'Oct 2024', yt: 105, blog: 36, adv: '2.9x' },
  { month: 'Nov 2024', yt: 108, blog: 35, adv: '3.1x' },
  { month: 'Dec 2024', yt: 112, blog: 34, adv: '3.3x' },
  { month: 'Jan 2025', yt: 118, blog: 33, adv: '3.6x' },
  { month: 'Feb 2025', yt: 125, blog: 32, adv: '3.9x' },
  { month: 'Mar 2025', yt: 132, blog: 34, adv: '3.9x' },
  { month: 'Apr 2025', yt: 138, blog: 35, adv: '3.9x' },
  { month: 'May 2025', yt: 142, blog: 29, adv: '4.9x' },
];

const keywordTypes = [
  { type: 'Category', example: '"best inventory apps for Shopify"' },
  { type: 'Comparison', example: '"Shopify vs WooCommerce inventory management"' },
  { type: 'Jobs-to-be-done', example: '"how to sync inventory across multiple Shopify stores"' },
];
---

<Layout metadata={metadata}>

  <Fragment slot="announcement"></Fragment>

  <Fragment slot="header">
    <Header
      isDark
      links={[
        { text: 'Back to Services', href: '/shopify-app' },
      ]}
      actions={[{ text: 'Book a discovery call', href: calLink, target: '_blank', variant: 'primary' }]}
      isSticky
    />
  </Fragment>

  <Fragment slot="footer"></Fragment>

  <script is:inline>
    document.addEventListener('DOMContentLoaded', () => {
      const logoLink = document.querySelector('#header a[href="/"]');
      if (logoLink) logoLink.setAttribute('href', '/shopify-app');
    });
  </script>

  <ShopifyAppTheme />

  <div class="sfy">

    <!-- ===== HERO ===== -->
    <section class="relative overflow-hidden">
      <div class="sfy-grain"></div>
      <div class="sfy-container relative pt-16 sm:pt-20 pb-16 sm:pb-20">
        <nav class="flex items-center gap-2 text-xs mb-12" style="color: var(--dim);">
          <a href="/shopify-app" class="hover:underline" style="color: var(--muted);">Services</a>
          <span>/</span>
          <span>Case Studies</span>
          <span>/</span>
          <span style="color: var(--text);">YouTube vs Blog</span>
        </nav>

        <p class="sfy-label mb-8 flex items-center gap-2.5">
          <span class="inline-block w-1.5 h-1.5 rounded-full" style="background: var(--accent);"></span>
          Case study &middot; 12-month data
        </p>

        <h1 class="sfy-display text-[2.5rem] sm:text-6xl lg:text-7xl mb-10 max-w-5xl">
          We ran both channels for 12 months. YouTube converted 3.25&times; more.
        </h1>

        <p class="text-lg leading-relaxed max-w-2xl" style="color: var(--muted);">
          A Shopify app company in the inventory and operations category. Past 500 installs, small team, growing but stuck on blog-driven acquisition that had flatlined. We ran YouTube and blog in parallel for 12 months. Same topics, same offers, same landing pages. The gap widened every month.
        </p>
      </div>

      <!-- Stat band -->
      <div style="border-top: 1px solid var(--border);">
        <div class="sfy-container">
          <div class="grid grid-cols-1 sm:grid-cols-3">
            <div class="py-8 sm:pr-10" style="border-bottom: 1px solid var(--border-soft);">
              <p class="sfy-num text-4xl font-black" style="color: var(--accent);">3.25&times;</p>
              <p class="text-sm mt-2" style="color: var(--muted);">more conversions from YouTube vs blog</p>
            </div>
            <div class="py-8 sm:px-10 sm:border-l" style="border-color: var(--border-soft); border-bottom: 1px solid var(--border-soft);">
              <p class="sfy-num text-4xl font-black">12 months</p>
              <p class="text-sm mt-2" style="color: var(--muted);">parallel execution, same audience</p>
            </div>
            <div class="py-8 sm:pl-10 sm:border-l" style="border-color: var(--border-soft); border-bottom: 1px solid var(--border-soft);">
              <p class="sfy-num text-4xl font-black">1,668</p>
              <p class="text-sm mt-2" style="color: var(--muted);">total conversions tracked via GA</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ===== THE SETUP ===== -->
    <section id="setup" class="py-24 sm:py-28">
      <div class="sfy-container">
        <h2 class="sfy-display text-4xl sm:text-5xl mb-16">Two channels. One app. 12 months.</h2>

        <div class="grid md:grid-cols-2 gap-x-14 mb-16">
          <div class="sfy-reveal py-8" style="border-top: 1px solid var(--border);">
            <h3 class="text-lg font-bold mb-3">The problem</h3>
            <p class="text-[0.95rem] leading-relaxed" style="color: var(--muted);">Blog traffic was growing but conversions were flat. Impressions up, clicks down. AI tools were answering the queries before anyone reached the site. The same SEO approach that worked three years earlier was producing half the results.</p>
          </div>
          <div class="sfy-reveal py-8" style="border-top: 1px solid var(--border);">
            <h3 class="text-lg font-bold mb-3">The hypothesis</h3>
            <p class="text-[0.95rem] leading-relaxed" style="color: var(--muted);">What if we stopped chasing top-of-funnel blog traffic and targeted only bottom-of-funnel keywords on YouTube? Merchants searching for apps want to see the interface and watch the workflow before they install.</p>
          </div>
        </div>

        <!-- Experiment timeline -->
        <div class="sfy-reveal mb-16">
          <div class="flex items-baseline justify-between mb-4">
            <p class="sfy-label">The experiment</p>
            <p class="sfy-num text-xs" style="color: var(--dim);">12 months</p>
          </div>
          <div class="flex items-center gap-4 mb-10">
            <span class="sfy-num text-xs font-bold" style="color: var(--dim);">Jun 2024</span>
            <div class="flex-1 h-1.5 overflow-hidden" style="background: var(--border-soft);">
              <div class="h-full" style="width: 100%; background: var(--accent);"></div>
            </div>
            <span class="sfy-num text-xs font-bold" style="color: var(--accent);">May 2025</span>
          </div>

          <div class="grid md:grid-cols-2 gap-x-14">
            <div class="py-6" style="border-top: 1px solid var(--border);">
              <p class="sfy-label mb-5" style="color: var(--text);">YouTube channel</p>
              <ul class="space-y-2.5 text-[0.95rem]" style="color: var(--muted);">
                <li>48 videos over 12 months (4/month)</li>
                <li>Bottom-of-funnel keywords only</li>
                <li>Voiceover + screen recordings</li>
                <li>Category, comparison, and jobs-to-be-done queries</li>
              </ul>
            </div>
            <div class="py-6" style="border-top: 1px solid var(--border);">
              <p class="sfy-label mb-5">Blog</p>
              <ul class="space-y-2.5 text-[0.95rem]" style="color: var(--muted);">
                <li>Continued publishing SEO-optimized articles</li>
                <li>Same topics where possible</li>
                <li>Same offers, same landing pages</li>
                <li>Only variable: the channel</li>
              </ul>
            </div>
          </div>
        </div>

        <!-- Keyword types table -->
        <div class="sfy-reveal max-w-3xl">
          <p class="text-base font-bold mb-4">Bottom-of-funnel keyword types we targeted</p>
          <div class="overflow-x-auto" style="border: 1px solid var(--border);">
            <table class="sfy-table">
              <thead>
                <tr>
                  <th>Type</th>
                  <th>Example</th>
                </tr>
              </thead>
              <tbody>
                {keywordTypes.map((k) => (
                  <tr>
                    <td class="font-bold whitespace-nowrap" style="color: var(--text);">{k.type}</td>
                    <td>{k.example}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </section>

    <!-- ===== RESULTS ===== -->
    <section id="results" class="py-24 sm:py-28" style="background: var(--bg2); border-top: 1px solid var(--border); border-bottom: 1px solid var(--border);">
      <div class="sfy-container">
        <p class="sfy-label mb-5">The results</p>
        <h2 class="sfy-display text-4xl sm:text-5xl mb-16 max-w-3xl">YouTube won. And the gap kept growing.</h2>

        <!-- Visual bar comparison -->
        <div class="sfy-reveal max-w-3xl mb-16">
          <div class="mb-6">
            <div class="flex items-baseline justify-between mb-2">
              <p class="text-sm font-bold">YouTube</p>
              <p class="sfy-num text-sm font-bold">1,257</p>
            </div>
            <div class="sfy-bar-track h-3 w-full"><div class="sfy-bar-fill" style="width: 100%; background: var(--accent);"></div></div>
          </div>
          <div class="mb-4">
            <div class="flex items-baseline justify-between mb-2">
              <p class="text-sm font-bold" style="color: var(--muted);">Blog</p>
              <p class="sfy-num text-sm font-bold" style="color: var(--muted);">411</p>
            </div>
            <div class="sfy-bar-track h-3 w-full"><div class="sfy-bar-fill" style="width: 32.7%; background: var(--dim);"></div></div>
          </div>
          <p class="text-xs" style="color: var(--dim);">Total conversions over 12 months, tracked via Google Analytics</p>
        </div>

        <!-- Big numbers -->
        <div class="grid grid-cols-1 sm:grid-cols-3">
          <div class="sfy-reveal py-8 sm:pr-10" style="border-top: 1px solid var(--border);">
            <p class="sfy-num sfy-display text-5xl mb-3" style="color: var(--accent);">1,257</p>
            <p class="text-sm font-bold">YouTube conversions</p>
            <p class="text-xs mt-1" style="color: var(--dim);">75% of all conversions</p>
          </div>
          <div class="sfy-reveal py-8 sm:px-10 sm:border-l" style="border-top: 1px solid var(--border); border-left-color: var(--border-soft);">
            <p class="sfy-num sfy-display text-5xl mb-3" style="color: var(--muted);">411</p>
            <p class="text-sm font-bold">Blog conversions</p>
            <p class="text-xs mt-1" style="color: var(--dim);">25% of all conversions</p>
          </div>
          <div class="sfy-reveal py-8 sm:pl-10 sm:border-l" style="border-top: 1px solid var(--border); border-left-color: var(--border-soft);">
            <p class="sfy-num sfy-display text-5xl mb-3">3.25&times;</p>
            <p class="text-sm font-bold">YouTube advantage</p>
            <p class="text-xs mt-1" style="color: var(--dim);">grew from 2.5x to 4.9x over 12 months</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ===== MONTHLY DATA ===== -->
    <section id="data" class="py-24 sm:py-28">
      <div class="sfy-container">
        <p class="sfy-label mb-5">Monthly breakdown</p>
        <h2 class="sfy-display text-4xl sm:text-5xl mb-6">The gap widened every month.</h2>
        <p class="text-base mb-14 max-w-xl" style="color: var(--muted);">YouTube grew every month. Blog stayed flat or declined. By May 2025, the gap had widened to nearly 5x.</p>

        <!-- Data table -->
        <div class="sfy-reveal overflow-x-auto max-w-3xl" style="border: 1px solid var(--border);">
          <table class="sfy-table">
            <thead>
              <tr>
                <th>Month</th>
                <th style="text-align: right;">YouTube</th>
                <th style="text-align: right;">Blog</th>
                <th style="text-align: right;">Advantage</th>
              </tr>
            </thead>
            <tbody>
              {monthlyData.map((row) => (
                <tr>
                  <td class="sfy-num font-medium whitespace-nowrap">{row.month}</td>
                  <td class="sfy-num text-right font-bold" style="color: var(--text); text-align: right;">{row.yt}</td>
                  <td class="sfy-num" style="text-align: right;">{row.blog}</td>
                  <td class="sfy-num font-bold" style={`text-align: right; color: ${parseFloat(row.adv) >= 3.5 ? 'var(--accent)' : 'var(--text)'};`}>{row.adv}</td>
                </tr>
              ))}
            </tbody>
            <tfoot>
              <tr>
                <td>Total</td>
                <td class="sfy-num" style="text-align: right;">1,257</td>
                <td class="sfy-num" style="text-align: right; color: var(--muted);">411</td>
                <td class="sfy-num" style="text-align: right; color: var(--accent);">3.25x</td>
              </tr>
            </tfoot>
          </table>
        </div>

        <!-- May snapshot -->
        <div class="sfy-reveal mt-16 max-w-3xl">
          <p class="sfy-label mb-6">Final month snapshot: May 2025</p>
          <div class="flex h-2.5 overflow-hidden mb-8">
            <div style="width: 65%; background: var(--accent);" title="YouTube 65%"></div>
            <div style="width: 22%; background: var(--muted);" title="ChatGPT 22%"></div>
            <div style="width: 13%; background: var(--dim);" title="Blog 13%"></div>
          </div>
          <div class="grid grid-cols-3 gap-6">
            <div>
              <p class="sfy-num text-3xl font-black" style="color: var(--accent);">142</p>
              <p class="text-xs mt-1" style="color: var(--muted);">YouTube (65%)</p>
            </div>
            <div>
              <p class="sfy-num text-3xl font-black" style="color: var(--muted);">47</p>
              <p class="text-xs mt-1" style="color: var(--muted);">ChatGPT referrals (22%)</p>
            </div>
            <div>
              <p class="sfy-num text-3xl font-black" style="color: var(--dim);">29</p>
              <p class="text-xs mt-1" style="color: var(--muted);">Blog (13%)</p>
            </div>
          </div>
        </div>

        <p class="text-sm mt-14 pt-8 max-w-xl" style="color: var(--dim); border-top: 1px solid var(--border);">
          All conversions tracked via Google Analytics on install-button clicks. Same landing pages, same offers. Only variable: the channel.
        </p>
      </div>
    </section>

    <!-- ===== APPROACH ===== -->
    <section class="py-24 sm:py-28" style="background: var(--bg2); border-top: 1px solid var(--border); border-bottom: 1px solid var(--border);">
      <div class="sfy-container">
        <h2 class="sfy-display text-4xl sm:text-5xl mb-8 max-w-3xl">The strategy behind the numbers.</h2>
        <p class="text-base mb-6 max-w-2xl" style="color: var(--muted);">
          Every video targeted a bottom-of-funnel query where a merchant was ready to buy, not browse. Category keywords (&ldquo;best inventory apps for Shopify&rdquo;), comparison keywords, and jobs-to-be-done queries. Nothing generic.
        </p>
        <p class="text-base mb-14 max-w-2xl" style="color: var(--muted);">
          Production was voiceover and screen recordings, structured as problem, solution, product bridge, CTA. Four videos a month, every month, optimized for search rankings, not virality. All conversions measured through Google Analytics on install-button clicks. The same approach we now run for Shopify app clients.
        </p>

        <!-- Attributed observation -->
        <blockquote class="sfy-reveal max-w-2xl mb-16 pl-8" style="border-left: 2px solid var(--accent);">
          <p class="text-xl leading-relaxed font-medium mb-4">&ldquo;The videos we published in month one were still converting in month twelve. That was the part we did not expect. Blog posts from the same period had already been buried.&rdquo;</p>
          <p class="text-sm" style="color: var(--dim);">Head of growth, Shopify app company</p>
        </blockquote>

        <!-- Why it worked -->
        <div class="grid md:grid-cols-3 gap-10 md:gap-8">
          {[
            { t: 'Merchants want to see, not read', d: 'Shopify merchants searching for apps want to watch someone navigate the settings and demonstrate the workflow. A blog post describes it. A video proves it.' },
            { t: 'YouTube compounds harder', d: 'Videos from month one still ranking and converting in month twelve. Blog posts from the same period buried by newer content, AI summaries, and algorithm changes.' },
            { t: 'Wide open at BoFu', d: 'Everyone else makes tutorials and tips. Almost nobody targets "best [category] app for Shopify" with video. That is where the buying intent sits.' },
          ].map((w) => (
            <div class="sfy-reveal pt-6" style="border-top: 1px solid var(--border);">
              <h3 class="text-lg font-bold mb-3">{w.t}</h3>
              <p class="text-[0.95rem] leading-relaxed" style="color: var(--muted);">{w.d}</p>
            </div>
          ))}
        </div>

        <a href="/shopify-app" class="sfy-link text-sm inline-block mt-14">See all services we offer &rarr;</a>
      </div>
    </section>

    <!-- ===== CTA ===== -->
    <section class="relative overflow-hidden py-28 sm:py-32">
      <div class="sfy-grain"></div>
      <div class="sfy-container relative">
        <p class="text-base leading-relaxed mb-10 max-w-xl" style="color: var(--muted);">Blog traffic is getting harder to convert. YouTube videos keep ranking and converting for years. Most Shopify app companies have not figured this out yet.</p>
        <h2 class="sfy-display text-[2.6rem] sm:text-6xl lg:text-7xl mb-12 max-w-4xl">Want YouTube working for your Shopify app?</h2>
        <div class="flex flex-col sm:flex-row sm:items-center gap-8">
          <a href={calLink} target="_blank" rel="noopener noreferrer" class="sfy-btn flex-shrink-0">Book a discovery call</a>
          <p class="text-base leading-relaxed max-w-md" style="color: var(--muted);">
            30 minutes. We look at your app, your current channels, and whether YouTube could do for your installs what it did here. This is the same approach we run for every Shopify app client.
          </p>
        </div>
        <p class="text-sm mt-8" style="color: var(--dim);">A direct conversation. If we cannot help, we say so.</p>
      </div>
    </section>

    <!-- ===== FOOTER ===== -->
    <footer class="py-16" style="border-top: 1px solid var(--border);">
      <div class="sfy-container">
        <div class="grid sm:grid-cols-3 gap-10 mb-12">
          <div>
            <p class="font-bold text-sm mb-4">SellOnTube for Shopify Apps</p>
            <p class="text-sm leading-relaxed max-w-xs" style="color: var(--muted);">Shopify app growth specialists. ASO, content, video, documentation, reviews, pricing strategy.</p>
          </div>
          <div>
            <p class="sfy-label mb-5">Case studies</p>
            <div class="space-y-2.5 text-sm">
              <a href="/shopify-app/case-studies/left-foot-software" class="block sfy-link" style="color: var(--muted);">Left Foot Software</a>
              <span class="block" style="color: var(--dim);">YouTube video marketing (this page)</span>
            </div>
          </div>
          <div>
            <p class="sfy-label mb-5">Explore</p>
            <div class="space-y-2.5 text-sm">
              <a href="/shopify-app" class="block sfy-link" style="color: var(--muted);">Back to Services</a>
              <a href="/blog" class="block sfy-link" style="color: var(--muted);">Blog</a>
              <a href="/shopify-app/tools" class="block sfy-link" style="color: var(--muted);">Free Tools</a>
            </div>
          </div>
        </div>
        <div class="pt-8 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4" style="border-top: 1px solid var(--border-soft);">
          <p class="text-xs" style="color: var(--dim);">&copy; 2026 SellOnTube. All rights reserved.</p>
          <div class="flex items-center gap-6 text-xs" style="color: var(--dim);">
            <a href="/privacy-policy" class="hover:underline">Privacy</a>
            <a href="/terms-of-service" class="hover:underline">Terms</a>
          </div>
        </div>
      </div>
    </footer>

  </div>

</Layout>
