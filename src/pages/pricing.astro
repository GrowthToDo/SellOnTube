      <!-- Countdown Timer (Scale tier rate increase) -->
      <div class="mt-4 max-w-lg mx-auto p-4 rounded-lg bg-gradient-to-r from-orange-50 to-red-50 dark:from-orange-900/20 dark:to-red-900/20 border border-orange-200 dark:border-orange-800">
