---
import Layout from '~/layouts/PageLayout.astro';

import Hero from '~/components/widgets/Hero.astro';
import Features from '~/components/widgets/Features.astro';
import Content from '~/components/widgets/Content.astro';
import Steps from '~/components/widgets/Steps.astro';
import FAQs from '~/components/widgets/FAQs.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import Note from '~/components/widgets/Note.astro';
import Image from '~/components/common/Image.astro';
import { SITE } from 'astrowind:config';

import ecommerceCheckout from '~/assets/images/ecommerce-checkout.jpg';
import personSearchingLaptop from '~/assets/images/person-searching-laptop.jpg';
import dataAnalysisCharts from '~/assets/images/data-analysis-charts.jpg';
import growthAnalyticsDashboard from '~/assets/images/growth-analytics-dashboard.jpg';

const metadata = {
  title: 'YouTube Marketing for Shopify Apps',
  description: 'Turn YouTube into a bottom-of-funnel acquisition channel for your Shopify app. Capture high-intent search demand and convert it into installs.',
  openGraph: {
    type: 'website',
    images: [{ url: '~/assets/images/default.png', width: 1200, height: 628 }],
  },
};

const calLink = 'https://cal.com/gautham-8bdvdx/30min';

const siteUrl = SITE.site || 'https://sellontube.com';

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": siteUrl },
    { "@type": "ListItem", "position": 2, "name": "YouTube for Shopify", "item": `${siteUrl}/youtube-for/shopify` }
  ]
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Is YouTube really bottom-of-funnel?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes, when built around search intent, not subscribers or trends."
      }
    },
    {
      "@type": "Question",
      "name": "How long until results?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Early traction can appear in weeks. Compounding impact builds over months."
      }
    },
    {
      "@type": "Question",
      "name": "We tried content before. Why is this different?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Most content fails because it's not tied to buying-intent queries."
      }
    },
    {
      "@type": "Question",
      "name": "Is our niche too small?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Smaller niches often convert better due to lower competition."
      }
    },
    {
      "@type": "Question",
      "name": "Do you handle everything?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "We handle strategy, research, and video creation. You provide product context and approvals."
      }
    },
    {
      "@type": "Question",
      "name": "Is this a replacement for ads?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "No. It's a complementary acquisition layer that reduces long-term dependency."
      }
    },
    {
      "@type": "Question",
      "name": "Do we need anyone on camera?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "No. All videos are faceless: screen recordings of the app and store with voiceover narration. Merchants want to see the product working, not a presenter."
      }
    },
    {
      "@type": "Question",
      "name": "How many videos do we publish per month?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Four. That cadence builds a library of roughly 48 search-targeted videos in year one, each aimed at a different buying-intent query."
      }
    },
    {
      "@type": "Question",
      "name": "How do we attribute installs to YouTube?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "UTM-tagged links in every description, app listing traffic trends, and \"how did you hear about us\" responses. Attribution is directional, but the trend is hard to miss once videos rank."
      }
    }
  ]
};
---

<Layout metadata={metadata}>
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  <!-- Hero Section -->
  <Hero
    actions={[
      {
        variant: 'primary',
        text: 'Book a 30-min Shopify App Growth Call',
        href: calLink,
        target: '_blank',
        rel: 'noopener noreferrer',
      },
      {
        text: 'See How It Works',
        href: '#system',
      },
    ]}
    image={{
      src: ecommerceCheckout,
      alt: 'E-commerce customer acquisition through YouTube search intent targeting',
    }}
  >
    <Fragment slot="title">
      Turn YouTube into a <span class="text-accent">bottom-of-funnel</span> acquisition channel for your Shopify app
    </Fragment>
    <Fragment slot="subtitle">
      <span class="block mb-1 font-semibold text-primary">For Shopify App Companies</span>
      We capture high-intent search demand on YouTube and convert it into app installs, demos, and qualified signups.
    </Fragment>
  </Hero>

  <!-- Philosophy Note -->
  <Note
    title="Our Approach:"
    description="Search-driven acquisition. Not content marketing. Not brand awareness. Demand capture."
  />

  <!-- Who This Is For (and Not For) -->
  <section class="py-16 md:py-20">
    <div class="max-w-6xl mx-auto px-4 sm:px-6">
      <div class="text-center mb-12">
        <p class="text-sm font-semibold uppercase tracking-wider text-primary mb-2">Fit Check</p>
        <h2 class="text-3xl md:text-4xl font-bold">Who This Is For (and Not For)</h2>
      </div>

      <div class="grid md:grid-cols-2 gap-6 lg:gap-8">
        <!-- This is for you if -->
        <div class="relative rounded-2xl border-2 border-green-500/30 bg-gradient-to-br from-green-50 to-emerald-50 dark:from-green-900/20 dark:to-emerald-900/20 p-8 shadow-lg">
          <div class="absolute -top-4 left-6">
            <span class="inline-flex items-center gap-2 bg-green-500 text-white text-sm font-semibold px-4 py-1.5 rounded-full shadow-md">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
              Good Fit
            </span>
          </div>
          <h3 class="text-xl font-bold text-green-800 dark:text-green-400 mb-6 mt-2">This is for you if:</h3>
          <ul class="space-y-4">
            <li class="flex gap-4 items-start">
              <span class="flex-shrink-0 w-6 h-6 rounded-full bg-green-500/20 flex items-center justify-center mt-0.5">
                <svg class="w-3.5 h-3.5 text-green-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path></svg>
              </span>
              <span class="text-gray-700 dark:text-slate-300">You run a <strong class="text-gray-900 dark:text-white">Shopify app</strong> doing ~$10k to $100k+ MRR</span>
            </li>
            <li class="flex gap-4 items-start">
              <span class="flex-shrink-0 w-6 h-6 rounded-full bg-green-500/20 flex items-center justify-center mt-0.5">
                <svg class="w-3.5 h-3.5 text-green-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path></svg>
              </span>
              <span class="text-gray-700 dark:text-slate-300">Paid ads work, but <strong class="text-gray-900 dark:text-white">CAC keeps rising</strong></span>
            </li>
            <li class="flex gap-4 items-start">
              <span class="flex-shrink-0 w-6 h-6 rounded-full bg-green-500/20 flex items-center justify-center mt-0.5">
                <svg class="w-3.5 h-3.5 text-green-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path></svg>
              </span>
              <span class="text-gray-700 dark:text-slate-300">Installs drop the moment ad spend pauses</span>
            </li>
            <li class="flex gap-4 items-start">
              <span class="flex-shrink-0 w-6 h-6 rounded-full bg-green-500/20 flex items-center justify-center mt-0.5">
                <svg class="w-3.5 h-3.5 text-green-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path></svg>
              </span>
              <span class="text-gray-700 dark:text-slate-300">You want a <strong class="text-gray-900 dark:text-white">compounding acquisition channel</strong>, not another experiment</span>
            </li>
          </ul>
        </div>

        <!-- This is not for -->
        <div class="relative rounded-2xl border-2 border-red-500/30 bg-gradient-to-br from-red-50 to-rose-50 dark:from-red-900/20 dark:to-rose-900/20 p-8 shadow-lg">
          <div class="absolute -top-4 left-6">
            <span class="inline-flex items-center gap-2 bg-red-500 text-white text-sm font-semibold px-4 py-1.5 rounded-full shadow-md">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
              Not a Fit
            </span>
          </div>
          <h3 class="text-xl font-bold text-red-800 dark:text-red-400 mb-6 mt-2">This is <em>not</em> for:</h3>
          <ul class="space-y-4">
            <li class="flex gap-4 items-start">
              <span class="flex-shrink-0 w-6 h-6 rounded-full bg-red-500/20 flex items-center justify-center mt-0.5">
                <svg class="w-3.5 h-3.5 text-red-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd"></path></svg>
              </span>
              <span class="text-gray-700 dark:text-slate-300">DTC brands selling physical products</span>
            </li>
            <li class="flex gap-4 items-start">
              <span class="flex-shrink-0 w-6 h-6 rounded-full bg-red-500/20 flex items-center justify-center mt-0.5">
                <svg class="w-3.5 h-3.5 text-red-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd"></path></svg>
              </span>
              <span class="text-gray-700 dark:text-slate-300">Creator-led or influencer-first strategies</span>
            </li>
            <li class="flex gap-4 items-start">
              <span class="flex-shrink-0 w-6 h-6 rounded-full bg-red-500/20 flex items-center justify-center mt-0.5">
                <svg class="w-3.5 h-3.5 text-red-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd"></path></svg>
              </span>
              <span class="text-gray-700 dark:text-slate-300">Teams looking for "brand awareness" videos</span>
            </li>
            <li class="flex gap-4 items-start">
              <span class="flex-shrink-0 w-6 h-6 rounded-full bg-red-500/20 flex items-center justify-center mt-0.5">
                <svg class="w-3.5 h-3.5 text-red-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd"></path></svg>
              </span>
              <span class="text-gray-700 dark:text-slate-300">One-off video projects without long-term intent</span>
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Case Study Section -->
  <section class="py-16 md:py-20 bg-gradient-to-b from-slate-900 to-slate-800">
    <div class="max-w-6xl mx-auto px-4 sm:px-6">
      <div class="text-center mb-10">
        <p class="text-sm font-semibold uppercase tracking-wider text-primary mb-2">Real Results</p>
        <h2 class="text-3xl md:text-4xl font-bold text-white">A 12-Month Shopify App Experiment</h2>
        <p class="text-xl text-slate-300 mt-4 max-w-3xl mx-auto">We ran YouTube and blog content in parallel for a Shopify app. Here's what happened.</p>
      </div>

      <div class="grid md:grid-cols-2 gap-8 mb-10">
        <!-- Key Result Card -->
        <div class="bg-gradient-to-br from-primary/20 to-primary/5 rounded-2xl p-8 border border-primary/30">
          <div class="text-center">
            <p class="text-6xl md:text-7xl font-bold text-white mb-2">3.25x</p>
            <p class="text-xl text-slate-300">More conversions from YouTube vs Blog</p>
          </div>
        </div>

        <!-- Stats Card -->
        <div class="bg-white/5 rounded-2xl p-8 border border-slate-700">
          <h3 class="text-xl font-bold text-white mb-6">12-Month Results</h3>
          <div class="space-y-4">
            <div class="flex justify-between items-center">
              <span class="text-slate-300">YouTube Conversions</span>
              <span class="text-2xl font-bold text-green-400">1,257</span>
            </div>
            <div class="h-px bg-slate-700"></div>
            <div class="flex justify-between items-center">
              <span class="text-slate-300">Blog Conversions</span>
              <span class="text-2xl font-bold text-slate-400">411</span>
            </div>
            <div class="h-px bg-slate-700"></div>
            <div class="flex justify-between items-center">
              <span class="text-slate-300">Total Conversions</span>
              <span class="text-2xl font-bold text-white">1,668</span>
            </div>
          </div>
        </div>
      </div>

      <!-- Key Insights -->
      <div class="grid sm:grid-cols-3 gap-6 mb-10">
        <div class="bg-white/5 rounded-xl p-6 border border-slate-700 text-center">
          <div class="w-12 h-12 rounded-full bg-green-500/20 flex items-center justify-center mx-auto mb-4">
            <svg class="w-6 h-6 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"></path></svg>
          </div>
          <p class="text-white font-semibold mb-2">YouTube grew every month</p>
          <p class="text-slate-400 text-sm">Conversions increased consistently over 12 months</p>
        </div>
        <div class="bg-white/5 rounded-xl p-6 border border-slate-700 text-center">
          <div class="w-12 h-12 rounded-full bg-amber-500/20 flex items-center justify-center mx-auto mb-4">
            <svg class="w-6 h-6 text-amber-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 12H4"></path></svg>
          </div>
          <p class="text-white font-semibold mb-2">Blog stayed flat</p>
          <p class="text-slate-400 text-sm">Traffic decayed as AI and algorithm changes hit</p>
        </div>
        <div class="bg-white/5 rounded-xl p-6 border border-slate-700 text-center">
          <div class="w-12 h-12 rounded-full bg-primary/20 flex items-center justify-center mx-auto mb-4">
            <svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
          </div>
          <p class="text-white font-semibold mb-2">BoFu keywords won</p>
          <p class="text-slate-400 text-sm">High-intent search queries drove real conversions</p>
        </div>
      </div>

      <!-- Quote -->
      <div class="bg-white/5 rounded-2xl p-8 border border-slate-700 mb-8">
        <blockquote class="text-xl md:text-2xl text-white text-center italic mb-6">
          "By the final month, YouTube was converting at nearly 5x the rate of our blog. The compounding effect is real."
        </blockquote>
        <p class="text-center text-slate-400">- Satya, who ran this experiment as Head of Marketing</p>
      </div>

      <!-- CTA to full case study -->
      <div class="text-center">
        <a
          href="/blog/youtube-vs-blog-shopify-app-case-study"
          class="inline-flex items-center justify-center gap-2 rounded-full px-6 py-3 font-semibold
                 bg-white/10 text-white hover:bg-white/20 border border-white/20
                 transition-all hover:scale-105"
        >
          Read the Full Case Study
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- The Real Problem Section -->
  <section class="py-16 md:py-20 bg-gradient-to-b from-slate-50 to-white dark:from-slate-900 dark:to-slate-800">
    <div class="max-w-6xl mx-auto px-4 sm:px-6">
      <div class="text-center mb-10">
        <p class="text-sm font-semibold uppercase tracking-wider text-primary mb-2">The Real Problem</p>
        <h2 class="text-3xl md:text-4xl font-bold">It's Not Your Product</h2>
      </div>

      <div class="grid md:grid-cols-2 gap-8 items-center">
        <div class="bg-white dark:bg-slate-800 rounded-2xl shadow-xl p-8 md:p-10 border border-slate-200 dark:border-slate-700">
          <div class="prose prose-lg dark:prose-invert max-w-none">
            <p class="text-xl leading-relaxed">Most Shopify apps don't have a product problem.</p>
            <p class="text-xl leading-relaxed">They have a <span class="font-bold text-primary">discovery problem</span>.</p>

            <div class="my-6 pl-6 border-l-4 border-primary/50 bg-primary/5 py-4 pr-4 rounded-r-lg">
              <p class="text-lg italic text-muted mb-0">Merchants don't wake up wanting <em>your</em> app.<br/>They wake up wanting to solve a problem.</p>
            </div>

            <p class="font-medium text-lg mb-3">They search:</p>
            <div class="space-y-2 mb-6">
              <div class="bg-slate-100 dark:bg-slate-700 rounded-lg px-4 py-2">
                <code class="text-sm">"Best [category] app for Shopify"</code>
              </div>
              <div class="bg-slate-100 dark:bg-slate-700 rounded-lg px-4 py-2">
                <code class="text-sm">"How to fix [problem] on Shopify"</code>
              </div>
              <div class="bg-slate-100 dark:bg-slate-700 rounded-lg px-4 py-2">
                <code class="text-sm">"[Tool A] vs [Tool B]"</code>
              </div>
            </div>

            <div class="bg-amber-50 dark:bg-amber-900/30 border border-amber-200 dark:border-amber-700 rounded-xl p-4">
              <p class="font-semibold text-amber-900 dark:text-amber-100 mb-0">
                If your app doesn't show up during this research phase, you lose the install, even if your product is better.
              </p>
              <p class="text-sm text-amber-800 dark:text-amber-200 mt-2 mb-0">
                <a href="/blog/youtube-views-but-no-leads" class="underline hover:no-underline">Getting views without installs</a> is the exact symptom of this gap.
              </p>
            </div>
          </div>
        </div>

        <div class="hidden md:block">
          <Image
            src={personSearchingLaptop}
            alt="Shopify merchant researching app solutions on a laptop"
            class="rounded-2xl shadow-xl w-full h-auto object-cover"
            widths={[400, 768, 1024]}
            sizes="(max-width: 768px) 100vw, 50vw"
            loading="lazy"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- Why YouTube Works Section -->
  <section class="py-16 md:py-20">
    <div class="max-w-5xl mx-auto px-4 sm:px-6">
      <div class="text-center mb-12">
        <p class="text-sm font-semibold uppercase tracking-wider text-primary mb-2">The Opportunity</p>
        <h2 class="text-3xl md:text-4xl font-bold">Why YouTube (When Done Right) Works for Shopify Apps</h2>
      </div>

      <div class="bg-slate-900 rounded-2xl shadow-2xl p-8 md:p-12 text-white mb-10">
        <p class="text-3xl md:text-4xl font-bold mb-6 text-center">YouTube is the second-largest search engine.</p>
        <p class="text-xl md:text-2xl text-slate-300 text-center max-w-3xl mx-auto">When videos are built around <strong class="text-white">buying-intent keywords</strong>, YouTube becomes:</p>

        <div class="grid sm:grid-cols-4 gap-4 mt-10">
          <div class="bg-white rounded-xl p-6 text-center">
            <div class="text-4xl mb-3">🔍</div>
            <p class="font-bold text-lg text-slate-900">Discovery</p>
          </div>
          <div class="bg-white rounded-xl p-6 text-center">
            <div class="text-4xl mb-3">📚</div>
            <p class="font-bold text-lg text-slate-900">Education</p>
          </div>
          <div class="bg-white rounded-xl p-6 text-center">
            <div class="text-4xl mb-3">⚖️</div>
            <p class="font-bold text-lg text-slate-900">Comparison</p>
          </div>
          <div class="bg-white rounded-xl p-6 text-center">
            <div class="text-4xl mb-3">🎯</div>
            <p class="font-bold text-lg text-slate-900">Conversion</p>
          </div>
        </div>
        <p class="text-center text-slate-300 mt-8 text-xl font-medium">All in one flow.</p>
      </div>

      <div class="bg-slate-100 dark:bg-slate-800 rounded-2xl p-8 border border-slate-200 dark:border-slate-700">
        <div class="flex flex-col md:flex-row gap-8 items-center">
          <div class="flex-1">
            <p class="font-medium text-lg mb-4">Most teams fail because they treat YouTube like:</p>
            <ul class="space-y-2 text-muted">
              <li class="flex items-center gap-2">
                <span class="w-2 h-2 rounded-full bg-red-400"></span>
                Social media
              </li>
              <li class="flex items-center gap-2">
                <span class="w-2 h-2 rounded-full bg-red-400"></span>
                Influencer marketing
              </li>
              <li class="flex items-center gap-2">
