---
import Layout from '~/layouts/PageLayout.astro';
import Header from '~/components/widgets/Header.astro';
import '~/assets/styles/sfo.css';

const metadata = {
  title: 'UK Jewellery Brand Case Study: Nine Years. Still Building. | SellOnTube',
  description: 'Full case study: nine years with UK Jewellery Brand, UK watches and jewelry. 8 hours to 15 minutes with a custom image processor. Under 1% compliance error rate. £1M to £5M+.',
};

const calLink = 'https://cal.com/gautham-8bdvdx/30min';

const logged = [
  'Product price changes: who, when, from what to what',
  'Inventory updates and out-of-stock events',
  'Order modifications and fulfilment actions',
  'Discount and promotion changes',
  'Staff login and access events',
];

const results = [
  { stat: '9 yrs', t: 'active partnership', d: 'Ongoing. Not a project.', hot: true },
  { stat: '£1M+', t: 'revenue at start', d: 'Scaled to £5M+.', hot: false },
  { stat: '50+', t: 'countries', d: '5 paid, 30+ organic.', hot: true },
  { stat: '97%', t: 'time saved', d: 'Image processing: 8h to 15 min/day.', hot: false },
  { stat: 'Under 1%', t: 'compliance errors', d: 'Merchant Center disapprovals nearly eliminated.', hot: true },
  { stat: '1,000+', t: 'active SKUs', d: 'Managed across 50+ markets.', hot: false },
];
---

<Layout metadata={metadata}>

  <Fragment slot="footer"></Fragment>

  <Fragment slot="header">
    <Header
      links={[
        { text: 'Results', href: '/shopify-store#proof' },
        { text: 'What We Build', href: '/shopify-store#work' },
        { text: 'Case Studies', links: [
          { text: 'US Supplements Brand', href: '/case-studies/us-supplements-brand' },
          { text: 'UK Jewellery Brand', href: '/case-studies/luxury-jewellery-client' },
        ]},
        { text: 'Pricing', href: '/shopify-store#pricing' },
      ]}
      actions={[{ text: 'Book a discovery call', href: calLink, target: '_blank', variant: 'primary' }]}
      isSticky
    />
  </Fragment>

  <script is:inline>
    // This page is light-only. The site theme script can re-apply .dark, so keep stripping it.
    (() => {
      const strip = () => {
        if (document.documentElement.classList.contains('dark')) {
          document.documentElement.classList.remove('dark');
        }
      };
      strip();
      new MutationObserver(strip).observe(document.documentElement, { attributes: true, attributeFilter: ['class'] });
    })();
  </script>

  <div class="sfo">

    <!-- ===== HERO ===== -->
    <section class="relative overflow-hidden">
      <div class="sfo-grid-light"></div>
      <div class="sfo-container relative pt-16 sm:pt-24 pb-14 sm:pb-20">
        <nav class="flex items-center gap-2 text-sm mb-12" style="color: var(--dim);">
          <a href="/shopify-store" class="sfo-link" style="color: var(--muted);">Shopify Services</a>
          <span>/</span>
          <span>Case study</span>
        </nav>
        <h1 class="sfo-display text-[2.7rem] sm:text-6xl lg:text-[5.2rem] mb-8 max-w-5xl">
          <span class="sfo-circ">Nine years.<svg class="sfo-anno sfo-anno-load" viewBox="0 0 320 110" preserveAspectRatio="none" aria-hidden="true"><path pathLength="1" style="stroke-width: 3.2;" d="M24,60 C16,30 92,10 168,9 C256,8 307,27 305,55 C303,86 234,102 148,100 C68,98 17,83 16,58 C15,37 54,21 110,15" /></svg></span> Our longest client relationship.
        </h1>
        <div class="flex flex-col lg:flex-row lg:items-end lg:justify-between gap-10">
          <p class="text-lg leading-relaxed max-w-xl" style="color: var(--muted);">
            This is what a decade of operational partnership looks like: from &pound;1M to &pound;5M+, 8 hours of daily work automated to 15 minutes, and a compliance error rate under 1%.
          </p>
          <dl class="flex flex-wrap gap-x-12 gap-y-4 flex-shrink-0">
            <div>
              <dt class="sfo-label mb-1.5">Client</dt>
              <dd class="text-sm font-bold">UK Jewellery Brand</dd>
            </div>
            <div>
              <dt class="sfo-label mb-1.5">Industry</dt>
              <dd class="text-sm font-bold">UK watches and jewelry</dd>
            </div>
            <div>
              <dt class="sfo-label mb-1.5">Engagement</dt>
              <dd class="text-sm font-bold">9 years, active</dd>
            </div>
          </dl>
        </div>
      </div>

      <!-- Stat band -->
      <div style="border-top: 1px solid var(--border);">
        <div class="sfo-container">
          <div class="grid grid-cols-2 lg:grid-cols-4">
            <div class="py-8 lg:pr-10" style="border-bottom: 1px solid var(--border-soft);">
              <p class="sfo-num text-4xl font-black" style="color: var(--accent-deep);">9 yrs</p>
              <p class="text-sm mt-2" style="color: var(--muted);">active engagement</p>
            </div>
            <div class="py-8 pl-6 lg:px-10 border-l" style="border-color: var(--border-soft); border-bottom: 1px solid var(--border-soft);">
              <p class="sfo-num text-4xl font-black">8h &rarr; 15m</p>
              <p class="text-sm mt-2" style="color: var(--muted);">image processing time</p>
            </div>
            <div class="py-8 lg:px-10 lg:border-l" style="border-color: var(--border-soft); border-bottom: 1px solid var(--border-soft);">
              <p class="sfo-num text-4xl font-black" style="color: var(--accent-deep);">Under 1%</p>
              <p class="text-sm mt-2" style="color: var(--muted);">compliance error rate</p>
            </div>
            <div class="py-8 pl-6 lg:pl-10 border-l" style="border-color: var(--border-soft); border-bottom: 1px solid var(--border-soft);">
              <p class="sfo-num text-4xl font-black">50+</p>
              <p class="text-sm mt-2" style="color: var(--muted);">countries</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ===== THE RELATIONSHIP ===== -->
    <section class="py-20 sm:py-28">
      <div class="sfo-container">
        <div class="grid lg:grid-cols-12 gap-12 lg:gap-16 items-start">
          <div class="lg:col-span-7 sfo-reveal">
            <p class="sfo-label mb-5">The relationship</p>
            <h2 class="sfo-display text-4xl sm:text-5xl mb-8">Not a project. Not a vendor. An operational partner.</h2>
            <p class="text-[0.95rem] leading-relaxed mb-4 max-w-xl" style="color: var(--muted);">
              UK Jewellery Brand sells luxury watches and jewelry in the UK and internationally. When they first came to us they were doing around &pound;1M in annual revenue, selling on a handful of markets, and dealing with the operational friction that comes with a large, complex catalog.
            </p>
            <p class="text-[0.95rem] leading-relaxed mb-4 max-w-xl" style="color: var(--muted);">
              Nine years later, we've scaled them to &pound;5M+, expanded to 50+ countries, and built a suite of custom tools that handle compliance, image processing, staff accountability, and Google Shopping automatically.
            </p>
            <p class="text-[0.95rem] leading-relaxed max-w-xl" style="color: var(--muted);">
              The relationship works because we're embedded in how the business runs. We know the catalog, the supplier relationships, the compliance requirements, and the growth priorities. Every year we identify the next problem worth solving and build the system for it.
            </p>
          </div>
          <div class="lg:col-span-5 sfo-reveal lg:pt-24">
            <p class="sfo-label mb-7">Revenue growth over the engagement</p>
            <div class="mb-5">
              <div class="flex items-baseline justify-between mb-2">
                <p class="text-sm font-bold" style="color: var(--muted);">Start of engagement</p>
                <p class="sfo-num text-sm font-bold" style="color: var(--muted);">&pound;1M</p>
              </div>
              <div class="h-3 w-full sfo-bar-track"><div class="sfo-bar-fill" style="width: 20%; background: var(--dim);"></div></div>
            </div>
            <div class="mb-4">
              <div class="flex items-baseline justify-between mb-2">
                <p class="text-sm font-bold">Peak revenue</p>
                <p class="sfo-num text-sm font-bold" style="color: var(--accent-deep);">&pound;5M+</p>
              </div>
              <div class="h-3 w-full sfo-bar-track"><div class="sfo-bar-fill" style="width: 100%; background: var(--accent);"></div></div>
            </div>
            <p class="text-xs" style="color: var(--dim);">5&times; growth across nine years of continuous operational work.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ===== CHAPTER 1: IMAGE PROCESSOR (espresso panel) ===== -->
    <section class="sfo-panel sfo-panel-espresso relative overflow-hidden py-24 sm:py-32">
      <div class="sfo-grain"></div>
      <div class="sfo-container relative">
        <p class="sfo-label mb-5" style="color: var(--dim);">Chapter 01</p>
        <h2 class="sfo-display text-4xl sm:text-5xl lg:text-6xl mb-14 max-w-4xl">8 hours of manual work. Automated to 15 minutes.</h2>

        <div class="grid lg:grid-cols-12 gap-10 lg:gap-14 items-start">
          <div class="lg:col-span-6 sfo-reveal">
            <p class="text-[0.95rem] leading-relaxed mb-4 max-w-xl" style="color: var(--muted);">
              One team member spent 8 hours every working day on product images. Every vendor delivered images in different sizes, formats, and backgrounds. Each one had to be resized to the right dimensions, backgrounds removed, and formatted separately for Shopify listings, Google Shopping, and paid ads.
            </p>
            <p class="text-[0.95rem] leading-relaxed mb-4 max-w-xl" style="color: var(--muted);">
              That's a full-time job for one person, producing nothing that grows the business. Just keeping the catalog in a usable state.
            </p>
            <p class="text-[0.95rem] leading-relaxed max-w-xl" style="color: var(--muted);">
              We built the Product Image Processor as a custom Sidekick app inside the Shopify admin. It ingests vendor images in any format, applies the transformation pipeline, and outputs correctly sized, correctly formatted images for every channel. Automatically. The entire workflow that took 8 hours now takes 15 minutes of review.
            </p>
          </div>
          <div class="lg:col-span-6 sfo-reveal">
            <p class="sfo-num sfo-display text-8xl sm:text-9xl mb-3 inline-flex items-end gap-4" style="color: #ff9d8a;">97%<svg class="sfo-anno mb-3 flex-shrink-0" width="44" height="38" viewBox="0 0 44 38" aria-hidden="true"><path pathLength="1" style="stroke-width: 2.6;" d="M5,6 C13,9 24,18 34,31 M34,31 l-10,-2 M34,31 l0.5,-10.5" /></svg></p>
            <p class="text-sm mb-10" style="color: var(--muted);">time reduction. That team member now does work that actually matters.</p>

            <p class="sfo-label mb-6" style="color: var(--dim);">Daily image processing time</p>
            <div class="mb-5">
              <div class="flex items-baseline justify-between mb-2">
                <p class="text-sm font-bold" style="color: var(--muted);">Before</p>
                <p class="sfo-num text-sm font-bold" style="color: var(--muted);">8 hours / day</p>
              </div>
              <div class="h-3 w-full" style="background: var(--border-soft);"><div class="h-full" style="width: 100%; background: rgba(243, 240, 234, 0.45);"></div></div>
            </div>
            <div>
              <div class="flex items-baseline justify-between mb-2">
                <p class="text-sm font-bold">After our app</p>
                <p class="sfo-num text-sm font-bold" style="color: #ff9d8a;">15 minutes / day</p>
              </div>
              <div class="h-3 w-full" style="background: var(--border-soft);"><div class="h-full" style="width: 3.125%; background: var(--accent);"></div></div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ===== CHAPTER 2: GTIN SCANNER ===== -->
    <section class="py-20 sm:py-28">
      <div class="sfo-container">
        <p class="sfo-label mb-5">Chapter 02</p>
        <h2 class="sfo-display text-4xl sm:text-5xl mb-14 max-w-3xl">Merchant Center disapprovals. Nearly gone.</h2>
        <div class="grid lg:grid-cols-12 gap-12 lg:gap-16 items-center">
          <div class="lg:col-span-6 sfo-reveal">
            <p class="text-[0.95rem] leading-relaxed mb-4 max-w-xl" style="color: var(--muted);">
              With ~1,000 active SKUs across 50+ countries, Google Merchant Center product disapprovals were a constant drain. Missing GTINs, duplicate barcodes, products flagged for ingredient restrictions in specific markets. Every disapproval is a product not showing in Google Shopping: lost revenue.
            </p>
            <p class="text-[0.95rem] leading-relaxed mb-4 max-w-xl" style="color: var(--muted);">
              Fixing them manually meant someone monitoring a dashboard, identifying issues, chasing the right data, and updating records one by one. Mistakes got caught weeks after they happened, if at all.
            </p>
            <p class="text-[0.95rem] leading-relaxed max-w-xl" style="color: var(--muted);">
              The GTIN and Barcode Scanner we built runs weekly health audits automatically. It checks every SKU for missing or duplicate GTINs, flags issues before they reach Google, and generates a prioritised fix list. Compliance errors dropped to under 1%. Disapprovals are nearly gone.
            </p>
          </div>
          <div class="lg:col-span-6 sfo-reveal">
            <p class="sfo-num sfo-display text-8xl sm:text-9xl mb-4" style="color: var(--accent-deep);"><span class="sfo-circ">&lt;1%<svg class="sfo-anno sfo-anno-reveal" viewBox="0 0 320 110" preserveAspectRatio="none" aria-hidden="true"><path pathLength="1" style="stroke-width: 2.6;" d="M24,60 C16,30 92,10 168,9 C256,8 307,27 305,55 C303,86 234,102 148,100 C68,98 17,83 16,58 C15,37 54,21 110,15" /></svg></span></p>
            <p class="text-sm font-bold mb-8">compliance error rate</p>
            <div class="py-5 max-w-md" style="border-top: 1px solid var(--border);">
              <p class="font-bold text-sm mb-1" style="color: var(--muted);">Before: high error rate</p>
              <p class="text-xs" style="color: var(--dim);">Regular Merchant Center disapprovals</p>
            </div>
            <div class="py-5 max-w-md" style="border-top: 1px solid var(--border); border-bottom: 1px solid var(--border);">
              <p class="font-bold text-sm mb-1">After: under 1%</p>
              <p class="text-xs" style="color: var(--dim);">Weekly automated audits. Issues caught before Google flags them.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ===== CHAPTER 3: STAFF ACCOUNTABILITY ===== -->
    <section class="py-20 sm:py-28" style="background: var(--bg2); border-top: 1px solid var(--border); border-bottom: 1px solid var(--border);">
      <div class="sfo-container">
        <p class="sfo-label mb-5">Chapter 03</p>
        <h2 class="sfo-display text-4xl sm:text-5xl mb-14 max-w-3xl">Who changed what. Searchable.</h2>
        <div class="grid lg:grid-cols-12 gap-12 lg:gap-16 items-start">
          <div class="lg:col-span-6 sfo-reveal">
            <p class="text-[0.95rem] leading-relaxed mb-4 max-w-xl" style="color: var(--muted);">
              As teams grow and more people have access to the Shopify admin, accountability becomes a real problem. A price changes. A product goes unavailable. An order gets incorrectly fulfilled. Shopify's native logs don't give you enough.
            </p>
            <p class="text-[0.95rem] leading-relaxed mb-10 max-w-xl" style="color: var(--muted);">
              The Staff Activity Monitor captures every product change, price edit, and order action, searchable by staff member, date, and action type. When a brand calls about a pricing issue, the answer is there in seconds.
            </p>
            <p class="sfo-label mb-5">What's logged</p>
            <ul class="max-w-xl">
              {logged.map((item) => (
                <li class="py-3.5 flex items-baseline gap-4 text-sm" style="border-top: 1px solid var(--border);">
                  <span class="inline-block w-1.5 h-1.5 rounded-full flex-shrink-0 translate-y-[-2px]" style="background: var(--accent);"></span>
                  <span style="color: var(--muted);">{item}</span>
                </li>
              ))}
            </ul>
          </div>
          <div class="lg:col-span-6 sfo-reveal">
            <div class="sfo-mat" style="background: #e9e4ea;">
              <figure class="sfo-shot">
                <img src="/images/shopify-portfolio/staff-activity-logs.png" alt="Staff Activity Logs app running inside the Shopify admin" width="1600" height="1000" loading="lazy" />
              </figure>
            </div>
            <p class="text-xs leading-relaxed px-1 pt-4 max-w-md" style="color: var(--muted);">The actual app, running in production inside the client&rsquo;s Shopify admin.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ===== CHAPTER 4: ORACLE ERP ===== -->
    <section class="py-20 sm:py-28">
      <div class="sfo-container">
        <p class="sfo-label mb-5">Chapter 04</p>
        <h2 class="sfo-display text-4xl sm:text-5xl mb-14 max-w-3xl">Moving to Oracle ERP. In progress.</h2>
        <div class="grid lg:grid-cols-12 gap-12 lg:gap-16 items-start">
          <div class="lg:col-span-7 sfo-reveal">
            <p class="text-[0.95rem] leading-relaxed mb-4 max-w-xl" style="color: var(--muted);">
              UK Jewellery Brand is currently migrating to Oracle ERP. We're managing the integration: mapping product data, syncing order flows between Shopify and Oracle, and ensuring the transition doesn't interrupt live operations.
            </p>
            <p class="text-[0.95rem] leading-relaxed max-w-xl" style="color: var(--muted);">
              ERP migrations are the kind of project that breaks stores when managed badly. Products vanish from feeds. Orders fail to sync. Price data corrupts. We've been in the store long enough to know every edge case.
            </p>
          </div>
          <div class="lg:col-span-5 sfo-reveal">
            <div class="pl-6" style="border-left: 3px solid var(--accent);">
              <p class="text-sm font-bold mb-1">Currently live</p>
              <p class="text-sm leading-relaxed" style="color: var(--muted);">This engagement is active and ongoing. The Oracle ERP migration is in progress.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ===== RESULTS (ink panel) ===== -->
    <section class="sfo-panel sfo-panel-ink relative overflow-hidden py-24 sm:py-32">
      <div class="sfo-grain"></div>
      <div class="sfo-container relative">
        <p class="sfo-label mb-5" style="color: var(--dim);">Nine years of work</p>
        <h2 class="sfo-display sfo-reveal sfo-anno-host text-4xl sm:text-5xl lg:text-6xl mb-16">What it <span class="sfo-circ">adds up to.<svg class="sfo-anno sfo-anno-reveal" viewBox="0 0 200 24" preserveAspectRatio="none" aria-hidden="true" style="top: auto; height: 0.15em; bottom: -0.13em;"><path pathLength="1" style="stroke-width: 3;" d="M5,10 C60,4 135,4 195,8 M18,17 C75,11.5 145,12 188,15" /></svg></span></h2>

        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-x-10">
          {results.map((r) => (
            <div class="sfo-reveal py-7" style="border-top: 1px solid var(--border);">
              <p class="sfo-num text-4xl font-black mb-2" style={r.hot ? 'color: #ff9d8a;' : ''}>{r.stat}</p>
              <p class="text-sm font-bold mb-1">{r.t}</p>
              <p class="text-xs leading-relaxed" style="color: var(--dim);">{r.d}</p>
            </div>
          ))}
        </div>

        <div class="mt-16 pt-12 flex flex-col sm:flex-row sm:items-center gap-8" style="border-top: 1px solid var(--border);">
          <a href={calLink} target="_blank" rel="noopener noreferrer" class="sfo-btn flex-shrink-0">Book a discovery call</a>
          <p class="text-base leading-relaxed max-w-sm" style="color: var(--muted);">
            Want an operational partner like this? 30 minutes. We&rsquo;ll tell you where we&rsquo;d start.
          </p>
        </div>
      </div>
    </section>

    <!-- ===== ALSO READ ===== -->
    <section class="py-14">
      <div class="sfo-container flex flex-col sm:flex-row items-start sm:items-center justify-between gap-6">
        <div>
          <p class="sfo-label mb-2">Also read</p>
          <p class="font-bold">US Supplements Brand: From $1.5M to $10M in 18 months.</p>
          <p class="text-sm mt-1" style="color: var(--muted);">Cross-border expansion, $1M+/yr email, 30 Merchant Centers, and a $100K+ disaster recovery.</p>
        </div>
        <a href="/case-studies/us-supplements-brand" class="sfo-link text-sm flex-shrink-0">Read the case study &rarr;</a>
      </div>
    </section>


    <!-- ===== FOOTER ===== -->
    <footer class="py-16" style="border-top: 1px solid var(--border);">
      <div class="sfo-container">
        <div class="grid sm:grid-cols-3 gap-10 mb-12">
          <div>
            <p class="font-bold text-sm mb-4">SellOnTube for Shopify Merchants</p>
            <p class="text-sm leading-relaxed max-w-xs" style="color: var(--muted);">Operations for scaled Shopify stores. Custom apps, cross-border infrastructure, Klaviyo email, compliance systems.</p>
          </div>
          <div>
            <p class="sfo-label mb-5">Services</p>
            <div class="space-y-2.5 text-sm" style="color: var(--muted);">
              <p>Custom Sidekick Apps</p>
              <p>Feed &amp; Merchant Center Management</p>
              <p>International Expansion</p>
              <p>Klaviyo Email</p>
              <p>Compliance Automation</p>
              <p>Backups &amp; Disaster Recovery</p>
            </div>
          </div>
          <div>
            <p class="sfo-label mb-5">Explore</p>
            <div class="space-y-2.5 text-sm">
              <a href="/shopify-store" class="block sfo-link" style="color: var(--muted);">Back to Shopify Services</a>
              <a href="/case-studies/us-supplements-brand" class="block sfo-link" style="color: var(--muted);">US Supplements Brand case study</a>
            </div>
          </div>
        </div>
        <div class="pt-8 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4" style="border-top: 1px solid var(--border-soft);">
          <p class="text-xs" style="color: var(--dim);">&copy; 2026 SellOnTube. All rights reserved.</p>
          <div class="flex items-center gap-6 text-xs" style="color: var(--dim);">
            <a href="/privacy-policy" class="hover:underline">Privacy</a>
            <a href="/terms-of-service" class="hover:underline">Terms</a>
          </div>
        </div>
      </div>
    </footer>

  </div>

  <script is:inline>
    (() => {
      if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
        document.querySelectorAll('.sfo-reveal').forEach((el) => el.classList.add('sfo-in'));
        return;
      }
      const io = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('sfo-in');
              io.unobserve(entry.target);
            }
          });
        },
        { rootMargin: '0px 0px -8% 0px' }
      );
      document.querySelectorAll('.sfo-reveal').forEach((el) => io.observe(el));
    })();
  </script>

</Layout>
