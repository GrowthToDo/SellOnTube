---
import Layout from '~/layouts/PageLayout.astro';
import Header from '~/components/widgets/Header.astro';
import '~/assets/styles/sfo.css';

const metadata = {
  title: 'US Supplements Brand: From $1.5M to $10M in 18 Months | SellOnTube',
  description: 'Full case study: how we scaled US Supplements Brand from $1.5M to $10M in 18 months. Cross-border infrastructure to 50+ countries, $1M+/yr email channel, 30 Merchant Centers, and Shopify automation.',
  openGraph: {
    images: [{ url: '~/assets/images/og/shopify-store.jpg', width: 1200, height: 630 }],
  },
};

const calLink = 'https://cal.com/gautham-8bdvdx/30min';

// Quarterly revenue trajectory ($M), months 1-18. Same data the old chart carried.
const revenuePoints = [0.38, 0.55, 0.92, 1.45, 2.1, 3.2, 4.2];
const revenueMax = 4.2;
const revenueSvg = revenuePoints
  .map((v, i) => `${20 + i * 100},${(200 - (v / revenueMax) * 180).toFixed(1)}`)
  .join(' ');

// Monthly email revenue from warmup to steady state.
const emailPoints = [0, 0, 0, 3200, 9500, 19000, 31000, 48000, 62000, 73000, 80000, 86000];
const emailMax = 86000;
const emailSvg = emailPoints
  .map((v, i) => `${(20 + i * 54.5).toFixed(1)},${(200 - (v / emailMax) * 180).toFixed(1)}`)
  .join(' ');

const countries = [
  { c: 'US', on: true }, { c: 'CA', on: true }, { c: 'GB', on: false }, { c: 'DE', on: false }, { c: 'FR', on: false }, { c: 'AU', on: false },
  { c: 'NL', on: false }, { c: 'ES', on: false }, { c: 'IT', on: false }, { c: 'CH', on: false }, { c: 'SE', on: false }, { c: 'NO', on: false },
  { c: 'DK', on: false }, { c: 'FI', on: false }, { c: 'IE', on: false }, { c: 'BE', on: false }, { c: 'AT', on: false }, { c: 'PT', on: false },
  { c: 'PL', on: false }, { c: 'CZ', on: false }, { c: 'GR', on: false }, { c: 'RO', on: false }, { c: 'HU', on: false }, { c: 'NZ', on: false },
  { c: 'JP', on: false }, { c: 'KR', on: false }, { c: 'SG', on: false }, { c: 'HK', on: false }, { c: 'AE', on: false }, { c: 'SA', on: false },
  { c: 'IL', on: false }, { c: 'ZA', on: false }, { c: 'MX', on: false }, { c: 'BR', on: false }, { c: 'CL', on: false }, { c: 'CO', on: false },
  { c: 'AR', on: false }, { c: 'IN', on: false }, { c: 'MY', on: false }, { c: 'TH', on: false }, { c: 'PH', on: false }, { c: 'ID', on: false },
  { c: 'TW', on: false }, { c: 'TR', on: false }, { c: 'HR', on: false }, { c: 'SK', on: false }, { c: 'SI', on: false }, { c: 'EE', on: false },
  { c: 'LV', on: false }, { c: 'LT', on: false }, { c: 'LU', on: false }, { c: 'IS', on: false },
];

const campaigns = [
  { t: 'Easter campaign', v: '$34,000', w: 100, hot: true },
  { t: 'Clearance email', v: '$12,000+', w: 35.3, hot: false },
  { t: 'New arrivals send', v: '$11,000', w: 32.4, hot: false },
  { t: 'Regular campaign', v: '$9,500', w: 27.9, hot: false },
];

const results = [
  { stat: '$10M', t: 'total revenue', d: 'From $1.5M. Shopify and marketplace combined.', hot: true },
  { stat: '$7M', t: 'Shopify revenue', d: '51% YoY same-month growth.', hot: false },
  { stat: '50+', t: 'countries', d: 'From 2. 30 paid, 50+ organic.', hot: true },
  { stat: '$1M+/yr', t: 'email revenue', d: 'From zero. 25% YoY growth.', hot: false },
  { stat: '30', t: 'Merchant Centers', d: 'Plus 30 ad accounts. From 1 feed.', hot: true },
  { stat: '$100K+', t: 'saved in one weekend', d: 'Rupee pricing disaster averted by backups.', hot: false },
];
---

<Layout metadata={metadata}>

  <Fragment slot="footer"></Fragment>

  <Fragment slot="header">
    <Header
      links={[
        { text: 'Results', href: '/shopify-store#proof' },
        { text: 'What We Build', href: '/shopify-store#work' },
        { text: 'Case Studies', links: [
          { text: 'US Supplements Brand', href: '/case-studies/us-supplements-brand' },
          { text: 'UK Jewellery Brand', href: '/case-studies/luxury-jewellery-client' },
        ]},
        { text: 'Pricing', href: '/shopify-store#pricing' },
      ]}
      actions={[{ text: 'Book a discovery call', href: calLink, target: '_blank', variant: 'primary' }]}
      isSticky
    />
  </Fragment>

  <script is:inline>
    // This page is light-only. The site theme script can re-apply .dark, so keep stripping it.
    (() => {
      const strip = () => {
        if (document.documentElement.classList.contains('dark')) {
          document.documentElement.classList.remove('dark');
        }
      };
      strip();
      new MutationObserver(strip).observe(document.documentElement, { attributes: true, attributeFilter: ['class'] });
    })();
  </script>

  <div class="sfo">

    <!-- ===== HERO ===== -->
    <section class="relative overflow-hidden">
      <div class="sfo-grid-light"></div>
      <div class="sfo-container relative pt-16 sm:pt-24 pb-14 sm:pb-20">
        <nav class="flex items-center gap-2 text-sm mb-12" style="color: var(--dim);">
          <a href="/shopify-store" class="sfo-link" style="color: var(--muted);">Shopify Services</a>
          <span>/</span>
          <span>Case study</span>
        </nav>
        <h1 class="sfo-display text-[2.7rem] sm:text-6xl lg:text-[5.2rem] mb-8 max-w-4xl">
          From $1.5M to <span class="sfo-circ">$10M<svg class="sfo-anno sfo-anno-load" viewBox="0 0 320 110" preserveAspectRatio="none" aria-hidden="true"><path pathLength="1" style="stroke-width: 3.2;" d="M24,60 C16,30 92,10 168,9 C256,8 307,27 305,55 C303,86 234,102 148,100 C68,98 17,83 16,58 C15,37 54,21 110,15" /></svg></span> in 18 months.
        </h1>
        <div class="flex flex-col lg:flex-row lg:items-end lg:justify-between gap-10">
          <p class="text-lg leading-relaxed max-w-xl" style="color: var(--muted);">
            How we scaled US Supplements Brand from a US-only supplement store to a $10M global operation across 50+ countries, with a $1M+/yr email channel built from nothing.
          </p>
          <dl class="flex flex-wrap gap-x-12 gap-y-4 flex-shrink-0">
            <div>
              <dt class="sfo-label mb-1.5">Client</dt>
              <dd class="text-sm font-bold">US Supplements Brand</dd>
            </div>
            <div>
              <dt class="sfo-label mb-1.5">Industry</dt>
              <dd class="text-sm font-bold">US nutraceuticals</dd>
            </div>
            <div>
              <dt class="sfo-label mb-1.5">Engagement</dt>
              <dd class="text-sm font-bold">18 months, ongoing</dd>
            </div>
          </dl>
        </div>
      </div>

      <!-- Stat band -->
      <div style="border-top: 1px solid var(--border);">
        <div class="sfo-container">
          <div class="grid grid-cols-2 lg:grid-cols-4">
            <div class="py-8 lg:pr-10" style="border-bottom: 1px solid var(--border-soft);">
              <p class="sfo-num text-4xl font-black" style="color: var(--accent-deep);">$10M</p>
              <p class="text-sm mt-2" style="color: var(--muted);">total revenue</p>
            </div>
            <div class="py-8 pl-6 lg:px-10 border-l" style="border-color: var(--border-soft); border-bottom: 1px solid var(--border-soft);">
              <p class="sfo-num text-4xl font-black">51%</p>
              <p class="text-sm mt-2" style="color: var(--muted);">YoY Shopify growth</p>
            </div>
            <div class="py-8 lg:px-10 lg:border-l" style="border-color: var(--border-soft); border-bottom: 1px solid var(--border-soft);">
              <p class="sfo-num text-4xl font-black">50+</p>
              <p class="text-sm mt-2" style="color: var(--muted);">countries reached</p>
            </div>
            <div class="py-8 pl-6 lg:pl-10 border-l" style="border-color: var(--border-soft); border-bottom: 1px solid var(--border-soft);">
              <p class="sfo-num text-4xl font-black" style="color: var(--accent-deep);">$1M+</p>
              <p class="text-sm mt-2" style="color: var(--muted);">annual email revenue</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ===== THE STARTING POINT ===== -->
    <section class="py-20 sm:py-28">
      <div class="sfo-container">
        <div class="grid lg:grid-cols-12 gap-12 lg:gap-16 items-start">
          <div class="lg:col-span-7 sfo-reveal">
            <p class="sfo-label mb-5">The starting point</p>
            <h2 class="sfo-display text-4xl sm:text-5xl mb-8">A well-run store with nowhere near its potential.</h2>
            <p class="text-[0.95rem] leading-relaxed mb-4 max-w-xl" style="color: var(--muted);">
              US Supplements Brand sells high-quality US vitamins and supplements. The founder had built a solid product range with real customers. But the business was entirely US and Canada-focused, every operational task was done manually, and a Klaviyo account sat untouched while revenue stayed flat.
            </p>
            <p class="text-[0.95rem] leading-relaxed max-w-xl" style="color: var(--muted);">
              The infrastructure to grow globally existed. Nobody had built it.
            </p>
          </div>
          <div class="lg:col-span-5 sfo-reveal">
            <div class="py-5" style="border-top: 1px solid var(--border);">
              <p class="sfo-label mb-2">Revenue at start</p>
              <p class="sfo-num text-3xl font-black">~$1.5M/yr</p>
              <p class="text-xs mt-1" style="color: var(--dim);">US and Canada only</p>
            </div>
            <div class="py-5" style="border-top: 1px solid var(--border);">
              <p class="sfo-label mb-2">Email revenue</p>
              <p class="sfo-num text-3xl font-black">$0</p>
              <p class="text-xs mt-1" style="color: var(--dim);">Klaviyo account sitting dormant</p>
            </div>
            <div class="py-5" style="border-top: 1px solid var(--border); border-bottom: 1px solid var(--border);">
              <p class="sfo-label mb-2">Countries</p>
              <p class="sfo-num text-3xl font-black">2</p>
              <p class="text-xs mt-1" style="color: var(--dim);">English-only website</p>
            </div>
          </div>
        </div>

        <!-- Revenue trajectory -->
        <div class="sfo-reveal mt-20 pt-14" style="border-top: 1px solid var(--border);">
          <div class="flex flex-wrap items-baseline justify-between gap-4 mb-10">
            <h3 class="text-2xl font-bold">Revenue over 18 months</h3>
            <p class="text-sm" style="color: var(--dim);">Shopify plus marketplace channels, approximate quarterly trajectory</p>
          </div>
          <svg viewBox="0 0 640 224" class="w-full" role="img" aria-label="Line chart of quarterly revenue rising from 0.38 million dollars in month 1 to 4.2 million dollars in month 18">
            <polygon points={`${revenueSvg} 620,200 20,200`} fill="rgba(216, 73, 47, 0.07)" />
            <polyline points={revenueSvg} fill="none" stroke="#b23a22" stroke-width="2.5" stroke-linejoin="round" stroke-linecap="round" />
            <line x1="20" y1="200" x2="620" y2="200" stroke="#ddd7cb" stroke-width="1" />
            <circle cx="20" cy="183.7" r="3.5" fill="#b23a22" />
            <circle cx="620" cy="20" r="3.5" fill="#b23a22" />
            <text x="20" y="172" font-size="13" font-weight="700" fill="#1b1915" font-family="inherit">$0.4M</text>
            <text x="614" y="14" font-size="13" font-weight="700" fill="#1b1915" text-anchor="end" font-family="inherit">$4.2M / quarter</text>
            <text x="20" y="218" font-size="11" fill="#8d877b" font-family="inherit">Month 1</text>
            <text x="320" y="218" font-size="11" fill="#8d877b" text-anchor="middle" font-family="inherit">Month 9</text>
            <text x="620" y="218" font-size="11" fill="#8d877b" text-anchor="end" font-family="inherit">Month 18</text>
          </svg>
        </div>
      </div>
    </section>

    <!-- ===== CHAPTER 1: INTERNATIONAL (green panel) ===== -->
    <section class="sfo-panel sfo-panel-green relative overflow-hidden py-24 sm:py-32">
      <div class="sfo-grain"></div>
      <div class="sfo-container relative">
        <p class="sfo-label mb-5" style="color: var(--dim);">Chapter 01</p>
        <h2 class="sfo-display text-4xl sm:text-5xl lg:text-6xl mb-14 max-w-3xl">Going global without rebuilding the store.</h2>

        <div class="grid lg:grid-cols-12 gap-10 lg:gap-14 items-start mb-16">
          <div class="lg:col-span-6 sfo-reveal">
            <p class="text-[0.95rem] leading-relaxed mb-4 max-w-xl" style="color: var(--muted);">
              The founder managed one English-language US site. Internationalisation usually means rebuilding: new domains, new translations, new Google Shopping feeds for each market, new ad accounts. That's months of engineering work and an ongoing maintenance burden.
            </p>
            <p class="text-[0.95rem] leading-relaxed mb-4 max-w-xl" style="color: var(--muted);">
              We used Glopal to turn the one English site into 100+ localised country subdomains automatically. Each subdomain is localised to the right language, currency, and shipping rules. Google treats each as a native site for that market.
            </p>
            <p class="text-[0.95rem] leading-relaxed max-w-xl" style="color: var(--muted);">
              The owner still manages only the English US site. Everything else auto-generates. The incremental management overhead of being in 50+ countries is near zero.
            </p>
          </div>
          <div class="lg:col-span-6 sfo-reveal">
            <div class="grid grid-cols-2">
              <div class="pr-8">
                <p class="sfo-label mb-3" style="color: var(--dim);">Before</p>
                <p class="sfo-num sfo-display text-7xl sm:text-8xl">2</p>
                <p class="text-sm mt-3" style="color: var(--muted);">countries. 1 language. 1 currency.</p>
              </div>
              <div class="pl-8 border-l" style="border-color: var(--border);">
                <p class="sfo-label mb-3" style="color: var(--dim);">After</p>
                <p class="sfo-num sfo-display text-7xl sm:text-8xl" style="color: #ff9d8a;"><span class="sfo-circ">100+<svg class="sfo-anno sfo-anno-reveal" viewBox="0 0 320 110" preserveAspectRatio="none" aria-hidden="true"><path pathLength="1" style="stroke-width: 2.6;" d="M24,60 C16,30 92,10 168,9 C256,8 307,27 305,55 C303,86 234,102 148,100 C68,98 17,83 16,58 C15,37 54,21 110,15" /></svg></span></p>
                <p class="text-sm mt-3" style="color: var(--muted);">localised subdomains. 30 paid markets. 50+ organic. Owner manages nothing extra.</p>
              </div>
            </div>
          </div>
        </div>

        <div class="sfo-reveal">
          <p class="sfo-label mb-5" style="color: var(--dim);">Market expansion</p>
          <div class="sfo-cgrid" role="img" aria-label="Grid of country codes showing expansion from 2 launch markets, US and Canada, to 52 active countries">
            {countries.map((k) => (
              <span class={k.on ? 'on' : ''}>{k.c}</span>
            ))}
          </div>
          <p class="text-xs mt-3" style="color: var(--dim);"><span style="color: #ff9d8a;">US, CA</span> launch markets &middot; every other tile is a market we opened</p>
        </div>
      </div>
    </section>

    <!-- ===== CHAPTER 2: MERCHANT CENTERS ===== -->
    <section class="py-20 sm:py-28">
      <div class="sfo-container">
        <p class="sfo-label mb-5">Chapter 02</p>
        <h2 class="sfo-display text-4xl sm:text-5xl mb-14 max-w-3xl">One product feed. 30 Merchant Centers.</h2>
        <div class="grid lg:grid-cols-12 gap-12 lg:gap-16 items-start">
          <div class="lg:col-span-6 sfo-reveal">
            <p class="text-[0.95rem] leading-relaxed mb-4 max-w-xl" style="color: var(--muted);">
              Getting Google Shopping running in a new country normally means: a new product feed in that country's currency and language, a new Merchant Center account, a new Google Ads account, and someone to manage all of it ongoing.
            </p>
            <p class="text-[0.95rem] leading-relaxed mb-4 max-w-xl" style="color: var(--muted);">
              For 30 countries that's 30 separate feeds, 30 Merchant Centers, and 30 ad accounts, all needing to stay in sync whenever the product catalog changes.
            </p>
            <p class="text-[0.95rem] leading-relaxed max-w-xl" style="color: var(--muted);">
              We built a feed architecture that takes the single US product feed and automatically generates localised versions for each market: GBP and English for the UK, EUR and German for Germany, and so on. Any change to the master feed propagates to all 30 markets automatically.
            </p>
          </div>
          <div class="lg:col-span-6 sfo-reveal">
            <p class="sfo-label mb-6">Infrastructure built</p>
            <div class="py-5 grid grid-cols-[5rem_1fr] gap-5 items-baseline" style="border-top: 1px solid var(--border);">
              <p class="sfo-num sfo-display text-5xl">1</p>
              <div>
                <p class="font-bold text-sm mb-1">Master product feed</p>
                <p class="text-xs" style="color: var(--dim);">Single source of truth, maintained by the team</p>
              </div>
            </div>
            <p class="sfo-label py-2 pl-1" style="color: var(--accent-deep);">&darr; auto-generates</p>
            <div class="py-5 grid grid-cols-[5rem_1fr] gap-5 items-baseline" style="border-top: 1px solid var(--border);">
              <p class="sfo-num sfo-display text-5xl" style="color: var(--accent-deep);">30</p>
              <div>
                <p class="font-bold text-sm mb-1">Localised feeds</p>
                <p class="text-xs" style="color: var(--dim);">Right currency, language, and product rules per market</p>
              </div>
            </div>
            <div class="py-5 grid grid-cols-[5rem_1fr] gap-5 items-baseline" style="border-top: 1px solid var(--border);">
              <p class="sfo-num sfo-display text-5xl" style="color: var(--accent-deep);">30</p>
              <div>
                <p class="font-bold text-sm mb-1">Merchant Centers</p>
                <p class="text-xs" style="color: var(--dim);">One per market, all synced automatically</p>
              </div>
            </div>
            <div class="py-5 grid grid-cols-[5rem_1fr] gap-5 items-baseline" style="border-top: 1px solid var(--border); border-bottom: 1px solid var(--border);">
              <p class="sfo-num sfo-display text-5xl" style="color: var(--accent-deep);">30</p>
              <div>
                <p class="font-bold text-sm mb-1">Google Ads accounts</p>
                <p class="text-xs" style="color: var(--dim);">Local currency bidding, local performance data</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ===== CHAPTER 3: EMAIL ===== -->
    <section class="py-20 sm:py-28" style="background: var(--bg2); border-top: 1px solid var(--border); border-bottom: 1px solid var(--border);">
      <div class="sfo-container">
        <p class="sfo-label mb-5">Chapter 03</p>
        <h2 class="sfo-display sfo-reveal sfo-anno-host text-4xl sm:text-5xl mb-14 max-w-3xl">$0 to <span class="sfo-circ">$1M+/yr<svg class="sfo-anno sfo-anno-reveal" viewBox="0 0 320 110" preserveAspectRatio="none" aria-hidden="true"><path pathLength="1" style="stroke-width: 2.4;" d="M24,60 C16,30 92,10 168,9 C256,8 307,27 305,55 C303,86 234,102 148,100 C68,98 17,83 16,58 C15,37 54,21 110,15" /></svg></span> in email revenue.</h2>

        <div class="grid lg:grid-cols-12 gap-12 lg:gap-16 items-start mb-16">
          <div class="lg:col-span-6 sfo-reveal">
            <p class="text-[0.95rem] leading-relaxed mb-4 max-w-xl" style="color: var(--muted);">
              A Klaviyo account with a list, no warmup, no flows, no campaigns. Sending from a cold domain to a cold list destroys deliverability: every email lands in spam and the domain gets flagged. Most stores in this situation just leave it.
            </p>
            <p class="text-[0.95rem] leading-relaxed mb-4 max-w-xl" style="color: var(--muted);">
              We ran a 6-week warmup: graduated sending volumes starting from a small, highly engaged segment, monitoring bounce rates and spam complaints at every stage, building domain reputation before the first real campaign went out.
            </p>
            <p class="text-[0.95rem] leading-relaxed max-w-xl" style="color: var(--muted);">
              Then we built the full flow stack: abandoned cart, post-purchase sequences, new arrivals (auto-tagged by our Sidekick app), winback, and browse abandonment. Plus a regular campaign cadence that generates double-digit revenue on every single send.
            </p>
          </div>
          <div class="lg:col-span-6 sfo-reveal">
            <div class="py-5" style="border-top: 1px solid var(--border);">
              <p class="sfo-num text-3xl font-black" style="color: var(--accent-deep);">15&ndash;20%</p>
              <p class="text-sm font-bold mt-1">of total Shopify revenue from email</p>
              <p class="text-xs mt-1" style="color: var(--dim);">Up from zero. 25% YoY growth.</p>
            </div>
            <div class="py-5" style="border-top: 1px solid var(--border);">
              <p class="sfo-num text-3xl font-black">$34,000</p>
              <p class="text-sm font-bold mt-1">from one Easter campaign</p>
              <p class="text-xs mt-1" style="color: var(--dim);">Single email send. Targeted segment.</p>
            </div>
            <div class="py-5" style="border-top: 1px solid var(--border); border-bottom: 1px solid var(--border);">
              <p class="sfo-num text-3xl font-black">$12,000+</p>
              <p class="text-sm font-bold mt-1">from one clearance email</p>
              <p class="text-xs mt-1" style="color: var(--dim);">Products about to expire, 10% off. Single send.</p>
            </div>
          </div>
        </div>

        <!-- Email revenue growth -->
        <div class="sfo-reveal mb-16">
          <div class="flex flex-wrap items-baseline justify-between gap-4 mb-10">
            <h3 class="text-2xl font-bold">Email revenue growth</h3>
            <p class="text-sm" style="color: var(--dim);">Monthly Klaviyo revenue from warmup to steady state, approximate</p>
          </div>
          <svg viewBox="0 0 640 224" class="w-full" role="img" aria-label="Line chart of monthly email revenue rising from zero during a six week warmup to 86 thousand dollars per month by month 18">
            <polygon points={`${emailSvg} 619.5,200 20,200`} fill="rgba(216, 73, 47, 0.07)" />
            <polyline points={emailSvg} fill="none" stroke="#b23a22" stroke-width="2.5" stroke-linejoin="round" stroke-linecap="round" />
            <line x1="20" y1="200" x2="620" y2="200" stroke="#ddd7cb" stroke-width="1" />
            <circle cx="129" cy="200" r="3.5" fill="#8d877b" />
            <circle cx="619.5" cy="20" r="3.5" fill="#b23a22" />
            <text x="24" y="190" font-size="12" fill="#8d877b" font-family="inherit">6-week warmup: $0 by design</text>
            <text x="614" y="14" font-size="13" font-weight="700" fill="#1b1915" text-anchor="end" font-family="inherit">$86K / month</text>
            <text x="20" y="218" font-size="11" fill="#8d877b" font-family="inherit">Week 1</text>
            <text x="620" y="218" font-size="11" fill="#8d877b" text-anchor="end" font-family="inherit">Month 18</text>
          </svg>
        </div>

        <!-- Campaign performance -->
        <div class="sfo-reveal max-w-2xl">
          <p class="sfo-label mb-7">Revenue per campaign send</p>
          {campaigns.map((c) => (
