---
import Layout from '~/layouts/PageLayout.astro';

const metadata = {
  title: 'Hebron Nutrition: From $1.5M to $10M in 18 Months | SellOnTube',
  description: 'Full case study: how we scaled Hebron Nutrition from $1.5M to $10M in 18 months — cross-border infrastructure to 50+ countries, $1M+/yr email channel, 30 Merchant Centers, and Shopify automation.',
};

const calLink = 'https://cal.com/gautham-8bdvdx/30min';
---

<Layout metadata={metadata}>

  <!-- Hero -->
  <section class="relative bg-slate-900 text-white pt-24 pb-20 overflow-hidden">
    <div class="absolute inset-0 pointer-events-none">
      <div class="absolute top-0 right-0 w-[700px] h-[700px] bg-emerald-500/10 rounded-full blur-3xl"></div>
      <div class="absolute bottom-0 left-0 w-[400px] h-[400px] bg-slate-700/40 rounded-full blur-3xl"></div>
    </div>
    <div class="relative max-w-4xl mx-auto px-6">
      <div class="flex items-center gap-2 text-sm text-slate-500 mb-8">
        <a href="/shopify-store" class="hover:text-slate-300 transition-colors">Shopify Services</a>
        <span>/</span>
        <span class="text-slate-400">Case Study</span>
      </div>
      <p class="text-emerald-400 text-xs font-bold uppercase tracking-[0.2em] mb-4">Case Study</p>
      <h1 class="text-4xl sm:text-6xl font-black leading-[1.05] tracking-tight mb-6">
        From $1.5M to $10M<br class="hidden sm:block" /> in 18 months.
      </h1>
      <p class="text-lg sm:text-xl text-slate-300 mb-10 max-w-2xl leading-relaxed">
        How we scaled Hebron Nutrition from a US-only supplement store to a $10M global operation across 50+ countries — with a $1M+/yr email channel built from nothing.
      </p>
      <div class="flex flex-wrap gap-3 text-sm">
        <span class="bg-slate-800 border border-slate-700 text-slate-300 px-4 py-1.5 rounded-full">Hebron Nutrition</span>
        <span class="bg-slate-800 border border-slate-700 text-slate-300 px-4 py-1.5 rounded-full">US nutraceuticals</span>
        <span class="bg-slate-800 border border-slate-700 text-slate-300 px-4 py-1.5 rounded-full">Vitamins and supplements</span>
        <span class="bg-slate-800 border border-slate-700 text-slate-300 px-4 py-1.5 rounded-full">18-month engagement</span>
      </div>
    </div>
  </section>

  <!-- Stats bar -->
  <section class="bg-emerald-600 py-8">
    <div class="max-w-4xl mx-auto px-6">
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 text-center text-white">
        <div>
          <p class="text-2xl sm:text-3xl font-black" data-counter data-target="10" data-prefix="$" data-suffix="M">$0M</p>
          <p class="text-emerald-100 text-xs mt-1">total revenue</p>
        </div>
        <div>
          <p class="text-2xl sm:text-3xl font-black" data-counter data-target="51" data-suffix="%">0%</p>
          <p class="text-emerald-100 text-xs mt-1">YoY Shopify growth</p>
        </div>
        <div>
          <p class="text-2xl sm:text-3xl font-black" data-counter data-target="50" data-suffix="+">0</p>
          <p class="text-emerald-100 text-xs mt-1">countries reached</p>
        </div>
        <div>
          <p class="text-2xl sm:text-3xl font-black">$1M+</p>
          <p class="text-emerald-100 text-xs mt-1">annual email revenue</p>
        </div>
      </div>
    </div>
  </section>

  <!-- The starting point -->
  <section class="py-20 bg-white dark:bg-slate-900">
    <div class="max-w-4xl mx-auto px-6">
      <div class="grid sm:grid-cols-2 gap-12 items-start">
        <div>
          <p class="text-xs font-bold text-emerald-600 dark:text-emerald-400 uppercase tracking-[0.2em] mb-4">The starting point</p>
          <h2 class="text-3xl font-black text-gray-900 dark:text-white mb-6 leading-tight">A well-run store with nowhere near its potential.</h2>
          <p class="text-gray-600 dark:text-slate-400 leading-relaxed mb-4">
            Hebron Nutrition sells high-quality US vitamins and supplements. The founder had built a solid product range with real customers. But the business was entirely US and Canada-focused, every operational task was done manually, and a Klaviyo account sat untouched while revenue stayed flat.
          </p>
          <p class="text-gray-600 dark:text-slate-400 leading-relaxed">
            The infrastructure to grow globally existed. Nobody had built it.
          </p>
        </div>
        <div class="space-y-3">
          <div class="bg-slate-50 dark:bg-slate-800/50 rounded-xl p-4 border border-slate-200 dark:border-slate-700">
            <p class="text-xs font-bold text-slate-400 uppercase tracking-widest mb-1">Revenue at start</p>
            <p class="text-2xl font-black text-gray-900 dark:text-white">~$1.5M/yr</p>
            <p class="text-xs text-gray-500 dark:text-slate-400">US and Canada only</p>
          </div>
          <div class="bg-slate-50 dark:bg-slate-800/50 rounded-xl p-4 border border-slate-200 dark:border-slate-700">
            <p class="text-xs font-bold text-slate-400 uppercase tracking-widest mb-1">Email revenue</p>
            <p class="text-2xl font-black text-gray-900 dark:text-white">$0</p>
            <p class="text-xs text-gray-500 dark:text-slate-400">Klaviyo account sitting dormant</p>
          </div>
          <div class="bg-slate-50 dark:bg-slate-800/50 rounded-xl p-4 border border-slate-200 dark:border-slate-700">
            <p class="text-xs font-bold text-slate-400 uppercase tracking-widest mb-1">Countries</p>
            <p class="text-2xl font-black text-gray-900 dark:text-white">2</p>
            <p class="text-xs text-gray-500 dark:text-slate-400">English-only website</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Revenue growth chart -->
  <section class="py-16 bg-slate-50 dark:bg-slate-800/40">
    <div class="max-w-4xl mx-auto px-6">
      <p class="text-xs font-bold text-emerald-600 dark:text-emerald-400 uppercase tracking-[0.2em] mb-2">The result</p>
      <h2 class="text-2xl font-bold text-gray-900 dark:text-white mb-2">Revenue over 18 months</h2>
      <p class="text-sm text-gray-500 dark:text-slate-400 mb-8">Shopify plus marketplace channels combined. Approximate quarterly trajectory.</p>
      <div class="bg-white dark:bg-slate-900 rounded-2xl p-6 border border-slate-200 dark:border-slate-700">
        <canvas id="revenueGrowthChart" height="220"></canvas>
      </div>
    </div>
  </section>

  <!-- Chapter 1: International -->
  <section class="py-20 bg-white dark:bg-slate-900">
    <div class="max-w-4xl mx-auto px-6">
      <p class="text-xs font-bold text-slate-400 uppercase tracking-[0.2em] mb-2">Chapter 01</p>
      <h2 class="text-3xl font-black text-gray-900 dark:text-white mb-6">Going global without rebuilding the store.</h2>
      <div class="grid sm:grid-cols-2 gap-10 mb-10">
        <div>
          <p class="text-gray-600 dark:text-slate-400 leading-relaxed mb-4">
            The founder managed one English-language US site. Internationalisation usually means rebuilding — new domains, new translations, new Google Shopping feeds for each market, new ad accounts. That's months of engineering work and an ongoing maintenance burden.
          </p>
          <p class="text-gray-600 dark:text-slate-400 leading-relaxed mb-4">
            We used Glopal to turn the one English site into 100+ localised country subdomains automatically. Each subdomain is localised to the right language, currency, and shipping rules. Google treats each as a native site for that market.
          </p>
          <p class="text-gray-600 dark:text-slate-400 leading-relaxed">
            The owner still manages only the English US site. Everything else auto-generates. The incremental management overhead of being in 50+ countries is near zero.
          </p>
        </div>
        <div class="space-y-4">
          <div class="bg-emerald-50 dark:bg-emerald-900/20 rounded-2xl p-6 border border-emerald-100 dark:border-emerald-800">
            <p class="text-xs font-bold text-emerald-600 dark:text-emerald-400 uppercase tracking-widest mb-3">Before</p>
            <p class="text-4xl font-black text-gray-900 dark:text-white mb-1">2</p>
            <p class="text-sm text-gray-600 dark:text-slate-400">countries. 1 language. 1 currency.</p>
          </div>
          <div class="bg-emerald-50 dark:bg-emerald-900/20 rounded-2xl p-6 border border-emerald-100 dark:border-emerald-800">
            <p class="text-xs font-bold text-emerald-600 dark:text-emerald-400 uppercase tracking-widest mb-3">After</p>
            <p class="text-4xl font-black text-emerald-600 dark:text-emerald-400 mb-1">100+</p>
            <p class="text-sm text-gray-600 dark:text-slate-400">localised subdomains. 30 paid markets. 50+ organic. Owner manages nothing extra.</p>
          </div>
        </div>
      </div>

      <!-- Country expansion visual -->
      <div class="bg-slate-50 dark:bg-slate-800/50 rounded-2xl p-8 border border-slate-200 dark:border-slate-700">
        <p class="text-xs font-bold text-slate-400 uppercase tracking-widest mb-6">Market expansion</p>
        <canvas id="countryChart" height="160"></canvas>
      </div>
    </div>
  </section>

  <!-- Chapter 2: Merchant Center -->
  <section class="py-20 bg-slate-50 dark:bg-slate-800/40">
    <div class="max-w-4xl mx-auto px-6">
      <p class="text-xs font-bold text-slate-400 uppercase tracking-[0.2em] mb-2">Chapter 02</p>
      <h2 class="text-3xl font-black text-gray-900 dark:text-white mb-6">One product feed. 30 Merchant Centers.</h2>
      <div class="grid sm:grid-cols-2 gap-10 items-center">
        <div>
          <p class="text-gray-600 dark:text-slate-400 leading-relaxed mb-4">
            Getting Google Shopping running in a new country normally means: a new product feed in that country's currency and language, a new Merchant Center account, a new Google Ads account, and someone to manage all of it ongoing.
          </p>
          <p class="text-gray-600 dark:text-slate-400 leading-relaxed mb-4">
            For 30 countries that's 30 separate feeds, 30 Merchant Centers, and 30 ad accounts — all needing to stay in sync whenever the product catalog changes.
          </p>
          <p class="text-gray-600 dark:text-slate-400 leading-relaxed">
            We built a feed architecture that takes the single US product feed and automatically generates localised versions for each market: GBP and English for the UK, EUR and German for Germany, and so on. Any change to the master feed propagates to all 30 markets automatically.
          </p>
        </div>
        <div class="bg-white dark:bg-slate-900 rounded-2xl p-6 border border-slate-200 dark:border-slate-700">
          <p class="text-xs font-bold text-slate-400 uppercase tracking-widest mb-6">Infrastructure built</p>
          <div class="space-y-4">
            <div class="flex items-center gap-4">
              <div class="w-10 h-10 rounded-xl bg-slate-100 dark:bg-slate-800 flex items-center justify-center flex-shrink-0">
                <span class="text-lg">1</span>
              </div>
              <div>
                <p class="font-semibold text-gray-900 dark:text-white text-sm">Master product feed</p>
                <p class="text-xs text-gray-500 dark:text-slate-400">Single source of truth, maintained by the team</p>
              </div>
            </div>
            <div class="flex items-center gap-2 ml-5">
              <div class="w-px h-6 bg-slate-200 dark:bg-slate-700 mx-2"></div>
              <p class="text-xs text-slate-400">auto-generates</p>
            </div>
            <div class="flex items-center gap-4">
              <div class="w-10 h-10 rounded-xl bg-emerald-100 dark:bg-emerald-900/40 flex items-center justify-center flex-shrink-0">
                <span class="text-lg font-black text-emerald-600 dark:text-emerald-400">30</span>
              </div>
              <div>
                <p class="font-semibold text-gray-900 dark:text-white text-sm">Localised feeds</p>
                <p class="text-xs text-gray-500 dark:text-slate-400">Right currency, language, and product rules per market</p>
              </div>
            </div>
            <div class="flex items-center gap-4">
              <div class="w-10 h-10 rounded-xl bg-emerald-100 dark:bg-emerald-900/40 flex items-center justify-center flex-shrink-0">
                <span class="text-lg font-black text-emerald-600 dark:text-emerald-400">30</span>
              </div>
              <div>
                <p class="font-semibold text-gray-900 dark:text-white text-sm">Merchant Centers</p>
                <p class="text-xs text-gray-500 dark:text-slate-400">One per market, all synced automatically</p>
              </div>
            </div>
            <div class="flex items-center gap-4">
              <div class="w-10 h-10 rounded-xl bg-emerald-100 dark:bg-emerald-900/40 flex items-center justify-center flex-shrink-0">
                <span class="text-lg font-black text-emerald-600 dark:text-emerald-400">30</span>
              </div>
              <div>
                <p class="font-semibold text-gray-900 dark:text-white text-sm">Google Ads accounts</p>
                <p class="text-xs text-gray-500 dark:text-slate-400">Local currency bidding, local performance data</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Chapter 3: Email -->
  <section class="py-20 bg-white dark:bg-slate-900">
    <div class="max-w-4xl mx-auto px-6">
      <p class="text-xs font-bold text-slate-400 uppercase tracking-[0.2em] mb-2">Chapter 03</p>
      <h2 class="text-3xl font-black text-gray-900 dark:text-white mb-6">$0 to $1M+/yr in email revenue.</h2>

      <div class="grid sm:grid-cols-2 gap-10 mb-12">
        <div>
          <p class="text-gray-600 dark:text-slate-400 leading-relaxed mb-4">
            A Klaviyo account with a list, no warmup, no flows, no campaigns. Sending from a cold domain to a cold list destroys deliverability — every email lands in spam and the domain gets flagged. Most stores in this situation just leave it.
          </p>
          <p class="text-gray-600 dark:text-slate-400 leading-relaxed mb-4">
            We ran a 6-week warmup: graduated sending volumes starting from a small, highly engaged segment, monitoring bounce rates and spam complaints at every stage, building domain reputation before the first real campaign went out.
          </p>
          <p class="text-gray-600 dark:text-slate-400 leading-relaxed">
            Then we built the full flow stack: abandoned cart, post-purchase sequences, new arrivals (auto-tagged by our Sidekick app), winback, and browse abandonment. Plus a regular campaign cadence that generates double-digit revenue on every single send.
          </p>
        </div>
        <div class="space-y-4">
          <div class="bg-slate-50 dark:bg-slate-800/50 rounded-2xl p-5 border border-slate-200 dark:border-slate-700">
            <p class="text-3xl font-black text-emerald-600 dark:text-emerald-400 mb-1">15–20%</p>
            <p class="text-sm font-semibold text-gray-900 dark:text-white mb-1">of total Shopify revenue from email</p>
            <p class="text-xs text-gray-500 dark:text-slate-400">Up from zero. 25% YoY growth.</p>
          </div>
          <div class="bg-slate-50 dark:bg-slate-800/50 rounded-2xl p-5 border border-slate-200 dark:border-slate-700">
            <p class="text-3xl font-black text-gray-900 dark:text-white mb-1">$34,000</p>
            <p class="text-sm font-semibold text-gray-900 dark:text-white mb-1">from one Easter campaign</p>
            <p class="text-xs text-gray-500 dark:text-slate-400">Single email send. Targeted segment.</p>
          </div>
          <div class="bg-slate-50 dark:bg-slate-800/50 rounded-2xl p-5 border border-slate-200 dark:border-slate-700">
            <p class="text-3xl font-black text-gray-900 dark:text-white mb-1">$12,000+</p>
            <p class="text-sm font-semibold text-gray-900 dark:text-white mb-1">from one clearance email</p>
            <p class="text-xs text-gray-500 dark:text-slate-400">Products about to expire, 10% off. Single send.</p>
          </div>
        </div>
      </div>

      <!-- Email growth chart -->
      <div class="bg-slate-50 dark:bg-slate-800/50 rounded-2xl p-6 border border-slate-200 dark:border-slate-700 mb-6">
        <p class="text-xs font-bold text-slate-400 uppercase tracking-widest mb-1">Email revenue growth</p>
        <p class="text-sm text-gray-500 dark:text-slate-400 mb-6">Monthly Klaviyo revenue from warmup to steady state (approximate)</p>
        <canvas id="emailGrowthChart" height="200"></canvas>
      </div>

      <!-- Campaign performance chart -->
      <div class="bg-emerald-50 dark:bg-emerald-900/20 rounded-2xl p-6 border border-emerald-100 dark:border-emerald-800">
        <p class="text-xs font-bold text-emerald-600 dark:text-emerald-400 uppercase tracking-widest mb-1">Revenue per campaign send</p>
        <p class="text-sm text-gray-600 dark:text-slate-400 mb-6">Every email that goes out is double-digit revenue</p>
        <canvas id="campaignChart" height="140"></canvas>
      </div>
    </div>
  </section>

  <!-- Chapter 4: Compliance -->
  <section class="py-20 bg-slate-50 dark:bg-slate-800/40">
    <div class="max-w-4xl mx-auto px-6">
      <p class="text-xs font-bold text-slate-400 uppercase tracking-[0.2em] mb-2">Chapter 04</p>
      <h2 class="text-3xl font-black text-gray-900 dark:text-white mb-6">400,000 compliance touchpoints. One screen.</h2>
      <div class="grid sm:grid-cols-2 gap-10 items-center">
        <div>
          <p class="text-gray-600 dark:text-slate-400 leading-relaxed mb-4">
            Hebron Nutrition carries 100+ brands. Each brand has MAP (Minimum Advertised Price) rules — specific prices below which products cannot be advertised. One wrong price on the wrong product means a brand can pull its exclusivity agreement.
          </p>
          <p class="text-gray-600 dark:text-slate-400 leading-relaxed mb-4">
            With 8,000 SKUs selling across 50 markets, that's 400,000 individual compliance touchpoints: 8,000 products times 50 markets. Managing that manually is not possible. Managing it with spreadsheets means it's always out of date.
          </p>
          <p class="text-gray-600 dark:text-slate-400 leading-relaxed">
            We built the Market Exclusion Manager — a custom Sidekick app that lives inside the Shopify admin. Set the rules once, per brand and per market. The app enforces them continuously and flags exceptions in real time.
          </p>
        </div>
        <div class="text-center bg-white dark:bg-slate-900 rounded-2xl p-8 border border-slate-200 dark:border-slate-700">
          <p class="text-xs font-bold text-slate-400 uppercase tracking-widest mb-4">Compliance touchpoints managed</p>
          <p class="text-7xl font-black text-emerald-600 dark:text-emerald-400 leading-none mb-2" data-counter data-target="400000" data-suffix="">0</p>
          <p class="text-sm text-gray-500 dark:text-slate-400">8,000 SKUs across 50 markets. Automated. One screen.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Chapter 5: Disaster Recovery -->
  <section class="py-20 bg-white dark:bg-slate-900">
    <div class="max-w-4xl mx-auto px-6">
      <p class="text-xs font-bold text-slate-400 uppercase tracking-[0.2em] mb-2">Chapter 05</p>
      <h2 class="text-3xl font-black text-gray-900 dark:text-white mb-6">The weekend a vendor nearly cost them $100K.</h2>
      <div class="max-w-2xl mb-10">
        <p class="text-gray-600 dark:text-slate-400 leading-relaxed mb-4">
          On a weekend, a vendor uploaded their entire catalog with rupee-denominated pricing. Products priced at $100 showed as $10,000. Every customer visiting the store over that weekend saw catastrophically wrong prices.
        </p>
        <p class="text-gray-600 dark:text-slate-400 leading-relaxed mb-4">
          Because we run daily full-catalog backups with rollback capability, the entire store was restored to the correct state in minutes. No permanent pricing damage. No orders processed at the wrong price. Estimated exposure avoided: $100K+.
        </p>
        <p class="text-gray-600 dark:text-slate-400 leading-relaxed">
          This is not a hypothetical. It happened. And it's the kind of event that ends businesses if the infrastructure isn't in place.
        </p>
      </div>

      <!-- Timeline -->
      <div class="bg-slate-50 dark:bg-slate-800/50 rounded-2xl p-8 border border-slate-200 dark:border-slate-700">
        <p class="text-xs font-bold text-slate-400 uppercase tracking-widest mb-8">What happened</p>
        <div class="space-y-0">
          <div class="flex gap-5">
            <div class="flex flex-col items-center">
              <div class="w-3 h-3 rounded-full bg-red-400 flex-shrink-0 mt-1"></div>
              <div class="w-px flex-1 bg-slate-200 dark:bg-slate-700 my-1"></div>
            </div>
            <div class="pb-8">
              <p class="text-xs font-bold text-red-500 uppercase tracking-widest mb-1">Incident</p>
              <p class="font-semibold text-gray-900 dark:text-white mb-1">Vendor uploads rupee pricing across the entire catalog</p>
              <p class="text-sm text-gray-500 dark:text-slate-400">$100 products showing as $10,000. Visible to all site visitors over the weekend.</p>
            </div>
          </div>
          <div class="flex gap-5">
            <div class="flex flex-col items-center">
              <div class="w-3 h-3 rounded-full bg-amber-400 flex-shrink-0 mt-1"></div>
              <div class="w-px flex-1 bg-slate-200 dark:bg-slate-700 my-1"></div>
            </div>
            <div class="pb-8">
              <p class="text-xs font-bold text-amber-500 uppercase tracking-widest mb-1">Detection</p>
              <p class="font-semibold text-gray-900 dark:text-white mb-1">Pricing anomaly identified</p>
              <p class="text-sm text-gray-500 dark:text-slate-400">Our monitoring flagged the mass price change. Escalated immediately.</p>
            </div>
          </div>
          <div class="flex gap-5">
            <div class="flex flex-col items-center">
              <div class="w-3 h-3 rounded-full bg-emerald-500 flex-shrink-0 mt-1"></div>
            </div>
            <div>
              <p class="text-xs font-bold text-emerald-600 dark:text-emerald-400 uppercase tracking-widest mb-1">Resolution</p>
              <p class="font-semibold text-gray-900 dark:text-white mb-1">Full catalog restored from daily backup</p>
              <p class="text-sm text-gray-500 dark:text-slate-400">Complete rollback in minutes. No orders processed at wrong prices. Estimated $100K+ exposure avoided.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Final Results -->
  <section class="py-20 bg-slate-900 text-white">
    <div class="max-w-4xl mx-auto px-6">
      <p class="text-xs font-bold text-emerald-400 uppercase tracking-[0.2em] mb-4">The full picture</p>
      <h2 class="text-3xl font-black mb-12">Everything built in 18 months.</h2>

      <div class="grid grid-cols-2 sm:grid-cols-3 gap-5 mb-12">
        <div class="bg-slate-800/60 rounded-2xl p-5 border border-slate-700/50">
          <p class="text-3xl font-black text-emerald-400 mb-1" data-counter data-target="10" data-prefix="$" data-suffix="M">$0M</p>
          <p class="text-sm font-semibold text-white mb-1">total revenue</p>
          <p class="text-xs text-slate-400">From $1.5M. Shopify and marketplace combined.</p>
        </div>
        <div class="bg-slate-800/60 rounded-2xl p-5 border border-slate-700/50">
          <p class="text-3xl font-black text-white mb-1" data-counter data-target="7" data-prefix="$" data-suffix="M">$0M</p>
          <p class="text-sm font-semibold text-white mb-1">Shopify revenue</p>
          <p class="text-xs text-slate-400">51% YoY same-month growth.</p>
        </div>
        <div class="bg-slate-800/60 rounded-2xl p-5 border border-slate-700/50">
          <p class="text-3xl font-black text-emerald-400 mb-1" data-counter data-target="50" data-suffix="+">0</p>
          <p class="text-sm font-semibold text-white mb-1">countries</p>
          <p class="text-xs text-slate-400">From 2. 30 paid, 50+ organic.</p>
        </div>
        <div class="bg-slate-800/60 rounded-2xl p-5 border border-slate-700/50">
