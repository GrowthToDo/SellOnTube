<script is:inline>
(function () {
  // Counter animations
  function animateCounter(el) {
    const target = parseFloat(el.dataset.target);
    const prefix = el.dataset.prefix || '';
    const suffix = el.dataset.suffix || '';
    const duration = 1600;
    const start = performance.now();
    const isDecimal = target % 1 !== 0;

    function update(now) {
      const elapsed = now - start;
      const progress = Math.min(elapsed / duration, 1);
      const eased = 1 - Math.pow(1 - progress, 3);
      const value = eased * target;
      el.textContent = prefix + (isDecimal ? value.toFixed(1) : Math.floor(value).toLocaleString()) + suffix;
      if (progress < 1) requestAnimationFrame(update);
    }
    requestAnimationFrame(update);
  }

  const counterObserver = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        animateCounter(entry.target);
        counterObserver.unobserve(entry.target);
      }
    });
  }, { threshold: 0.5 });

  document.querySelectorAll('[data-counter]').forEach(el => counterObserver.observe(el));

  // Charts
  const chartScript = document.createElement('script');
  chartScript.src = 'https://cdn.jsdelivr.net/npm/chart.js@4/dist/chart.umd.min.js';
  chartScript.onload = initCharts;
  document.head.appendChild(chartScript);

  function initCharts() {
    const dark = document.documentElement.classList.contains('dark');
    const textColor = dark ? '#94a3b8' : '#6b7280';
    const gridColor = dark ? 'rgba(255,255,255,0.06)' : 'rgba(0,0,0,0.05)';
    const emerald = '#10b981';
    const emeraldLight = '#34d399';
    const emeraldLighter = '#6ee7b7';

    Chart.defaults.font.family = 'inherit';
    Chart.defaults.color = textColor;

    // Revenue growth line chart
    const revCtx = document.getElementById('revenueGrowthChart');
    if (revCtx) {
      new Chart(revCtx, {
        type: 'line',
        data: {
          labels: ['Month 1', 'Month 3', 'Month 6', 'Month 9', 'Month 12', 'Month 15', 'Month 18'],
          datasets: [{
            label: 'Revenue ($M)',
            data: [0.38, 0.55, 0.92, 1.45, 2.10, 3.20, 4.20],
            borderColor: emerald,
            backgroundColor: dark ? 'rgba(16,185,129,0.12)' : 'rgba(16,185,129,0.08)',
            borderWidth: 3,
            fill: true,
            tension: 0.4,
            pointBackgroundColor: emerald,
            pointRadius: 5,
            pointHoverRadius: 7,
          }]
        },
        options: {
          responsive: true,
          plugins: {
            legend: { display: false },
            tooltip: { callbacks: { label: (c) => ' $' + c.parsed.y.toFixed(2) + 'M quarterly' } }
          },
          scales: {
            x: { grid: { color: gridColor }, border: { display: false } },
            y: {
              grid: { color: gridColor },
              border: { display: false },
              ticks: { callback: (v) => '$' + v + 'M' }
            }
          }
        }
      });
    }

    // Country expansion bar chart
    const countryCtx = document.getElementById('countryChart');
    if (countryCtx) {
      new Chart(countryCtx, {
        type: 'bar',
        data: {
          labels: ['Before', 'Paid markets', 'Organic reach'],
          datasets: [{
            data: [2, 30, 50],
            backgroundColor: [
              dark ? 'rgba(148,163,184,0.3)' : 'rgba(148,163,184,0.4)',
              emerald,
              emeraldLight,
            ],
            borderRadius: 8,
            borderSkipped: false,
          }]
        },
        options: {
          responsive: true,
          plugins: {
            legend: { display: false },
            tooltip: { callbacks: { label: (c) => ' ' + c.parsed.y + ' countries' } }
          },
          scales: {
            x: { grid: { display: false }, border: { display: false } },
            y: { grid: { color: gridColor }, border: { display: false }, ticks: { callback: (v) => v + ' countries' } }
          }
        }
      });
    }

    // Email growth line chart
    const emailCtx = document.getElementById('emailGrowthChart');
    if (emailCtx) {
      new Chart(emailCtx, {
        type: 'line',
        data: {
          labels: ['Wk 1', 'Wk 3', 'Wk 6', 'M3', 'M4', 'M5', 'M6', 'M8', 'M10', 'M12', 'M15', 'M18'],
          datasets: [{
            label: 'Monthly email revenue',
            data: [0, 0, 0, 3200, 9500, 19000, 31000, 48000, 62000, 73000, 80000, 86000],
            borderColor: emerald,
            backgroundColor: dark ? 'rgba(16,185,129,0.15)' : 'rgba(16,185,129,0.1)',
            borderWidth: 3,
            fill: true,
            tension: 0.45,
            pointBackgroundColor: emerald,
            pointRadius: 4,
            pointHoverRadius: 6,
          }]
        },
        options: {
          responsive: true,
          plugins: {
            legend: { display: false },
            tooltip: { callbacks: { label: (c) => ' $' + c.parsed.y.toLocaleString() + '/mo' } }
          },
          scales: {
            x: { grid: { color: gridColor }, border: { display: false } },
            y: {
              grid: { color: gridColor },
              border: { display: false },
              ticks: { callback: (v) => '$' + (v >= 1000 ? (v / 1000).toFixed(0) + 'K' : v) }
            }
          }
        }
      });
    }

    // Campaign performance horizontal bars
    const campCtx = document.getElementById('campaignChart');
    if (campCtx) {
      new Chart(campCtx, {
        type: 'bar',
        data: {
          labels: ['Easter campaign', 'Clearance email', 'New arrivals send', 'Regular campaign'],
          datasets: [{
            data: [34000, 12000, 11000, 9500],
            backgroundColor: [emerald, emeraldLight, emeraldLighter, dark ? 'rgba(110,231,183,0.5)' : 'rgba(110,231,183,0.7)'],
            borderRadius: 6,
            borderSkipped: false,
          }]
        },
        options: {
          indexAxis: 'y',
          responsive: true,
          plugins: {
            legend: { display: false },
            tooltip: { callbacks: { label: (c) => ' $' + c.parsed.x.toLocaleString() } }
          },
          scales: {
            x: {
              grid: { color: gridColor },
              border: { display: false },
              ticks: { callback: (v) => '$' + (v / 1000) + 'K' }
            },
            y: { grid: { display: false }, border: { display: false } }
          }
        }
      });
    }
  }
})();
</script>
