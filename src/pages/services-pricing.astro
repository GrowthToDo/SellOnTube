---
import Layout from '~/layouts/PageLayout.astro';

const metadata = {
  title: `YouTube Marketing Agency for B2B | SellonTube`,
  description: `SellonTube is a YouTube marketing agency for B2B founders and SaaS teams. Done-for-you channel strategy, content, and SEO. Retainers from $2,500/mo.`,
  canonical: 'https://sellontube.com/services-pricing',
  openGraph: {
    type: 'website',
    url: 'https://sellontube.com/services-pricing',
    images: [{ url: '~/assets/images/default.png', width: 1200, height: 628 }],
  },
};

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "YouTube Marketing Agency Services",
  "provider": { "@type": "Organization", "name": "SellonTube", "url": "https://sellontube.com" },
  "description": "Done-for-you YouTube marketing retainers for B2B businesses. Strategy, content production, SEO optimisation, and channel management.",
  "areaServed": "Worldwide",
  "offers": [
    { "@type": "Offer", "name": "Foundation", "price": "2500", "priceCurrency": "USD", "priceSpecification": { "@type": "UnitPriceSpecification", "billingDuration": "P1M" } },
    { "@type": "Offer", "name": "Growth", "price": "4000", "priceCurrency": "USD", "priceSpecification": { "@type": "UnitPriceSpecification", "billingDuration": "P1M" } },
    { "@type": "Offer", "name": "Scale", "price": "6000", "priceCurrency": "USD", "priceSpecification": { "@type": "UnitPriceSpecification", "billingDuration": "P1M" } }
  ]
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What's the minimum commitment?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "All tiers run on a 3-month minimum engagement. YouTube is a compounding channel — 3 months is the minimum to see meaningful data and make smart adjustments."
      }
    },
    {
      "@type": "Question",
      "name": "Do we need to already have a YouTube channel?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "No. We can help you start from zero or build on what you have. The Foundation tier includes a full channel setup and optimization sprint."
      }
    },
    {
      "@type": "Question",
      "name": "What does our team need to do?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Minimal involvement on your end. You approve topics, review scripts, and publish videos. On Growth and Scale, we handle most of the execution."
      }
    },
    {
      "@type": "Question",
      "name": "How is this different from hiring a YouTube manager?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Most YouTube managers optimize for views and subscriber growth. We optimize for buyer-intent topics, lead capture, and customer acquisition. Different goal, different system."
      }
    },
    {
      "@type": "Question",
      "name": "Can we start with Foundation and upgrade?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. Most clients start at Foundation or Growth to validate the channel, then upgrade to Scale once they're seeing pipeline."
      }
    },
    {
      "@type": "Question",
      "name": "How much does YouTube marketing cost?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Our YouTube marketing packages start at $2,500/month for the Foundation retainer. The cost of YouTube marketing with SellonTube depends on the level of execution support your team needs."
      }
    }
  ]
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://sellontube.com" },
    { "@type": "ListItem", "position": 2, "name": "Services Pricing", "item": "https://sellontube.com/services-pricing" }
  ]
};
---

<Layout metadata={metadata}>
  <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />

  <!-- HERO SECTION -->
  <section class="py-12 sm:py-16">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 text-center">
      <h1 class="text-4xl sm:text-5xl font-bold tracking-tight leading-tight">
        We Run Your YouTube Acquisition Engine
