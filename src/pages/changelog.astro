---
import Layout from '~/layouts/PageLayout.astro';

const metadata = {
  title: 'Changelog | SellOnTube',
  description: 'Internal changelog for SellOnTube.',
  robots: { index: false, follow: false },
};
---

<Layout metadata={metadata}>
  <!-- Login Screen -->
  <div id="login-screen" class="min-h-screen flex items-center justify-center bg-gray-50 dark:bg-slate-900 px-4">
    <div class="w-full max-w-sm bg-white dark:bg-slate-800 rounded-xl shadow-md p-8">
      <h1 class="text-xl font-bold text-gray-900 dark:text-white mb-1">SellOnTube Changelog</h1>
      <p class="text-sm text-gray-500 dark:text-slate-400 mb-6">Internal access only</p>
      <div id="login-error" class="hidden mb-4 text-sm text-red-600 dark:text-red-400">Incorrect credentials.</div>
      <div class="flex flex-col gap-3">
        <input
          id="username"
          type="text"
          placeholder="Username"
          autocomplete="username"
          class="w-full px-4 py-2 border border-gray-300 dark:border-slate-600 rounded-lg text-sm bg-white dark:bg-slate-700 text-gray-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-green-500"
        />
        <input
          id="password"
          type="password"
          placeholder="Password"
          autocomplete="current-password"
          class="w-full px-4 py-2 border border-gray-300 dark:border-slate-600 rounded-lg text-sm bg-white dark:bg-slate-700 text-gray-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-green-500"
        />
        <button
          id="login-btn"
          class="w-full py-2 bg-green-600 hover:bg-green-700 text-white text-sm font-semibold rounded-lg transition-colors"
        >
          Sign in
        </button>
      </div>
    </div>
  </div>

  <!-- Changelog Content (hidden until authenticated) -->
  <div id="changelog-content" class="hidden max-w-3xl mx-auto px-4 sm:px-6 py-16">
    <div class="mb-10">
      <h1 class="text-3xl font-bold text-gray-900 dark:text-white mb-1">Changelog</h1>
      <p class="text-sm text-gray-500 dark:text-slate-400">SellOnTube, internal log of all site changes.</p>
    </div>

    <!-- Entries -->
    <div class="flex flex-col gap-10">

      <!-- v1.1.0 -->
      <div class="border-l-2 border-green-500 pl-6">
        <div class="flex items-center gap-3 mb-2">
          <span class="text-xs font-mono font-semibold bg-green-100 dark:bg-green-900/40 text-green-700 dark:text-green-400 px-2 py-0.5 rounded">v1.1.0</span>
          <span class="text-sm text-gray-500 dark:text-slate-400">19 May 2026</span>
        </div>
        <h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-2">Pricing update</h2>
        <ul class="text-sm text-gray-600 dark:text-slate-300 flex flex-col gap-1 list-disc list-inside">
          <li>Growth plan raised from $4,000 → $5,000/month</li>
          <li>Scale plan raised from $6,000 → $7,500/month</li>
          <li>Priority spot updated to $6,500/month</li>
          <li>Rate increase deadline updated to June 30, 2026</li>
          <li>ROI calculator base price updated to $5,000 (Growth plan)</li>
        </ul>
      </div>

      <!-- v1.0.0 -->
      <div class="border-l-2 border-gray-200 dark:border-slate-700 pl-6">
        <div class="flex items-center gap-3 mb-2">
          <span class="text-xs font-mono font-semibold bg-gray-100 dark:bg-slate-700 text-gray-600 dark:text-slate-300 px-2 py-0.5 rounded">v1.0.0</span>
          <span class="text-sm text-gray-500 dark:text-slate-400">May 2026</span>
        </div>
        <h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-2">Site launched</h2>
        <ul class="text-sm text-gray-600 dark:text-slate-300 flex flex-col gap-1 list-disc list-inside">
          <li>SellOnTube.com live, YouTube marketing agency + Shopify services</li>
          <li>Pricing page, tools, blog, Shopify services page shipped</li>
        </ul>
      </div>

    </div>
  </div>
</Layout>

<script>
  const CREDENTIALS = { username: 'gautham', password: 'sathya' };
  const SESSION_KEY = 'sot_cl_auth';

  const loginScreen = document.getElementById('login-screen')!;
  const changelogContent = document.getElementById('changelog-content')!;
  const loginError = document.getElementById('login-error')!;
  const loginBtn = document.getElementById('login-btn')!;
  const usernameInput = document.getElementById('username') as HTMLInputElement;
  const passwordInput = document.getElementById('password') as HTMLInputElement;

  function showChangelog() {
    loginScreen.classList.add('hidden');
    changelogContent.classList.remove('hidden');
  }

  // Check existing session
  if (sessionStorage.getItem(SESSION_KEY) === 'true') {
    showChangelog();
  }

  function attempt() {
    const u = usernameInput.value.trim().toLowerCase();
    const p = passwordInput.value.trim().toLowerCase();
    if (u === CREDENTIALS.username && p === CREDENTIALS.password) {
      sessionStorage.setItem(SESSION_KEY, 'true');
      loginError.classList.add('hidden');
      showChangelog();
    } else {
      loginError.classList.remove('hidden');
    }
  }

  loginBtn.addEventListener('click', attempt);
  passwordInput.addEventListener('keydown', (e) => { if (e.key === 'Enter') attempt(); });
</script>
