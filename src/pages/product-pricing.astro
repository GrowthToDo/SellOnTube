---
import Layout from '~/layouts/PageLayout.astro';

const metadata = {
  title: `YouTube SEO Tools & Software — SellonTube`,
  description: `SellonTube gives B2B teams YouTube SEO tools, keyword research, and channel analytics to turn YouTube into a customer acquisition channel. Free plan included.`,
  canonical: 'https://sellontube.com/product-pricing',
  openGraph: {
    type: 'website',
    url: 'https://sellontube.com/product-pricing',
    images: [{ url: '~/assets/images/default.png', width: 1200, height: 628 }],
  },
};

const softwareSchema = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  "name": "SellonTube",
  "applicationCategory": "BusinessApplication",
  "description": "YouTube SEO tools and channel analytics for B2B businesses",
  "url": "https://sellontube.com",
  "offers": [
    {
      "@type": "Offer",
      "name": "Explorer",
      "price": "0",
      "priceCurrency": "USD",
      "priceSpecification": { "@type": "UnitPriceSpecification", "billingDuration": "P1M" }
    },
    {
      "@type": "Offer",
      "name": "Research",
      "price": "49",
      "priceCurrency": "USD",
      "priceSpecification": { "@type": "UnitPriceSpecification", "billingDuration": "P1M" }
    },
    {
      "@type": "Offer",
      "name": "Strategy",
      "price": "199",
      "priceCurrency": "USD",
      "priceSpecification": { "@type": "UnitPriceSpecification", "billingDuration": "P1M" }
    }
  ]
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Do I need a large YouTube channel?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "No. Buyer-intent videos can generate leads even on small channels. The topic matters more than your subscriber count."
      }
    },
    {
      "@type": "Question",
      "name": "Does this work for B2B businesses?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. B2B companies often benefit the most because buyers research solutions before purchasing. YouTube is where that research happens."
      }
    },
    {
      "@type": "Question",
      "name": "Do I need to appear on camera?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Not necessarily. Many businesses use product demos, tutorials, screen recordings, or educational videos."
      }
    },
    {
      "@type": "Question",
      "name": "How long does it take to see results?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Most businesses start seeing traction once they publish several buyer-intent videos targeting real customer problems."
      }
    }
  ]
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://sellontube.com" },
    { "@type": "ListItem", "position": 2, "name": "Product Pricing", "item": "https://sellontube.com/product-pricing" }
  ]
};
---

<Layout metadata={metadata}>
  <script type="application/ld+json" set:html={JSON.stringify(softwareSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />

  <!-- HERO SECTION -->
  <section class="py-12 sm:py-16">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 text-center">
      <nav class="mb-4 flex items-center justify-center gap-2 text-sm text-gray-500 dark:text-slate-400">
        <a href="/" class="hover:text-gray-700 dark:hover:text-slate-200">Home</a>
        <span>/</span>
        <span class="text-gray-700 dark:text-slate-200">Product Pricing</span>
      </nav>
      <h1 class="text-4xl sm:text-5xl font-bold tracking-tight text-gray-900 dark:text-white">
        Turn YouTube Into a Customer Acquisition Channel
      </h1>
      <p class="mt-4 text-lg sm:text-xl text-gray-600 dark:text-slate-300 max-w-3xl mx-auto">
        Most businesses chase YouTube views. The real opportunity is buyer-intent videos that bring customers. Choose the plan that fits where you are.
      </p>
