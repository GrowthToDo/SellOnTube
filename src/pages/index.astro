---
import Layout from '~/layouts/PageLayout.astro';

import Hero from '~/components/widgets/Hero.astro';
import HeroProofPanel from '~/components/widgets/HeroProofPanel.astro';
import Features from '~/components/widgets/Features.astro';
import Features3 from '~/components/widgets/Features3.astro';
import CaseStudyShowcase from '~/components/widgets/CaseStudyShowcase.astro';
import ROICalculator from '~/components/widgets/ROICalculator.astro';
import Content from '~/components/widgets/Content.astro';
import FAQs from '~/components/widgets/FAQs.astro';
import BlogLatestPosts from '~/components/widgets/BlogLatestPosts.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import StickyEmailCapture from '~/components/widgets/StickyEmailCapture.astro';
import FloatingEmailCapture from '~/components/widgets/FloatingEmailCapture.astro';

import dataVisualizationScreen from '~/assets/images/data-visualization-screen.jpg';

const metadata = {
  title: 'SellOnTube | YouTube Customers, No Recording',
  ignoreTitleTemplate: true,
  description: 'Done-for-you YouTube channels that acquire customers through search: strategy, scripting, voiceover, production, and SEO. No recording needed.',
  openGraph: {
    type: 'website',
    images: [{ url: '~/assets/images/default.png', width: 1200, height: 628 }],
  },
};

const calLink = 'https://cal.com/gautham-8bdvdx/30min';

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Do I need to be on camera?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "No. We use professional voiceover and visual storytelling. You never need to appear on camera unless you want to."
      }
    },
    {
      "@type": "Question",
      "name": "How long before I see results?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "YouTube behaves like SEO. Early wins are possible, but the real value is in compounding. We aim for meaningful traction within 90-120 days."
      }
    },
    {
      "@type": "Question",
      "name": "How do you know if YouTube will work for my business?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "We analyse your market, offer, and search demand in a diagnostic call. If the economics don't support profitable acquisition, we'll tell you upfront."
      }
    },
    {
      "@type": "Question",
      "name": "What does working together look like?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Each month we align on topics, collect inputs from you (calls, docs), then handle full production and publishing. Your involvement stays light."
      }
    },
    {
      "@type": "Question",
      "name": "How do you know my industry?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "We research deeply before we script. We study your market, competitors, and customer language. You review every script before production to ensure accuracy."
      }
    },
    {
      "@type": "Question",
      "name": "What if it doesn't work?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "We recommend a strategic review after 120 days. If the channel isn't showing traction or the economics don't justify continuing, we'll tell you. No long-term lock-in."
      }
    }
  ]
};
---

<Layout metadata={metadata}>
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

  <style is:global>
    /* ROI worksheet: registration ticks on the calculator card */
    #roi-calculator .rounded-2xl.border {
      position: relative;
    }
    #roi-calculator .rounded-2xl.border::before,
    #roi-calculator .rounded-2xl.border::after {
      content: '';
      position: absolute;
      width: 13px;
      height: 13px;
      pointer-events: none;
    }
    #roi-calculator .rounded-2xl.border::before {
      top: -7px;
      left: -7px;
      border-top: 2px solid rgb(216 73 47);
      border-left: 2px solid rgb(216 73 47);
    }
    #roi-calculator .rounded-2xl.border::after {
      bottom: -7px;
      right: -7px;
      border-bottom: 2px solid rgb(216 73 47);
      border-right: 2px solid rgb(216 73 47);
    }

    /* The approach image reads as a pinned artifact, not a stock photo */
    section:has(img[alt^="Data visualization"]) img {
      border: 1px solid rgba(17, 17, 19, 0.6);
      border-radius: 2px !important;
      box-shadow: 6px 6px 0 rgba(17, 17, 19, 0.12);
      transform: rotate(-0.5deg);
    }
    .dark section:has(img[alt^="Data visualization"]) img {
      border-color: rgba(247, 248, 248, 0.35);
      box-shadow: 6px 6px 0 rgba(247, 248, 248, 0.08);
    }
  </style>



  <!-- Hero Widget ******************* -->

  <div class="son-grid">
  <Hero
    actions={[
      {
        variant: 'primary',
        text: 'See your profit potential',
        href: '#roi-calculator',
      },
      {
        text: 'Book a diagnostic call',
        href: calLink,
        target: '_blank',
        rel: 'noopener noreferrer',
      },
    ]}
  >
    <Fragment slot="title">
      We acquire customers for your business through <span class="son-circ">YouTube<svg class="son-anno son-anno-load" viewBox="0 0 320 110" preserveAspectRatio="none" aria-hidden="true"><path pathLength="1" style="stroke-width: 3;" d="M24,60 C16,30 92,10 168,9 C256,8 307,27 305,55 C303,86 234,102 148,100 C68,98 17,83 16,58 C15,37 54,21 110,15" /></svg></span> - without you recording a single video.
    </Fragment>
    <Fragment slot="subtitle">
      Done-for-you strategy, scripting, voiceover, production, and publishing. You get qualified leads without appearing on camera.
    </Fragment>
    <Fragment slot="image">
      <div class="son-pin">
        <HeroProofPanel />
      </div>
    </Fragment>
  </Hero>
  </div>

  <!-- Social Proof Bar *************** -->
  <section class="py-8 bg-slate-50 dark:bg-slate-800/50 border-y border-white/5">
    <div class="max-w-4xl mx-auto px-4">
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4 sm:gap-12 text-center">
        <div>
          <p class="text-3xl font-bold tabular-nums inline-flex items-end gap-2.5 text-[#c23f27] dark:text-[#e0755f]">3.25x<svg class="son-anno mb-0.5" width="32" height="28" viewBox="0 0 40 34" aria-hidden="true"><path d="M4,30 C12,27.5 23,19 31,6.5 M31,6.5 l-9.5,2 M31,6.5 l-0.5,10" /></svg></p>
          <p class="text-sm text-gray-600 dark:text-slate-400">more conversions than blog content</p>
        </div>
        <div class="hidden sm:block w-px h-12 bg-slate-300 dark:bg-slate-600"></div>
        <div>
          <p class="text-3xl font-bold text-gray-900 dark:text-white tabular-nums">90-120 days</p>
          <p class="text-sm text-gray-600 dark:text-slate-400">to meaningful traction</p>
        </div>
        <div class="hidden sm:block w-px h-12 bg-slate-300 dark:bg-slate-600"></div>
        <div>
          <p class="text-3xl font-bold text-gray-900 dark:text-white son-circ">No contracts<svg class="son-anno son-anno-reveal" viewBox="0 0 200 24" preserveAspectRatio="none" aria-hidden="true" style="top: auto; height: 0.15em; bottom: -0.16em;"><path pathLength="1" style="stroke-width: 2.6;" d="M5,10 C60,4 135,4 195,8 M18,17 C75,11.5 145,12 188,15" /></svg></p>
          <p class="text-sm text-gray-600 dark:text-slate-400">month-to-month, cancel anytime</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Who Benefits Most ************* -->

  <Features3
    title="YouTube acquisition works best for..."
    subtitle="Businesses with meaningful customer lifetime value and prospects who research before buying."
    columns={2}
    items={[
      {
        title: 'Coaching & Consulting',
        description: 'High-ticket programs where prospects research problems on YouTube before buying.',
        icon: 'tabler:school',
      },
      {
        title: 'Agencies & DFY Services',
        description: 'Businesses where one new client justifies months of acquisition investment.',
        icon: 'tabler:briefcase',
      },
      {
        title: 'Courses & Info Products',
        description: 'Knowledge products with strong margins and audiences who learn through video.',
        icon: 'tabler:book',
      },
      {
        title: 'Software Companies',
        description: 'B2B and B2C products with search demand and scalable revenue per user.',
        icon: 'tabler:cpu',
      },
    ]}
    classes={{ container: 'max-w-5xl' }}
  />

  <!-- ROI Calculator **************** -->

  <div id="roi-calculator" class="son-grid bg-gradient-to-br from-[#faf6f2] to-slate-50 dark:from-slate-900 dark:to-slate-800">
    <ROICalculator title="Check if the math works for your business" />
  </div>

  <!-- Case Study Showcase *********** -->

  <div class="son-grid-dark">
  <CaseStudyShowcase />
  </div>

  <!-- What We Do ******************** -->

  <div class="pt-20 pb-6">
    <div class="max-w-4xl mx-auto px-4">
      <svg viewBox="0 0 972 113" class="w-full" role="img" aria-label="Hand-drawn pipeline: search demand leads to video, video leads to viewer, viewer leads to customer">
        <g transform="scale(1.35)">
          <g fill="none" stroke="rgb(216 73 47)" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M138,42 C152,38 166,44 180,41 M180,41 l-8,-3 M180,41 l-6,6" />
            <path d="M304,42 C322,38 342,44 360,41 M360,41 l-8,-3 M360,41 l-6,6" />
            <path d="M516,42 C530,38 544,44 558,41 M558,41 l-8,-3 M558,41 l-6,6" />
          </g>
          <g font-family="Satoshi, sans-serif" font-weight="700" font-size="17" fill="currentColor" class="text-gray-900 dark:text-slate-200">
            <text x="10" y="48">search demand</text>
            <text x="188" y="48">ranked video</text>
            <text x="376" y="48">qualified viewer</text>
            <text x="568" y="48">customer</text>
          </g>
        </g>
      </svg>
    </div>
  </div>

  <Features
    id="features"
    tagline="What we handle"
    title='A complete YouTube acquisition <span class="son-circ">engine<svg class="son-anno son-anno-reveal" viewBox="0 0 320 110" preserveAspectRatio="none" aria-hidden="true"><path pathLength="1" style="stroke-width: 2.8;" d="M24,60 C16,30 92,10 168,9 C256,8 307,27 305,55 C303,86 234,102 148,100 C68,98 17,83 16,58 C15,37 54,21 110,15" /></svg></span>'
    subtitle="You focus on your business. We handle everything needed to turn YouTube into a customer acquisition channel."
    items={[
      {
        title: 'Strategy & topic selection',
        description:
          'We identify high-intent search queries and plan content that captures demand, not just views.',
        icon: 'tabler:target',
      },
      {
        title: 'Scripting & voiceover',
        description:
          'Scripts designed to convert, narrated by professional voiceover artists. No camera needed.',
        icon: 'tabler:microphone',
      },
      {
        title: 'Production & editing',
        description:
          'Storyboarded visuals, motion graphics, and editing that keeps viewers engaged.',
        icon: 'tabler:video',
      },
      {
        title: 'SEO & publishing',
        description:
          'Titles, descriptions, tags, and thumbnails optimized for search. Published to your channel.',
        icon: 'tabler:search',
      },
      {
        title: 'Reporting & iteration',
        description:
          "Clear updates on what's working and how we're adjusting to improve performance.",
        icon: 'tabler:chart-line',
      },
      {
        title: 'Consistent monthly output',
        description:
          'A predictable flow of acquisition-focused videos that compound over time.',
        icon: 'tabler:calendar-stats',
      },
    ]}
  />

  <!-- Why Switch ******************** -->

  <div class="son-grid bg-[#faf6f2] dark:bg-slate-900/40 py-14 md:py-16">
    <div class="max-w-3xl mx-auto px-4">
      <h3 class="text-center text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-10">
        Why founders switch from <span class="son-circ">ad agencies<svg class="son-anno son-anno-reveal" viewBox="0 0 200 24" preserveAspectRatio="none" aria-hidden="true" style="top: auto; height: 0.15em; bottom: -0.13em;"><path pathLength="1" style="stroke-width: 2.8;" d="M5,10 C60,4 135,4 195,8 M18,17 C75,11.5 145,12 188,15" /></svg></span>
      </h3>
      <div class="grid sm:grid-cols-2 gap-6">
        <div class="bg-white dark:bg-slate-800/60 rounded-xl p-6 ring-1 ring-black/5 dark:ring-white/10">
          <p class="text-sm font-semibold text-gray-500 dark:text-slate-400 uppercase tracking-wide mb-4">Typical ad agency</p>
          <ul class="space-y-3 text-sm text-gray-700 dark:text-slate-300">
            <li class="flex items-start gap-2.5">
              <svg class="son-mark son-mark-muted w-4 h-4 mt-0.5 flex-shrink-0" viewBox="0 0 16 16" aria-hidden="true"><path d="M3,3 L13,13 M13,3 L3,13" stroke-width="2" /></svg>
              Pay per click, stops the moment you stop paying
            </li>
            <li class="flex items-start gap-2.5">
              <svg class="son-mark son-mark-muted w-4 h-4 mt-0.5 flex-shrink-0" viewBox="0 0 16 16" aria-hidden="true"><path d="M3,3 L13,13 M13,3 L3,13" stroke-width="2" /></svg>
              Locked into 6-12 month contracts
            </li>
            <li class="flex items-start gap-2.5">
              <svg class="son-mark son-mark-muted w-4 h-4 mt-0.5 flex-shrink-0" viewBox="0 0 16 16" aria-hidden="true"><path d="M3,3 L13,13 M13,3 L3,13" stroke-width="2" /></svg>
              You're one of dozens of accounts on their roster
            </li>
          </ul>
        </div>
        <div class="son-pin bg-white dark:bg-slate-800/60 rounded-xl p-6 ring-1 ring-[rgb(216,73,47)]/25">
          <p class="text-sm font-semibold text-[rgb(194,63,39)] dark:text-[rgb(224,117,95)] uppercase tracking-wide mb-4">SellOnTube</p>
          <ul class="space-y-3 text-sm text-gray-900 dark:text-white font-medium">
            <li class="flex items-start gap-2.5">
              <svg class="son-mark w-4 h-4 mt-0.5 flex-shrink-0" viewBox="0 0 16 16" aria-hidden="true"><path d="M2,8 L6,12 L14,3" stroke-width="2" /></svg>
              Videos rank and keep converting long after you stop paying us
            </li>
            <li class="flex items-start gap-2.5">
              <svg class="son-mark w-4 h-4 mt-0.5 flex-shrink-0" viewBox="0 0 16 16" aria-hidden="true"><path d="M2,8 L6,12 L14,3" stroke-width="2" /></svg>
              Month-to-month, cancel anytime
            </li>
            <li class="flex items-start gap-2.5">
              <svg class="son-mark w-4 h-4 mt-0.5 flex-shrink-0" viewBox="0 0 16 16" aria-hidden="true"><path d="M2,8 L6,12 L14,3" stroke-width="2" /></svg>
              Small roster by design, your channel gets real attention
            </li>
          </ul>
        </div>
      </div>
    </div>
  </div>

  <!-- How We Think ****************** -->

  <Content
    isReversed
    tagline="Our approach"
    title='YouTube as <span class="son-circ">acquisition,<svg class="son-anno son-anno-reveal" viewBox="0 0 200 24" preserveAspectRatio="none" aria-hidden="true" style="top: auto; height: 0.15em; bottom: -0.13em;"><path pathLength="1" style="stroke-width: 2.8;" d="M5,10 C60,4 135,4 195,8 M18,17 C75,11.5 145,12 188,15" /></svg></span> not content marketing'
    items={[
      {
        title: 'Acquisition-first',
        description:
          'We design your channel around customer acquisition and business math, not entertainment metrics.',
      },
      {
        title: 'Compounding returns',
        description:
          'Videos rank for search terms and keep bringing qualified prospects month after month.',
      },
      {
        title: 'Low founder involvement',
        description:
          'You never need to get on camera, learn filming, or become a creator.',
      },
    ]}
    image={{
      src: dataVisualizationScreen,
      alt: 'Data visualization showing YouTube acquisition metrics and strategy performance',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">
        Built for businesses who want customers, not a YouTube 'presence'
      </h3>
      We treat your channel like an acquisition asset that should pay for itself.
    </Fragment>

    <Fragment slot="bg">
      <div class="absolute inset-0 bg-[#f7f3ec] dark:bg-transparent"></div>
    </Fragment>
  </Content>

  <!-- FAQs Widget ******************* -->

  <div class="son-grid">
  <FAQs
    title="Common Questions"
    tagline="FAQs"
    classes={{ container: 'max-w-4xl' }}
    items={[
      {
        title: 'Do I need to be on camera?',
        description:
          'No. We use professional voiceover and visual storytelling. You never need to appear on camera unless you want to.',
      },
      {
        title: 'How long before I see results?',
        description:
          'YouTube behaves like SEO. Early wins are possible, but the real value is in compounding. We aim for meaningful traction within 90-120 days.',
      },
      {
        title: 'How do you know if YouTube will work for my business?',
        description:
          'We analyse your market, offer, and search demand in a diagnostic call. If the economics don\'t support profitable acquisition, we\'ll tell you upfront.',
      },
      {
        title: 'What does working together look like?',
        description:
          'Each month we align on topics, collect inputs from you (calls, docs), then handle full production and publishing. Your involvement stays light.',
      },
      {
        title: 'How do you know my industry?',
        description:
          'We research deeply before we script. We study your market, competitors, and customer language. You review every script before production to ensure accuracy.',
      },
      {
        title: 'What if it doesn\'t work?',
        description:
          'We recommend a strategic review after 120 days. If the channel isn\'t showing traction or the economics don\'t justify continuing, we\'ll tell you. No long-term lock-in.',
      },
    ]}
  />
  </div>

  <!-- Latest Blog Posts ************* -->

  <BlogLatestPosts
    title="Latest from the blog"
    information="Strategies and insights on YouTube customer acquisition for search-driven businesses."
    count={6}
    linkText="Read the full playbook"
  />

  <!-- CallToAction Widget *********** -->

  <div class="son-grid son-anno-host">
  <CallToAction
    actions={[
      {
        variant: 'primary',
        text: 'Book a free diagnostic call',
        href: calLink,
        target: '_blank',
        rel: 'noopener noreferrer',
      },
    ]}
  >
    <Fragment slot="title">
      See if YouTube can be your next <span class="son-circ">acquisition&nbsp;channel<svg class="son-anno son-anno-reveal" viewBox="0 0 200 24" preserveAspectRatio="none" aria-hidden="true" style="top: auto; height: 0.15em; bottom: -0.13em;"><path pathLength="1" style="stroke-width: 3;" d="M5,10 C60,4 135,4 195,8 M18,17 C75,11.5 145,12 188,15" /></svg></span>
    </Fragment>

    <Fragment slot="subtitle">
      In 30 minutes, we'll evaluate whether YouTube makes sense for your business and show you what a search-driven approach would look like.
    </Fragment>
  </CallToAction>
  </div>

  <!-- Sticky Email Capture Bar -->
  <!-- <StickyEmailCapture /> -->

  <!-- Floating Action Button -->
  <FloatingEmailCapture />
</Layout>
