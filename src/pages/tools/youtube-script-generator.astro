<script>
  const APPS_SCRIPT_URL = 'https://script.google.com/macros/s/AKfycbwNJSU1oWry-OSkFGit4OCs1f_0W6KX9K9WASHhah5ZXcDSxjZWUQ5Uw2S4PSSoZhgD/exec';
  const GATE_EMAIL_DOMAINS = ['gmail.com', 'yahoo.com', 'hotmail.com', 'outlook.com', 'icloud.com', 'aol.com', 'protonmail.com', 'mail.com', 'ymail.com', 'live.com'];

  async function submitWaitlist(): Promise<void> {
    const emailInput = document.getElementById('waitlist-email') as HTMLInputElement;
    const errorEl = document.getElementById('waitlist-error') as HTMLElement;
    const btn = document.getElementById('waitlist-btn') as HTMLButtonElement;
    const email = emailInput.value.trim().toLowerCase();

    const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
    if (!emailRegex.test(email)) {
      errorEl.textContent = 'Please enter a valid email address.';
      errorEl.classList.remove('hidden');
      return;
    }

    const domain = email.split('@')[1];
    if (GATE_EMAIL_DOMAINS.includes(domain)) {
      errorEl.textContent = 'Please use a business email address (not Gmail, Yahoo, etc.)';
      errorEl.classList.remove('hidden');
      return;
    }

    errorEl.classList.add('hidden');
    btn.textContent = 'Submitting...';
    btn.setAttribute('disabled', 'true');

    try {
      await fetch(APPS_SCRIPT_URL, {
        method: 'POST',
        mode: 'no-cors',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email, source: 'youtube-script-generator-waitlist' }),
      });
    } catch { /* no-cors always resolves */ }

    window.dataLayer = window.dataLayer || [];
    window.dataLayer.push({ event: 'tool_waitlist_submitted', tool: 'youtube-script-generator' });

    const form = document.getElementById('waitlist-form') as HTMLElement;
    const success = document.getElementById('waitlist-success') as HTMLElement;
    form.classList.add('hidden');
    success.classList.remove('hidden');
  }

  document.getElementById('waitlist-btn')?.addEventListener('click', submitWaitlist);
  document.getElementById('waitlist-email')?.addEventListener('keydown', (e) => {
    if ((e as KeyboardEvent).key === 'Enter') submitWaitlist();
  });
</script>
