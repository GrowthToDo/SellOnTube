<script>
  // ===== CONSTANTS =====

  const RATE_LIMIT = 3;
  const COUNT_KEY = 'sot_competitor_analysis_count';
  const EMAIL_KEY = 'sot_competitor_analysis_email';
  const GATE_EMAIL_DOMAINS = ['gmail.com', 'yahoo.com', 'hotmail.com', 'outlook.com', 'icloud.com', 'aol.com', 'protonmail.com', 'mail.com', 'ymail.com', 'live.com'];
  const APPS_SCRIPT_URL = 'https://script.google.com/macros/s/AKfycbwNJSU1oWry-OSkFGit4OCs1f_0W6KX9K9WASHhah5ZXcDSxjZWUQ5Uw2S4PSSoZhgD/exec';

  // ===== BEATABLE HEURISTIC =====

  function getVideoSignal(viewCount: number, publishedAt: string): { color: string; label: string } {
    const ageMs = Date.now() - new Date(publishedAt).getTime();
    const ageMonths = ageMs / (1000 * 60 * 60 * 24 * 30.44);
    if (viewCount < 5000) return { color: 'green', label: 'Easy' };
    if (viewCount < 10000 && ageMonths > 12) return { color: 'green', label: 'Easy' };
    if (viewCount < 10000 && ageMonths <= 12) return { color: 'amber', label: 'New' };
    if (viewCount >= 10000 && viewCount <= 50000 && ageMonths > 18) return { color: 'amber', label: 'Stale' };
    if (viewCount >= 10000 && viewCount <= 50000 && ageMonths <= 18) return { color: 'red', label: 'Solid' };
    if (viewCount > 50000 && ageMonths < 12) return { color: 'red', label: 'Strong' };
    return { color: 'red', label: 'Solid' };
  }

  function formatAge(publishedAt: string): string {
    const ageMs = Date.now() - new Date(publishedAt).getTime();
    const totalMonths = Math.floor(ageMs / (1000 * 60 * 60 * 24 * 30.44));
    const years = Math.floor(totalMonths / 12);
    const months = totalMonths % 12;
    if (years === 0) return months + 'mo';
    if (months === 0) return years + 'y';
    return years + 'y ' + months + 'mo';
  }

  function formatViewCount(n: number): string {
    if (n >= 1000000) return (n / 1000000).toFixed(1) + 'M';
    if (n >= 1000) return (n / 1000).toFixed(1) + 'K';
    return n.toLocaleString();
  }

  // ===== STORAGE =====

  function getCount(): number { return parseInt(localStorage.getItem(COUNT_KEY) || '0', 10); }
  function incrementCount(): void { localStorage.setItem(COUNT_KEY, (getCount() + 1).toString()); }
  function isEmailSubmitted(): boolean { return localStorage.getItem(EMAIL_KEY) === 'true'; }
  function setEmailSubmitted(): void { localStorage.setItem(EMAIL_KEY, 'true'); }

  // ===== STEP MANAGEMENT =====

  const STEPS = ['step-input', 'step-loading', 'step-email-gate', 'step-results'];
  function showStep(id: string): void {
    STEPS.forEach((s) => {
      const el = document.getElementById(s);
      if (el) el.classList.toggle('hidden', s !== id);
    });
    if (id === 'step-results') {
      const heading = document.getElementById('result-keyword');
      heading?.focus();
    }
  }

  // ===== COUNTER LABEL =====

  function updateCounterLabel(): void {
    const label = document.getElementById('counter-label');
    if (!label) return;
    if (isEmailSubmitted()) {
      label.textContent = 'Unlimited checks unlocked';
      return;
    }
    const remaining = Math.max(0, RATE_LIMIT - getCount());
    label.textContent = remaining === 1 ? '1 free check remaining' : remaining + ' free checks remaining';
  }

  // ===== INLINE VALIDATION =====

  function showFieldError(fieldId: string, message: string): void {
    const input = document.getElementById(fieldId) as HTMLInputElement | null;
    const errorId = fieldId.replace('-input', '-error');
    const error = document.getElementById(errorId);
    if (input) input.setAttribute('aria-invalid', 'true');
    if (error) { error.textContent = message; error.classList.remove('hidden'); }
  }

  function clearFieldError(fieldId: string): void {
    const input = document.getElementById(fieldId) as HTMLInputElement | null;
    const errorId = fieldId.replace('-input', '-error');
    const error = document.getElementById(errorId);
    if (input) input.removeAttribute('aria-invalid');
    if (error) { error.textContent = ''; error.classList.add('hidden'); }
  }

  function validateInputs(): boolean {
    const keyword = (document.getElementById('keyword-input') as HTMLInputElement).value.trim();
    if (!keyword || keyword.length < 2) {
      showFieldError('keyword-input', 'Please enter a keyword to analyze.');
      return false;
    }
    clearFieldError('keyword-input');
    return true;
  }

  // ===== SIGNAL COLORS =====

  function signalClasses(color: string): { dot: string; bg: string; text: string; border: string } {
    if (color === 'green') return { dot: 'bg-emerald-500', bg: 'bg-emerald-500/10', text: 'text-emerald-600 dark:text-emerald-400', border: 'border-emerald-500/20' };
    if (color === 'amber') return { dot: 'bg-amber-500', bg: 'bg-amber-500/10', text: 'text-amber-600 dark:text-amber-400', border: 'border-amber-500/20' };
    return { dot: 'bg-rose-500', bg: 'bg-rose-500/10', text: 'text-rose-600 dark:text-rose-400', border: 'border-rose-500/20' };
  }

  // ===== ESCAPE HTML =====

  function escapeHtml(text: string): string {
    return text.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
  }

  // ===== RENDER RESULTS =====

  interface VideoResult {
    position: number;
    videoId: string;
    title: string;
    channelTitle: string;
    channelId: string;
    viewCount: number;
    publishedAt: string;
    isOwnVideo: boolean;
  }

  interface RankCheckResponse {
    keyword: string;
    channelId: string | null;
    rank: number | null;
    results: VideoResult[];
  }

  function getSignalExplanation(signal: { color: string; label: string }, views: string, age: string): string {
    switch (signal.label) {
      case 'Easy': return views + ' views in ' + age + '. Low traction, very beatable.';
      case 'New': return views + ' views in ' + age + '. Still growing, but catchable with better SEO.';
      case 'Stale': return views + ' views in ' + age + '. Decent views but aging. A fresh take could overtake it.';
      case 'Solid': return views + ' views in ' + age + '. Performing well. You need stronger content to compete.';
      case 'Strong': return views + ' views in ' + age + '. High performer. Very hard to outrank directly.';
      default: return views + ' views in ' + age + '.';
    }
  }

  function getVerdictAction(beatableCount: number, keyword: string): string {
    if (beatableCount >= 4) return 'Create a video targeting "' + keyword + '" this week. Optimize title, description, and tags for this exact keyword.';
    if (beatableCount >= 2) return 'Winnable with effort. Write a tighter script, use the exact keyword in your title, and add chapters.';
    return 'Try a long-tail variation like "' + keyword + ' for [your niche]" to find an easier opening.';
  }

  function getGapText(top5: VideoResult[]): string {
    const viewCounts = top5.map(v => v.viewCount).sort((a, b) => a - b);
    const lowestBeatable = viewCounts[0];
    const medianViews = viewCounts[Math.floor(viewCounts.length / 2)];

    if (lowestBeatable < 1000) return 'The weakest competitor has under 1K views. A well-optimized video should break into the top 5 within weeks.';
    if (lowestBeatable < 5000) return 'Target ' + formatViewCount(lowestBeatable) + '+ views in your first 30 days. Focus on click-through rate and watch time to signal relevance to YouTube.';
    if (medianViews < 20000) return 'Median competitor has ' + formatViewCount(medianViews) + ' views. You need strong SEO + a compelling hook to break through. Promote on other channels in the first 48 hours.';
    return 'Competitors average ' + formatViewCount(medianViews) + '+ views. This keyword demands high production value and an established audience. Consider a more specific angle.';
  }

  function renderResults(data: RankCheckResponse): void {
    const keywordEl = document.getElementById('result-keyword');
    if (keywordEl) keywordEl.textContent = '"' + data.keyword + '"';

    const top5 = data.results.slice(0, 5);

    const signals = top5.map(v => getVideoSignal(v.viewCount, v.publishedAt));
    const beatableCount = signals.filter(s => s.label === 'Easy' || s.label === 'New').length;

    // Verdict card
    const verdictCard = document.getElementById('verdict-card');
    const verdictScore = document.getElementById('verdict-score');
    const verdictText = document.getElementById('verdict-text');
    const verdictAction = document.getElementById('verdict-action');

    if (verdictCard && verdictScore && verdictText) {
      verdictScore.textContent = beatableCount + '/5 beatable';

      if (beatableCount >= 4) {
        verdictCard.className = 'rounded-xl p-5 bg-emerald-500/10 border border-emerald-500/20';
        verdictScore.className = 'text-2xl sm:text-3xl font-bold mb-2 text-emerald-600 dark:text-emerald-400';
        verdictText.className = 'text-sm font-medium text-emerald-600/80 dark:text-emerald-400/80';
        verdictText.textContent = 'High opportunity. The competition is weak for this keyword.';
      } else if (beatableCount >= 2) {
        verdictCard.className = 'rounded-xl p-5 bg-amber-500/10 border border-amber-500/20';
        verdictScore.className = 'text-2xl sm:text-3xl font-bold mb-2 text-amber-600 dark:text-amber-400';
        verdictText.className = 'text-sm font-medium text-amber-600/80 dark:text-amber-400/80';
        verdictText.textContent = 'Moderate opportunity. Some openings exist, but you need stronger content than what is ranking.';
      } else {
        verdictCard.className = 'rounded-xl p-5 bg-rose-500/10 border border-rose-500/20';
        verdictScore.className = 'text-2xl sm:text-3xl font-bold mb-2 text-rose-600 dark:text-rose-400';
        verdictText.className = 'text-sm font-medium text-rose-600/80 dark:text-rose-400/80';
        verdictText.textContent = 'Tough competition. Strong videos dominate this keyword.';
      }

      if (verdictAction) {
        verdictAction.textContent = getVerdictAction(beatableCount, data.keyword);
      }
    }

    // Competitor cards
    const list = document.getElementById('competitors-list');
    if (list) {
      list.innerHTML = top5.map((v, i) => {
        const signal = signals[i];
        const sc = signalClasses(signal.color);
        const age = formatAge(v.publishedAt);
        const views = formatViewCount(v.viewCount);
        const videoUrl = 'https://www.youtube.com/watch?v=' + encodeURIComponent(v.videoId);
        const explanation = getSignalExplanation(signal, views, age);

        return (
          '<div class="rounded-xl bg-gray-950 dark:bg-gray-950 p-4 sm:p-5 border border-slate-800/60">' +
            '<div class="flex items-start gap-3">' +
              '<span class="flex-shrink-0 w-7 h-7 rounded-full bg-slate-800 text-slate-400 text-xs font-bold flex items-center justify-center mt-0.5">' + (i + 1) + '</span>' +
              '<div class="min-w-0 flex-1">' +
                '<div class="flex items-start justify-between gap-3">' +
                  '<div class="min-w-0 flex-1">' +
                    '<a href="' + escapeHtml(videoUrl) + '" target="_blank" rel="noopener noreferrer" class="text-sm font-semibold text-white hover:text-emerald-400 transition-colors leading-snug block" data-video-title="' + i + '"></a>' +
                    '<p class="text-xs text-slate-500 mt-1" data-channel-name="' + i + '"></p>' +
                  '</div>' +
                  '<span class="flex-shrink-0 inline-flex items-center gap-1.5 text-[11px] font-semibold px-2.5 py-1 rounded-full ' + sc.bg + ' ' + sc.text + ' border ' + sc.border + '">' +
                    '<span class="w-1.5 h-1.5 rounded-full ' + sc.dot + '"></span>' +
                    escapeHtml(signal.label) +
                  '</span>' +
                '</div>' +
                '<div class="flex items-center gap-3 mt-2.5 pt-2.5 border-t border-slate-800/60">' +
                  '<p class="text-xs text-slate-400">' + escapeHtml(views) + ' views &middot; ' + escapeHtml(age) + ' old</p>' +
                '</div>' +
                '<p class="text-xs text-slate-500 mt-1.5 leading-relaxed">' + escapeHtml(explanation) + '</p>' +
              '</div>' +
            '</div>' +
          '</div>'
        );
      }).join('');

      list.querySelectorAll('[data-video-title]').forEach((el) => {
        const idx = parseInt((el as HTMLElement).dataset.videoTitle || '0', 10);
        (el as HTMLElement).textContent = top5[idx].title;
      });
      list.querySelectorAll('[data-channel-name]').forEach((el) => {
        const idx = parseInt((el as HTMLElement).dataset.channelName || '0', 10);
        (el as HTMLElement).textContent = top5[idx].channelTitle;
      });
    }

    // Gap analysis
    const gapText = document.getElementById('gap-text');
    if (gapText && top5.length > 0) {
      gapText.textContent = getGapText(top5);
    }

    // Next steps
    const nextSteps = document.getElementById('next-steps');
    if (nextSteps) {
      const kw = encodeURIComponent(data.keyword);
      nextSteps.innerHTML =
        '<a href="/tools/youtube-title-generator" class="flex items-center gap-3 p-3 rounded-lg border border-slate-200 dark:border-slate-700 hover:border-emerald-500/40 hover:bg-emerald-500/5 transition-colors group">' +
          '<div class="flex-shrink-0 w-8 h-8 rounded-lg bg-emerald-500/10 flex items-center justify-center"><svg class="w-4 h-4 text-emerald-500" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L10.582 16.07a4.5 4.5 0 01-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 011.13-1.897l8.932-8.931zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0115.75 21H5.25A2.25 2.25 0 013 18.75V8.25A2.25 2.25 0 015.25 6H10" /></svg></div>' +
          '<div><p class="text-sm font-semibold text-gray-900 dark:text-white group-hover:text-emerald-500 transition-colors">Write a winning title</p><p class="text-xs text-gray-500 dark:text-slate-400">Generate buyer-intent titles for this keyword</p></div>' +
        '</a>' +
        '<a href="/tools/youtube-description-generator?keyword=' + kw + '" class="flex items-center gap-3 p-3 rounded-lg border border-slate-200 dark:border-slate-700 hover:border-emerald-500/40 hover:bg-emerald-500/5 transition-colors group">' +
          '<div class="flex-shrink-0 w-8 h-8 rounded-lg bg-emerald-500/10 flex items-center justify-center"><svg class="w-4 h-4 text-emerald-500" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" /></svg></div>' +
          '<div><p class="text-sm font-semibold text-gray-900 dark:text-white group-hover:text-emerald-500 transition-colors">Optimize your description</p><p class="text-xs text-gray-500 dark:text-slate-400">SEO-optimized description with this keyword</p></div>' +
        '</a>' +
        '<a href="/tools/youtube-tag-generator" class="flex items-center gap-3 p-3 rounded-lg border border-slate-200 dark:border-slate-700 hover:border-emerald-500/40 hover:bg-emerald-500/5 transition-colors group">' +
          '<div class="flex-shrink-0 w-8 h-8 rounded-lg bg-emerald-500/10 flex items-center justify-center"><svg class="w-4 h-4 text-emerald-500" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M9.568 3H5.25A2.25 2.25 0 003 5.25v4.318c0 .597.237 1.17.659 1.591l9.581 9.581c.699.699 1.78.872 2.607.33a18.095 18.095 0 005.223-5.223c.542-.827.369-1.908-.33-2.607L11.16 3.66A2.25 2.25 0 009.568 3z" /><path stroke-linecap="round" stroke-linejoin="round" d="M6 6h.008v.008H6V6z" /></svg></div>' +
          '<div><p class="text-sm font-semibold text-gray-900 dark:text-white group-hover:text-emerald-500 transition-colors">Generate buyer-intent tags</p><p class="text-xs text-gray-500 dark:text-slate-400">Tags that help buyers find your video</p></div>' +
        '</a>' +
        '<a href="/tools/youtube-script-generator" class="flex items-center gap-3 p-3 rounded-lg border border-slate-200 dark:border-slate-700 hover:border-emerald-500/40 hover:bg-emerald-500/5 transition-colors group">' +
          '<div class="flex-shrink-0 w-8 h-8 rounded-lg bg-emerald-500/10 flex items-center justify-center"><svg class="w-4 h-4 text-emerald-500" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M3.375 19.5h17.25m-17.25 0a1.125 1.125 0 01-1.125-1.125M3.375 19.5h1.5C5.496 19.5 6 18.996 6 18.375m-3.75 0V5.625m0 12.75v-1.5c0-.621.504-1.125 1.125-1.125m18.375 2.625V5.625m0 12.75c0 .621-.504 1.125-1.125 1.125m1.125-1.125v-1.5c0-.621-.504-1.125-1.125-1.125m0 3.75h-1.5A1.125 1.125 0 0118 18.375M20.625 4.5H3.375m17.25 0c.621 0 1.125.504 1.125 1.125M20.625 4.5h-1.5C18.504 4.5 18 5.004 18 5.625m3.75 0v1.5c0 .621-.504 1.125-1.125 1.125M3.375 4.5c-.621 0-1.125.504-1.125 1.125M3.375 4.5h1.5C5.496 4.5 6 5.004 6 5.625m-3.75 0v1.5c0 .621.504 1.125 1.125 1.125m0 0h1.5m-1.5 0c-.621 0-1.125.504-1.125 1.125v1.5c0 .621.504 1.125 1.125 1.125m1.5-3.75C5.496 8.25 6 7.746 6 7.125v-1.5M4.875 8.25C5.496 8.25 6 8.754 6 9.375v1.5m0-5.25v5.25m0-5.25C6 5.004 6.504 4.5 7.125 4.5h9.75c.621 0 1.125.504 1.125 1.125m1.125 2.625h1.5m-1.5 0A1.125 1.125 0 0118 7.125v-1.5m1.125 2.625c-.621 0-1.125.504-1.125 1.125v1.5m2.625-2.625c.621 0 1.125.504 1.125 1.125v1.5c0 .621-.504 1.125-1.125 1.125M18 5.625v5.25M7.125 12h9.75m-9.75 0A1.125 1.125 0 016 10.875M7.125 12C6.504 12 6 12.504 6 13.125m0-2.25C6 11.496 5.496 12 4.875 12M18 10.875c0 .621-.504 1.125-1.125 1.125M18 10.875c0 .621.504 1.125 1.125 1.125m-2.25 0c.621 0 1.125.504 1.125 1.125m-12 5.25v-5.25m0 5.25c0 .621.504 1.125 1.125 1.125h9.75c.621 0 1.125-.504 1.125-1.125m-12 0v-1.5c0-.621-.504-1.125-1.125-1.125M18 18.375v-5.25m0 5.25v-1.5c0-.621.504-1.125 1.125-1.125M18 13.125v1.5c0 .621.504 1.125 1.125 1.125M18 13.125c0-.621.504-1.125 1.125-1.125M6 13.125v1.5c0 .621-.504 1.125-1.125 1.125M6 13.125C6 12.504 5.496 12 4.875 12m-1.5 0h1.5m-1.5 0c-.621 0-1.125-.504-1.125-1.125v-1.5c0-.621.504-1.125 1.125-1.125m1.5 2.625c0-.621-.504-1.125-1.125-1.125M19.5 12h1.5m0 0c.621 0 1.125-.504 1.125-1.125v-1.5c0-.621-.504-1.125-1.125-1.125m0 2.625h-1.5" /></svg></div>' +
          '<div><p class="text-sm font-semibold text-gray-900 dark:text-white group-hover:text-emerald-500 transition-colors">Write the script</p><p class="text-xs text-gray-500 dark:text-slate-400">Full buyer-intent script ready for recording</p></div>' +
        '</a>';
    }
  }

  // ===== API CALL =====

  async function fetchAnalysis(keyword: string): Promise<void> {
    const btn = document.getElementById('analyze-btn') as HTMLButtonElement;

    try {
      const res = await fetch('/api/youtube-rank-check', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ keyword, maxResults: 5 }),
      });

      if (res.status === 429) {
        showStep('step-input');
        btn.disabled = false;
        btn.textContent = 'Analyze Competition \u2192';
        showFieldError('keyword-input', 'AI is at capacity right now. Free daily limit reached. Please try again in a moment.');
        window.dataLayer = window.dataLayer || [];
        window.dataLayer.push({ event: 'tool_generate_error', tool: 'youtube-competitor-analysis', reason: 'quota_exceeded' });
        return;
      }

      if (!res.ok) throw new Error('API error ' + res.status);

      const data: RankCheckResponse = await res.json();

      if (!data.results || data.results.length === 0) {
        showStep('step-input');
        btn.disabled = false;
        btn.textContent = 'Analyze Competition \u2192';
        showFieldError('keyword-input', 'No YouTube results found for this keyword. Try a different search term.');
        return;
      }

      renderResults(data);
      incrementCount();
      updateCounterLabel();
      showStep('step-results');
      document.getElementById('step-results')?.scrollIntoView({ behavior: 'smooth', block: 'start' });

      window.dataLayer = window.dataLayer || [];
      window.dataLayer.push({ event: 'tool_generate_success', tool: 'youtube-competitor-analysis' });

    } catch {
      showStep('step-input');
      btn.disabled = false;
      btn.textContent = 'Analyze Competition \u2192';
      showFieldError('keyword-input', 'Something went wrong on our end. Please try again in a moment.');
      window.dataLayer = window.dataLayer || [];
      window.dataLayer.push({ event: 'tool_generate_error', tool: 'youtube-competitor-analysis', reason: 'api_error' });
    }
  }

  // ===== ANALYZE =====

  async function runAnalysis(): Promise<void> {
    if (!validateInputs()) return;

    const keyword = (document.getElementById('keyword-input') as HTMLInputElement).value.trim();

    // Email gate check
    if (getCount() >= RATE_LIMIT && !isEmailSubmitted()) {
      window.dataLayer = window.dataLayer || [];
      window.dataLayer.push({ event: 'tool_email_gate_shown', tool: 'youtube-competitor-analysis' });
      showStep('step-email-gate');
      return;
    }

    window.dataLayer = window.dataLayer || [];
    window.dataLayer.push({ event: 'tool_generate_click', tool: 'youtube-competitor-analysis' });

    const btn = document.getElementById('analyze-btn') as HTMLButtonElement;
    btn.disabled = true;
    btn.textContent = 'Analyzing...';
    showStep('step-loading');

    await fetchAnalysis(keyword);
  }

  // ===== EMAIL GATE =====

  async function submitGateEmail(): Promise<void> {
    const emailInput = document.getElementById('gate-email') as HTMLInputElement;
    const email = emailInput.value.trim().toLowerCase();
    const errorEl = document.getElementById('gate-email-error');

    const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
    if (!emailRegex.test(email)) {
      if (errorEl) { errorEl.textContent = 'Please enter a valid business email address.'; errorEl.classList.remove('hidden'); }
      return;
    }

    const domain = email.split('@')[1];
    if (GATE_EMAIL_DOMAINS.includes(domain)) {
      if (errorEl) { errorEl.textContent = 'Please use a business email address (not Gmail, Yahoo, etc.)'; errorEl.classList.remove('hidden'); }
      return;
    }

    if (errorEl) errorEl.classList.add('hidden');

    const btn = document.getElementById('gate-submit-btn') as HTMLButtonElement;
    btn.textContent = 'Submitting...';
    btn.setAttribute('disabled', 'true');

    try {
      await fetch(APPS_SCRIPT_URL, {
        method: 'POST',
        mode: 'no-cors',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email, source: 'youtube-competitor-analysis' }),
      });
    } catch { /* no-cors always resolves */ }

    setEmailSubmitted();
    updateCounterLabel();

    window.dataLayer = window.dataLayer || [];
    window.dataLayer.push({ event: 'tool_email_submitted', tool: 'youtube-competitor-analysis' });

    const form = document.getElementById('gate-form') as HTMLElement;
    const success = document.getElementById('gate-success') as HTMLElement;
    form.classList.add('hidden');
    success.classList.remove('hidden');

    setTimeout(() => {
      form.classList.remove('hidden');
      success.classList.add('hidden');
      btn.textContent = 'Continue Analyzing';
      btn.removeAttribute('disabled');
      emailInput.value = '';
      runAnalysis();
    }, 1200);
  }

  // ===== RESET =====

  function reset(): void {
    (document.getElementById('keyword-input') as HTMLInputElement).value = '';
    clearFieldError('keyword-input');
    showStep('step-input');
    (document.getElementById('keyword-input') as HTMLInputElement).focus();
    const btn = document.getElementById('analyze-btn') as HTMLButtonElement;
    btn.disabled = false;
    btn.textContent = 'Analyze Competition \u2192';
  }

  // ===== CTA TRACKING =====

  document.getElementById('results-cta')?.addEventListener('click', () => {
    window.dataLayer = window.dataLayer || [];
    window.dataLayer.push({ event: 'tool_cta_click', tool: 'youtube-competitor-analysis' });
  });

  // ===== EVENT LISTENERS =====

  document.getElementById('analyze-btn')?.addEventListener('click', runAnalysis);
  document.getElementById('reset-btn')?.addEventListener('click', reset);
  document.getElementById('gate-submit-btn')?.addEventListener('click', submitGateEmail);

  document.getElementById('keyword-input')?.addEventListener('keydown', (e) => {
    if ((e as KeyboardEvent).key === 'Enter') {
      e.preventDefault();
      runAnalysis();
    }
  });

  document.getElementById('gate-email')?.addEventListener('keydown', (e) => {
    if ((e as KeyboardEvent).key === 'Enter') submitGateEmail();
  });

  updateCounterLabel();
</script>
