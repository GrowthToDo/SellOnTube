<script>
  // ===== TYPE DECLARATIONS =====
  declare global { interface Window { dataLayer: Record<string, unknown>[]; } }

  interface KeywordResult {
    keyword: string;
    position: number | null;
    status: 'ranking' | 'within_reach' | 'not_found' | 'error';
    inTags: boolean;
    inTitle: boolean;
    inDescription: boolean;
  }

  interface VideoReport {
    video: {
      videoId: string;
      title: string;
      channel: string;
      thumbnail: string;
      tags: string[];
    };
    keywords: KeywordResult[];
    summary: {
      total: number;
      ranking: number;
      withinReach: number;
      notFound: number;
      grade: string;
    };
    recommendations: string[];
    suggestedTitle: string | null;
  }

  // ===== CONSTANTS =====

  const RATE_LIMIT = 3;
  const COUNT_KEY = 'sot_keyword_finder_count';
  const EMAIL_KEY = 'sot_tools_email_unlocked';
  const GATE_EMAIL_DOMAINS = ['gmail.com', 'yahoo.com', 'hotmail.com', 'outlook.com', 'icloud.com', 'aol.com', 'protonmail.com', 'mail.com', 'ymail.com', 'live.com'];
  const CAPTURE_URL = '/.netlify/functions/capture-email';
  const EXAMPLE_VIDEO = 'https://www.youtube.com/watch?v=dQw4w9WgXcQ';

  const LOADING_MESSAGES = [
    "Reading your video's metadata...",
    'Scanning YouTube autocomplete for real search terms...',
    'Selecting the 8 highest-intent keywords...',
    'Checking your position for each keyword...',
    'Building your keyword report...',
  ];

  // ===== STORAGE =====

  let currentReport: VideoReport | null = null;

  function getCount(): number { return parseInt(localStorage.getItem(COUNT_KEY) || '0', 10); }
  function incrementCount(): void { localStorage.setItem(COUNT_KEY, (getCount() + 1).toString()); }
  function isEmailSubmitted(): boolean { return localStorage.getItem(EMAIL_KEY) === 'true'; }
  function setEmailSubmitted(): void { localStorage.setItem(EMAIL_KEY, 'true'); }

  function getCachedReport(videoId: string): VideoReport | null {
    try {
      const raw = sessionStorage.getItem(`sot_kwf_${videoId}`);
      return raw ? JSON.parse(raw) : null;
    } catch { return null; }
  }

  function setCachedReport(videoId: string, report: VideoReport): void {
    try { sessionStorage.setItem(`sot_kwf_${videoId}`, JSON.stringify(report)); } catch { /* quota */ }
  }

  // ===== STEP MANAGEMENT =====

  const STEPS = ['step-input', 'step-loading', 'step-email-gate', 'step-results'];
  function showStep(id: string): void {
    STEPS.forEach((s) => {
      const el = document.getElementById(s);
      if (el) el.classList.toggle('hidden', s !== id);
    });
    if (id === 'step-results') {
      document.getElementById('video-title')?.focus();
    }
  }

  // ===== COUNTER LABEL =====

  function updateCounterLabel(): void {
    const label = document.getElementById('counter-label');
    if (!label) return;
    if (isEmailSubmitted()) {
      label.textContent = 'Unlimited reports unlocked';
      return;
    }
    const remaining = Math.max(0, RATE_LIMIT - getCount());
    label.textContent = remaining === 1 ? '1 free report remaining' : remaining + ' free reports remaining';
  }

  // ===== LOADING STATE =====

  let loadingInterval: ReturnType<typeof setInterval> | null = null;

  function startLoadingMessages(): void {
    let index = 0;
    const statusEl = document.getElementById('loading-status');
    if (statusEl) statusEl.textContent = LOADING_MESSAGES[0];

    loadingInterval = setInterval(() => {
      index = (index + 1) % LOADING_MESSAGES.length;
      if (statusEl) statusEl.textContent = LOADING_MESSAGES[index];
    }, 2500);
  }

  function stopLoadingMessages(): void {
    if (loadingInterval) {
      clearInterval(loadingInterval);
      loadingInterval = null;
    }
  }

  // ===== VALIDATION =====

  function showError(message: string): void {
    const error = document.getElementById('url-error');
    const input = document.getElementById('video-url-input') as HTMLInputElement;
    if (input) input.setAttribute('aria-invalid', 'true');
    if (error) { error.textContent = message; error.classList.remove('hidden'); }
  }

  function clearError(): void {
    const error = document.getElementById('url-error');
    const input = document.getElementById('video-url-input') as HTMLInputElement;
    if (input) input.removeAttribute('aria-invalid');
    if (error) { error.textContent = ''; error.classList.add('hidden'); }
  }

  function extractVideoIdClient(input: string): string | null {
    const trimmed = input.trim();
    if (/^[a-zA-Z0-9_-]{11}$/.test(trimmed)) return trimmed;

    try {
      const url = new URL(trimmed.startsWith('http') ? trimmed : 'https://' + trimmed);
      const vParam = url.searchParams.get('v');
      if (vParam && /^[a-zA-Z0-9_-]{11}$/.test(vParam)) return vParam;

      const pathPatterns = [
        /\/(?:embed|shorts|v)\/([a-zA-Z0-9_-]{11})/,
        /^\/([a-zA-Z0-9_-]{11})$/,
      ];
      for (const pattern of pathPatterns) {
        const match = url.pathname.match(pattern);
        if (match) return match[1];
      }
      if (url.hostname === 'youtu.be') {
        const id = url.pathname.slice(1).split('/')[0];
        if (/^[a-zA-Z0-9_-]{11}$/.test(id)) return id;
      }
    } catch { /* not a URL */ }

    return null;
  }

