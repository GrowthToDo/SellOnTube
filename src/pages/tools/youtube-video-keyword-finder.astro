---
import Layout from '~/layouts/PageLayout.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import { SITE } from 'astrowind:config';

const siteUrl = SITE.site || 'https://sellontube.com';

const metadata = {
  title: 'Free YouTube Video Keyword Finder for Business',
  description:
    'Find every keyword your YouTube video ranks for. Paste any URL, see your exact positions, and discover hidden ranking opportunities. Free, no signup.',
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": siteUrl },
    { "@type": "ListItem", "position": 2, "name": "Tools", "item": `${siteUrl}/tools` },
    { "@type": "ListItem", "position": 3, "name": "YouTube Video Keyword Finder", "item": `${siteUrl}/tools/youtube-video-keyword-finder` }
  ]
};

const webAppSchema = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "SellonTube YouTube Video Keyword Finder",
  "url": `${siteUrl}/tools/youtube-video-keyword-finder`,
  "description": "Find every keyword your YouTube video ranks for. Paste any URL, see your exact positions, and discover hidden ranking opportunities. Free, no signup.",
  "applicationCategory": "SEOApplication",
  "operatingSystem": "Any",
  "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
  "provider": { "@type": "Organization", "name": "SellonTube", "url": siteUrl }
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    { "@type": "Question", "name": "Is this tool free?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. You get 3 free keyword reports without any signup. After that, enter your business email to keep discovering your video keywords. There is no paid tier." } },
    { "@type": "Question", "name": "How do I find what keywords my YouTube video ranks for?", "acceptedAnswer": { "@type": "Answer", "text": "Paste your video URL into the tool above. It extracts your video's metadata, scans YouTube autocomplete for real search terms related to your topic, checks your position for each keyword, and gives you a complete report in under 15 seconds. No login required." } },
    { "@type": "Question", "name": "Can I check a competitor's video?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. Paste any public YouTube video URL. Many business owners use this to reverse-engineer which keywords a competitor's top video ranks for, then target the same keywords with better content." } },
    { "@type": "Question", "name": "How accurate are the keyword suggestions?", "acceptedAnswer": { "@type": "Answer", "text": "The keywords come from YouTube's own autocomplete system, which reflects real search behavior. The ranking positions are checked against live YouTube search results in real time. The keyword list is a focused selection of your 8 highest buyer-intent ranking terms, not every possible keyword." } },
    { "@type": "Question", "name": "How is this different from VidIQ or TubeBuddy?", "acceptedAnswer": { "@type": "Answer", "text": "Three differences. First, VidIQ and TubeBuddy show rankings only for the tags already on your video. This tool generates keywords independently. Second, this tool uses real YouTube autocomplete data instead of fabricated search volume numbers. Third, VidIQ and TubeBuddy cost $20-49/month for rank tracking. This tool is free." } },
    { "@type": "Question", "name": "Does YouTube show you what keywords your video ranks for?", "acceptedAnswer": { "@type": "Answer", "text": "YouTube Studio shows search terms that drove clicks to your video, but only for the last 28 days, only for keywords that reached a minimum traffic threshold, and without position data. Small channels and B2B channels often see almost no search term data because their traffic is too low to meet YouTube's thresholds." } },
    { "@type": "Question", "name": "How often should I run this?", "acceptedAnswer": { "@type": "Answer", "text": "Check after publishing a new video to see if it's picking up search visibility. Check again 2 weeks later to see how positions have shifted. Run it on your top 5 videos quarterly to catch ranking changes." } },
    { "@type": "Question", "name": "Why only 8 keywords?", "acceptedAnswer": { "@type": "Answer", "text": "Each keyword check queries YouTube's search results in real time. Eight buyer-intent keywords gives a focused picture of your video's commercial search visibility while keeping the tool fast and free. For a deeper analysis, book a diagnostic call." } },

    { "@type": "Question", "name": "Can I see what keywords a competitor's YouTube video ranks for?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. This works on any public video. Paste a competitor's video URL, see which keywords they rank for, and use the results to find gaps in your own content strategy." } },
    { "@type": "Question", "name": "How to find what keywords a YouTube video ranks for without paying", "acceptedAnswer": { "@type": "Answer", "text": "This tool does it for free. Paste any video URL and get an 8-keyword buyer-intent report with real-time positions. The alternative is manually searching keywords one by one in an incognito browser, which works but takes 20-30 minutes per video. Paid tools like VidIQ and TubeBuddy charge $20-49/month and only check keywords already in your tags." } },
    { "@type": "Question", "name": "Can I use this for YouTube keyword research?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. Run it on 3-5 top-ranking videos in your niche. The keywords they rank for are proven search terms. Compile the results into a keyword list for your next video. This is faster and more accurate than guessing keywords or using search volume estimates." } },
    { "@type": "Question", "name": "Why is my YouTube video not showing up in search?", "acceptedAnswer": { "@type": "Answer", "text": "Three common causes. First, your metadata (title, description, tags) does not include the keywords people are searching. This tool shows you exactly which keywords are missing. Second, stronger competitors own the top positions. Third, your video is too new. YouTube typically takes 1-2 weeks to fully index and rank a video." } },
    { "@type": "Question", "name": "How many keywords should a YouTube video target?", "acceptedAnswer": { "@type": "Answer", "text": "One primary keyword in the title, 2-3 secondary keywords in the description, and 8-15 tags covering variations and related terms. This tool helps you identify which of those keywords are actually working and which are missing from your metadata." } },
  ]
};
---

<Layout metadata={metadata}>
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(webAppSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

  <!-- Hero -->
  <section class="bg-white dark:bg-slate-950 pt-16 pb-12 sm:pt-20 sm:pb-16">
    <div class="max-w-3xl mx-auto px-4 text-center">
      <div class="flex flex-wrap justify-center gap-2 mb-6">
        <span class="inline-flex items-center text-xs font-semibold text-emerald-400 bg-emerald-500/10 border border-emerald-500/20 rounded-full px-3 py-1">8 buyer-intent keywords</span>
        <span class="inline-flex items-center text-xs font-semibold text-emerald-400 bg-emerald-500/10 border border-emerald-500/20 rounded-full px-3 py-1">Real-time positions</span>
        <span class="inline-flex items-center text-xs font-semibold text-emerald-400 bg-emerald-500/10 border border-emerald-500/20 rounded-full px-3 py-1">Built for B2B</span>
      </div>
      <h1 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-gray-900 dark:text-white leading-tight mb-4">
        Free YouTube Video Keyword Finder<br class="hidden sm:block" /> for Business
      </h1>
      <p class="text-gray-500 dark:text-slate-400 text-base sm:text-lg max-w-xl mx-auto">
        Paste any video URL and discover every keyword it ranks for in YouTube search. See your exact positions and find the keywords you are missing.
      </p>
    </div>
  </section>

  <!-- Tool -->
  <section class="bg-white dark:bg-slate-950 pb-20">
    <div id="tool-container" class="max-w-xl mx-auto px-4">

      <!-- Step: Input -->
      <div id="step-input" class="rounded-2xl border border-slate-200 dark:border-slate-700 bg-slate-50 dark:bg-slate-900 p-6 sm:p-8">
        <div class="space-y-5">
          <div>
            <label for="video-url-input" class="block text-xs font-semibold uppercase tracking-wider text-gray-500 dark:text-slate-400 mb-2">
              YouTube video URL
            </label>
            <input
              type="text"
              id="video-url-input"
              placeholder="https://www.youtube.com/watch?v=..."
              class="w-full text-base font-medium px-4 py-3 rounded-xl border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-800 text-gray-900 dark:text-white placeholder-gray-400 dark:placeholder-slate-500
                     focus:ring-1 focus:ring-emerald-500 focus:border-emerald-500 outline-none transition-colors"
              aria-describedby="url-helper url-error"
            />
            <p id="url-helper" class="mt-1.5 text-xs text-gray-400 dark:text-slate-600">
              Any public YouTube video URL or video ID. Works with your videos and competitor videos.
            </p>
            <p id="url-error" class="hidden mt-1.5 text-xs text-rose-600 dark:text-rose-400" role="alert"></p>
          </div>

          <button
            id="try-example-btn"
            class="text-xs font-medium text-emerald-600 dark:text-emerald-400 hover:underline cursor-pointer"
          >
            Try with an example video
          </button>
        </div>

        <button
          id="generate-btn"
          class="mt-7 w-full inline-flex items-center justify-center rounded-xl px-6 py-3.5 text-base font-bold
                 bg-emerald-500 text-white dark:text-slate-950 hover:bg-emerald-400 transition-colors"
        >
          Find my ranking keywords &rarr;
        </button>

        <p id="counter-label" class="mt-3 text-center text-xs text-gray-400 dark:text-slate-600">
          3 free reports remaining
        </p>
      </div>

      <!-- Step: Loading -->
      <div
        id="step-loading"
        class="hidden rounded-2xl border border-slate-200 dark:border-slate-700 bg-slate-50 dark:bg-slate-900 p-6 sm:p-8 text-center"
      >
        <div class="flex flex-col items-center gap-4 py-10">
          <div class="w-10 h-10 border-[3px] border-emerald-500 border-t-transparent rounded-full animate-spin"></div>
          <p id="loading-status" class="text-sm font-medium text-gray-500 dark:text-slate-400">Reading your video's metadata...</p>
          <p class="text-xs text-gray-400 dark:text-slate-600">This usually takes 10-15 seconds</p>
        </div>
      </div>

      <!-- Step: Email Gate -->
      <div
        id="step-email-gate"
        class="hidden rounded-2xl border border-slate-200 dark:border-slate-700 bg-slate-50 dark:bg-slate-900 p-6 sm:p-8"
      >
        <div class="text-center mb-6">
          <p class="text-base font-semibold text-gray-900 dark:text-white mb-2">You've used your 3 free reports</p>
          <p class="text-sm text-gray-500 dark:text-slate-400">
            Enter your business email to keep discovering your video keywords. It's free.
          </p>
        </div>
        <div id="gate-form" class="space-y-3">
          <input
            type="email"
            id="gate-email"
            placeholder="your@company.com"
            class="w-full px-4 py-3 rounded-xl border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-800 text-gray-900 dark:text-white placeholder-gray-400 dark:placeholder-slate-500
                   focus:ring-1 focus:ring-emerald-500 focus:border-emerald-500 outline-none"
            aria-describedby="gate-email-error"
          />
          <p id="gate-email-error" class="hidden text-xs text-rose-600 dark:text-rose-400" role="alert"></p>
          <button
            id="gate-submit-btn"
            class="w-full inline-flex items-center justify-center rounded-xl px-6 py-3.5 text-base font-bold
                   bg-emerald-500 text-white dark:text-slate-950 hover:bg-emerald-400 transition-colors"
          >
            Unlock unlimited reports
          </button>
          <p class="text-center text-xs text-gray-400 dark:text-slate-600">No spam. We'll only send you content marketing resources from SellonTube.</p>
        </div>
        <div id="gate-success" class="hidden text-center mt-4">
          <p class="text-sm font-semibold text-emerald-600 dark:text-emerald-400">You're in. Generating your report now...</p>
        </div>
      </div>

    </div>

    <!-- Step: Results -->
    <div
      id="step-results"
      class="hidden max-w-2xl mx-auto px-4 mt-2 space-y-3"
      role="status"
      aria-live="polite"
    >
      <!-- Video + Grade + Stats -->
      <div class="rounded-2xl bg-white dark:bg-slate-900 border border-slate-200/80 dark:border-slate-700/80 shadow-sm overflow-hidden">
        <div class="p-5 sm:p-6">
          <div class="flex gap-4">
            <img id="video-thumbnail" src="" alt="" class="w-24 sm:w-28 aspect-video rounded-xl object-cover flex-shrink-0" loading="lazy" />
            <div class="flex-1 min-w-0 flex flex-col justify-center">
              <p id="video-title" tabindex="-1" class="text-sm font-semibold text-gray-900 dark:text-white leading-snug line-clamp-2 mb-1"></p>
              <p id="video-channel" class="text-xs text-gray-500 dark:text-slate-400"></p>
            </div>
            <div id="grade-badge" class="flex-shrink-0 w-14 h-14 rounded-2xl flex items-center justify-center text-2xl font-black"></div>
          </div>
        </div>
        <div class="px-5 sm:px-6 py-3 bg-slate-50/80 dark:bg-slate-800/30 border-t border-slate-100 dark:border-slate-800 flex flex-wrap items-center gap-x-5 gap-y-1">
          <span class="text-xs text-gray-500 dark:text-slate-400"><span id="stat-total" class="font-bold text-gray-800 dark:text-white">0</span> checked</span>
          <span class="text-xs text-gray-500 dark:text-slate-400"><span class="inline-block w-1.5 h-1.5 rounded-full bg-emerald-500 mr-1 align-middle"></span><span id="stat-ranking" class="font-bold text-emerald-600 dark:text-emerald-400">0</span> top 5</span>
          <span class="text-xs text-gray-500 dark:text-slate-400"><span class="inline-block w-1.5 h-1.5 rounded-full bg-amber-400 mr-1 align-middle"></span><span id="stat-within-reach" class="font-bold text-amber-600 dark:text-amber-400">0</span> within reach</span>
          <span class="text-xs text-gray-500 dark:text-slate-400"><span class="inline-block w-1.5 h-1.5 rounded-full bg-rose-400 mr-1 align-middle"></span><span id="stat-not-found" class="font-bold text-rose-500 dark:text-rose-400">0</span> invisible</span>
        </div>
      </div>

      <!-- Keywords -->
      <div class="rounded-2xl bg-white dark:bg-slate-900 border border-slate-200/80 dark:border-slate-700/80 shadow-sm overflow-hidden">
        <div class="px-5 sm:px-6 pt-5 pb-1">
          <p class="text-[11px] font-semibold text-gray-400 dark:text-slate-500 uppercase tracking-wider">Keyword positions</p>
        </div>

        <div id="keywords-ranking"></div>
        <div id="keywords-within-reach"></div>
        <div id="keywords-not-found"></div>

        <div class="px-5 sm:px-6 py-3.5 border-t border-slate-100 dark:border-slate-800 flex flex-wrap items-center gap-2">
          <button id="copy-report-btn" class="px-3 py-1.5 rounded-lg text-[11px] font-semibold text-gray-500 dark:text-slate-400 bg-slate-50 dark:bg-slate-800 hover:bg-emerald-50 hover:text-emerald-600 dark:hover:bg-emerald-900/20 dark:hover:text-emerald-400 transition-colors">Copy report</button>
          <button id="download-csv-btn" class="px-3 py-1.5 rounded-lg text-[11px] font-semibold text-gray-500 dark:text-slate-400 bg-slate-50 dark:bg-slate-800 hover:bg-emerald-50 hover:text-emerald-600 dark:hover:bg-emerald-900/20 dark:hover:text-emerald-400 transition-colors">Download CSV</button>
        </div>
        <div id="csv-email-gate" class="hidden px-5 sm:px-6 pb-4">
          <div class="rounded-xl bg-slate-50 dark:bg-slate-800/50 p-4">
            <p class="text-xs font-semibold text-gray-700 dark:text-slate-300 mb-2">Enter your business email to download</p>
            <div class="flex gap-2">
              <input type="email" id="csv-gate-email" placeholder="your@company.com"
                class="flex-1 px-3 py-2 rounded-lg border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-900 text-sm text-gray-900 dark:text-white placeholder-gray-400 dark:placeholder-slate-500 focus:ring-1 focus:ring-emerald-500 focus:border-emerald-500 outline-none" />
              <button id="csv-gate-submit" class="px-4 py-2 rounded-lg bg-emerald-500 text-white dark:text-slate-950 text-xs font-bold hover:bg-emerald-400 transition-colors">Unlock</button>
            </div>
            <p id="csv-gate-error" class="hidden mt-1.5 text-xs text-rose-600 dark:text-rose-400"></p>
          </div>
        </div>
      </div>

      <!-- What to fix -->
      <div id="fixes-section" class="hidden rounded-2xl bg-white dark:bg-slate-900 border border-slate-200/80 dark:border-slate-700/80 shadow-sm overflow-hidden">
        <div class="p-5 sm:p-6">
          <p class="text-[11px] font-semibold text-gray-400 dark:text-slate-500 uppercase tracking-wider mb-4">What to fix</p>

          <!-- Suggested title -->
          <div id="suggested-title-block" class="hidden mb-5">
            <p class="text-[10px] font-semibold text-gray-400 dark:text-slate-500 uppercase tracking-wide mb-2">Suggested title</p>
            <div class="rounded-xl bg-emerald-50/50 dark:bg-emerald-900/10 border border-emerald-200/60 dark:border-emerald-800/30 p-4 flex items-start gap-3">
              <p id="suggested-title-text" class="flex-1 text-sm font-medium text-gray-800 dark:text-slate-200 leading-relaxed"></p>
              <button id="copy-suggested-title" class="flex-shrink-0 text-gray-400 dark:text-slate-500 hover:text-emerald-600 dark:hover:text-emerald-400 transition-colors mt-0.5">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg>
              </button>
            </div>
          </div>

          <!-- Action items -->
          <div id="fixes-list" class="space-y-1 divide-y divide-slate-100 dark:divide-slate-800"></div>
        </div>
      </div>

      <!-- Next steps -->
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
        <a href="/tools/youtube-seo-tool" class="group rounded-2xl bg-white dark:bg-slate-900 border border-slate-200/80 dark:border-slate-700/80 shadow-sm p-5 hover:border-emerald-500/30 hover:shadow-md transition-all tool-cta-link" data-destination="seo-tool">
          <p class="text-sm font-semibold text-gray-900 dark:text-white group-hover:text-emerald-600 dark:group-hover:text-emerald-400 transition-colors mb-1">Run a full SEO audit</p>
          <p class="text-xs text-gray-500 dark:text-slate-400">Get title, description, and tag rewrites for this video.</p>
        </a>
        <a href="/tools/youtube-ranking-checker" class="group rounded-2xl bg-white dark:bg-slate-900 border border-slate-200/80 dark:border-slate-700/80 shadow-sm p-5 hover:border-emerald-500/30 hover:shadow-md transition-all tool-cta-link" data-destination="ranking-checker">
          <p class="text-sm font-semibold text-gray-900 dark:text-white group-hover:text-emerald-600 dark:group-hover:text-emerald-400 transition-colors mb-1">Check a specific keyword</p>
          <p class="text-xs text-gray-500 dark:text-slate-400">See who you are competing against and their view counts.</p>
        </a>
      </div>

      <!-- Reset -->
      <button id="reset-btn" class="w-full py-2.5 text-xs font-medium text-gray-400 dark:text-slate-500 hover:text-gray-600 dark:hover:text-slate-300 transition-colors">
        &larr; Check another video
      </button>
    </div>
  </section>

  <!-- How it works: 3 steps -->
  <section class="py-10 sm:py-12 border-t border-slate-100 dark:border-slate-800">
    <div class="max-w-3xl mx-auto px-4">
      <div class="relative grid grid-cols-1 sm:grid-cols-3 gap-6 sm:gap-4">
        <!-- Connecting line (desktop) -->
        <div class="hidden sm:block absolute top-5 left-[calc(16.67%+20px)] right-[calc(16.67%+20px)] h-px bg-emerald-200 dark:bg-emerald-800" aria-hidden="true"></div>

        <div class="relative flex sm:flex-col items-center sm:text-center gap-4 sm:gap-0">
          <div class="flex-shrink-0 w-10 h-10 rounded-full bg-emerald-500/10 border border-emerald-500/20 text-emerald-600 dark:text-emerald-400 text-sm font-bold flex items-center justify-center relative z-10 bg-white dark:bg-slate-950">1</div>
          <div class="sm:mt-3">
            <p class="text-sm font-semibold text-gray-900 dark:text-white">Paste any video URL</p>
            <p class="text-xs text-gray-500 dark:text-slate-400 mt-0.5">Your own or a competitor's</p>
          </div>
        </div>

        <div class="relative flex sm:flex-col items-center sm:text-center gap-4 sm:gap-0">
          <div class="flex-shrink-0 w-10 h-10 rounded-full bg-emerald-500/10 border border-emerald-500/20 text-emerald-600 dark:text-emerald-400 text-sm font-bold flex items-center justify-center relative z-10 bg-white dark:bg-slate-950">2</div>
          <div class="sm:mt-3">
            <p class="text-sm font-semibold text-gray-900 dark:text-white">We find and check 8 buyer-intent keywords</p>
            <p class="text-xs text-gray-500 dark:text-slate-400 mt-0.5">Real autocomplete data, real positions</p>
          </div>
        </div>

        <div class="relative flex sm:flex-col items-center sm:text-center gap-4 sm:gap-0">
          <div class="flex-shrink-0 w-10 h-10 rounded-full bg-emerald-500 text-white text-sm font-bold flex items-center justify-center relative z-10">3</div>
          <div class="sm:mt-3">
            <p class="text-sm font-semibold text-gray-900 dark:text-white">Get your keyword report</p>
            <p class="text-xs text-gray-500 dark:text-slate-400 mt-0.5">Rankings, metadata gaps, and what to fix</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Methodology -->
  <section class="py-14 sm:py-16 bg-white dark:bg-slate-950">
    <div class="max-w-2xl mx-auto px-4">
      <h2 class="text-xl font-bold text-gray-900 dark:text-white mb-6">How the YouTube keyword finder works</h2>

      <div class="space-y-4 text-gray-600 dark:text-slate-400 leading-relaxed mb-10">
        <p>The tool extracts seed terms from your video's title and runs them through YouTube's autocomplete system to find real search terms people type. AI then selects the 8 highest buyer-intent keywords from those results and checks your actual position for each one in real time.</p>
        <p>This is an intelligent scan, not an exhaustive index. YouTube does not provide a "show all ranking keywords" endpoint to anyone. The difference is that this tool is transparent about that fact, while others present estimates as definitive data.</p>
      </div>

      <h3 class="text-base font-semibold text-gray-900 dark:text-white mb-3">Why autocomplete data instead of "search volume"</h3>
      <div class="rounded-xl border border-slate-200 dark:border-slate-700 bg-slate-50 dark:bg-slate-900 p-5 mb-10">
        <p class="text-sm text-gray-600 dark:text-slate-400 leading-relaxed">YouTube's API does not share search volume data with any third party. Every "search volume" number in VidIQ or TubeBuddy is an estimate, and their estimates frequently contradict each other. This tool skips the made-up numbers and focuses on what is verifiable: does your video appear when someone searches this term?</p>
      </div>

      <h3 class="text-base font-semibold text-gray-900 dark:text-white mb-3">The problem this solves for business channels</h3>
      <div class="rounded-xl border border-slate-200 dark:border-slate-700 bg-slate-50 dark:bg-slate-900 p-5">
        <p class="text-sm text-gray-600 dark:text-slate-400 leading-relaxed mb-3">YouTube Studio only shows search terms that drove clicks, not all keywords you appear for. B2B channels with lower view counts see even less data because YouTube hides metrics below undisclosed thresholds.</p>
        <p class="text-sm text-gray-600 dark:text-slate-400 leading-relaxed">The alternative was manually searching keywords one by one in incognito, or paying $99/month for rank tracking. This tool gives you an 8-keyword scan in seconds, for free. For manual methods and how this tool compares, read our guide on <a href="/blog/how-to-find-youtube-video-ranking-keywords" class="text-emerald-600 dark:text-emerald-400 font-medium hover:underline">how to find what keywords your YouTube videos rank for</a>.</p>
      </div>
    </div>
  </section>

  <!-- Comparison Table -->
  <section class="py-16 sm:py-20 bg-white dark:bg-slate-950">
    <div class="max-w-4xl mx-auto px-4">
      <h2 class="text-xl font-bold text-gray-900 dark:text-white mb-6 text-center">How this compares to other keyword tools</h2>
