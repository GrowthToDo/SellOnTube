  // ===== QUICK FIXES =====

  interface QuickFix {
    priority: number; // 1=title, 2=description, 3=tags
    text: string;
  }

  function generateQuickFixes(report: VideoReport): QuickFix[] {
    const fixes: QuickFix[] = [];

    for (const kw of report.keywords) {
      const escaped = kw.keyword.replace(/</g, '&lt;').replace(/>/g, '&gt;');

      // Title fixes: ranking keywords (top 5) missing from title
      if (kw.status === 'ranking' && kw.position && !kw.inTitle) {
        fixes.push({
          priority: 1,
          text: `You rank #${kw.position} for "${escaped}" but it is not in your title. Add it to strengthen your position.`,
        });
      }

      // Description fixes: within-reach keywords missing from description
      if (kw.status === 'within_reach' && kw.position && !kw.inDescription) {
        fixes.push({
          priority: 2,
          text: `You are at #${kw.position} for "${escaped}". Add this keyword to the first two lines of your description.`,
        });
      }

      // Tag fixes: any keyword not in tags
      if (!kw.inTags && (kw.status === 'ranking' || kw.status === 'within_reach')) {
        fixes.push({
          priority: 3,
          text: `Add "${escaped}" to your video tags.`,
        });
      }
    }

    // Sort by priority (title first, then description, then tags)
    fixes.sort((a, b) => a.priority - b.priority);
    return fixes;
  }

  function renderFixes(report: VideoReport): void {
    const section = document.getElementById('fixes-section');
    const list = document.getElementById('fixes-list');
    if (!section || !list) return;

    const quickFixes = generateQuickFixes(report);
    const hasQuickFixes = quickFixes.length > 0;
    const hasRecs = report.recommendations.length > 0;
    const hasSuggestedTitle = !!report.suggestedTitle;

    if (!hasQuickFixes && !hasRecs && !hasSuggestedTitle) {
      section.classList.add('hidden');
      return;
    }

    section.classList.remove('hidden');

    // Suggested title
    const titleBlock = document.getElementById('suggested-title-block');
    const titleText = document.getElementById('suggested-title-text');
    if (titleBlock && titleText && hasSuggestedTitle) {
      titleBlock.classList.remove('hidden');
      titleText.textContent = report.suggestedTitle!;

      const copyBtn = document.getElementById('copy-suggested-title');
      if (copyBtn) {
        copyBtn.addEventListener('click', () => {
          navigator.clipboard.writeText(report.suggestedTitle!).then(() => {
            copyBtn.innerHTML = `<svg class="w-4 h-4 text-emerald-500" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M20 6L9 17l-5-5"/></svg>`;
            setTimeout(() => {
              copyBtn.innerHTML = `<svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg>`;
            }, 1500);
          });
          window.dataLayer = window.dataLayer || [];
          window.dataLayer.push({ event: 'suggested_title_copied', tool: 'video-keyword-finder' });
        });
      }
    } else if (titleBlock) {
      titleBlock.classList.add('hidden');
    }

    // Merge quick fixes + AI recommendations into one list
    const priorityLabels: Record<number, { label: string; color: string }> = {
      1: { label: 'Title', color: 'bg-rose-100 text-rose-700 dark:bg-rose-900/30 dark:text-rose-400' },
      2: { label: 'Description', color: 'bg-amber-100 text-amber-700 dark:bg-amber-900/30 dark:text-amber-400' },
      3: { label: 'Tags', color: 'bg-blue-100 text-blue-700 dark:bg-blue-900/30 dark:text-blue-400' },
    };

    let items = '';

    if (hasQuickFixes) {
      items += quickFixes.map((fix) => {
        const pl = priorityLabels[fix.priority] || priorityLabels[3];
        return `<div class="flex items-start gap-3 py-2.5">
          <span class="flex-shrink-0 mt-0.5 text-[10px] font-bold rounded px-1.5 py-0.5 ${pl.color}">${pl.label}</span>
          <p class="text-sm text-gray-600 dark:text-slate-400 leading-relaxed">${fix.text}</p>
        </div>`;
      }).join('');
    }

    if (hasRecs) {
      items += report.recommendations.map((rec) => {
        const escaped = rec.replace(/</g, '&lt;').replace(/>/g, '&gt;');
        return `<div class="flex items-start gap-3 py-2.5">
          <span class="flex-shrink-0 mt-1 w-1.5 h-1.5 rounded-full bg-slate-300 dark:bg-slate-600"></span>
          <p class="text-sm text-gray-600 dark:text-slate-400 leading-relaxed">${escaped}</p>
        </div>`;
      }).join('');
    }

    list.innerHTML = items;
  }

  // ===== CSV DOWNLOAD =====

  function generateCSV(): string {
    if (!currentReport) return '';
    const header = 'Keyword,Position,Status,In Title,In Description,In Tags';
    const rows = currentReport.keywords.map((kw) => {
      const keyword = kw.keyword.includes(',') ? `"${kw.keyword}"` : kw.keyword;
      const position = kw.position !== null ? String(kw.position) : '';
      const statusMap: Record<string, string> = { ranking: 'Top 5', within_reach: 'Within Reach', not_found: 'Not Found', error: 'Error' };
      const status = statusMap[kw.status] || kw.status;
      return `${keyword},${position},${status},${kw.inTitle ? 'Yes' : 'No'},${kw.inDescription ? 'Yes' : 'No'},${kw.inTags ? 'Yes' : 'No'}`;
    });
    return [header, ...rows].join('\n');
  }

  function triggerCSVDownload(): void {
    const csv = generateCSV();
    if (!csv) return;
    const blob = new Blob([csv], { type: 'text/csv;charset=utf-8;' });
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url;
    const videoTitle = currentReport?.video.title?.replace(/[^a-zA-Z0-9]/g, '_').substring(0, 40) || 'keywords';
    a.download = `keyword_report_${videoTitle}.csv`;
    document.body.appendChild(a);
    a.click();
    document.body.removeChild(a);
    URL.revokeObjectURL(url);

    window.dataLayer = window.dataLayer || [];
    window.dataLayer.push({ event: 'csv_downloaded', tool: 'video-keyword-finder' });
  }

  function handleCSVDownload(): void {
    if (localStorage.getItem(EMAIL_KEY) === 'true') {
      triggerCSVDownload();
      return;
    }

    const gate = document.getElementById('csv-email-gate');
    if (gate) {
      gate.classList.toggle('hidden');
    }
  }

  async function submitCSVGateEmail(): Promise<void> {
    const emailInput = document.getElementById('csv-gate-email') as HTMLInputElement;
    const email = emailInput.value.trim().toLowerCase();
    const errorEl = document.getElementById('csv-gate-error');

    const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
    if (!emailRegex.test(email)) {
      if (errorEl) { errorEl.textContent = 'Please enter a valid business email address.'; errorEl.classList.remove('hidden'); }
      return;
    }

    const domain = email.split('@')[1];
    if (GATE_EMAIL_DOMAINS.includes(domain)) {
      if (errorEl) { errorEl.textContent = 'Please use a business email address (not Gmail, Yahoo, etc.)'; errorEl.classList.remove('hidden'); }
      return;
    }

    if (errorEl) errorEl.classList.add('hidden');

    const btn = document.getElementById('csv-gate-submit') as HTMLButtonElement;
    btn.textContent = 'Unlocking...';
    btn.setAttribute('disabled', 'true');

    try {
      await fetch(CAPTURE_URL, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email, source: 'youtube-video-keyword-finder-csv' }),
      });
    } catch { /* silent */ }

    setEmailSubmitted();
    updateCounterLabel();

    window.dataLayer = window.dataLayer || [];
    window.dataLayer.push({ event: 'tool_email_submitted', tool: 'video-keyword-finder', trigger: 'csv_download' });

    const gate = document.getElementById('csv-email-gate');
    if (gate) gate.classList.add('hidden');

    btn.textContent = 'Unlock';
    btn.removeAttribute('disabled');
    emailInput.value = '';

    triggerCSVDownload();
  }

