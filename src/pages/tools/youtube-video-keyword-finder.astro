  // ===== COPY FUNCTIONS =====

  function copyFullReport(): void {
    if (!currentReport) return;
    const r = currentReport;
    const now = new Date().toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });

    const ranking = r.keywords.filter((k) => k.status === 'ranking');
    const withinReach = r.keywords.filter((k) => k.status === 'within_reach');
    const notFound = r.keywords.filter((k) => k.status === 'not_found' || k.status === 'error');

    const formatKw = (k: KeywordResult, showPos: boolean) => {
      const pos = showPos && k.position ? `#${k.position}` : '-';
      const meta: string[] = [];
      if (k.inTitle) meta.push('title');
      if (k.inDescription) meta.push('desc');
      if (k.inTags) meta.push('tags');
      const metaLabel = meta.length > 0 ? `[in ${meta.join(', ')}]` : '[not in title/desc/tags]';
      return `${pos} ${k.keyword} ${metaLabel}`;
    };

    let text = `YouTube Keyword Report: ${r.video.title}\nChannel: ${r.video.channel}\nGrade: ${r.summary.grade} (${r.summary.ranking} ranking, ${r.summary.withinReach} within reach, ${r.summary.notFound} invisible)\nGenerated: ${now}\n`;

    if (ranking.length > 0) {
      text += '\nRANKING (Top 5):\n' + ranking.map((k) => formatKw(k, true)).join('\n') + '\n';
    }
    if (withinReach.length > 0) {
      text += '\nWITHIN REACH (6-20):\n' + withinReach.map((k) => formatKw(k, true)).join('\n') + '\n';
    }
    if (notFound.length > 0) {
      text += '\nNOT RANKING:\n' + notFound.map((k) => formatKw(k, false)).join('\n') + '\n';
    }

    text += '\nGenerated by SellonTube YouTube Video Keyword Finder\nhttps://sellontube.com/tools/youtube-video-keyword-finder';

    navigator.clipboard.writeText(text);
    const btn = document.getElementById('copy-report-btn');
    if (btn) {
      btn.textContent = 'Copied!';
      setTimeout(() => { btn.textContent = 'Copy report'; }, 1500);
    }
    window.dataLayer = window.dataLayer || [];
    window.dataLayer.push({ event: 'report_copied', tool: 'video-keyword-finder' });
  }

  // ===== API CALL =====

  async function fetchKeywordReport(videoUrl: string): Promise<void> {
    const btn = document.getElementById('generate-btn') as HTMLButtonElement;

    try {
      const res = await fetch('/api/find-video-keywords', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ videoUrl }),
      });

      stopLoadingMessages();

      if (res.status === 429) {
        showStep('step-input');
        btn.disabled = false;
        btn.textContent = 'Find my ranking keywords →';
        const data = await res.json().catch(() => ({}));
        if (data.detail?.includes('YouTube')) {
          showError("YouTube's API limit has been reached for today. Try again tomorrow, or check a specific keyword with our Ranking Checker.");
        } else {
          showError('AI analysis is at capacity right now. Free daily limit reached. Check back tomorrow.');
        }
        window.dataLayer = window.dataLayer || [];
        window.dataLayer.push({ event: 'tool_generate_error', tool: 'video-keyword-finder', reason: 'quota_exceeded' });
        return;
      }

      if (!res.ok) {
        const data = await res.json().catch(() => ({}));
        if (res.status === 400 && data.error) {
          showStep('step-input');
          btn.disabled = false;
          btn.textContent = 'Find my ranking keywords →';
          showError(data.error);
          return;
        }
        throw new Error('API error ' + res.status);
      }

      const report: VideoReport = await res.json();

      // Cache the report
      setCachedReport(report.video.videoId, report);

      renderResults(report);
      incrementCount();
      updateCounterLabel();
      showStep('step-results');
      document.getElementById('step-results')?.scrollIntoView({ behavior: 'smooth', block: 'start' });

      window.dataLayer = window.dataLayer || [];
      window.dataLayer.push({
        event: 'tool_generate_success',
        tool: 'video-keyword-finder',
        grade: report.summary.grade,
        ranking_count: report.summary.ranking,
      });

    } catch {
      stopLoadingMessages();
      showStep('step-input');
      btn.disabled = false;
      btn.textContent = 'Find my ranking keywords →';
      showError('Something went wrong on our end. Try again in a moment.');
      window.dataLayer = window.dataLayer || [];
      window.dataLayer.push({ event: 'tool_generate_error', tool: 'video-keyword-finder', reason: 'api_error' });
    }
  }

  // ===== GENERATE =====

  async function generate(): Promise<void> {
    const input = document.getElementById('video-url-input') as HTMLInputElement;
    let videoUrl = input.value.trim();

    if (!videoUrl || videoUrl.length < 10) {
      showError("That doesn't look like a YouTube video URL. Paste a link like https://www.youtube.com/watch?v=... or an 11-character video ID.");
      return;
    }

    clearError();

    // Auto-prepend https://
    if (videoUrl && !videoUrl.startsWith('http') && videoUrl.includes('.')) {
      videoUrl = 'https://' + videoUrl;
      input.value = videoUrl;
    }

    // Client-side video ID check
    const videoId = extractVideoIdClient(videoUrl);
    if (!videoId) {
      showError("That doesn't look like a YouTube video URL. Paste a link like https://www.youtube.com/watch?v=... or an 11-character video ID.");
      return;
    }

    // Check session cache
    const cached = getCachedReport(videoId);
    if (cached) {
      renderResults(cached);
      showStep('step-results');
      document.getElementById('step-results')?.scrollIntoView({ behavior: 'smooth', block: 'start' });
      return;
    }

    // Email gate check
    if (getCount() >= RATE_LIMIT && !isEmailSubmitted()) {
      window.dataLayer = window.dataLayer || [];
      window.dataLayer.push({ event: 'tool_email_gate_shown', tool: 'video-keyword-finder' });
      showStep('step-email-gate');
      return;
    }

    window.dataLayer = window.dataLayer || [];
    window.dataLayer.push({ event: 'tool_generate_click', tool: 'video-keyword-finder' });

    const btn = document.getElementById('generate-btn') as HTMLButtonElement;
    btn.disabled = true;
    btn.textContent = 'Analyzing...';
    showStep('step-loading');
    startLoadingMessages();

    await fetchKeywordReport(videoUrl);
  }

