---
import Layout from '~/layouts/PageLayout.astro';
import HeroText from '~/components/widgets/HeroText.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import { SITE } from 'astrowind:config';

const siteUrl = SITE.site || 'https://sellontube.com';

const metadata = {
  title: 'Free YouTube Tools for Business',
  description:
    'Free tools to evaluate YouTube topics, calculate ROI, and build a channel that generates customers. Built for B2B founders and SaaS businesses.',
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": siteUrl },
    { "@type": "ListItem", "position": 2, "name": "Tools", "item": `${siteUrl}/tools` }
  ]
};

const collectionPageSchema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": "Free YouTube Tools for Business",
  "description": "Free tools to evaluate YouTube topics, calculate ROI, and build a channel that generates customers. Built for B2B founders and SaaS businesses.",
  "url": `${siteUrl}/tools`,
  "publisher": { "@type": "Organization", "name": "SellOnTube", "url": siteUrl }
};

const tools = [
  {
    name: 'YouTube SEO Tool',
    slug: '/tools/youtube-seo-tool',
    tagline: "Why aren't buyers finding your YouTube videos?",
    description:
      'Paste your video URL and website. Get a buyer-intent score across 5 dimensions: title relevance, description quality, keyword coverage, CTA strength, and chapter labels. Includes the exact rewritten text to fix each failing dimension.',
    badge: 'SEO Audit',
    badgeColor: 'emerald',
  },
  {
    name: 'YouTube Autocomplete Keywords',
    slug: '/tools/youtube-autocomplete-keywords',
    tagline: 'What are people actually searching for on YouTube?',
    description:
      'Enter a seed keyword and scrape YouTube autocomplete suggestions across A-Z variations and buyer-intent modifiers. Keywords categorized by intent: Comparison, Mistakes, Results, How-To, Research. Export as CSV.',
    badge: 'Keywords',
    badgeColor: 'emerald',
  },
  {
    name: 'YouTube Ranking Checker',
    slug: '/tools/youtube-ranking-checker',
    tagline: 'Where does your video rank for that keyword?',
    description:
      'Enter a keyword and your channel. See your position in the top 20 YouTube search results, plus the top 10 competing videos with view counts and age.',
    badge: 'Rankings',
    badgeColor: 'emerald',
  },
  {
    name: 'YouTube Video Keyword Finder',
    slug: '/tools/youtube-video-keyword-finder',
    tagline: 'What keywords does your YouTube video rank for?',
    description:
      'Paste any video URL and discover 8 buyer-intent keywords it ranks for in YouTube search. See exact positions, tag gaps, and specific recommendations to improve.',
    badge: 'Keywords',
    badgeColor: 'emerald',
  },
  {
    name: 'YouTube Competitor Analysis',
    slug: '/tools/youtube-competitor-analysis',
    tagline: 'Can you beat what\'s already ranking on YouTube?',
    description:
      'Enter a keyword. See the top 5 competing videos with view counts, age, and beatable signals. Know if this keyword is worth targeting before you invest in production.',
    badge: 'Competition',
    badgeColor: 'emerald',
  },
  {
    name: 'YouTube Tag Generator',
    slug: '/tools/youtube-tag-generator',
    tagline: 'What tags will make buyers find your YouTube videos?',
    description:
      'Paste any YouTube video URL. Get 15-20 buyer-intent tags based on your title, description, and transcript. Flags tagging mistakes and shows your primary keyword.',
    badge: 'Tags',
    badgeColor: 'emerald',
  },
  {
    name: 'YouTube Video Ideas Generator',
    slug: '/tools/youtube-video-ideas-generator',
    tagline: 'What YouTube videos should I create to attract buyers?',
    description:
      'Enter your product, target customer, and the problem you solve. Get 5 buyer-intent video ideas built to drive leads and customers, not just views.',
    badge: 'Idea Generation',
    badgeColor: 'emerald',
  },
  {
    name: 'YouTube Title Generator',
    slug: '/tools/youtube-title-generator',
    tagline: 'What title will make buyers click your video?',
    description:
      'Enter your video topic, pick a format, and describe your buyer. Get 3 scored YouTube titles optimised for buyer intent, keyword framing, and click-through rate.',
    badge: 'Titles',
    badgeColor: 'emerald',
  },
  {
    name: 'YouTube Video Idea Evaluator',
    slug: '/tools/youtube-video-ideas-evaluator',
    tagline: 'Does this video idea attract buyers or just viewers?',
    description:
      'Paste a YouTube video idea, your target customer, and what you sell. Get an instant verdict on whether it will generate leads, scored across 4 buyer intent dimensions.',
    badge: 'Buyer Intent',
    badgeColor: 'emerald',
  },
  {
    name: 'YouTube Script Generator',
    slug: '/tools/youtube-script-generator',
    tagline: 'Turn your buyer-intent video idea into a complete script.',
    description:
      'Enter your video topic, target customer, and product. Get a full script with hook, body, product bridge, and CTA. Written in spoken English, ready for a teleprompter.',
    badge: 'Scripts',
    badgeColor: 'emerald',
  },
  {
    name: 'YouTube Description Generator',
    slug: '/tools/youtube-description-generator',
    tagline: 'Write YouTube descriptions that get found by buyers.',
    description:
      'Enter your video title, topic, and target keyword. Get an SEO-optimized description with above-the-fold hook, full body, timestamps template, and tags.',
    badge: 'Descriptions',
    badgeColor: 'emerald',
  },
  {
    name: 'YouTube Channel Audit',
    slug: '/tools/youtube-channel-audit',
    tagline: 'Is your YouTube channel actually reaching buyers?',
    description:
      'Enter your channel URL. Get a score across 4 dimensions: title quality, description quality, publishing consistency, and SEO optimization. Scores your last 10 videos.',
    badge: 'Audit',
    badgeColor: 'emerald',
  },
  {
    name: 'YouTube Transcript Generator',
    slug: '/tools/youtube-transcript-generator',
    tagline: 'What are your competitors actually saying in their videos?',
    description:
      'Paste any YouTube video URL and get a clean, accurate transcript in seconds. Study competitor scripts, analyze keyword usage, and extract content insights.',
    badge: 'Transcripts',
    badgeColor: 'emerald',
  },
  {
    name: 'YouTube ROI Calculator',
    slug: '/tools/youtube-roi-calculator',
    tagline: 'Does YouTube make financial sense for your business?',
    description:
      'Enter your customer LTV and COGS. See your break-even point and monthly profit projections at different customer volumes.',
    badge: 'ROI',
    badgeColor: 'emerald',
  },
];
---

<Layout metadata={metadata}>
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(collectionPageSchema)} />
  <HeroText
    title="Free YouTube Tools for Business"
    subtitle="Every tool here is framed around one question: will this generate customers? Not views, not subscribers, customers."
  />

  <section class="py-10 sm:py-12">
    <div class="max-w-2xl mx-auto px-4 space-y-5">
      {tools.map((tool) => (
        <a
          href={tool.slug}
          class="block rounded-3xl border border-slate-200 bg-white/70 shadow-sm hover:shadow-md
                 dark:bg-slate-900/70 dark:border-slate-700 p-6 sm:p-8
                 transition-shadow group"
        >
          <div class="flex items-start justify-between gap-4 mb-3">
            <h2 class="text-lg font-bold text-gray-900 dark:text-white group-hover:text-emerald-600 dark:group-hover:text-emerald-400 transition-colors">
              {tool.name}
            </h2>
            <span class={`flex-shrink-0 text-xs font-semibold px-3 py-1 rounded-full ${tool.badgeColor === 'amber' ? 'bg-amber-50 text-amber-700 dark:bg-amber-900/30 dark:text-amber-400' : 'bg-emerald-50 text-emerald-700 dark:bg-emerald-900/30 dark:text-emerald-400'}`}>
              {tool.badge}
            </span>
          </div>
          <p class="text-sm font-medium text-gray-700 dark:text-slate-300 mb-2">{tool.tagline}</p>
          <p class="text-sm text-gray-500 dark:text-slate-400 leading-relaxed">{tool.description}</p>
          <p class="mt-4 text-sm font-semibold text-emerald-600 dark:text-emerald-400 group-hover:underline">
            Use this tool →
          </p>
        </a>
      ))}
    </div>

    <div class="max-w-2xl mx-auto px-4 mt-8">
      <p class="text-sm text-gray-500 dark:text-slate-400">
        Looking for our full YouTube SEO software suite? <a href="/product-pricing" class="text-primary font-semibold hover:underline">See plans and pricing</a>.
      </p>
    </div>
  </section>

  <CallToAction
    title="Tools are useful. A strategy is better."
    subtitle="In our diagnostic, we map your full YouTube acquisition system and tell you exactly what to build first."
    actions={[
      {
        variant: 'primary',
        text: 'Book a diagnostic call',
        href: 'https://cal.com/gautham-8bdvdx/30min',
        target: '_blank',
        rel: 'noopener noreferrer',
      },
    ]}
  />
</Layout>
