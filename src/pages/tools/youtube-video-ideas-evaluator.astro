---
import Layout from '~/layouts/PageLayout.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import { SITE } from 'astrowind:config';

const siteUrl = SITE.site || 'https://sellontube.com';

const metadata = {
  title: 'YouTube Video Idea Evaluator | Free Buyer Intent Checker',
  description:
    'Enter any YouTube video idea and find out if it targets buyers or browsers. Free buyer intent scoring for B2B founders: 4 scored dimensions, instant verdict.',
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": siteUrl },
    { "@type": "ListItem", "position": 2, "name": "Tools", "item": `${siteUrl}/tools` },
    { "@type": "ListItem", "position": 3, "name": "YouTube Video Idea Evaluator", "item": `${siteUrl}/tools/youtube-video-ideas-evaluator` }
  ]
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    { "@type": "Question", "name": "Is this video idea evaluator free?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. You get 3 free evaluations without signup. Enter a business email to unlock unlimited evaluations at no cost. There is no paid version." } },
    { "@type": "Question", "name": "How is buyer intent different from search volume?", "acceptedAnswer": { "@type": "Answer", "text": "Search volume tells you how many people type a query. Buyer intent tells you whether those people are ready to purchase. This tool measures intent, not volume." } },
    { "@type": "Question", "name": "Can I evaluate ideas I did not generate with SellOnTube?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. Paste any video idea from any source. The evaluator works on any topic, regardless of where the idea originated." } },
    { "@type": "Question", "name": "What does the Funnel Stage classification mean?", "acceptedAnswer": { "@type": "Answer", "text": "Awareness means the viewer is learning about a problem. Consideration means they are evaluating solutions. Decision means they are choosing between specific options. For B2B channels, Consideration and Decision stage ideas generate the most pipeline." } },
    { "@type": "Question", "name": "How accurate is the scoring?", "acceptedAnswer": { "@type": "Answer", "text": "The evaluator uses keyword pattern matching across proven buyer-intent signals. It is directionally accurate for deciding whether to invest production time in an idea. Think of it as a quality gate, not a prediction engine." } },
    { "@type": "Question", "name": "Should I only produce ideas that score High?", "acceptedAnswer": { "@type": "Answer", "text": "Not necessarily. A Moderate score with strong Audience Fit can still generate leads if the viewer matches your ICP. But Low scoring ideas should be reframed or replaced." } },
  ]
};

const softwareSchema = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  "name": "YouTube Video Ideas Evaluator",
  "description": metadata.description,
  "url": `${siteUrl}/tools/youtube-video-ideas-evaluator`,
  "applicationCategory": "WebApplication",
  "operatingSystem": "Any",
  "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
  "creator": { "@type": "Organization", "name": "SellOnTube", "url": siteUrl }
};

---

<Layout metadata={metadata}>
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(softwareSchema)} />

  <!-- Hero -->
  <section class="bg-white dark:bg-slate-950 pt-16 pb-12 sm:pt-20 sm:pb-16">
    <div class="max-w-3xl mx-auto px-4 text-center">
      <div class="flex flex-wrap justify-center gap-2 mb-6">
        <span class="inline-flex items-center text-xs font-semibold text-emerald-400 bg-emerald-500/10 border border-emerald-500/20 rounded-full px-3 py-1">4 scoring dimensions</span>
        <span class="inline-flex items-center text-xs font-semibold text-emerald-400 bg-emerald-500/10 border border-emerald-500/20 rounded-full px-3 py-1">Instant verdict</span>
        <span class="inline-flex items-center text-xs font-semibold text-emerald-400 bg-emerald-500/10 border border-emerald-500/20 rounded-full px-3 py-1">Built for B2B</span>
      </div>
      <h1 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-gray-900 dark:text-white leading-tight mb-4">
        Will this YouTube video idea attract<br class="hidden sm:block" /> buyers or just viewers?
      </h1>
      <p class="text-gray-500 dark:text-slate-400 text-base sm:text-lg max-w-xl mx-auto">
        Paste a YouTube video idea, your target customer, and what you sell. Get an instant verdict on whether it will generate leads.
      </p>
    </div>
  </section>

  <!-- Tool -->
  <section class="bg-white dark:bg-slate-950 pb-20">
    <div id="tool-container" class="max-w-xl mx-auto px-4">

      <!-- Step: Input -->
      <div
        id="step-input"
        class="rounded-2xl border border-slate-200 dark:border-slate-700 bg-slate-50 dark:bg-slate-900 p-6 sm:p-8"
      >
        <div class="space-y-5">
          <div>
            <label for="topic-input" class="block text-xs font-semibold uppercase tracking-wider text-gray-500 dark:text-slate-400 mb-2">
              YouTube video idea
            </label>
            <input
              type="text"
              id="topic-input"
              placeholder="e.g. How Shopify Apps Make Money"
              class="w-full text-base font-medium px-4 py-3 rounded-xl border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-800 text-gray-900 dark:text-white placeholder-gray-400 dark:placeholder-slate-500
                     focus:ring-1 focus:ring-emerald-500 focus:border-emerald-500 outline-none transition-colors"
              aria-describedby="topic-error"
            />
            <p id="topic-error" class="hidden mt-1.5 text-xs text-rose-600 dark:text-rose-400" role="alert"></p>
          </div>

          <div>
            <label for="customer-input" class="block text-xs font-semibold uppercase tracking-wider text-gray-500 dark:text-slate-400 mb-2">
              Your target customer
            </label>
            <input
              type="text"
              id="customer-input"
              placeholder="e.g. Shopify store owners"
              class="w-full text-base font-medium px-4 py-3 rounded-xl border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-800 text-gray-900 dark:text-white placeholder-gray-400 dark:placeholder-slate-500
                     focus:ring-1 focus:ring-emerald-500 focus:border-emerald-500 outline-none transition-colors"
              aria-describedby="customer-error"
            />
            <p id="customer-error" class="hidden mt-1.5 text-xs text-rose-600 dark:text-rose-400" role="alert"></p>
          </div>

          <div>
            <label for="product-input" class="block text-xs font-semibold uppercase tracking-wider text-gray-500 dark:text-slate-400 mb-2">
              Your product or service
            </label>
            <input
              type="text"
              id="product-input"
              placeholder="e.g. Upsell app for Shopify"
              class="w-full text-base font-medium px-4 py-3 rounded-xl border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-800 text-gray-900 dark:text-white placeholder-gray-400 dark:placeholder-slate-500
                     focus:ring-1 focus:ring-emerald-500 focus:border-emerald-500 outline-none transition-colors"
              aria-describedby="product-error"
            />
            <p id="product-error" class="hidden mt-1.5 text-xs text-rose-600 dark:text-rose-400" role="alert"></p>
          </div>
        </div>

        <button
          id="evaluate-btn"
          class="mt-7 w-full inline-flex items-center justify-center rounded-xl px-6 py-3.5 text-base font-bold
                 bg-emerald-500 text-white dark:text-slate-950 hover:bg-emerald-400 transition-colors"
        >
          Evaluate this video idea &rarr;
        </button>

        <p id="eval-counter-label" class="mt-3 text-center text-xs text-gray-400 dark:text-slate-600">
          3 free evaluations remaining
        </p>
      </div>

      <!-- Step: Loading -->
      <div
        id="step-loading"
        class="hidden rounded-2xl border border-slate-200 dark:border-slate-700 bg-slate-50 dark:bg-slate-900 p-6 sm:p-8 text-center"
      >
        <div class="flex flex-col items-center gap-4 py-10">
          <div class="w-10 h-10 border-[3px] border-emerald-500 border-t-transparent rounded-full animate-spin"></div>
          <p class="text-sm font-medium text-gray-500 dark:text-slate-400">Analysing buyer intent...</p>
          <p class="text-xs text-gray-400 dark:text-slate-600">Scoring 4 dimensions</p>
        </div>
      </div>

      <!-- Step: Email Gate -->
      <div
        id="step-email-gate"
        class="hidden rounded-2xl border border-slate-200 dark:border-slate-700 bg-slate-50 dark:bg-slate-900 p-6 sm:p-8"
      >
        <div class="text-center mb-6">
          <p class="text-base font-semibold text-gray-900 dark:text-white mb-2">You've used your 3 free evaluations</p>
          <p class="text-sm text-gray-500 dark:text-slate-400">
            Enter your business email to keep evaluating. It's free.
          </p>
        </div>
        <div id="gate-form" class="space-y-3">
          <input
            type="email"
            id="gate-email"
            placeholder="your@company.com"
            class="w-full px-4 py-3 rounded-xl border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-800 text-gray-900 dark:text-white placeholder-gray-400 dark:placeholder-slate-500
                   focus:ring-1 focus:ring-emerald-500 focus:border-emerald-500 outline-none"
            aria-describedby="gate-email-error"
          />
          <p id="gate-email-error" class="hidden text-xs text-rose-600 dark:text-rose-400" role="alert"></p>
          <button
            id="gate-submit-btn"
            class="w-full inline-flex items-center justify-center rounded-xl px-6 py-3.5 text-base font-bold
                   bg-emerald-500 text-white dark:text-slate-950 hover:bg-emerald-400 transition-colors"
          >
            Continue evaluating
          </button>
          <p class="text-center text-xs text-gray-400 dark:text-slate-600">No spam. We'll only send you content marketing resources from SellonTube.</p>
        </div>
        <div id="gate-success" class="hidden text-center mt-4">
          <p class="text-sm font-semibold text-emerald-600 dark:text-emerald-400">Done. Evaluating now...</p>
        </div>
      </div>

    </div>

    <!-- Step: Results (wider) -->
    <div id="step-results" class="hidden max-w-2xl mx-auto px-4 mt-2" role="status" aria-live="polite">
      <div class="rounded-2xl border border-slate-200 dark:border-slate-700 bg-slate-50 dark:bg-slate-900 overflow-hidden">

        <!-- Verdict -->
        <div class="p-6 sm:p-8 border-b border-slate-200 dark:border-slate-700/60">
          <p class="text-xs font-semibold uppercase tracking-wider text-gray-400 dark:text-slate-500 mb-1">Video idea evaluated</p>
          <p id="result-topic" class="text-sm font-medium text-gray-600 dark:text-slate-400 mb-5"></p>

          <div id="verdict-block" class="rounded-xl p-5 mb-4">
            <p id="verdict-title" class="text-base font-bold mb-2"></p>
            <p id="verdict-body" class="text-sm leading-relaxed"></p>
          </div>

          <a
            id="verdict-cta"
            href="/tools/youtube-video-ideas-generator"
            class="hidden items-center gap-2 text-sm font-semibold text-emerald-600 dark:text-emerald-400 hover:text-emerald-500 transition-colors"
          >
            Generate buyer-intent ideas instead &rarr;
          </a>
        </div>

        <!-- Classifications -->
        <div class="px-6 py-4 sm:px-8 border-b border-slate-200 dark:border-slate-700/60 flex flex-wrap gap-6">
          <div>
            <p class="text-xs font-semibold uppercase tracking-wider text-gray-400 dark:text-slate-500 mb-1">Funnel Stage</p>
            <span id="funnel-stage-badge" class="text-sm font-semibold text-gray-700 dark:text-slate-300"></span>
          </div>
          <div>
            <p class="text-xs font-semibold uppercase tracking-wider text-gray-400 dark:text-slate-500 mb-1">Search Intent</p>
            <span id="search-intent-badge" class="text-sm font-semibold text-gray-700 dark:text-slate-300"></span>
          </div>
        </div>

        <!-- Score bars -->
        <div class="p-6 sm:p-8 border-b border-slate-200 dark:border-slate-700/60">
          <p class="text-xs font-semibold uppercase tracking-wider text-gray-400 dark:text-slate-500 mb-5">Dimension breakdown</p>
          <div class="space-y-4">

            <div>
              <div class="flex items-center justify-between mb-1.5">
                <span class="text-sm text-gray-700 dark:text-slate-300">Buyer Intent</span>
                <span id="badge-buyer-intent" class="text-xs font-semibold"></span>
              </div>
              <div class="h-1.5 bg-slate-200 dark:bg-slate-800 rounded-full overflow-hidden">
                <div id="bar-buyer-intent" class="h-full rounded-full transition-all duration-700 ease-out bg-slate-300 dark:bg-slate-700" style="width:0%"></div>
              </div>
            </div>

            <div>
              <div class="flex items-center justify-between mb-1.5">
                <span class="text-sm text-gray-700 dark:text-slate-300">Audience Fit</span>
                <span id="badge-audience-fit" class="text-xs font-semibold"></span>
              </div>
              <div class="h-1.5 bg-slate-200 dark:bg-slate-800 rounded-full overflow-hidden">
                <div id="bar-audience-fit" class="h-full rounded-full transition-all duration-700 ease-out bg-slate-300 dark:bg-slate-700" style="width:0%"></div>
              </div>
            </div>

            <div>
              <div class="flex items-center justify-between mb-1.5">
                <span class="text-sm text-gray-700 dark:text-slate-300">Problem Urgency</span>
                <span id="badge-problem-urgency" class="text-xs font-semibold"></span>
              </div>
              <div class="h-1.5 bg-slate-200 dark:bg-slate-800 rounded-full overflow-hidden">
                <div id="bar-problem-urgency" class="h-full rounded-full transition-all duration-700 ease-out bg-slate-300 dark:bg-slate-700" style="width:0%"></div>
              </div>
            </div>

            <div>
              <div class="flex items-center justify-between mb-1.5">
                <span class="text-sm text-gray-700 dark:text-slate-300">Conversion Path</span>
                <span id="badge-conversion-path" class="text-xs font-semibold"></span>
              </div>
              <div class="h-1.5 bg-slate-200 dark:bg-slate-800 rounded-full overflow-hidden">
                <div id="bar-conversion-path" class="h-full rounded-full transition-all duration-700 ease-out bg-slate-300 dark:bg-slate-700" style="width:0%"></div>
              </div>
            </div>

          </div>
        </div>

        <!-- Reset -->
        <div class="px-6 pb-6 sm:px-8 sm:pb-8 pt-6">
          <button
            id="reset-btn"
            class="w-full py-3 rounded-xl border border-slate-200 dark:border-slate-700 text-sm font-medium text-gray-500 dark:text-slate-400 hover:text-gray-900 dark:hover:text-white hover:border-slate-400 dark:hover:border-slate-500 transition-colors"
          >
            &larr; Evaluate another video idea
          </button>
        </div>

      </div>

      <!-- Post-evaluation CTA -->
      <div class="mt-4">
        <p class="text-sm text-center text-gray-500 dark:text-slate-400 mb-3">Tried a topic idea? Now find more like it.</p>
        <a
          href="/tools/youtube-video-ideas-generator"
          class="w-full inline-flex items-center justify-center rounded-xl px-6 py-3.5 text-base font-bold bg-emerald-500 text-white dark:text-slate-950 hover:bg-emerald-400 transition-colors"
        >
          Generate buyer-intent video ideas for my business &rarr;
        </a>
      </div>

    </div>
  </section>

  <CallToAction
    title="Your video ideas score well. Your conversion setup might not."
    subtitle="In our diagnostic, we map your full YouTube acquisition system: topics, CTAs, and the lead path from viewer to customer."
    actions={[
      {
        variant: 'primary',
        text: 'Book a diagnostic call',
        href: 'https://cal.com/gautham-8bdvdx/30min',
        target: '_blank',
        rel: 'noopener noreferrer',
      },
    ]}
  />

  <!-- How it works -->
  <section class="py-16 sm:py-20 bg-white dark:bg-slate-950">
    <div class="max-w-4xl mx-auto px-4">
      <p class="text-xs font-semibold uppercase tracking-wider text-gray-400 dark:text-slate-500 text-center mb-10">How it works</p>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-8 sm:gap-6">
        <div>
          <div class="inline-flex items-center justify-center w-9 h-9 rounded-full bg-emerald-500/10 border border-emerald-500/20 text-emerald-600 dark:text-emerald-400 text-sm font-bold mb-4">1</div>
          <h3 class="text-gray-900 dark:text-white font-semibold mb-2">Enter your video idea</h3>
          <p class="text-sm text-gray-500 dark:text-slate-400 leading-relaxed">Type any YouTube video idea you're considering, your target customer, and what you sell.</p>
        </div>
        <div>
          <div class="inline-flex items-center justify-center w-9 h-9 rounded-full bg-emerald-500/10 border border-emerald-500/20 text-emerald-600 dark:text-emerald-400 text-sm font-bold mb-4">2</div>
          <h3 class="text-gray-900 dark:text-white font-semibold mb-2">Get a clear verdict</h3>
          <p class="text-sm text-gray-500 dark:text-slate-400 leading-relaxed">See a direct verdict on whether this topic will generate leads, plus scores across four buyer intent dimensions.</p>
        </div>
        <div>
          <div class="inline-flex items-center justify-center w-9 h-9 rounded-full bg-emerald-500/10 border border-emerald-500/20 text-emerald-600 dark:text-emerald-400 text-sm font-bold mb-4">3</div>
          <h3 class="text-gray-900 dark:text-white font-semibold mb-2">Act on it</h3>
          <p class="text-sm text-gray-500 dark:text-slate-400 leading-relaxed">If the idea scores well, produce it with confidence. If it doesn't, generate better buyer-intent ideas before you spend production time.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Methodology -->
  <section class="py-16 sm:py-20">
    <div class="max-w-2xl mx-auto px-4 space-y-14">

      <div>
        <h2 class="text-xl font-bold text-gray-900 dark:text-white mb-4">How the Video Idea Evaluator works</h2>
        <p class="text-gray-600 dark:text-slate-400 leading-relaxed mb-4">
          Every topic is scored across four BuyerFit dimensions: Buyer Intent, Audience Fit, Problem Urgency, and Conversion Path. These map directly to whether a viewer is likely to become a customer.
        </p>
        <p class="text-gray-600 dark:text-slate-400 leading-relaxed mb-4">
          Buyer Intent checks for signal words in your video idea: "best," "vs," "review," "setup," "fix," "cost." These indicate a viewer researching a decision, not satisfying curiosity. Audience Fit checks whether the video idea attracts your actual target customer or a different audience. Problem Urgency measures how close the viewer is to an active problem they need solved today.
        </p>
        <p class="text-gray-600 dark:text-slate-400 leading-relaxed">
          Conversion Path is where most businesses underestimate the analysis. A topic can attract the right viewer and still have no natural moment to introduce your product. The evaluator checks whether the video's subject creates a logical opening, or forces your product into an unrelated conversation.
        </p>
      </div>

      <div>
        <h2 class="text-xl font-bold text-gray-900 dark:text-white mb-4">Buyer intent beats search volume for B2B YouTube</h2>
        <p class="text-gray-600 dark:text-slate-400 leading-relaxed mb-4">
          A video with 200 views and 40 qualified leads is worth more than a video with 50,000 views and zero pipeline. That is not a controversial claim. Yet almost every YouTube planning framework optimises for the second outcome.
        </p>
        <p class="text-gray-600 dark:text-slate-400 leading-relaxed mb-4">
          Search volume tells you how many people type a query. It says nothing about whether those people have money, a problem you solve, or any intention to buy. B2B channels that grow revenue from YouTube consistently target low-to-medium volume topics with high buyer intent over high-volume topics that attract the wrong audience.
        </p>
        <p class="text-gray-600 dark:text-slate-400 leading-relaxed">
          The difference between "How Shopify Apps Make Money" and "Best Upsell Apps for Shopify Stores" is not the search volume. It is who types each query and what they do afterward.
        </p>
      </div>

      <div>
        <h2 class="text-xl font-bold text-gray-900 dark:text-white mb-4">What to do when your video idea scores low</h2>
        <p class="text-gray-600 dark:text-slate-400 leading-relaxed mb-4">
          A low Buyer Intent score almost always means the video idea is framed around explanation rather than problem-solving. The fix is usually in the title. "How email marketing works" becomes "Why your email sequences aren't converting Shopify visitors." Same broad subject, completely different viewer and intent.
        </p>
        <p class="text-gray-600 dark:text-slate-400 leading-relaxed mb-4">
          A low Audience Fit score means the video idea attracts the wrong people. No amount of CTA optimisation fixes this. Use the <a href="/tools/youtube-video-ideas-generator" class="text-emerald-600 dark:text-emerald-400 font-medium hover:underline">Video Ideas Generator</a> to find topics that start from your buyer's specific context.
        </p>
        <p class="text-gray-600 dark:text-slate-400 leading-relaxed">
          A weak Conversion Path score is the hardest to fix in post. If the video subject has no logical moment to introduce your product, that moment will feel forced. Start with a better idea from the Generator, built around the buyer's problem from the first frame.
        </p>
      </div>

      <!-- Visual: Score interpretation guide -->
      <div class="rounded-xl border border-slate-200 dark:border-slate-700 overflow-hidden">
        <div class="px-5 py-3 bg-slate-100 dark:bg-slate-800 border-b border-slate-200 dark:border-slate-700">
          <p class="text-xs font-semibold uppercase tracking-wider text-gray-500 dark:text-slate-400">How to read your scores</p>
        </div>
        <div class="overflow-x-auto">
          <table class="w-full text-xs">
            <thead>
              <tr class="border-b border-slate-200 dark:border-slate-700">
                <th class="text-left px-4 py-3 font-semibold text-gray-500 dark:text-slate-400">Score</th>
                <th class="text-left px-4 py-3 font-semibold text-gray-500 dark:text-slate-400">What it means</th>
                <th class="text-left px-4 py-3 font-semibold text-gray-500 dark:text-slate-400">What to do</th>
              </tr>
            </thead>
            <tbody class="text-gray-600 dark:text-slate-400">
              <tr class="border-b border-slate-100 dark:border-slate-800">
                <td class="px-4 py-2.5 font-medium text-emerald-600 dark:text-emerald-400">High</td>
                <td class="px-4 py-2.5">Viewers are evaluating or purchasing. Strong conversion potential.</td>
                <td class="px-4 py-2.5">Produce it. Move to title and script.</td>
              </tr>
              <tr class="border-b border-slate-100 dark:border-slate-800">
                <td class="px-4 py-2.5 font-medium text-amber-600 dark:text-amber-400">Medium</td>
                <td class="px-4 py-2.5">Mixed audience. Some buyers, some researchers.</td>
                <td class="px-4 py-2.5">Reframe with buyer-specific language. Test a tighter angle.</td>
              </tr>
              <tr>
                <td class="px-4 py-2.5 font-medium text-rose-600 dark:text-rose-400">Low</td>
                <td class="px-4 py-2.5">Viewers are learning, not buying. No conversion path.</td>
                <td class="px-4 py-2.5">Replace the idea. Generate new ones with the Ideas Generator.</td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>

      <!-- Section: Who this is for / not for -->
      <div>
        <h2 class="text-xl font-bold text-gray-900 dark:text-white mb-4">Who this evaluator is for</h2>
        <p class="text-gray-600 dark:text-slate-400 leading-relaxed mb-4">
          This tool is for B2B founders, marketers, and content teams who use YouTube to generate pipeline. If your goal is leads, demos, or sales conversations from YouTube, the evaluator checks whether a video idea will deliver that before you spend production time.
        </p>
        <p class="text-gray-600 dark:text-slate-400 leading-relaxed mb-4">
