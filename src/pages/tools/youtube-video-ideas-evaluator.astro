<script>
  // ===== TYPE DECLARATIONS =====
  declare global { interface Window { dataLayer: Record<string, unknown>[]; } }

  // ===== SCORING ENGINE =====

  const HIGH_INTENT_STRONG = [
    'best', 'top', 'vs', 'versus', 'comparison', 'compare', 'compared to',
    'review', 'reviews', 'rated', 'ranking', 'alternatives', 'alternative to',
    'pricing', 'cost', 'price', 'how much', 'worth it', 'roi',
    'return on investment', 'should i use', 'which is better',
  ];

  const HIGH_INTENT_MEDIUM = [
    'tutorial', 'setup', 'how to', 'guide', 'step by step', 'checklist',
    'template', 'fix', 'fixing', 'mistake', 'mistakes', 'avoid', 'increase',
    'improve', 'optimize', 'boost', 'grow', 'strategy', 'tips', 'tactics',
    'quick', 'fast', 'easy way', 'proven',
  ];

  const LOW_INTENT = [
    'what is', 'what are', 'how does', 'how do', 'history of',
    'introduction to', 'intro to', 'overview', 'explained', 'understanding',
    'basics', 'fundamentals', 'theory', 'definition', 'meaning of',
    'types of', 'all about', 'what does', 'who is',
  ];

  const PROBLEM_STRONG = [
    'not working', "doesn't work", 'doesnt work', 'broken', 'fix', 'fixing',
    'solve', 'problem', 'issue', 'error', 'failing', 'failed', 'troubleshoot',
    'struggling', 'stuck', 'losing', 'dropping', 'declining', 'not converting',
    'not getting', "why isn't", 'why isnt', 'why is my',
  ];

  const PROBLEM_MEDIUM = [
    'increase', 'improve', 'optimize', 'boost', 'better', 'mistakes',
    'avoid', 'prevent', 'pitfalls', 'challenges', 'common errors',
    'what to do when', 'how to handle',
  ];

  function scoreBuyerIntent(topic: string): 'Low' | 'Medium' | 'High' {
    const t = topic.toLowerCase();
    const isStructuralLow = LOW_INTENT.some((s) => t.startsWith(s));
    const hasStrongHigh = HIGH_INTENT_STRONG.some((s) => t.includes(s));
    if (isStructuralLow && !hasStrongHigh) return 'Low';

    let score = 0;
    HIGH_INTENT_STRONG.forEach((s) => { if (t.includes(s)) score += 2; });
    HIGH_INTENT_MEDIUM.forEach((s) => { if (t.includes(s)) score += 1; });
    LOW_INTENT.forEach((s) => { if (t.includes(s)) score -= 2; });

    if (score >= 2) return 'High';
    if (score >= 0) return 'Medium';
    return 'Low';
  }

  function scoreProblemUrgency(topic: string): 'Low' | 'Medium' | 'High' {
    const t = topic.toLowerCase();
    let score = 0;
    PROBLEM_STRONG.forEach((s) => { if (t.includes(s)) score += 2; });
    PROBLEM_MEDIUM.forEach((s) => { if (t.includes(s)) score += 1; });
    if (score >= 2) return 'High';
    if (score >= 1) return 'Medium';
    return 'Low';
  }

  function scoreAudienceFit(
    topic: string,
    targetCustomer: string,
    product: string
  ): 'Low' | 'Medium' | 'High' {
    const t = topic.toLowerCase();
    const stop = new Set(['for', 'the', 'a', 'an', 'and', 'or', 'of', 'in', 'at', 'by', 'to', 'is', 'are', 'with', 'your']);
    const customerWords = targetCustomer.toLowerCase().split(/\s+/).filter((w) => w.length > 3 && !stop.has(w));
    const productWords = product.toLowerCase().split(/\s+/).filter((w) => w.length > 3 && !stop.has(w));

    let score = 0;
    customerWords.forEach((w) => { if (t.includes(w)) score += 2; });
    productWords.forEach((w) => { if (t.includes(w)) score += 1; });

    // Builder/user mismatch: "how to build" + buyer-type customer
    const builderTopic = ['how to build', 'how to create', 'how to make', 'how to develop', 'building a', 'creating a'].some((w) => t.includes(w));
    const userCustomer = ['owner', 'manager', 'founder', 'operator', 'user', 'buyer', 'client', 'customer', 'brand'].some((w) => targetCustomer.toLowerCase().includes(w));
    if (builderTopic && userCustomer) score -= 3;

    if (score >= 2) return 'High';
    if (score >= 1) return 'Medium';
    return 'Low';
  }

  function scoreConversionPath(
    topic: string,
    buyerIntent: string,
    product: string
  ): 'Weak' | 'Moderate' | 'Strong' {
    if (buyerIntent === 'Low') return 'Weak';
    const t = topic.toLowerCase();
    const prod = product.toLowerCase();
    const strongSignals = ['best', 'top', 'alternatives', 'vs', 'versus', 'review', 'comparison', 'pricing', 'cost'];
    if (strongSignals.some((s) => t.includes(s))) return 'Strong';
    const prodWords = prod.split(/\s+/).filter((w) => w.length > 3);
    const topicHasProd = prodWords.some((w) => t.includes(w));
    if (topicHasProd && buyerIntent === 'High') return 'Strong';
    if (topicHasProd || buyerIntent === 'High') return 'Moderate';
    return 'Weak';
  }

  function classifySearchIntent(topic: string): string {
    const t = topic.toLowerCase();
    const isStructuralLow = LOW_INTENT.some((s) => t.startsWith(s));
    const hasHighOverride = [...HIGH_INTENT_STRONG, 'fix', 'mistake', 'problem'].some((s) => t.includes(s));
    if (isStructuralLow && !hasHighOverride) return 'Educational';
    if (PROBLEM_STRONG.some((s) => t.includes(s))) return 'Problem Solving';
    if (['pricing', 'cost', 'price', 'worth it', 'should i', 'is it worth'].some((s) => t.includes(s))) return 'Purchase Decision';
    if (['best', 'top', 'vs', 'versus', 'alternatives', 'review', 'comparison'].some((s) => t.includes(s))) return 'Tool Evaluation';
    if (HIGH_INTENT_MEDIUM.some((s) => t.includes(s))) return 'Problem Solving';
    return 'Research';
  }

  function classifyFunnelStage(searchIntent: string): string {
    if (searchIntent === 'Educational') return 'Awareness';
    if (searchIntent === 'Tool Evaluation' || searchIntent === 'Purchase Decision') return 'Decision';
    return 'Consideration';
  }

  interface Verdict {
    acquisitionPotential: 'High' | 'Moderate' | 'Low';
    title: string;
    body: string;
    showCta: boolean;
  }

  function generateVerdict(
    buyerIntent: string,
    audienceFit: string,
    problemUrgency: string
  ): Verdict {
    if (buyerIntent === 'High' && audienceFit !== 'Low') {
      const urgencyNote = problemUrgency === 'High'
        ? 'The urgency signal is strong. Viewers are experiencing this problem right now.'
        : 'Viewers are in evaluation mode and receptive to specific recommendations.';
      return {
        acquisitionPotential: 'High',
        title: 'Strong video idea for your business.',
        body: 'Viewers searching this are in evaluation mode: comparing options, shortlisting tools, or ready to decide. ' + urgencyNote,
        showCta: false,
      };
    }
    if (buyerIntent === 'High' && audienceFit === 'Low') {
      return {
        acquisitionPotential: 'Moderate',
        title: 'Weak video idea for lead generation.',
        body: 'Strong buyer intent, but this topic attracts the wrong audience. The phrasing signals a buyer but pulls in viewers who aren\'t your target customer. Refine the framing with customer-specific language, or start with a better idea.',
        showCta: true,
      };
    }
    if (buyerIntent === 'Medium') {
      return {
        acquisitionPotential: 'Moderate',
        title: 'Weak video idea for lead generation.',
        body: 'This attracts people in research mode, not buyers. They\'re gathering information, not making decisions. You will get views, not conversions.',
        showCta: true,
      };
    }
    return {
      acquisitionPotential: 'Low',
      title: 'This topic will not generate leads.',
      body: 'Viewers searching this are learning, not buying. There is no conversion opportunity here. The content serves the curious, not the committed.',
      showCta: true,
    };
  }

  function evaluateTopic(topic: string, targetCustomer: string, product: string) {
    const buyerIntent = scoreBuyerIntent(topic);
    const audienceFit = scoreAudienceFit(topic, targetCustomer, product);
    const problemUrgency = scoreProblemUrgency(topic);
    const conversionPath = scoreConversionPath(topic, buyerIntent, product);
    const searchIntent = classifySearchIntent(topic);
    const funnelStage = classifyFunnelStage(searchIntent);
    const verdict = generateVerdict(buyerIntent, audienceFit, problemUrgency);
    return { evaluation: { buyerIntent, audienceFit, problemUrgency, conversionPath }, searchIntent, funnelStage, verdict };
  }

  // ===== INPUT CORRECTION =====

  const EXACT_CORRECTIONS: Record<string, string> = {
    'aov': 'AOV', 'ltv': 'LTV', 'cac': 'CAC', 'roi': 'ROI', 'mrr': 'MRR', 'arr': 'ARR',
    'saas': 'SaaS', 'b2b': 'B2B', 'b2c': 'B2C', 'crm': 'CRM', 'seo': 'SEO',
    'api': 'API', 'ui': 'UI', 'ux': 'UX', 'cto': 'CTO', 'coo': 'COO', 'cfo': 'CFO',
  };

  const KNOWN_TERMS: string[] = [
    'Shopify', 'WooCommerce', 'Amazon', 'WordPress', 'HubSpot', 'Salesforce',
    'LinkedIn', 'YouTube', 'Instagram', 'Facebook', 'Twitter', 'TikTok',
    'Stripe', 'Zapier', 'Notion', 'Slack', 'Zoom', 'Mailchimp', 'Klaviyo',
