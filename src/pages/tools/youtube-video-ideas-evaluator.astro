  function verdictBlockStyle(potential: string): string {
    if (potential === 'High') return 'bg-emerald-500/10 border border-emerald-500/20';
    if (potential === 'Moderate') return 'bg-amber-500/10 border border-amber-500/20';
    return 'bg-rose-500/10 border border-rose-500/20';
  }

  function verdictTitleClass(potential: string): string {
    if (potential === 'High') return 'text-emerald-700 dark:text-emerald-400';
    if (potential === 'Moderate') return 'text-amber-700 dark:text-amber-400';
    return 'text-rose-700 dark:text-rose-400';
  }

  const STEPS = ['step-input', 'step-loading', 'step-email-gate', 'step-results'];
  function showStep(id: string): void {
    STEPS.forEach((s) => {
      const el = document.getElementById(s);
      if (el) el.classList.toggle('hidden', s !== id);
    });
    if (id === 'step-results') {
      document.getElementById('step-results')?.scrollIntoView({ behavior: 'smooth', block: 'start' });
    }
  }

  function updateCounterLabel(): void {
    const label = document.getElementById('eval-counter-label') as HTMLElement;
    if (!label) return;
    if (isEmailSubmitted()) {
      label.textContent = 'Unlimited evaluations unlocked';
      return;
    }
    const remaining = Math.max(0, RATE_LIMIT - getCount());
    label.textContent = remaining === 1 ? '1 free evaluation remaining' : remaining + ' free evaluations remaining';
  }

  function showFieldError(fieldId: string, message: string): void {
    const input = document.getElementById(fieldId) as HTMLInputElement | null;
    const error = document.getElementById(fieldId.replace('-input', '-error'));
    if (input) input.setAttribute('aria-invalid', 'true');
    if (error) { error.textContent = message; error.classList.remove('hidden'); }
  }

  function clearFieldError(fieldId: string): void {
    const input = document.getElementById(fieldId) as HTMLInputElement | null;
    const error = document.getElementById(fieldId.replace('-input', '-error'));
    if (input) input.removeAttribute('aria-invalid');
    if (error) { error.textContent = ''; error.classList.add('hidden'); }
  }

  function validateInputs(): boolean {
    const topic = (document.getElementById('topic-input') as HTMLInputElement).value.trim();
    const customer = (document.getElementById('customer-input') as HTMLInputElement).value.trim();
    const product = (document.getElementById('product-input') as HTMLInputElement).value.trim();
    let valid = true;

    if (!topic || topic.length < 5) {
      showFieldError('topic-input', 'Please enter your video idea (min 5 characters).');
      valid = false;
    } else { clearFieldError('topic-input'); }

    if (!customer || customer.length < 3) {
      showFieldError('customer-input', 'Please enter your target customer (min 3 characters).');
      valid = false;
    } else { clearFieldError('customer-input'); }

    if (!product || product.length < 3) {
      showFieldError('product-input', 'Please enter your product or service (min 3 characters).');
      valid = false;
    } else { clearFieldError('product-input'); }

    return valid;
  }

  function renderResults(data: ReturnType<typeof evaluateTopic>): void {
    const ev = data.evaluation;
    const verdict = data.verdict;

    // Verdict block
    const block = document.getElementById('verdict-block') as HTMLElement;
    block.className = 'rounded-xl p-5 mb-4 ' + verdictBlockStyle(verdict.acquisitionPotential);

    const title = document.getElementById('verdict-title') as HTMLElement;
    title.textContent = verdict.title;
    title.className = 'text-base font-bold mb-2 ' + verdictTitleClass(verdict.acquisitionPotential);

    (document.getElementById('verdict-body') as HTMLElement).textContent = verdict.body;

    const cta = document.getElementById('verdict-cta') as HTMLElement;
    if (verdict.showCta) {
      cta.classList.remove('hidden');
      cta.classList.add('inline-flex');
    } else {
      cta.classList.add('hidden');
      cta.classList.remove('inline-flex');
    }

    // Classifications
    (document.getElementById('funnel-stage-badge') as HTMLElement).textContent = data.funnelStage;
    (document.getElementById('search-intent-badge') as HTMLElement).textContent = data.searchIntent;

    // Score bars
    const setBar = (badgeId: string, barId: string, value: string) => {
      const style = scoreToBar(value);
      const badgeEl = document.getElementById(badgeId) as HTMLElement;
      badgeEl.textContent = value;
      badgeEl.className = 'text-xs font-semibold ' + style.textClass;
      const barEl = document.getElementById(barId) as HTMLElement;
      barEl.className = 'h-full rounded-full transition-all duration-700 ease-out ' + style.barClass;
      barEl.style.width = '0%';
      setTimeout(() => { barEl.style.width = style.width; }, 80);
    };

    setBar('badge-buyer-intent', 'bar-buyer-intent', ev.buyerIntent);
    setBar('badge-audience-fit', 'bar-audience-fit', ev.audienceFit);
    setBar('badge-problem-urgency', 'bar-problem-urgency', ev.problemUrgency);
    setBar('badge-conversion-path', 'bar-conversion-path', ev.conversionPath);
  }

  function evaluate(): void {
    if (!validateInputs()) return;

    const topic = correctInput((document.getElementById('topic-input') as HTMLInputElement).value.trim());
    const targetCustomer = correctInput((document.getElementById('customer-input') as HTMLInputElement).value.trim());
    const product = correctInput((document.getElementById('product-input') as HTMLInputElement).value.trim());

    // Update displayed topic with corrected value
    (document.getElementById('result-topic') as HTMLElement).textContent = topic;

    if (getCount() >= RATE_LIMIT && !isEmailSubmitted()) {
      window.dataLayer = window.dataLayer || [];
      window.dataLayer.push({ event: 'tool_email_gate_shown', tool: 'video-ideas-evaluator' });
      showStep('step-email-gate');
      return;
    }

    window.dataLayer = window.dataLayer || [];
    window.dataLayer.push({ event: 'tool_evaluate_click', tool: 'video-ideas-evaluator' });

    showStep('step-loading');

    setTimeout(() => {
      const data = evaluateTopic(topic, targetCustomer, product);
      incrementCount();
      updateCounterLabel();
      renderResults(data);
      showStep('step-results');

      window.dataLayer = window.dataLayer || [];
      window.dataLayer.push({
        event: 'tool_evaluate_success',
        tool: 'video-ideas-evaluator',
        acquisition_potential: data.verdict.acquisitionPotential,
      });
    }, 700);
  }

  async function submitGateEmail(): Promise<void> {
    const emailInput = document.getElementById('gate-email') as HTMLInputElement;
    const errorEl = document.getElementById('gate-email-error') as HTMLElement;
    const btn = document.getElementById('gate-submit-btn') as HTMLButtonElement;
    const email = emailInput.value.trim().toLowerCase();

    const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
    if (!emailRegex.test(email)) {
      errorEl.textContent = 'Please enter a valid email address.';
      errorEl.classList.remove('hidden');
      return;
    }

    const domain = email.split('@')[1];
    if (GATE_EMAIL_DOMAINS.includes(domain)) {
      errorEl.textContent = 'Please use a business email address (not Gmail, Yahoo, etc.)';
      errorEl.classList.remove('hidden');
      return;
    }

    errorEl.classList.add('hidden');
    btn.textContent = 'Submitting...';
    btn.setAttribute('disabled', 'true');

    try {
      await fetch(APPS_SCRIPT_URL, {
        method: 'POST',
        mode: 'no-cors',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email, source: 'youtube-video-ideas-evaluator' }),
      });
    } catch { /* no-cors always resolves */ }

    setEmailSubmitted();
    updateCounterLabel();

    window.dataLayer = window.dataLayer || [];
    window.dataLayer.push({ event: 'tool_email_submitted', tool: 'video-ideas-evaluator' });

    const form = document.getElementById('gate-form') as HTMLElement;
    const success = document.getElementById('gate-success') as HTMLElement;
    form.classList.add('hidden');
    success.classList.remove('hidden');

    setTimeout(() => {
      form.classList.remove('hidden');
      success.classList.add('hidden');
      btn.textContent = 'Continue evaluating';
      btn.removeAttribute('disabled');
      emailInput.value = '';
      evaluate();
    }, 1200);
  }

  function reset(): void {
    (['topic-input', 'customer-input', 'product-input'] as string[]).forEach((id) => {
      (document.getElementById(id) as HTMLInputElement).value = '';
      clearFieldError(id);
    });
    showStep('step-input');
    (document.getElementById('topic-input') as HTMLInputElement).focus();
    const btn = document.getElementById('evaluate-btn') as HTMLButtonElement;
    btn.disabled = false;
    btn.textContent = 'Evaluate this video idea \u2192';
  }

  // CTA tracking
  document.getElementById('verdict-cta')?.addEventListener('click', () => {
    window.dataLayer = window.dataLayer || [];
    window.dataLayer.push({ event: 'tool_cta_click', tool: 'video-ideas-evaluator', destination: 'generator' });
  });

  document.getElementById('evaluate-btn')?.addEventListener('click', evaluate);
  document.getElementById('reset-btn')?.addEventListener('click', reset);
  document.getElementById('gate-submit-btn')?.addEventListener('click', submitGateEmail);

  const inputIds = ['topic-input', 'customer-input', 'product-input'];
  inputIds.forEach((id, i) => {
    document.getElementById(id)?.addEventListener('keydown', (e) => {
      if ((e as KeyboardEvent).key === 'Enter') {
        e.preventDefault();
        if (i < inputIds.length - 1) {
          (document.getElementById(inputIds[i + 1]) as HTMLInputElement)?.focus();
        } else {
          evaluate();
        }
      }
    });
  });

  document.getElementById('gate-email')?.addEventListener('keydown', (e) => {
    if ((e as KeyboardEvent).key === 'Enter') submitGateEmail();
  });

  updateCounterLabel();
</script>
