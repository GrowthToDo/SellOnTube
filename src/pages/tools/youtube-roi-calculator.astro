<script define:vars={{ monthlyServiceCost: PRICING.current }}>
  const MONTHLY_COST = monthlyServiceCost;

  // Elements
  const revenueInput = document.getElementById('revenue-input');
  const cogsInput = document.getElementById('cogs-input');
  const calculateBtn = document.getElementById('calculate-btn');
  const recalculateBtn = document.getElementById('recalculate-btn');
  const stepInput = document.getElementById('step-input');
  const stepResults = document.getElementById('step-results');
  const emailInput = document.getElementById('email-input');
  const productUrlInput = document.getElementById('product-url-input');
  const getProjectionBtn = document.getElementById('get-projection-btn');
  const emailForm = document.getElementById('email-form');
  const successMessage = document.getElementById('success-message');

  // Check for URL params on load
  function checkUrlParams() {
    const params = new URLSearchParams(window.location.search);
    const revenue = params.get('revenue');
    const cogs = params.get('cogs');

    if (revenue) {
      revenueInput.value = revenue;
      cogsInput.value = cogs || '0';
      // Auto-calculate after a brief delay to ensure DOM is ready
      setTimeout(() => calculate(), 100);
    }
  }

  function formatMoney(amount) {
    return '$' + Math.abs(amount).toLocaleString();
  }

  function formatProfit(amount) {
    if (amount >= 0) {
      return '+$' + amount.toLocaleString();
    }
    return '-$' + Math.abs(amount).toLocaleString();
  }

  function calculate() {
    try {
      const revenue = parseFloat(revenueInput.value);
      const cogs = parseFloat(cogsInput.value) || 0;

      if (!revenue || revenue <= 0) {
        alert('Please enter a valid customer LTV');
        return;
      }

      if (cogs >= revenue) {
        alert('COGS must be less than LTV');
        return;
      }

      const margin = revenue - cogs;
      const breakeven = Math.ceil(MONTHLY_COST / margin);

      // Update breakeven display
      document.getElementById('breakeven-display').textContent = breakeven.toString();
      document.getElementById('breakeven-math').textContent =
        `${formatMoney(MONTHLY_COST)}/month ÷ ${formatMoney(margin)} margin = ${breakeven} customers`;

      // Update margin display (de-emphasized)
      document.getElementById('margin-display').textContent = formatMoney(margin);
      document.getElementById('margin-math').textContent =
        `(${formatMoney(revenue)} LTV − ${formatMoney(cogs)} COGS)`;

      // Calculate examples (breakeven + 1, breakeven + 3, breakeven * 2 or more)
      const ex1Customers = breakeven + 1;
      const ex2Customers = breakeven + 3;
      const ex3Customers = Math.max(breakeven + 5, breakeven * 2);

      const ex1Profit = (ex1Customers * margin) - MONTHLY_COST;
      const ex2Profit = (ex2Customers * margin) - MONTHLY_COST;
      const ex3Profit = (ex3Customers * margin) - MONTHLY_COST;

      document.getElementById('ex1-customers').textContent = ex1Customers.toString();
      document.getElementById('ex2-customers').textContent = ex2Customers.toString();
      document.getElementById('ex3-customers').textContent = ex3Customers.toString();

      document.getElementById('ex1-profit').textContent = formatProfit(ex1Profit) + '/month';
      document.getElementById('ex2-profit').textContent = formatProfit(ex2Profit) + '/month';
      document.getElementById('ex3-profit').textContent = formatProfit(ex3Profit) + '/month';

      // Show results
      stepInput?.classList.add('hidden');
      stepResults?.classList.remove('hidden');
      window.splitbee?.track('roi_calculated');
    } catch (error) {
      console.error('Error in calculate function:', error);
      alert('An error occurred. Please try again.');
    }
  }

  function recalculate() {
    stepResults?.classList.add('hidden');
    stepInput?.classList.remove('hidden');
    emailForm?.classList.remove('hidden');
    successMessage?.classList.add('hidden');
    revenueInput.focus();
  }

  async function submitEmail() {
    const email = emailInput.value.trim();
    const productUrl = productUrlInput.value.trim();

    if (!email || !email.includes('@')) {
      alert('Please enter a valid email address');
      return;
    }

    // Disable button while submitting
    if (getProjectionBtn) {
      getProjectionBtn.textContent = 'Submitting...';
      getProjectionBtn.setAttribute('disabled', 'true');
    }

    try {
      const res = await fetch('/.netlify/functions/capture-email', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
        },
        body: JSON.stringify({
          email,
          productUrl,
          revenue: revenueInput.value,
          cogs: cogsInput.value,
          source: 'roi-calculator'
        }),
      });

      if (!res.ok) throw new Error(`HTTP ${res.status}`);

      emailForm?.classList.add('hidden');
      successMessage?.classList.remove('hidden');
      window.splitbee?.track('roi_email_submit');
    } catch (error) {
      console.error('Error submitting:', error);
      alert('Something went wrong. Please try again.');
      if (getProjectionBtn) {
        getProjectionBtn.textContent = 'Email me my projection →';
        getProjectionBtn.removeAttribute('disabled');
      }
    }
  }

  // Event listeners
  calculateBtn?.addEventListener('click', () => calculate());
  recalculateBtn?.addEventListener('click', recalculate);
  getProjectionBtn?.addEventListener('click', submitEmail);

  revenueInput?.addEventListener('keypress', (e) => {
    if (e.key === 'Enter') cogsInput.focus();
  });

  cogsInput?.addEventListener('keypress', (e) => {
    if (e.key === 'Enter') calculate();
  });

  emailInput?.addEventListener('keypress', (e) => {
    if (e.key === 'Enter') productUrlInput?.focus();
  });

  productUrlInput?.addEventListener('keypress', (e) => {
    if (e.key === 'Enter') submitEmail();
  });

  // Check for URL params on page load
  checkUrlParams();
</script>
