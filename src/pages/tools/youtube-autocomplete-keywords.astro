---
import Layout from '~/layouts/PageLayout.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import { SITE } from 'astrowind:config';

const siteUrl = SITE.site || 'https://sellontube.com';

const metadata = {
  title: 'YouTube Autocomplete Keyword Tool - Free Long-Tail Finder',
  description:
    'Scrape YouTube autocomplete suggestions for any keyword. Get long-tail keywords categorized by search intent. Free, no signup for quick results.',
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": siteUrl },
    { "@type": "ListItem", "position": 2, "name": "Tools", "item": `${siteUrl}/tools` },
    { "@type": "ListItem", "position": 3, "name": "YouTube Autocomplete Keywords", "item": `${siteUrl}/tools/youtube-autocomplete-keywords` }
  ]
};

const webAppSchema = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "SellonTube YouTube Autocomplete Keyword Tool",
  "url": `${siteUrl}/tools/youtube-autocomplete-keywords`,
  "description": "Scrape YouTube autocomplete suggestions for any seed keyword. Get long-tail keywords categorized by search intent: Comparison, Mistakes, Results, How-To, Research. Export as CSV. Free, no signup for quick results.",
  "applicationCategory": "BusinessApplication",
  "operatingSystem": "Any",
  "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
  "provider": { "@type": "Organization", "name": "SellonTube", "url": siteUrl }
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    { "@type": "Question", "name": "Is this YouTube autocomplete keyword tool free to use?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. Quick results (A-Z scrape, 30-80 keywords) are instant with no signup. The exhaustive scrape (100+ keywords with intent categorization and CSV export) requires an email address. No credit card, no subscription." } },
    { "@type": "Question", "name": "How is YouTube autocomplete different from using VidIQ or TubeBuddy for keyword research?", "acceptedAnswer": { "@type": "Answer", "text": "VidIQ and TubeBuddy estimate search volume using panel data and clickstream samples. Those numbers are approximations. This tool scrapes what YouTube actually suggests when users type, which is a direct signal of real-time search demand. Keywords are also categorized by buyer intent so you can prioritize comparison and evaluation queries over generic informational ones." } },
    { "@type": "Question", "name": "Should I use autocomplete keywords in my YouTube titles and descriptions?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. Autocomplete keywords are the exact phrases YouTube's algorithm expects in your metadata. Use the high-priority Comparison keywords as video titles. Place related variations in the first 150 characters of your description. Add remaining phrases to tags and chapter labels." } },
    { "@type": "Question", "name": "What do the five intent categories mean and why do they matter?", "acceptedAnswer": { "@type": "Answer", "text": "Each category maps to a stage in the buyer journey. Comparison & Evaluation (High) covers viewers actively comparing solutions. Mistakes & Red Flags (High) catches viewers avoiding bad decisions. Results & Proof (High) targets viewers seeking evidence before committing. How-To & Problem-Solving (Medium) captures viewers with an active problem to solve. Research & Discovery (Low) covers early-stage learning queries. The priority tells you which keywords to target first for business results." } },
    { "@type": "Question", "name": "How many keywords will I get from the exhaustive scrape?", "acceptedAnswer": { "@type": "Answer", "text": "Typically 100-200+, depending on how popular your topic is on YouTube. The exhaustive mode adds 19 buyer-intent modifiers (best, vs, alternatives to, how to, mistakes, results, review, pricing, cost, worth it, tutorial, and more) to your seed keyword, querying YouTube 60-100+ times." } },
    { "@type": "Question", "name": "Can I target different countries with this tool?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. Select your target geography from the dropdown before running the scrape. YouTube returns different autocomplete suggestions for different countries. If you sell to US customers, run it with United States selected. The default Global returns suggestions aggregated across all markets." } },
    { "@type": "Question", "name": "How often should I run this tool for the same keyword?", "acceptedAnswer": { "@type": "Answer", "text": "At least quarterly. YouTube autocomplete changes as search behavior shifts. New keywords appear when competitors launch products, features ship, or trends start. Running the tool quarterly for your core topics catches new long-tail phrases before competitors build content around them." } },
  ]
};

const geoOptions = [
  { label: 'Global', gl: '', hl: 'en' },
  { label: 'United States', gl: 'us', hl: 'en' },
  { label: 'United Kingdom', gl: 'gb', hl: 'en' },
  { label: 'India', gl: 'in', hl: 'en' },
  { label: 'Australia', gl: 'au', hl: 'en' },
  { label: 'Canada', gl: 'ca', hl: 'en' },
  { label: 'Germany', gl: 'de', hl: 'de' },
  { label: 'France', gl: 'fr', hl: 'fr' },
  { label: 'Brazil', gl: 'br', hl: 'pt' },
  { label: 'Japan', gl: 'jp', hl: 'ja' },
  { label: 'South Korea', gl: 'kr', hl: 'ko' },
  { label: 'Indonesia', gl: 'id', hl: 'id' },
  { label: 'Philippines', gl: 'ph', hl: 'en' },
  { label: 'Thailand', gl: 'th', hl: 'th' },
  { label: 'Singapore', gl: 'sg', hl: 'en' },
  { label: 'Malaysia', gl: 'my', hl: 'en' },
  { label: 'UAE', gl: 'ae', hl: 'en' },
  { label: 'South Africa', gl: 'za', hl: 'en' },
  { label: 'Mexico', gl: 'mx', hl: 'es' },
  { label: 'Nigeria', gl: 'ng', hl: 'en' },
];
---

<Layout metadata={metadata}>
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(webAppSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

  <!-- Hero -->
  <section class="bg-white dark:bg-slate-950 pt-16 pb-12 sm:pt-20 sm:pb-16">
    <div class="max-w-3xl mx-auto px-4 text-center">
      <div class="flex flex-wrap justify-center gap-2 mb-6">
        <span class="inline-flex items-center text-xs font-semibold text-emerald-400 bg-emerald-500/10 border border-emerald-500/20 rounded-full px-3 py-1">Long-tail keywords</span>
        <span class="inline-flex items-center text-xs font-semibold text-emerald-400 bg-emerald-500/10 border border-emerald-500/20 rounded-full px-3 py-1">Intent categorized</span>
        <span class="inline-flex items-center text-xs font-semibold text-emerald-400 bg-emerald-500/10 border border-emerald-500/20 rounded-full px-3 py-1">CSV export</span>
      </div>
      <h1 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-gray-900 dark:text-white leading-tight mb-4">
        YouTube Autocomplete<br class="hidden sm:block" /> Keyword Tool
      </h1>
      <p class="text-gray-500 dark:text-slate-400 text-base sm:text-lg max-w-xl mx-auto">
        Enter a seed keyword. Get every phrase YouTube suggests, categorized by search intent. Find the long-tail queries your competitors are missing.
      </p>
    </div>
  </section>

  <!-- Tool -->
  <section class="bg-white dark:bg-slate-950 pb-20">
    <div id="tool-container" class="max-w-xl mx-auto px-4">

      <!-- Step: Input -->
      <div id="step-input" class="rounded-2xl border border-slate-200 dark:border-slate-700 bg-slate-50 dark:bg-slate-900 p-6 sm:p-8">
        <div class="space-y-5">

          <div>
            <label for="seed-input" class="block text-xs font-semibold uppercase tracking-wider text-gray-500 dark:text-slate-400 mb-2">
              Seed keyword
            </label>
            <input
              type="text"
              id="seed-input"
              placeholder="e.g. crm for small business"
              class="w-full text-base font-medium px-4 py-3 rounded-xl border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-800 text-gray-900 dark:text-white placeholder-gray-400 dark:placeholder-slate-500
                     focus:ring-1 focus:ring-emerald-500 focus:border-emerald-500 outline-none transition-colors"
              aria-describedby="seed-error"
            />
            <p id="seed-error" class="hidden mt-1.5 text-xs text-rose-600 dark:text-rose-400" role="alert"></p>
          </div>

          <div>
            <label for="geo-select" class="block text-xs font-semibold uppercase tracking-wider text-gray-500 dark:text-slate-400 mb-2">
              Geography
            </label>
            <select
              id="geo-select"
              class="w-full text-base font-medium px-4 py-3 rounded-xl border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-800 text-gray-900 dark:text-white
                     focus:ring-1 focus:ring-emerald-500 focus:border-emerald-500 outline-none transition-colors appearance-none"
              style="background-image: url('data:image/svg+xml;charset=UTF-8,%3Csvg%20xmlns%3D%22http%3A%2F%2Fwww.w3.org%2F2000%2Fsvg%22%20width%3D%2212%22%20height%3D%2212%22%20viewBox%3D%220%200%2012%2012%22%3E%3Cpath%20fill%3D%22%236b7280%22%20d%3D%22M6%208L1%203h10z%22%2F%3E%3C%2Fsvg%3E'); background-repeat: no-repeat; background-position: right 1rem center;"
            >
              {geoOptions.map(g => (
                <option value={`${g.gl}|${g.hl}`}>{g.label}</option>
              ))}
            </select>
          </div>

        </div>

        <button
          id="generate-btn"
          class="mt-7 w-full inline-flex items-center justify-center rounded-xl px-6 py-3.5 text-base font-bold
                 bg-emerald-500 text-white dark:text-slate-950 hover:bg-emerald-400 transition-colors"
        >
          Generate Keywords &rarr;
        </button>
      </div>

      <!-- Step: Loading -->
      <div
        id="step-loading"
        class="hidden rounded-2xl border border-slate-200 dark:border-slate-700 bg-slate-50 dark:bg-slate-900 p-6 sm:p-8 text-center"
      >
        <div class="flex flex-col items-center gap-4 py-10">
          <div class="w-10 h-10 border-[3px] border-emerald-500 border-t-transparent rounded-full animate-spin"></div>
          <p class="text-sm font-medium text-gray-500 dark:text-slate-400">Scraping YouTube autocomplete suggestions...</p>
          <div class="w-full max-w-xs mx-auto">
            <div class="w-full h-1.5 bg-slate-200 dark:bg-slate-700 rounded-full overflow-hidden">
              <div id="progress-bar" class="h-full bg-emerald-500 rounded-full transition-all duration-700 ease-out" style="width: 0%"></div>
            </div>
            <p id="progress-text" class="mt-2 text-xs text-gray-400 dark:text-slate-600">Querying A-Z variations...</p>
          </div>
        </div>
      </div>

    </div>

    <!-- Step: Results (wider) -->
    <div
      id="step-results"
      class="hidden max-w-2xl mx-auto px-4 mt-2"
      role="status"
      aria-live="polite"
    >
      <!-- Results header -->
      <div class="rounded-2xl border border-slate-200 dark:border-slate-700 bg-slate-50 dark:bg-slate-900 overflow-hidden">

        <div class="p-6 sm:p-8 border-b border-slate-200 dark:border-slate-700/60">
          <div>
            <p class="text-xs font-semibold uppercase tracking-wider text-gray-400 dark:text-slate-500 mb-1">Autocomplete keywords for</p>
            <p id="result-seed" class="text-sm font-semibold text-gray-900 dark:text-white"></p>
            <p id="result-geo" class="text-xs text-gray-400 dark:text-slate-500 mt-0.5"></p>
          </div>
        </div>

        <!-- Intent group teaser cards (quick results) -->
        <div id="intent-groups" class="divide-y divide-slate-200 dark:divide-slate-700/60"></div>

        <!-- Email gate for exhaustive scrape -->
        <div id="email-gate" class="hidden border-t-2 border-emerald-500/30">
          <!-- Teaser bar showing what's locked -->
          <div class="px-6 sm:px-8 pt-6 pb-3 bg-gradient-to-b from-emerald-500/5 to-transparent">
            <div class="flex items-center gap-3 mb-2">
              <div class="flex-shrink-0 w-8 h-8 rounded-full bg-emerald-500/10 border border-emerald-500/20 flex items-center justify-center">
                <svg class="w-4 h-4 text-emerald-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><rect x="3" y="11" width="18" height="11" rx="2" ry="2" stroke-width="2"/><path d="M7 11V7a5 5 0 0110 0v4" stroke-width="2"/></svg>
              </div>
              <div>
                <p class="text-sm font-bold text-gray-900 dark:text-white">Unlock the full list + CSV export</p>
                <p id="gate-teaser-count" class="text-xs text-gray-500 dark:text-slate-400"></p>
              </div>
            </div>
            <p class="text-xs text-gray-500 dark:text-slate-400 mb-4 ml-11">
              The exhaustive scrape adds buyer-intent modifiers ("best", "vs", "alternatives to", "mistakes", "pricing", "worth it") to your seed keyword. Typically returns 2-3x more keywords, categorized and exported as CSV.
            </p>
            <div id="gate-form" class="flex flex-col sm:flex-row gap-2 ml-11">
              <input
                type="email"
                id="gate-email"
                placeholder="your@company.com"
                class="flex-1 px-4 py-2.5 rounded-xl border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-800 text-gray-900 dark:text-white placeholder-gray-400 dark:placeholder-slate-500
                       text-sm focus:ring-1 focus:ring-emerald-500 focus:border-emerald-500 outline-none"
                aria-describedby="gate-email-error"
              />
              <button
                id="gate-submit-btn"
                class="inline-flex items-center justify-center rounded-xl px-5 py-2.5 text-sm font-bold
                       bg-emerald-500 text-white dark:text-slate-950 hover:bg-emerald-400 transition-colors whitespace-nowrap"
              >
                Get full list + CSV &rarr;
              </button>
            </div>
            <p id="gate-email-error" class="hidden mt-1.5 ml-11 text-xs text-rose-600 dark:text-rose-400" role="alert"></p>
            <p class="mt-2 ml-11 text-xs text-gray-400 dark:text-slate-600">No spam. We only send YouTube acquisition resources.</p>
          </div>
        </div>

        <!-- Exhaustive loading -->
        <div id="exhaustive-loading" class="hidden p-6 sm:p-8 border-t border-slate-200 dark:border-slate-700/60 text-center">
          <div class="flex flex-col items-center gap-3 py-4">
            <div class="w-8 h-8 border-[3px] border-emerald-500 border-t-transparent rounded-full animate-spin"></div>
            <p class="text-sm font-medium text-gray-500 dark:text-slate-400">Running exhaustive scrape (A-Z + 0-9 + modifiers)...</p>
            <p class="text-xs text-gray-400 dark:text-slate-600">This takes 15-20 seconds</p>
          </div>
        </div>

        <!-- Exhaustive results -->
        <div id="exhaustive-results" class="hidden">
          <div class="p-6 sm:p-8 border-t border-slate-200 dark:border-slate-700/60 bg-emerald-500/5">
            <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3 mb-4">
              <div>
                <p class="text-xs font-semibold uppercase tracking-wider text-emerald-600 dark:text-emerald-400 mb-1">Exhaustive scrape complete</p>
                <p id="exhaustive-count" class="text-sm font-semibold text-gray-900 dark:text-white"></p>
              </div>
              <div class="flex gap-2">
                <button
                  id="copy-exhaustive-btn"
                  class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-xs font-semibold border border-slate-200 dark:border-slate-700 text-gray-600 dark:text-slate-400 hover:text-gray-900 dark:hover:text-white hover:border-slate-400 dark:hover:border-slate-500 transition-colors"
                >
                  <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><rect x="9" y="9" width="13" height="13" rx="2" ry="2" stroke-width="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1" stroke-width="2"/></svg>
                  Copy All
                </button>
                <button
                  id="export-exhaustive-csv-btn"
                  class="inline-flex items-center gap-1.5 px-4 py-2 rounded-lg text-xs font-bold bg-emerald-500 text-white dark:text-slate-950 hover:bg-emerald-400 transition-colors"
                >
                  <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4M7 10l5 5 5-5M12 15V3" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                  Download CSV
                </button>
              </div>
            </div>
          </div>
          <div id="exhaustive-intent-groups" class="divide-y divide-slate-200 dark:divide-slate-700/60"></div>
        </div>

        <!-- Reset -->
        <div class="px-6 pb-6 sm:px-8 sm:pb-8 pt-6">
          <button
            id="reset-btn"
            class="w-full py-3 rounded-xl border border-slate-200 dark:border-slate-700 text-sm font-medium text-gray-500 dark:text-slate-400 hover:text-gray-900 dark:hover:text-white hover:border-slate-400 dark:hover:border-slate-500 transition-colors"
          >
            &larr; Research another keyword
          </button>
        </div>

      </div>

      <!-- Inline CTA to related tools -->
      <div class="mt-4 rounded-2xl border border-slate-200 dark:border-slate-700 bg-slate-50 dark:bg-slate-900 p-6 sm:p-8">
        <p class="text-sm font-medium text-gray-700 dark:text-slate-300 mb-1">Found your keywords? Check if your videos are optimized for them.</p>
        <p class="text-xs text-gray-400 dark:text-slate-500 mb-4">Run your video through our free YouTube SEO tool to see how well it ranks for these terms.</p>
        <div class="flex flex-wrap gap-2">
          <a
            href="/tools/youtube-seo-tool"
            class="inline-flex items-center justify-center rounded-xl px-5 py-2.5 text-sm font-bold bg-emerald-500 text-white dark:text-slate-950 hover:bg-emerald-400 transition-colors"
          >
            Check your video SEO score &rarr;
          </a>
          <a
            href="/tools/youtube-title-generator"
            class="inline-flex items-center justify-center rounded-xl px-5 py-2.5 text-sm font-medium border border-slate-200 dark:border-slate-700 text-gray-600 dark:text-slate-400 hover:text-gray-900 dark:hover:text-white hover:border-slate-400 dark:hover:border-slate-500 transition-colors"
          >
            Generate titles from keywords
          </a>
        </div>
      </div>
    </div>
  </section>

  <CallToAction
    title="Keywords are the starting point. Strategy is the system."
    subtitle="In a diagnostic call, we map your full YouTube acquisition system: keywords, topics, titles, CTAs, and the path from viewer to customer."
    actions={[
      {
        variant: 'primary',
        text: 'Book a diagnostic call',
        href: 'https://cal.com/gautham-8bdvdx/30min',
        target: '_blank',
        rel: 'noopener noreferrer',
      },
    ]}
  />

  <!-- How it works -->
  <section class="py-16 sm:py-20 bg-white dark:bg-slate-950">
    <div class="max-w-4xl mx-auto px-4">
      <p class="text-xs font-semibold uppercase tracking-wider text-gray-400 dark:text-slate-500 text-center mb-10">How it works</p>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-8 sm:gap-6">
        <div>
          <div class="inline-flex items-center justify-center w-9 h-9 rounded-full bg-emerald-500/10 border border-emerald-500/20 text-emerald-600 dark:text-emerald-400 text-sm font-bold mb-4">1</div>
          <h3 class="text-gray-900 dark:text-white font-semibold mb-2">Enter your seed keyword</h3>
          <p class="text-sm text-gray-500 dark:text-slate-400 leading-relaxed">Type a topic, product, or niche. Pick your target geography. One keyword, two fields, under 10 seconds.</p>
        </div>
        <div>
          <div class="inline-flex items-center justify-center w-9 h-9 rounded-full bg-emerald-500/10 border border-emerald-500/20 text-emerald-600 dark:text-emerald-400 text-sm font-bold mb-4">2</div>
          <h3 class="text-gray-900 dark:text-white font-semibold mb-2">We scrape YouTube autocomplete</h3>
          <p class="text-sm text-gray-500 dark:text-slate-400 leading-relaxed">The tool queries YouTube's suggestion API with A-Z variations of your seed keyword, collecting every phrase YouTube thinks users want to search next.</p>
        </div>
        <div>
          <div class="inline-flex items-center justify-center w-9 h-9 rounded-full bg-emerald-500/10 border border-emerald-500/20 text-emerald-600 dark:text-emerald-400 text-sm font-bold mb-4">3</div>
          <h3 class="text-gray-900 dark:text-white font-semibold mb-2">Keywords sorted by intent</h3>
          <p class="text-sm text-gray-500 dark:text-slate-400 leading-relaxed">Every keyword is categorized by buyer intent: Comparison, Mistakes, Results, How-To, or Research. Each gets a priority tag (High, Medium, Low) so you know which keywords to target first for business results.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Section 1: Why autocomplete -->
  <section class="py-16 sm:py-20 border-t border-slate-100 dark:border-slate-800">
    <div class="max-w-2xl mx-auto px-4 space-y-5">
      <h2 class="text-2xl font-bold text-gray-900 dark:text-white">Why YouTube autocomplete beats volume-based keyword tools</h2>
      <p class="text-gray-600 dark:text-slate-400 leading-relaxed">
        YouTube keyword tools estimate search volume using panel data or clickstream samples. The numbers are approximations, often months out of date. YouTube autocomplete shows you the exact phrases YouTube surfaces when real users type a query right now. These suggestions reflect actual search frequency, recency, and user behavior patterns.
      </p>
      <p class="text-gray-600 dark:text-slate-400 leading-relaxed">
        <strong>YouTube autocomplete keyword research</strong> is the process of systematically scraping YouTube's search suggestions to discover the long-tail phrases your target audience actually types. Unlike volume estimates, these are real queries driven by real demand.
      </p>
      <p class="text-gray-600 dark:text-slate-400 leading-relaxed">
        Every experienced YouTube marketer already does this manually: type your topic, add a, b, c, and record what auto-completes. This tool runs 27 queries in seconds for the quick scrape. The exhaustive scrape fires 60-100+ queries with buyer-intent modifiers, returning 100-200+ unique keyword phrases. Same technique, zero manual effort.
      </p>

      <!-- Comparison table -->
      <div class="rounded-xl border border-slate-200 dark:border-slate-700 overflow-hidden bg-white dark:bg-slate-900 shadow-sm mt-8">
        <div class="bg-slate-50 dark:bg-slate-800 px-5 py-4 border-b border-slate-200 dark:border-slate-700">
          <p class="text-sm font-semibold text-gray-900 dark:text-white">Autocomplete scraping vs volume-based tools</p>
        </div>
        <div class="overflow-x-auto">
          <table class="w-full text-sm">
            <thead>
              <tr class="border-b border-slate-200 dark:border-slate-700">
                <th class="text-left px-5 py-3 text-xs font-semibold uppercase tracking-wider text-gray-400 dark:text-slate-500">Dimension</th>
                <th class="text-left px-5 py-3 text-xs font-semibold uppercase tracking-wider text-gray-400 dark:text-slate-500">Volume tools (VidIQ, TubeBuddy)</th>
                <th class="text-left px-5 py-3 text-xs font-semibold uppercase tracking-wider text-emerald-600 dark:text-emerald-400">Autocomplete scraping</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-slate-100 dark:divide-slate-800">
              {[
                { dim: 'Data source', vol: 'Panel estimates, third-party clickstream', auto: 'YouTube\'s own suggestion algorithm, real-time' },
                { dim: 'Freshness', vol: 'Monthly or quarterly updates', auto: 'Live data, reflects this week\'s search trends' },
                { dim: 'Long-tail depth', vol: 'Misses niche phrases with low estimated volume', auto: 'Surfaces exact phrases users type, including 4-6 word queries' },
                { dim: 'Buyer intent signal', vol: 'Volume number with no intent context', auto: 'Phrases naturally reveal intent: "best X", "X vs Y", "how to set up X"' },
                { dim: 'Cost', vol: '$7.99-$49.99/month for keyword features', auto: 'Free. No API key, no quota limit' },
                { dim: 'Limitation', vol: 'Estimates can be inaccurate for niche topics', auto: 'No exact volume numbers, only relative demand signal' },
              ].map((row) => (
                <tr>
                  <td class="px-5 py-3 font-medium text-gray-900 dark:text-white whitespace-nowrap">{row.dim}</td>
