<script>
  // ===== CONSTANTS =====

  const RATE_LIMIT = 3;
  const COUNT_KEY = 'sot_desc_gen_count';
  const EMAIL_KEY = 'sot_desc_gen_email_submitted';
  const GATE_EMAIL_DOMAINS = ['gmail.com', 'yahoo.com', 'hotmail.com', 'outlook.com', 'icloud.com', 'aol.com', 'protonmail.com', 'mail.com', 'ymail.com', 'live.com'];
  const CAPTURE_URL = '/.netlify/functions/capture-email';

  // ===== STORAGE =====

  function getCount(): number { return parseInt(localStorage.getItem(COUNT_KEY) || '0', 10); }
  function incrementCount(): void { localStorage.setItem(COUNT_KEY, (getCount() + 1).toString()); }
  function isEmailSubmitted(): boolean { return localStorage.getItem(EMAIL_KEY) === 'true'; }
  function setEmailSubmitted(): void { localStorage.setItem(EMAIL_KEY, 'true'); }

  // ===== STEP MANAGEMENT =====

  const STEPS = ['step-input', 'step-loading', 'step-email-gate', 'step-results'];
  function showStep(id: string): void {
    STEPS.forEach((s) => {
      const el = document.getElementById(s);
      if (el) el.classList.toggle('hidden', s !== id);
    });
    if (id === 'step-results') {
      const heading = document.getElementById('result-title');
      heading?.focus();
    }
  }

  // ===== COUNTER LABEL =====

  function updateCounterLabel(): void {
    const label = document.getElementById('counter-label');
    if (!label) return;
    if (isEmailSubmitted()) {
      label.textContent = 'Unlimited generations unlocked';
      return;
    }
    const remaining = Math.max(0, RATE_LIMIT - getCount());
    label.textContent = remaining === 1 ? '1 free generation remaining' : remaining + ' free generations remaining';
  }

  // ===== INLINE VALIDATION =====

  function showFieldError(fieldId: string, message: string): void {
    const input = document.getElementById(fieldId) as HTMLInputElement | null;
    const errorId = fieldId.replace('-input', '-error');
    const error = document.getElementById(errorId);
    if (input) input.setAttribute('aria-invalid', 'true');
    if (error) { error.textContent = message; error.classList.remove('hidden'); }
  }

  function clearFieldError(fieldId: string): void {
    const input = document.getElementById(fieldId) as HTMLInputElement | null;
    const errorId = fieldId.replace('-input', '-error');
    const error = document.getElementById(errorId);
    if (input) input.removeAttribute('aria-invalid');
    if (error) { error.textContent = ''; error.classList.add('hidden'); }
  }

  function validateInputs(): boolean {
    const videoUrl = (document.getElementById('video-url-input') as HTMLInputElement).value.trim();
    const ctaLink = (document.getElementById('cta-link-input') as HTMLInputElement).value.trim();

    let valid = true;

    // Basic YouTube URL validation
    const ytPattern = /^(https?:\/\/)?(www\.)?(youtube\.com|youtu\.be)\/.+/;
    const isVideoId = /^[\w-]{11}$/.test(videoUrl);
    if (!videoUrl || (!ytPattern.test(videoUrl) && !isVideoId)) {
      showFieldError('video-url-input', 'Please enter a valid YouTube video URL.');
      valid = false;
    } else { clearFieldError('video-url-input'); }

    if (!ctaLink || !ctaLink.match(/^https?:\/\/.+/)) {
      showFieldError('cta-link-input', 'Please enter a valid URL starting with https://');
      valid = false;
    } else { clearFieldError('cta-link-input'); }

    return valid;
  }

  // ===== RESULT RENDERING =====

  interface DescriptionResult {
    videoTitle: string;
    aboveFold: string;
    fullDescription: string;
    timestamps: string[];
    tags: string[];
    ctaWithUtm: string;
    hasTranscript: boolean;
  }

  function renderResults(data: DescriptionResult): void {
    const resultTitle = document.getElementById('result-title');
    if (resultTitle) resultTitle.textContent = data.videoTitle;

    // Transcript note
    const transcriptNote = document.getElementById('transcript-note');
    if (transcriptNote) {
      if (data.hasTranscript) {
        transcriptNote.classList.remove('hidden');
      } else {
        transcriptNote.textContent = 'No transcript available. Timestamps are estimated based on the video topic.';
        transcriptNote.classList.remove('hidden');
        transcriptNote.classList.remove('text-emerald-600', 'dark:text-emerald-400');
        transcriptNote.classList.add('text-gray-400', 'dark:text-slate-500');
      }
    }

    // Above the fold
    const aboveFoldEl = document.getElementById('above-fold-text');
    if (aboveFoldEl) aboveFoldEl.textContent = data.aboveFold;

    const countEl = document.getElementById('above-fold-count');
    if (countEl) countEl.textContent = data.aboveFold.length + ' characters';

    // CTA with UTM
    const ctaSection = document.getElementById('cta-utm-section');
    const ctaText = document.getElementById('cta-utm-text');
    if (ctaSection && ctaText && data.ctaWithUtm) {
      ctaText.textContent = data.ctaWithUtm;
      ctaSection.classList.remove('hidden');
    }

    // Full description
    const fullDescEl = document.getElementById('full-desc-text');
    if (fullDescEl) fullDescEl.textContent = data.fullDescription;

    // Timestamps
    const timestampsList = document.getElementById('timestamps-list');
    if (timestampsList) {
      timestampsList.innerHTML = data.timestamps.map((ts) => {
        const escaped = ts.replace(/</g, '&lt;').replace(/>/g, '&gt;');
        return '<p class="text-sm text-gray-700 dark:text-slate-300 font-mono">' + escaped + '</p>';
      }).join('');
    }

    // Tags
    const tagsList = document.getElementById('tags-list');
    if (tagsList) {
      tagsList.innerHTML = data.tags.map((tag) => {
        const escaped = tag.replace(/</g, '&lt;').replace(/>/g, '&gt;');
        return '<span class="inline-flex items-center text-xs font-medium px-2.5 py-1 rounded-full bg-slate-100 dark:bg-slate-800 text-gray-600 dark:text-slate-400 border border-slate-200 dark:border-slate-700">' + escaped + '</span>';
      }).join('');
    }
  }

  function buildFullCopyText(data: DescriptionResult): string {
    let text = data.aboveFold + '\n\n';
    text += data.fullDescription + '\n\n';
    text += '--- Timestamps ---\n';
    text += data.timestamps.join('\n') + '\n\n';
    text += '--- Tags ---\n';
    text += data.tags.join(', ');
    return text;
  }

  // ===== API CALL =====

  let lastResult: DescriptionResult | null = null;

  async function fetchDescription(videoUrl: string, ctaLink: string, addUtm: boolean): Promise<void> {
    const btn = document.getElementById('generate-btn') as HTMLButtonElement;

    try {
      const res = await fetch('/api/generate-description', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ videoUrl, ctaLink, addUtm }),
      });

      if (res.status === 429) {
        showStep('step-input');
        btn.disabled = false;
        btn.textContent = 'Generate Description \u2192';
        showFieldError('cta-link-input', 'AI is at capacity right now. Free daily limit reached. Please try again in a moment.');
        window.dataLayer = window.dataLayer || [];
        window.dataLayer.push({ event: 'tool_generate_error', tool: 'youtube-description-generator', reason: 'quota_exceeded' });
        return;
      }

      if (!res.ok) {
        const errData = await res.json().catch(() => ({}));
        const msg = errData?.error || 'API error ' + res.status;
        throw new Error(msg);
      }

      const data = await res.json();
      if (!data?.aboveFold || !data?.fullDescription || !Array.isArray(data?.timestamps) || !Array.isArray(data?.tags)) {
        throw new Error('Invalid response structure');
      }

      lastResult = data as DescriptionResult;
      renderResults(lastResult);
      incrementCount();
      updateCounterLabel();
      showStep('step-results');
      document.getElementById('step-results')?.scrollIntoView({ behavior: 'smooth', block: 'start' });

      window.dataLayer = window.dataLayer || [];
      window.dataLayer.push({ event: 'tool_generate_success', tool: 'youtube-description-generator' });

    } catch (err) {
      showStep('step-input');
      btn.disabled = false;
      btn.textContent = 'Generate Description \u2192';
      const message = (err instanceof Error && err.message.includes('Video not found'))
        ? err.message
        : 'Something went wrong on our end. Please try again in a moment.';
      showFieldError('video-url-input', message);
      window.dataLayer = window.dataLayer || [];
      window.dataLayer.push({ event: 'tool_generate_error', tool: 'youtube-description-generator', reason: 'api_error' });
    }
  }

  // ===== GENERATE =====

  async function generate(): Promise<void> {
    if (!validateInputs()) return;

    const videoUrl = (document.getElementById('video-url-input') as HTMLInputElement).value.trim();
    const ctaLink = (document.getElementById('cta-link-input') as HTMLInputElement).value.trim();
    const addUtm = (document.getElementById('utm-toggle') as HTMLInputElement).checked;

    // Email gate check
    if (getCount() >= RATE_LIMIT && !isEmailSubmitted()) {
      window.dataLayer = window.dataLayer || [];
      window.dataLayer.push({ event: 'tool_email_gate_shown', tool: 'youtube-description-generator' });
      showStep('step-email-gate');
      return;
    }

    window.dataLayer = window.dataLayer || [];
    window.dataLayer.push({ event: 'tool_generate_click', tool: 'youtube-description-generator' });

    const btn = document.getElementById('generate-btn') as HTMLButtonElement;
    btn.disabled = true;
    btn.textContent = 'Generating...';
    showStep('step-loading');

    await fetchDescription(videoUrl, ctaLink, addUtm);
  }

  // ===== EMAIL GATE =====

  async function submitGateEmail(): Promise<void> {
    const emailInput = document.getElementById('gate-email') as HTMLInputElement;
    const email = emailInput.value.trim().toLowerCase();
    const errorEl = document.getElementById('gate-email-error');

    // Validate format
    const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
    if (!emailRegex.test(email)) {
      if (errorEl) { errorEl.textContent = 'Please enter a valid business email address.'; errorEl.classList.remove('hidden'); }
      return;
    }

    // Block personal domains
    const domain = email.split('@')[1];
    if (GATE_EMAIL_DOMAINS.includes(domain)) {
      if (errorEl) { errorEl.textContent = 'Please use a business email address (not Gmail, Yahoo, etc.)'; errorEl.classList.remove('hidden'); }
      return;
    }

    if (errorEl) errorEl.classList.add('hidden');

    const btn = document.getElementById('gate-submit-btn') as HTMLButtonElement;
    btn.textContent = 'Submitting...';
    btn.setAttribute('disabled', 'true');

    try {
      await fetch(CAPTURE_URL, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email, source: 'youtube-description-generator' }),
      });
    } catch { /* silent */ }

    setEmailSubmitted();
    updateCounterLabel();

    window.dataLayer = window.dataLayer || [];
    window.dataLayer.push({ event: 'tool_email_submitted', tool: 'youtube-description-generator' });

    const form = document.getElementById('gate-form') as HTMLElement;
    const success = document.getElementById('gate-success') as HTMLElement;
    form.classList.add('hidden');
    success.classList.remove('hidden');

    // Proceed with generation after brief confirmation
    setTimeout(() => {
      form.classList.remove('hidden');
      success.classList.add('hidden');
      btn.textContent = 'Continue Generating';
      btn.removeAttribute('disabled');
      emailInput.value = '';
      generate();
    }, 1200);
  }

  // ===== COPY BUTTONS =====

  function handleCopy(btnId: string, textFn: () => string, eventLabel: string): void {
    const btn = document.getElementById(btnId);
    if (!btn) return;
    btn.addEventListener('click', () => {
      const text = textFn();
      navigator.clipboard.writeText(text).then(() => {
        const original = btn.textContent;
        btn.textContent = 'Copied!';
        (btn as HTMLElement).classList.add('text-emerald-600', 'dark:text-emerald-400');
        setTimeout(() => {
          btn.textContent = original;
          (btn as HTMLElement).classList.remove('text-emerald-600', 'dark:text-emerald-400');
        }, 1500);
      });
      window.dataLayer = window.dataLayer || [];
      window.dataLayer.push({ event: 'description_copied', tool: 'youtube-description-generator', section: eventLabel });
    });
  }

  handleCopy('copy-above-fold-btn', () => lastResult?.aboveFold || '', 'above_fold');
  handleCopy('copy-cta-btn', () => lastResult?.ctaWithUtm || '', 'cta_utm');
  handleCopy('copy-full-btn', () => lastResult ? buildFullCopyText(lastResult) : '', 'full');

  // ===== RESET =====

  function reset(): void {
    (document.getElementById('video-url-input') as HTMLInputElement).value = '';
    clearFieldError('video-url-input');
    (document.getElementById('cta-link-input') as HTMLInputElement).value = '';
    clearFieldError('cta-link-input');
    (document.getElementById('utm-toggle') as HTMLInputElement).checked = true;
    lastResult = null;

    // Hide CTA UTM section and reset transcript note
    const ctaSection = document.getElementById('cta-utm-section');
    if (ctaSection) ctaSection.classList.add('hidden');
    const transcriptNote = document.getElementById('transcript-note');
    if (transcriptNote) {
      transcriptNote.classList.add('hidden');
      transcriptNote.classList.remove('text-gray-400', 'dark:text-slate-500');
      transcriptNote.classList.add('text-emerald-600', 'dark:text-emerald-400');
      transcriptNote.textContent = 'Timestamps generated from video transcript';
    }

    showStep('step-input');
    (document.getElementById('video-url-input') as HTMLInputElement).focus();
    const btn = document.getElementById('generate-btn') as HTMLButtonElement;
    btn.disabled = false;
    btn.textContent = 'Generate Description \u2192';
  }

  // ===== CTA TRACKING =====

  document.getElementById('results-cta')?.addEventListener('click', (e) => {
    const videoUrl = (document.getElementById('video-url-input') as HTMLInputElement).value.trim();
    if (videoUrl) {
      e.preventDefault();
      const target = (e.currentTarget as HTMLAnchorElement);
      target.href = '/tools/youtube-tag-generator?v=' + encodeURIComponent(videoUrl);
      window.location.href = target.href;
    }
    window.dataLayer = window.dataLayer || [];
    window.dataLayer.push({ event: 'tool_cta_click', tool: 'youtube-description-generator' });
  });

  // ===== PRE-FILL FROM QUERY PARAM =====

  const urlParams = new URLSearchParams(window.location.search);
  const prefillVideo = urlParams.get('v');
  if (prefillVideo) {
    (document.getElementById('video-url-input') as HTMLInputElement).value = prefillVideo;
  }

  // ===== EVENT LISTENERS =====

  document.getElementById('generate-btn')?.addEventListener('click', generate);
  document.getElementById('reset-btn')?.addEventListener('click', reset);
  document.getElementById('gate-submit-btn')?.addEventListener('click', submitGateEmail);

  // Enter key navigation
  document.getElementById('video-url-input')?.addEventListener('keydown', (e) => {
    if ((e as KeyboardEvent).key === 'Enter') {
      e.preventDefault();
      (document.getElementById('cta-link-input') as HTMLInputElement)?.focus();
    }
  });

  document.getElementById('cta-link-input')?.addEventListener('keydown', (e) => {
    if ((e as KeyboardEvent).key === 'Enter') {
      e.preventDefault();
      generate();
    }
  });

  document.getElementById('gate-email')?.addEventListener('keydown', (e) => {
    if ((e as KeyboardEvent).key === 'Enter') submitGateEmail();
  });

  updateCounterLabel();
</script>
