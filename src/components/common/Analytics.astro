---
import { GoogleAnalytics } from '@astrolib/analytics';
import { ANALYTICS } from 'astrowind:config';
---

{
  ANALYTICS?.vendors?.googleAnalytics?.id ? (
    <GoogleAnalytics
      id={String(ANALYTICS.vendors.googleAnalytics.id)}
      partytown={ANALYTICS?.vendors?.googleAnalytics?.partytown}
    />
  ) : null
}

{/*
  Main-thread gtag() shim.

  @astrolib/analytics emits its gtag bootstrap with type="text/partytown", so that
  bootstrap runs inside the Partytown web worker and window.gtag never exists on the
  main thread. Page scripts therefore cannot call gtag() directly.

  This defines gtag() on the main thread. It pushes the same `arguments` object the
  real bootstrap does, and Partytown's `forward: ['dataLayer.push']` (astro.config.ts)
  relays the call into the worker where gtag.js consumes it.

  window.dataLayer is resolved at call time, not captured, so this keeps working
  whichever order the shim and the Partytown forward proxy initialise in.

  Do NOT use dataLayer.push({ event: 'name' }) in page code. That is Google Tag
  Manager syntax; there is no GTM container on this site and gtag.js ignores it.
  Every such event was silently dropped until 2026-07-21.
*/}
<script is:inline>
  window.dataLayer = window.dataLayer || [];
  window.gtag =
    window.gtag ||
    function () {
      window.dataLayer.push(arguments);
    };
</script>

<script is:inline>
  (function(c,l,a,r,i,t,y){
    c[a]=c[a]||function(){(c[a].q=c[a].q||[]).push(arguments)};
    t=l.createElement(r);t.async=1;t.src="https://www.clarity.ms/tag/"+i;
    y=l.getElementsByTagName(r)[0];y.parentNode.insertBefore(t,y);
  })(window, document, "clarity", "script", "w3uumrqmgd");
</script>
