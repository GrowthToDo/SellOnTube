---
import { GoogleAnalytics } from '@astrolib/analytics';
import { ANALYTICS } from 'astrowind:config';
---

{/*
  Main-thread gtag() shim + opt-in debug mode.

  ORDER MATTERS: this block must stay ABOVE <GoogleAnalytics />. gtag.js
  replays window.dataLayer in order, so gtag('set', ...) only affects events
  queued after it. The bootstrap emitted by <GoogleAnalytics /> immediately
  calls gtag('config', id), which sends page_view -- so a 'set' placed after
  that component would miss page_view and anything else already queued.
  Verified 2026-07-21: with this block below the component, DebugView stayed
  empty because no event ever carried the debug flag.

  Analytics events MUST be sent with window.gtag('event', name, params).
  Do NOT use dataLayer.push({ event: 'name' }) -- that is Google Tag Manager
  syntax, there is no GTM container on this site, and gtag.js silently ignores
  it. Every such event was dropped between launch and 2026-07-21.

  Appending ?debug_mode=1 to any URL routes that session into GA4 DebugView
  (Admin > Data display > DebugView) without needing the Google Analytics
  Debugger browser extension. It persists for the tab via sessionStorage so
  in-site navigation keeps reporting. Off by default; real visitors unaffected.
*/}
<script is:inline>
  window.dataLayer = window.dataLayer || [];
  window.gtag =
    window.gtag ||
    function () {
      window.dataLayer.push(arguments);
    };

  try {
    var qsDebug = new URLSearchParams(window.location.search).get('debug_mode') === '1';
    if (qsDebug) {
      window.sessionStorage.setItem('ga_debug_mode', '1');
    }
    if (qsDebug || window.sessionStorage.getItem('ga_debug_mode') === '1') {
      window.gtag('set', { debug_mode: true });
    }
  } catch (e) {
    /* debug mode is best-effort; never break the page for it */
  }
</script>

{
  ANALYTICS?.vendors?.googleAnalytics?.id ? (
    <GoogleAnalytics
      id={String(ANALYTICS.vendors.googleAnalytics.id)}
      partytown={ANALYTICS?.vendors?.googleAnalytics?.partytown}
    />
  ) : null
}

<script is:inline>
  (function(c,l,a,r,i,t,y){
    c[a]=c[a]||function(){(c[a].q=c[a].q||[]).push(arguments)};
    t=l.createElement(r);t.async=1;t.src="https://www.clarity.ms/tag/"+i;
    y=l.getElementsByTagName(r)[0];y.parentNode.insertBefore(t,y);
  })(window, document, "clarity", "script", "w3uumrqmgd");
</script>
