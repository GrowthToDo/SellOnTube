---
/**
 * JSON-LD Structured Data Component
 * Adds Organization and WebSite schema (with SitelinksSearchbox) for better SEO and AI discoverability
 */

import { SITE } from 'astrowind:config';

const siteUrl = SITE.site || 'https://sellontube.com';

const organizationSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "SellOnTube",
  "url": siteUrl,
  "logo": {
    "@type": "ImageObject",
    "url": `${siteUrl}/favicon.svg`
  },
  "description": "SellOnTube is a done-for-you YouTube acquisition agency for B2B businesses. We build and run YouTube channels that acquire customers through search-optimized, voiceover-driven videos.",
  "foundingDate": "2025-01-01",
  "founder": [
    {
      "@type": "Person",
      "name": "Sathyanand S",
      "jobTitle": "Co-Founder",
      "url": "https://www.linkedin.com/in/sathyanands/",
      "sameAs": [
        "https://www.linkedin.com/in/sathyanands/",
        "https://x.com/SathyaHQ"
      ]
    },
    {
      "@type": "Person",
      "name": "Gautham",
      "jobTitle": "Co-Founder",
      "url": "https://www.linkedin.com/in/mindcharting/",
      "sameAs": [
        "https://www.linkedin.com/in/mindcharting/",
        "https://x.com/MindCharting"
      ]
    }
  ],
  "sameAs": [
    "https://twitter.com/SellOnTube",
    "https://youtube.com/@SellOnTube",
    "https://linkedin.com/company/sell-on-youtube"
  ],
  "contactPoint": {
    "@type": "ContactPoint",
    "contactType": "sales",
    "url": "https://cal.com/gautham-8bdvdx/30min"
  },
  "numberOfEmployees": {
    "@type": "QuantitativeValue",
    "value": 2
  }
};

const websiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "SellOnTube",
  "url": siteUrl,
  "description": "SellOnTube turns YouTube search intent into predictable leads for B2B businesses. Done-for-you strategy, scripting, voiceover, production, and SEO.",
  "publisher": {
    "@type": "Organization",
    "name": "SellOnTube"
  },
  "potentialAction": {
    "@type": "SearchAction",
    "target": {
      "@type": "EntryPoint",
      "urlTemplate": `${siteUrl}/blog?q={search_term_string}`
    },
    "query-input": "required name=search_term_string"
  }
};
---

<script type="application/ld+json" set:html={JSON.stringify(organizationSchema)} />
<script type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />
