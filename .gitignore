# SEO data pipeline — never commit credentials or raw data
scripts/credentials.json
scripts/seo_data/*.json
# Keyword research — ignore binary Excel files, but commit CSVs (plain text, diffable)
research/**/*.xlsx
research/**/*.xls

# Claude Code local settings — ignore tokens/config, but track shared commands
.claude/*
!.claude/commands/

# Local Netlify folder
.netlify
