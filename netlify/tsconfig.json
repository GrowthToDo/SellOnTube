{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ES2020",
    "moduleResolution": "node",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "./dist",
    "baseUrl": ".",
    "paths": {
      "~/*": ["../src/*"]
    }
  },
  "include": ["functions/**/*"],
  "exclude": ["dist/"]
}
